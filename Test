    selection2.Name = "Selection2"
    selection2.Text = "On"
    selection2.Size = UDim2.new(1, -64, 1, 0)
    selection2.Position = UDim2.new(0, 96, 0, 0)
    selection2.BackgroundTransparency = 1
    selection2.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
