local function setupSliderScript()
	local Slider = LMG2L["SliderInner_13"]
	local LeftButton = LMG2L["SliderLeftButton_14"]
	local RightButton = LMG2L["SliderRightButton_16"]
	local StepsContainer = LMG2L["StepsContainer_18"]
	
	local ACTIVE_COLOR = Color3.fromRGB(255, 255, 255)
	local INACTIVE_COLOR = Color3.fromRGB(57, 59, 61)
	
	local steps = {}
	local fillers = {}
	
	for i = 1, 10 do
		local step = StepsContainer:FindFirstChild("Step" .. i)
		if step then
			step.BackgroundColor3 = INACTIVE_COLOR
			table.insert(steps, step)
			
			local filler = step:FindFirstChild("Filler")
			if filler then
				filler.BackgroundColor3 = INACTIVE_COLOR
				fillers[i] = filler
			end
		end
	end
	
	LeftButton.Visible = false
	RightButton.Visible = true
	
	local function GetLastActiveStep()
		for i = #steps, 1, -1 do
			if steps[i].BackgroundColor3 == ACTIVE_COLOR then
				return i
			end
		end
		return 0
	end
	
	local function UpdateButtonsVisibility()
		local lastActive = GetLastActiveStep()
		
		if lastActive >= #steps then
			RightButton.Visible = false
		else
			RightButton.Visible = true
		end
		
		if lastActive <= 0 then
			LeftButton.Visible = false
		else
			LeftButton.Visible = true
		end
	end
	
	local function ActivateStep(index)
		if index >= 1 and index <= #steps then
			steps[index].BackgroundColor3 = ACTIVE_COLOR
			
			if fillers[index] then
				fillers[index].BackgroundColor3 = ACTIVE_COLOR
			end
		end
	end
	
	local function DeactivateStep(index)
		if index >= 1 and index <= #steps then
			steps[index].BackgroundColor3 = INACTIVE_COLOR
			
			if fillers[index] then
				fillers[index].BackgroundColor3 = INACTIVE_COLOR
			end
		end
	end

	-- Nova função principal para ajustar o slider diretamente
	local function SetSlider(targetIndex)
		targetIndex = math.clamp(targetIndex, 0, #steps)
		local current = GetLastActiveStep()
		
		if targetIndex > current then
			for i = current + 1, targetIndex do
				ActivateStep(i)
			end
		elseif targetIndex < current then
			for i = current, targetIndex + 1, -1 do
				DeactivateStep(i)
			end
		end
		UpdateButtonsVisibility()
	end
	
	local function IncreaseSlider()
		SetSlider(GetLastActiveStep() + 1)
	end
	
	local function DecreaseSlider()
		SetSlider(GetLastActiveStep() - 1)
	end
	
	RightButton.MouseButton1Click:Connect(IncreaseSlider)
	LeftButton.MouseButton1Click:Connect(DecreaseSlider)
	
	-- ==========================================
	-- SISTEMA DE DRAG E CLIQUE NO SLIDER
	-- ==========================================
	local isDragging = false
	
	-- Atualiza o slider baseado na posição do Mouse / Dedo
	local function UpdateFromInput(input)
		local containerPos = StepsContainer.AbsolutePosition.X
		local containerSize = StepsContainer.AbsoluteSize.X
		local inputPos = input.Position.X
		
		local relativePos = inputPos - containerPos
		local percentage = math.clamp(relativePos / containerSize, 0, 1)
		
		local targetStep = math.round(percentage * #steps)
		SetSlider(targetStep)
	end
	
	-- Inicia o clique no container principal
	StepsContainer.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true
			UpdateFromInput(input)
		end
	end)
	
	-- Inicia o clique diretamente em algum step específico
	for i, step in ipairs(steps) do
		step.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = true
				SetSlider(i)
			end
		end)
	end
	
	-- Detecta o movimento (arrasto)
	UserInputService.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			UpdateFromInput(input)
		end
	end)
	
	-- Finaliza o clique/arrasto
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = false
		end
	end)
	
	print("Sistema de Slider interativo (Drag & Click) iniciado!")
end


