local function setupDropdownScript()
	local DropdownFrameButton = LMG2L["DropdownFrameButton_6"]
	local DropdownFrame = LMG2L["DropdownFrame_d"]
	local DropdownSelectionText = LMG2L["DropdownSelectionText_a"]
	local ScrollingFrame = LMG2L["DropdownScrollingFrame_10"]

	-- Abrir ou fechar ao clicar no botão principal do dropdown
	DropdownFrameButton.MouseButton1Click:Connect(function()
		DropdownFrame.Visible = not DropdownFrame.Visible
	end)

	-- Fechar se clicar no fundo do DropdownFrame (qualquer lugar ao lado)
	DropdownFrame.MouseButton1Click:Connect(function()
		DropdownFrame.Visible = false
	end)

	-- Sistema para atualizar o texto ao selecionar uma opção do ScrollingFrame
	for _, child in ipairs(ScrollingFrame:GetChildren()) do
		if child:IsA("TextButton") then
			child.MouseButton1Click:Connect(function()
				DropdownSelectionText.Text = child.Text
				DropdownFrame.Visible = false
				print("[DROPDOWN] Selecionado: " .. child.Text)
			end)
		end
	end

	-- Adicionar suporte dinâmico se novas opções forem inseridas no ScrollingFrame
	ScrollingFrame.ChildAdded:Connect(function(newChild)
		if newChild:IsA("TextButton") then
			newChild.MouseButton1Click:Connect(function()
				DropdownSelectionText.Text = newChild.Text
				DropdownFrame.Visible = false
				print("[DROPDOWN] Selecionado: " .. newChild.Text)
			end)
		end
	end)

	print("Sistema de Dropdown iniciado com sucesso!")
end

