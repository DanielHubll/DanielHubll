    -- ──────────────────────────────────────────────────────
    -- AddTab
    -- ──────────────────────────────────────────────────────
    function Win:AddTab(name, icon)
        local isFirst = #Win._tabs == 0
        local tab = { _name = name, _elems = {} }
        local lo = #Win._tabs + 1

        -- Sidebar button
        local TabBtn = U.New("TextButton", {
            BackgroundColor3 = Theme.AccentSubtle,
            BackgroundTransparency = isFirst and 0 or 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1,0,0, isMobile and 40 or 33),
            Font = Theme.FontSemi,
            Text = (icon and icon.." " or "") .. name,
            TextColor3 = isFirst and Theme.Accent or Theme.TextSecondary,
            TextSize = isMobile and 13 or 11,
            LayoutOrder = lo,
            ZIndex = 13,
            Parent = Sidebar,
        })
        U.Corner(TabBtn, 5)

        local Ind = U.New("Frame", {
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel = 0,
            Position = UDim2.new(0,0,0.12,0),
            Size = UDim2.new(0, isFirst and 3 or 0, 0.76, 0),
            ZIndex = 14,
            Parent = TabBtn,
        })
        U.Corner(Ind, 2)

        -- Scroll frame content
        local Scroll = U.New("ScrollingFrame", {
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1,0,1,0),
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Accent,
            CanvasSize = UDim2.new(0,0,0,0),
            Visible = isFirst,
            ZIndex = 12,
            Parent = ContentArea,
        })
        local ListL = U.New("UIListLayout", {
            Padding = UDim.new(0,5),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = Scroll,
        })
        U.New("UIPadding", {
            PaddingTop    = UDim.new(0,10),
            PaddingLeft   = UDim.new(0,10),
            PaddingRight  = UDim.new(0,10),
            PaddingBottom = UDim.new(0,10),
            Parent = Scroll,
        })
        ListL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Scroll.CanvasSize = UDim2.new(0,0,0, ListL.AbsoluteContentSize.Y + 20)
        end)

        if isFirst then Win._active = tab end
        tab._btn = TabBtn; tab._ind = Ind; tab._scroll = Scroll
        tab._lo = 0

        local function nlo() tab._lo += 1; return tab._lo end

        -- Switch
        TabBtn.MouseButton1Click:Connect(function()
            if Win._active == tab then return end
            local old = Win._active
            if old then
                old._scroll.Visible = false
                U.Tween(old._btn, { TextColor3 = Theme.TextSecondary, BackgroundTransparency = 1 }, 0.12)
                U.Tween(old._ind, { Size = UDim2.new(0,0,0.76,0) }, 0.12)
            end
            Win._active = tab
            Scroll.Visible = true
            U.Tween(TabBtn, { TextColor3 = Theme.Accent, BackgroundTransparency = 0, BackgroundColor3 = Theme.AccentSubtle }, 0.12)
            U.Tween(Ind, { Size = UDim2.new(0,3,0.76,0) }, 0.2, Enum.EasingStyle.Back)
        end)

        table.insert(Win._tabs, tab)

        -- ─────────────────────────────────────────────────
        -- Helper: base row
        -- ─────────────────────────────────────────────────
