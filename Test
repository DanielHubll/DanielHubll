--  CREATE SLIDER
-- ═══════════════════════════════════════════════════════════════

function TabObject:CreateSlider(config)
    -- config = { Name = "Volume", Min = 0, Max = 100, Default = 50, Callback = function(v) end }
    if type(config) == "string" then
        config = { Name = config, Min = 0, Max = 100, Default = 50, Callback = function() end }
    end

    self.ElementCount = self.ElementCount + 1
    local order = self.ElementCount * 10

    local container = createElementContainer(self.Page, order, 55)
    container.Name = config.Name or "Slider_" .. order

    local label = createElementLabel(container, config.Name or "Slider")

    -- Valor display
    local valueLabel = Instance.new("TextLabel", container)
    valueLabel.ZIndex = 3
    valueLabel.TextSize = 15
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.FontFace = Font.new(
        "rbxasset://fonts/families/BuilderSans.json",
        Enum.FontWeight.Bold, Enum.FontStyle.Normal
    )
    valueLabel.TextColor3 = Color3.fromRGB(0, 170, 255)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Size = UDim2.new(0.3, -20, 0, 20)
    valueLabel.Text = tostring(config.Default or 50)
    valueLabel.Name = "ValueLabel"
    valueLabel.Position = UDim2.new(0.7, 0, 0, 5)

    -- Barra do slider
    local sliderBar = Instance.new("Frame", container)
    sliderBar.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    sliderBar.BorderSizePixel = 0
    sliderBar.Size = UDim2.new(0.55, -20, 0, 6)
    sliderBar.Position = UDim2.new(0.4, 10, 0.7, 0)
    sliderBar.Name = "SliderBar"
    sliderBar.ZIndex = 2

    local barCorner = Instance.new("UICorner", sliderBar)

    -- Fill do slider
    local sliderFill = Instance.new("Frame", sliderBar)
    sliderFill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    sliderFill.BorderSizePixel = 0
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderFill.Name = "Fill"
    sliderFill.ZIndex = 3

    local fillCorner = Instance.new("UICorner", sliderFill)

    -- Estado
    local min = config.Min or 0
    local max = config.Max or 100
    local current = config.Default or 50
    local callback = config.Callback or function() end

    local function updateSlider(value)
        current = math.clamp(value, min, max)
        local pct = (current - min) / (max - min)
        sliderFill.Size = UDim2.new(pct, 0, 1, 0)
        valueLabel.Text = tostring(math.floor(current))
    end

    updateSlider(current)

    -- Botões de incremento/decremento
    local leftBtn = Instance.new("TextButton", container)
    leftBtn.Text = "◄"
    leftBtn.TextSize = 16
    leftBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    leftBtn.BackgroundTransparency = 1
    leftBtn.Size = UDim2.new(0, 30, 0, 30)
    leftBtn.Position = UDim2.new(0.35, -5, 0.55, 0)
    leftBtn.ZIndex = 4
    leftBtn.Name = "Decrement"

    local rightBtn = Instance.new("TextButton", container)
    rightBtn.Text = "►"
    rightBtn.TextSize = 16
    rightBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    rightBtn.BackgroundTransparency = 1
    rightBtn.Size = UDim2.new(0, 30, 0, 30)
    rightBtn.Position = UDim2.new(0.95, -5, 0.55, 0)
    rightBtn.ZIndex = 4
    rightBtn.Name = "Increment"

    local step = (max - min) / 20  -- 5% por clique

    leftBtn.MouseButton1Click:Connect(function()
        updateSlider(current - step)
        callback(current)
    end)

    rightBtn.MouseButton1Click:Connect(function()
        updateSlider(current + step)
        callback(current)
    end)

    local sliderApi = {
        Element = container,
        Set = function(self, value)
            updateSlider(value)
            callback(current)
        end,
        Get = function(self)
            return current
        end,
        SetCallback = function(self, newCallback)
            callback = newCallback
        end,
        Destroy = function(self)
            container:Destroy()
        end,
    }

    return sliderApi
end

