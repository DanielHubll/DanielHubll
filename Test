-- Referência aos serviços
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

-- Constantes de design
local COLORS = {
    Accent = Color3.fromRGB(99, 102, 241),      -- Roxo/Indigo
    AccentDark = Color3.fromRGB(79, 70, 229),
    Background = Color3.fromRGB(30, 30, 35),
    Surface = Color3.fromRGB(40, 40, 48),
    SurfaceLight = Color3.fromRGB(50, 50, 58),
    Text = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(160, 160, 170),
    Success = Color3.fromRGB(52, 211, 153),     -- Verde
    Danger = Color3.fromRGB(248, 113, 113),     -- Vermelho
    Warning = Color3.fromRGB(251, 191, 36)      -- Amarelo
}

local TYPOGRAPHY = {
    Title = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal),
    Body = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal),
    Caption = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
}

local ROUNDING = {
    Small = UDim.new(0, 6),
    Medium = UDim.new(0, 8),
    Large = UDim.new(0, 12)
}

-- ============================================================
-- FUNÇÕES UTILITÁRIAS
-- ============================================================

local function createTween(obj, props, duration)
    return TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props)
end

local function addStroke(element, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or COLORS.SurfaceLight
    stroke.Thickness = thickness or 1
    stroke.Parent = element
    return stroke
end

local function addCorner(element, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or ROUNDING.Medium
    corner.Parent = element
    return corner
end

local function addGradient(element, colors)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new(colors or {
        ColorSequenceKeypoint.new(0, Color3.fromRGB(99, 102, 241)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(168, 85, 247))
    })
    gradient.Rotation = 90
    gradient.Parent = element
    return gradient
end

