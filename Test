		ChLabel.Size = UDim2.new(0, 14, 1, 0)
		ChLabel.Position = UDim2.new(0, 0, 0, 0)
		ChLabel.Text = chName
		ChLabel.TextColor3 = channelColors[chName]
		ChLabel.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
		ChLabel.TextSize = 14
		ChLabel.ZIndex = 11
