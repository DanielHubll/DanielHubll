    if config.Draggable then
        Utility.MakeDraggable(MainFrame, TopBar)
    end

    -- Minimize logic
    local originalSize = config.Size
    if MinimizeBtn then
        MinimizeBtn.MouseButton1Click:Connect(function()
            Window.Minimized = not Window.Minimized
            if Window.Minimized then
                Utility.Tween(MainFrame, { Size = UDim2.new(0, config.Size.X.Offset, 0, 46) }, 0.3, Enum.EasingStyle.Back)
                TabBar.Visible = false
