	print(string.format("[Library] Tab criada: %s (Ícone: %s) | Total tabs: %d | Largura: %dpx",
		tabName, tabIcon, getLibraryTabCount(), calculateOptimalWidth()))

	return Tab
end

function Library:SelectTab(tab)
	if not tab or not tab.Button then return end

	if HubBarContainer and isValidElement(HubBarContainer) then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				deselectButton(child)
			end
		end
	end

	hideAllPages()
	selectButton(tab.Button)

	local page = getPageForButton(tab.Button)
	if page then
		page.Visible = true
	end

	activeTab = tab.Button
	print("[Library] Tab selecionada via API: " .. tab.Name)
end

function Library:GetTabs()
	local tabs = {}
	if HubBarContainer and isValidElement(HubBarContainer) then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") and child:GetAttribute("LuminaTab") then
				table.insert(tabs, child)
			end
		end
	end
	return tabs
end

function Library:GetActiveTab()
	return activeTab
end

function Library:GetTabCount()
	return getLibraryTabCount()
end

function Library:IsMobile()
	return isMobile
end

-- ============================================================
-- SISTEMA DE MONITORAMENTO AUTOMÁTICO
-- ============================================================

local function cleanupConnections()
	for _, conn in ipairs(monitoringConnections) do
		if conn then
			conn:Disconnect()
		end
	end
	monitoringConnections = {}
end

local function setupMonitoring()
	cleanupConnections()

	setupSettingsShieldMonitor()

	if HubBarContainer and isValidElement(HubBarContainer) then
		local function connectButton(button)
			if button:GetAttribute("LuminaConnected") then
				return
			end

			button:SetAttribute("LuminaConnected", true)

			button.MouseButton1Click:Connect(function()
				task.defer(function()
					for _, v in ipairs(HubBarContainer:GetChildren()) do
						if v:IsA("TextButton") and v ~= button then
							deselectButton(v)

							local page = getPageForButton(v)
							if page then
								page.Visible = false
							end
						end
					end

					selectButton(button)

					local page = getPageForButton(button)
					if page then
						page.Visible = true
					end

					activeTab = button

					print("[Library] Aba clicada (monitor universal): " .. button.Name)
				end)
			end)
		end

		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				connectButton(child)
			end
		end

		local childAddedConn = HubBarContainer.ChildAdded:Connect(function(child)
			if child:IsA("TextButton") then
				connectButton(child)

				if child:GetAttribute("LuminaTab") then
					print("[Library] Nova aba da library detectada: " .. child.Name)
					adjustHubBarWidth(true)
				end
			end
		end)
		table.insert(monitoringConnections, childAddedConn)

		local childRemovedConn = HubBarContainer.ChildRemoved:Connect(function(child)
			if child:IsA("TextButton") and child:GetAttribute("LuminaTab") then
				print("[Library] Aba da library removida: " .. child.Name)
				if activeTab == child then
					activeTab = nil
				end
				adjustHubBarWidth(true)
			end
		end)
		table.insert(monitoringConnections, childRemovedConn)
	end

	local descendantAddedConn = CoreGui.DescendantAdded:Connect(function(descendant)
		if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
			setupSettingsShieldMonitor()
		elseif descendant.Name == "HubBar" and descendant:IsA("ImageLabel") then
			HubBar = descendant
			task.wait(0.2)
			adjustHubBarWidth(true)
		elseif descendant.Name == "HubBarContainer" then
			HubBarContainer = descendant
			setupMonitoring()
			task.wait(0.3)
			adjustHubBarWidth(true)
		elseif descendant.Name == "PageViewInnerFrame" then
			PageViewInnerFrame = descendant
		end
	end)
	table.insert(monitoringConnections, descendantAddedConn)

	print("[Library] Monitoramento universal configurado! Todas as abas serão controladas.")
end

-- ============================================================
-- INICIALIZAÇÃO AUTOMÁTICA
-- ============================================================

task.spawn(function()
	systemReady = initializeSystem()

	if systemReady then
		setupMonitoring()

		task.wait(0.5)
		adjustHubBarWidth(true)

		print(string.format("[Library] Pronta para uso! Tabs existentes: %d | Plataforma: %s",
			getLibraryTabCount(), isMobile and "Mobile" or "PC"))
	else
		warn("[Library] Falha na inicialização. Tente novamente mais tarde.")
	end
end)

return Library
