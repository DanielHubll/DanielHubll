                svField.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svCursor.Position = UDim2.new(s, -5, 1 - v, -5)
                hueCursor.Position = UDim2.new(h, -3, 0.5, 0)
                local r,g,b = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
                hexInput.Text = string.format("#%02X%02X%02X", r, g, b)
                if callback then callback(color) end
            end

            -- SV drag
            local svDragging = false
            svField.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    svDragging = true
                    local rel = input.Position - svField.AbsolutePosition
                    s = math.clamp(rel.X / svField.AbsoluteSize.X, 0, 1)
                    v = math.clamp(1 - rel.Y / svField.AbsoluteSize.Y, 0, 1)
                    updateAll()
                end
            end)

            -- Hue drag
            local hueDragging = false
            hueBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    hueDragging = true
                    h = math.clamp((input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                    updateAll()
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch then
                    if svDragging then
                        local rel = input.Position - svField.AbsolutePosition
                        s = math.clamp(rel.X / svField.AbsoluteSize.X, 0, 1)
                        v = math.clamp(1 - rel.Y / svField.AbsoluteSize.Y, 0, 1)
                        updateAll()
                    elseif hueDragging then
                        h = math.clamp((input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                        updateAll()
                    end
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    svDragging = false
                    hueDragging = false
                end
            end)

            applyBtn.MouseButton1Click:Connect(function()
                local hex = hexInput.Text:gsub("#","")
                if #hex == 6 then
                    local r = tonumber(hex:sub(1,2),16) or 255
                    local g = tonumber(hex:sub(3,4),16) or 0
                    local b = tonumber(hex:sub(5,6),16) or 0
                    color = Color3.fromRGB(r,g,b)
                    h,s,v = color:ToHSV()
                    updateAll()
                end
            end)

            colorPreview.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    local abs = colorPreview.AbsolutePosition
                    pickerPanel.Position = UDim2.new(0, abs.X - 200, 0, abs.Y + 28)
                    pickerPanel.Visible = true
                    pickerPanel.BackgroundTransparency = 1
                    Utility.Tween(pickerPanel, { BackgroundTransparency = 0 }, 0.15)
                else
                    Utility.Tween(pickerPanel, { BackgroundTransparency = 1 }, 0.15)
                    task.wait(0.15)
                    pickerPanel.Visible = false
                end
            end)

            updateAll()

            local Element = { _row = row }
            function Element:Get() return color end
            function Element:Set(c)
                color = c
                h, s, v = c:ToHSV()
                updateAll()
            end
            table.insert(Tab.Elements, Element)
            return Element
        end

