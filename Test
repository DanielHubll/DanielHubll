-- TAB:ADDTEXTBOX
-- ============================================================
--[[
  Tab:AddTextBox({
      Name         = "Player Name",
      Placeholder  = "Digite aqui...",
      Default      = "",
      ClearOnFocus = false,           -- limpa ao focar (padrão: false)
      Callback     = function(v) end, -- dispara ao perder foco / Enter
      OnChanged    = function(v) end, -- dispara a cada caractere digitado
  })
  API:
    tb.Value
    tb:Set("novo texto")
    tb:GetBox()   → retorna a instância TextBox (para GetPropertyChangedSignal etc.)
]]
function Tab:AddTextBox(config)
	config = config or {}
	local Name         = config.Name         or "TextBox"
	local Placeholder  = config.Placeholder  or "Digite..."
	local Callback     = config.Callback     or function() end
	local OnChanged    = config.OnChanged    or function() end
	local ClearOnFocus = config.ClearOnFocus == true  -- padrão false

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))

	-- ── caixa de texto ──────────────────────────────────────────
	local Box = Instance.new("TextBox")
	Box.Size             = UDim2.new(0, 150, 0, 30)
	Box.Position         = UDim2.new(1, -160, 0.5, -15)
	Box.BackgroundColor3 = Color3.fromRGB(36, 38, 40)   -- igual ao container
	Box.BorderSizePixel  = 0
	Box.TextColor3       = Color3.fromRGB(255, 255, 255)
	Box.TextTransparency = 0.3
	Box.PlaceholderColor3 = Color3.fromRGB(140, 140, 140)
	Box.PlaceholderText  = Placeholder
	Box.Text             = config.Default or ""
	Box.FontFace         = Font.new(
		"rbxasset://fonts/families/BuilderSans.json",
		Enum.FontWeight.Bold,
		Enum.FontStyle.Normal
	)
	Box.TextSize         = 14
	Box.TextXAlignment   = Enum.TextXAlignment.Left
	Box.ClearTextOnFocus = ClearOnFocus
	Box.ZIndex           = 3
	Box.Name             = "TextBox"
	Instance.new("UICorner").Parent = Box

	-- padding interno
	local BoxPad = Instance.new("UIPadding")
	BoxPad.PaddingLeft  = UDim.new(0, 8)
	BoxPad.PaddingRight = UDim.new(0, 8)
	BoxPad.Parent = Box

	-- borda branca semitransparente (stroke)
	local Border = Instance.new("UIStroke")
	Border.Name              = "Border"
	Border.Color             = Color3.fromRGB(255, 255, 255)
	Border.Transparency      = 0.7
	Border.ApplyStrokeMode   = Enum.ApplyStrokeMode.Border
	Border.Parent = Box

	Box.Parent = Frame

	-- foco: borda fica mais visível
	Box.Focused:Connect(function()
		TweenService:Create(Border, TweenInfo.new(0.12), { Transparency = 0.3 }):Play()
		TweenService:Create(Box, TweenInfo.new(0.12), { TextTransparency = 0 }):Play()
	end)

	-- perda de foco: volta ao estado normal + dispara Callback
	Box.FocusLost:Connect(function(pressedEnter)
		TweenService:Create(Border, TweenInfo.new(0.12), { Transparency = 0.7 }):Play()
		TweenService:Create(Box, TweenInfo.new(0.12), { TextTransparency = 0.3 }):Play()
		Callback(Box.Text, pressedEnter)
	end)

	-- callback em tempo real
	Box:GetPropertyChangedSignal("Text"):Connect(function()
		OnChanged(Box.Text)
	end)

	local obj = { Frame = Frame, Value = Box.Text }

	function obj:Set(v)
		Box.Text  = tostring(v)
		self.Value = Box.Text
	end

	function obj:GetBox()
		return Box
	end

	return obj
end

