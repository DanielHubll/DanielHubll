        -- ── AddScrollingList ──────────────────────────────────
        function Tab:AddScrollingList(text, items, callback)
            local selected = nil
            local row = BaseRow(120)
            row.Size = UDim2.new(1, 0, 0, 120)

            if text then
                Utility.Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0, 4),
                    Size = UDim2.new(1, -16, 0, 16),
                    Font = config.Theme.FontSemibold,
                    Text = text,
                    TextColor3 = config.Theme.TextSecondary,
                    TextSize = 10,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 14,
                    Parent = row
                })
            end

            local listFrame = Utility.Create("ScrollingFrame", {
                BackgroundColor3 = config.Theme.SurfaceDark,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 8, 0, text and 22 or 4),
                Size = UDim2.new(1, -16, 1, text and -26 or -8),
                ScrollBarThickness = 2,
                ScrollBarImageColor3 = config.Theme.Accent,
                CanvasSize = UDim2.new(0, 0, 0, #items * 26),
                ZIndex = 14,
                Parent = row
            })
            Utility.RoundCorner(listFrame, 4)

            local ll = Utility.Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Parent = listFrame })

            local itemBtns = {}
            for i, item in ipairs(items) do
                local btn = Utility.Create("TextButton", {
                    BackgroundColor3 = Color3.new(0,0,0),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 26),
                    Font = config.Theme.FontRegular,
                    Text = "  " .. tostring(item),
                    TextColor3 = config.Theme.TextPrimary,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    LayoutOrder = i,
                    ZIndex = 15,
                    Parent = listFrame
                })
                table.insert(itemBtns, btn)

                btn.MouseButton1Click:Connect(function()
                    selected = item
                    for _, b in ipairs(itemBtns) do
                        Utility.Tween(b, {
                            BackgroundTransparency = 1,
                            TextColor3 = config.Theme.TextPrimary
                        }, 0.1)
                    end
                    Utility.Tween(btn, {
                        BackgroundTransparency = 0,
                        BackgroundColor3 = config.Theme.AccentSubtle,
                        TextColor3 = config.Theme.Accent
                    }, 0.1)
                    if callback then callback(item) end
                end)
            end

            local Element = { _row = row }
            function Element:Get() return selected end
            function Element:AddItem(item)
                table.insert(items, item)
                local btn = Utility.Create("TextButton", {
                    BackgroundTransparency = 1, BorderSizePixel = 0,
                    Size = UDim2.new(1,0,0,26), Font = config.Theme.FontRegular,
                    Text = "  "..tostring(item), TextColor3 = config.Theme.TextPrimary,
                    TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left,
                    LayoutOrder = #items, ZIndex = 15, Parent = listFrame
                })
                listFrame.CanvasSize = UDim2.new(0,0,0,#items*26)
                table.insert(itemBtns, btn)
                btn.MouseButton1Click:Connect(function()
                    selected = item
                    if callback then callback(item) end
                end)
            end
            table.insert(Tab.Elements, Element)
            return Element
        end

        table.insert(Window.Tabs, Tab)
        return Tab
    end

    -- ── Notify ───────────────────────────────────────────────
    function Window:Notify(message, notifType, duration)
        duration = duration or 3
        notifType = notifType or "info"
        Window._notifCount = Window._notifCount + 1

        local typeColors = {
            success = config.Theme.Success,
            warning = config.Theme.Warning,
            error   = config.Theme.Error,
            info    = config.Theme.Info,
        }
        local typeIcons = {
            success = "✓",
            warning = "⚠",
            error   = "✕",
            info    = "ℹ",
        }

        local barColor = typeColors[notifType] or config.Theme.Info
        local icon = typeIcons[notifType] or "ℹ"

        local notif = Utility.Create("Frame", {
            BackgroundColor3 = config.Theme.Surface,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, 0),
            ClipsDescendants = true,
            LayoutOrder = Window._notifCount,
            ZIndex = 100,
            Parent = NotifStack
        })
        Utility.RoundCorner(notif, 6)
        Utility.Stroke(notif, config.Theme.Border)

        -- Left accent bar
        Utility.Create("Frame", {
            BackgroundColor3 = barColor,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 3, 1, 0),
            ZIndex = 101,
            Parent = notif
        })
        Utility.RoundCorner(notif:FindFirstChildOfClass("Frame"), 3)

        -- Icon circle
        local iconCircle = Utility.Create("Frame", {
            BackgroundColor3 = barColor,
            BackgroundTransparency = 0.8,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(0, 12, 0.5, -12),
            ZIndex = 101,
            Parent = notif
        })
        Utility.RoundCorner(iconCircle, 6)
        Utility.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,1,0),
            Font = config.Theme.Font,
            Text = icon,
            TextColor3 = barColor,
            TextSize = 12,
            ZIndex = 102,
            Parent = iconCircle
        })

        -- Message
        Utility.Create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 44, 0.5, -8),
            Size = UDim2.new(1, -56, 0, 16),
            Font = config.Theme.FontRegular,
            Text = message,
            TextColor3 = config.Theme.TextPrimary,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 101,
            Parent = notif
        })

        -- Progress bar
        local progressBar = Utility.Create("Frame", {
            BackgroundColor3 = barColor,
            BorderSizePixel = 0,
            BackgroundTransparency = 0.5,
            Position = UDim2.new(0, 3, 1, -2),
            Size = UDim2.new(1, -6, 0, 2),
            ZIndex = 102,
            Parent = notif
        })
        Utility.RoundCorner(progressBar, 2)

        -- Animate in
        Utility.Tween(notif, { Size = UDim2.new(1, 0, 0, 42) }, 0.3, Enum.EasingStyle.Back)
        Utility.Tween(progressBar, { Size = UDim2.new(0, 0, 0, 2) }, duration - 0.3, Enum.EasingStyle.Linear)

        task.delay(duration, function()
            Utility.Tween(notif, { Size = UDim2.new(1,0,0,0), BackgroundTransparency = 1 }, 0.2)
            task.wait(0.2)
            notif:Destroy()
        end)

        return notif
    end

    -- ── SetWatermark ─────────────────────────────────────────
    function Window:SetWatermark(text)
        WatermarkFrame.Visible = true
        WatermarkText.Text = text
    end

    -- ── UpdateWatermark ───────────────────────────────────────
    function Window:UpdateWatermark(text)
        WatermarkText.Text = text
    end

    -- ── SetTheme ─────────────────────────────────────────────
    function Window:SetTheme(newTheme)
        for k, v in pairs(newTheme) do
            config.Theme[k] = v
        end
        -- Note: existing elements won't auto-update (create new window for full retheme)
    end

    -- ── Destroy ──────────────────────────────────────────────
    function Window:Destroy()
        ScreenGui:Destroy()
    end

    -- ── Toggle ───────────────────────────────────────────────
    function Window:Toggle()
        Window.Visible = not Window.Visible
        MainFrame.Visible = Window.Visible
    end

    -- Mobile: larger touch targets
    if Utility.IsMobile() then
        -- Increase all row heights and font sizes slightly
        -- (elements check IsMobile on creation above where relevant)
        -- Tab buttons get wider tap zones
        for _, child in ipairs(TabBar:GetChildren()) do
            if child:IsA("TextButton") then
                child.Size = UDim2.new(1, 0, 0, 42)
                child.TextSize = 13
            end
        end
    end

    return Window
end

