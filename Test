local Library = {}

-- Serviços
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

-- Variáveis do sistema
local HubBarContainer = nil
local PageViewInnerFrame = nil
local HubBar = nil
local SettingsShield = nil
local tabs = {}
local activeTab = nil

-- Configurações
local BASE_WIDTH = 800
local WIDTH_PER_BUTTON = 100
local MIN_WIDTH = 300

-- ============================================================
-- FUNÇÕES UTILITÁRIAS
-- ============================================================

local function findDescendant(parent, name)
	for _, v in ipairs(parent:GetDescendants()) do
		if v.Name == name then
			return v
		end
	end
	return nil
end

local function waitForElement(parent, name, timeout)
	timeout = timeout or 10
	local startTime = tick()
	
	while tick() - startTime < timeout do
		local element = findDescendant(parent, name)
		if element then
			return element
		end
		task.wait(0.1)
	end
	
	return nil
end

-- ============================================================
-- SISTEMA DE INICIALIZAÇÃO
-- ============================================================

local function initializeSystem()
	-- Aguardar elementos principais
	HubBarContainer = waitForElement(CoreGui, "HubBarContainer", 15)
	PageViewInnerFrame = waitForElement(CoreGui, "PageViewInnerFrame", 15)
	
	if not HubBarContainer or not PageViewInnerFrame then
		warn("[Library] Não foi possível encontrar os elementos principais do CoreGui")
		return false
	end
	
	print("[Library] Sistema inicializado com sucesso!")
	return true
end

-- ============================================================
-- SISTEMA DE HUBBAR
-- ============================================================

local function countButtons()
	local count = 0
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				count = count + 1
			end
		end
	end
	return count
end

local function adjustHubBarWidth()
	HubBar = findDescendant(CoreGui, "HubBar")

	if not HubBar or not HubBar:IsA("ImageLabel") then
		return
	end

	local buttons = countButtons()
	local width = BASE_WIDTH

	if buttons > 5 then
		width = math.max(
			MIN_WIDTH,
			BASE_WIDTH - ((buttons - 5) * WIDTH_PER_BUTTON)
		)
	end

	if HubBar.Size.X.Offset ~= width then
		HubBar.Size = UDim2.new(
			0,
			width,
			HubBar.Size.Y.Scale,
			HubBar.Size.Y.Offset
		)
	end
end

-- ============================================================
-- SISTEMA DE SELEÇÃO VISUAL
-- ============================================================

local function deselectButton(button)
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")
	
	if tabSelection then
		tabSelection.Visible = false
	end
	
	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0.5 end
		if title then title.TextTransparency = 0.5 end
	end
end

local function selectButton(button)
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")
	
	if tabSelection then
		tabSelection.Visible = true
	end
	
	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0 end
		if title then title.TextTransparency = 0 end
	end
end

-- ============================================================
-- SISTEMA DE PÁGINAS
-- ============================================================

local function getPageForButton(button)
	if not PageViewInnerFrame then return nil end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name == button.Name then
			return child
		end
	end
	return nil
end

local function hideAllPages()
	if not PageViewInnerFrame then return end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") then
			child.Visible = false
		end
	end
end

local function showPage(page)
	if not page then return end
	hideAllPages()
	page.Visible = true
end

local function onTabClicked(clickedButton)
	-- Controlar visual dos botões
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			if child == clickedButton then
				selectButton(child)
			else
				deselectButton(child)
			end
		end
	end
	
	-- Controlar visibilidade dos frames
	local correspondingPage = getPageForButton(clickedButton)
	if correspondingPage then
		showPage(correspondingPage)
		activeTab = clickedButton
		print("[Library] Aba ativada: " .. clickedButton.Name)
	else
		warn("[Library] Página não encontrada para: " .. clickedButton.Name)
	end
end

-- ============================================================
-- SISTEMA DE SETTINGS SHIELD
-- ============================================================

local function deselectAllButtons()
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				deselectButton(child)
			end
		end
	end
	activeTab = nil
end

local function setupSettingsShieldMonitor()
	SettingsShield = findDescendant(CoreGui, "SettingsShield")
	
	if SettingsShield and SettingsShield:IsA("ImageButton") then
		print("[Library] SettingsShield encontrado! Monitorando...")
		
		if SettingsShield.Visible == false then
			deselectAllButtons()
			hideAllPages()
		end
		
		local connection
		connection = SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
			if SettingsShield.Visible == false then
				print("[Library] SettingsShield fechado - Desselecionando todas as abas")
				deselectAllButtons()
				hideAllPages()
			end
		end)
		
		SettingsShield.AncestryChanged:Connect(function(_, parent)
			if not parent then
				print("[Library] SettingsShield removido - Procurando novamente...")
				connection:Disconnect()
				task.wait(0.5)
				setupSettingsShieldMonitor()
			end
		end)
	else
		print("[Library] SettingsShield não encontrado - Tentando em 1s...")
		task.wait(1)
		setupSettingsShieldMonitor()
	end
end

-- ============================================================
-- CRIAÇÃO DE BOTÃO NO HUBBAR
-- ============================================================

local function createHubBarButton(name, icon)
	local button = Instance.new("TextButton")
	button.Name = name
	button.Selectable = false
	button.ZIndex = 3
	button.BackgroundTransparency = 1
	button.Size = UDim2.new(0.2, 0, 1, 0)
	button.Text = ""
	button.Parent = HubBarContainer
	
	-- TabSelection (indicador visual de seleção)
	local tabSelection = Instance.new("ImageLabel")
	tabSelection.Name = "TabSelection"
	tabSelection.ZIndex = 3
	tabSelection.BorderSizePixel = 0
	tabSelection.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	tabSelection.Size = UDim2.new(1, -2, 0, 2)
	tabSelection.Visible = false
	tabSelection.Position = UDim2.new(0, 3, 1, -2)
	tabSelection.Parent = button
	
	-- TabLabel (container do ícone e título)
	local tabLabel = Instance.new("Frame")
	tabLabel.Name = "TabLabel"
	tabLabel.ZIndex = 3
	tabLabel.BorderSizePixel = 0
	tabLabel.Size = UDim2.new(1, 0, 1, 0)
	tabLabel.BackgroundTransparency = 1
	tabLabel.Parent = button
	
	-- Layout
	local layout = Instance.new("UIListLayout")
	layout.Name = "Layout"
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Padding = UDim.new(0, 10)
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.Parent = tabLabel
	
	-- Ícone
	local iconLabel = Instance.new("TextLabel")
	iconLabel.Name = "Icon"
	iconLabel.TextWrapped = true
	iconLabel.ZIndex = 3
	iconLabel.TextTransparency = 0.5
	iconLabel.TextScaled = true
	iconLabel.FontFace = Font.new(
		"rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json",
		Enum.FontWeight.Regular,
		Enum.FontStyle.Normal
	)
	iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Size = UDim2.new(0, 24, 0, 24)
	iconLabel.Text = icon or "gear"
	iconLabel.Position = UDim2.new(0, 10, 0.5, -18)
	iconLabel.Parent = tabLabel
	
	local aspectRatio = Instance.new("UIAspectRatioConstraint")
	aspectRatio.Name = "AspectRatioConstraint"
	aspectRatio.Parent = iconLabel
	
	-- Título
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.ZIndex = 3
	titleLabel.TextSize = 19
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTransparency = 0.5
	titleLabel.FontFace = Font.new(
		"rbxasset://fonts/families/BuilderSans.json",
		Enum.FontWeight.Medium,
		Enum.FontStyle.Normal
	)
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = name
	titleLabel.AutomaticSize = Enum.AutomaticSize.XY
	titleLabel.Position = UDim2.new(1.2, 5, 0, -2)
	titleLabel.Parent = tabLabel
	
	-- Conectar clique
	button.MouseButton1Click:Connect(function()
		onTabClicked(button)
	end)
	
	return button
end

-- ============================================================
-- CRIAÇÃO DE PÁGINA (FRAME)
-- ============================================================

local function createPage(name)
	local page = Instance.new("Frame")
	page.Name = name
	page.ZIndex = 5
	page.AutomaticSize = Enum.AutomaticSize.Y
	page.Size = UDim2.new(1, 0, 0, 1174)
	page.Position = UDim2.new(0, 0, 0, 0)
	page.BackgroundTransparency = 1
	page.SelectionGroup = true
	page.Visible = false
	page.Parent = PageViewInnerFrame
	
	-- UIPadding
	local padding = Instance.new("UIPadding")
	padding.PaddingRight = UDim.new(0, 11)
	padding.PaddingLeft = UDim.new(0, 12)
	padding.Parent = page
	
	-- RowListLayout
	local layout = Instance.new("UIListLayout")
	layout.Name = "RowListLayout"
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = page
	
	return page
end

-- ============================================================
-- API PÚBLICA
-- ============================================================

function Library:CreateTab(config)
	config = config or {}
	local tabName = config.Name or "Tab"
	local tabIcon = config.Icon or "gear"
	
	-- Criar botão no HubBar
	local button = createHubBarButton(tabName, tabIcon)
	
	-- Criar página correspondente
	local page = createPage(tabName)
	
	-- Criar objeto Tab
	local Tab = {
		Name = tabName,
		Icon = tabIcon,
		Button = button,
		Page = page,
		-- Placeholders para componentes futuros
		Toggle = nil,
		Button = nil,
		Slider = nil,
		Textbox = nil,
		Dropdown = nil,
		ColorPicker = nil,
		Keybind = nil,
		Label = nil,
		Paragraph = nil,
		Section = nil
	}
	
	-- Adicionar à lista de tabs
	table.insert(tabs, Tab)
	
	-- Se for a primeira tab, selecionar automaticamente
	if #tabs == 1 then
		onTabClicked(button)
	end
	
	print(string.format("[Library] Tab criada: %s (Ícone: %s)", tabName, tabIcon))
	
	return Tab
end

function Library:GetTabs()
	return tabs
end

function Library:GetActiveTab()
	return activeTab
end

-- ============================================================
-- INICIALIZAÇÃO AUTOMÁTICA
-- ============================================================

local systemReady = false

task.spawn(function()
	systemReady = initializeSystem()
	
	if systemReady then
		-- Configurar monitoramento do SettingsShield
		setupSettingsShieldMonitor()
		
		-- Configurar ajuste contínuo do HubBar
		task.spawn(function()
			while true do
				if systemReady then
					adjustHubBarWidth()
				end
				task.wait(0.1)
			end
		end)
		
		print("[Library] Pronta para uso!")
	else
		warn("[Library] Falha na inicialização. Tente novamente mais tarde.")
	end
end)

-- ============================================================
-- RETORNO
-- ============================================================

return Library
