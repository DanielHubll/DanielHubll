	local obj = { Wrapper = Wrapper, Selected = getSelectedList() }
	function obj:Set(values)
		Selected = {}
		for _, v in ipairs(values) do Selected[v] = true end
		for optName, refs in pairs(checkboxRefs) do
			local on = Selected[optName] == true
			refs.mark.Visible = on
			refs.bg.BackgroundColor3 = on and Color3.fromRGB(99, 102, 241) or Color3.fromRGB(55, 58, 65)
		end
		updatePreview()
		self.Selected = getSelectedList()
		Callback(self.Selected)
	end
	return obj
end

