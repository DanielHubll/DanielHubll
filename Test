	-- DROPDOWN (MOBILE & PC)
	function Tab:Dropdown(config)
		config = config or {}
		local Options = config.Options or {}
		local Value = config.Default or ""
		local Callback = config.Callback or function() end
		local IsOpen = false
		
		local DropdownFrame = Instance.new("Frame")
		DropdownFrame.Size = UDim2.new(1, -24, 0, 50)
		DropdownFrame.BackgroundColor3 = Theme.ComponentBg
		DropdownFrame.ClipsDescendants = false
		DropdownFrame.ZIndex = 10
		DropdownFrame.Parent = page
		Instance.new("UICorner", DropdownFrame).CornerRadius = UDim.new(0, 8)
		
		local Label = Instance.new("TextLabel")
		Label.BackgroundTransparency = 1
		Label.Size = UDim2.new(1, -30, 1, 0)
		Label.Position = UDim2.new(0, 15, 0, 0)
		Label.Font = Enum.Font.Gotham
		Label.TextSize = 14
		Label.TextColor3 = Theme.Text
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Text = Value ~= "" and (config.Name .. ": " .. Value) or config.Name
		Label.ZIndex = 11
		Label.Parent = DropdownFrame
		
		local Arrow = Instance.new("TextLabel")
		Arrow.BackgroundTransparency = 1
		Arrow.Size = UDim2.new(0, 20, 0, 20)
		Arrow.Position = UDim2.new(1, -30, 0.5, -10)
		Arrow.Font = Enum.Font.GothamBold
		Arrow.TextSize = 14
		Arrow.TextColor3 = Theme.Text
		Arrow.Text = "▼"
		Arrow.ZIndex = 11
		Arrow.Parent = DropdownFrame
		
		local OptionContainer = Instance.new("Frame")
		OptionContainer.Size = UDim2.new(1, 0, 0, 0)
		OptionContainer.Position = UDim2.new(0, 0, 1, 5)
		OptionContainer.BackgroundColor3 = Theme.ComponentHover
		OptionContainer.ClipsDescendants = true
		OptionContainer.ZIndex = 10
		OptionContainer.Visible = false
		OptionContainer.Parent = DropdownFrame
		Instance.new("UICorner", OptionContainer).CornerRadius = UDim.new(0, 8)
		
		local OptionList = Instance.new("UIListLayout")
		OptionList.SortOrder = Enum.SortOrder.LayoutOrder
		OptionList.Parent = OptionContainer
		Instance.new("UIPadding", OptionContainer).PaddingTop = UDim.new(0, 5)
		
		local function UpdateDropdown()
			OptionContainer.Visible = IsOpen
			OptionContainer.Size = IsOpen and UDim2.new(1, 0, 0, #Options * 30 + 10) or UDim2.new(1, 0, 0, 0)
			Arrow.Text = IsOpen and "▲" or "▼"
		end
		
		local function BuildOptions()
			for _, child in ipairs(OptionContainer:GetChildren()) do
				if child:IsA("TextButton") then child:Destroy() end
			end
			
			for _, option in ipairs(Options) do
				local Btn = Instance.new("TextButton")
				Btn.Size = UDim2.new(1, -10, 0, 30)
				Btn.Position = UDim2.new(0, 5, 0, 0)
				Btn.BackgroundTransparency = 1
				Btn.Font = Enum.Font.Gotham
				Btn.TextSize = 13
				Btn.TextColor3 = option == Value and Theme.Accent or Theme.TextDim
				Btn.Text = option
				Btn.TextXAlignment = Enum.TextXAlignment.Left
				Btn.ZIndex = 11
				Btn.Parent = OptionContainer
				
				Btn.MouseButton1Click:Connect(function()
					Value = option; Label.Text = config.Name .. ": " .. Value
					IsOpen = false; UpdateDropdown(); Callback(Value)
					BuildOptions()
				end)
			end
		end
		BuildOptions()
		
		DropdownFrame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				IsOpen = not IsOpen; UpdateDropdown()
			end
		end)
		
		local DropdownObject = {}
		function DropdownObject:Set(newValue) Value = newValue; Label.Text = config.Name .. ": " .. Value; BuildOptions(); Callback(Value) end
		function DropdownObject:Refresh(newOptions) Options = newOptions; Value = ""; Label.Text = config.Name; BuildOptions() end
		return DropdownObject
	end
	
	-- COLORPICKER (MOBILE & PC)
	function Tab:ColorPicker(config)
		config = config or {}
		local Value = config.Default or Color3.fromRGB(255, 255, 255)
		local Callback = config.Callback or function() end
		local IsOpen = false
		
		local PickerFrame = Instance.new("Frame")
		PickerFrame.Size = UDim2.new(1, -24, 0, 50)
		PickerFrame.BackgroundColor3 = Theme.ComponentBg
		PickerFrame.ClipsDescendants = false
		PickerFrame.ZIndex = 10
		PickerFrame.Parent = page
		Instance.new("UICorner", PickerFrame).CornerRadius = UDim.new(0, 8)
		
		local Label = Instance.new("TextLabel")
		Label.BackgroundTransparency = 1
		Label.Size = UDim2.new(1, -50, 1, 0)
		Label.Position = UDim2.new(0, 15, 0, 0)
		Label.Font = Enum.Font.Gotham
		Label.TextSize = 14
		Label.TextColor3 = Theme.Text
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Text = config.Name or "Color Picker"
		Label.ZIndex = 11
		Label.Parent = PickerFrame
		
		local ColorPreview = Instance.new("Frame")
		ColorPreview.Size = UDim2.new(0, 24, 0, 24)
		ColorPreview.Position = UDim2.new(1, -40, 0.5, -12)
		ColorPreview.BackgroundColor3 = Value
		ColorPreview.ZIndex = 11
		ColorPreview.Parent = PickerFrame
		Instance.new("UICorner", ColorPreview).CornerRadius = UDim.new(0, 6)
		
		local ColorContainer = Instance.new("Frame")
		ColorContainer.Size = UDim2.new(1, 0, 0, 0)
		ColorContainer.Position = UDim2.new(0, 0, 1, 5)
		ColorContainer.BackgroundColor3 = Theme.ComponentHover
		ColorContainer.ClipsDescendants = true
		ColorContainer.ZIndex = 10
		ColorContainer.Visible = false
		ColorContainer.Parent = PickerFrame
		Instance.new("UICorner", ColorContainer).CornerRadius = UDim.new(0, 8)
		
		local function createColorSlider(parent, name, color, posY)
			local SliderFrame = Instance.new("Frame")
			SliderFrame.Size = UDim2.new(1, -20, 0, 40)
			SliderFrame.Position = UDim2.new(0, 10, 0, posY)
			SliderFrame.BackgroundTransparency = 1
			SliderFrame.ZIndex = 11
			SliderFrame.Parent = parent
			
			local SliderLabel = Instance.new("TextLabel")
			SliderLabel.BackgroundTransparency = 1
			SliderLabel.Size = UDim2.new(0, 20, 1, 0)
			SliderLabel.Font = Enum.Font.GothamBold
			SliderLabel.TextColor3 = color
			SliderLabel.Text = name
			SliderLabel.ZIndex = 11
			SliderLabel.Parent = SliderFrame
			
			local SliderBar = Instance.new("Frame")
			SliderBar.Size = UDim2.new(1, -30, 0, 4)
			SliderBar.Position = UDim2.new(0, 25, 0.5, -2)
			SliderBar.BackgroundColor3 = Theme.Background
			SliderBar.ZIndex = 11
			SliderBar.Parent = SliderFrame
			
			local Fill = Instance.new("Frame")
			Fill.BackgroundColor3 = color
			Fill.ZIndex = 11
			Fill.Parent = SliderBar
			return SliderBar, Fill
		end
		
		local RBar, RFill = createColorSlider(ColorContainer, "R", Color3.fromRGB(255, 0, 0), 10)
		local GBar, GFill = createColorSlider(ColorContainer, "G", Color3.fromRGB(0, 255, 0), 55)
		local BBar, BFill = createColorSlider(ColorContainer, "B", Color3.fromRGB(0, 0, 255), 100)
		
		local function UpdateColor()
			RFill.Size = UDim2.new(Value.R, 0, 1, 0)
			GFill.Size = UDim2.new(Value.G, 0, 1, 0)
			BFill.Size = UDim2.new(Value.B, 0, 1, 0)
			ColorPreview.BackgroundColor3 = Value
			Callback(Value)
		end
		
		local function setupInteraction(bar, comp)
			local MouseHeld = false
			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					MouseHeld = true
					local relPos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
					if comp == "R" then Value = Color3.fromRGB(relPos*255, Value.G*255, Value.B*255)
					elseif comp == "G" then Value = Color3.fromRGB(Value.R*255, relPos*255, Value.B*255)
					else Value = Color3.fromRGB(Value.R*255, Value.G*255, relPos*255) end
					UpdateColor()
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then MouseHeld = false end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if MouseHeld and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					local relPos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
					if comp == "R" then Value = Color3.fromRGB(relPos*255, Value.G*255, Value.B*255)
					elseif comp == "G" then Value = Color3.fromRGB(Value.R*255, relPos*255, Value.B*255)
					else Value = Color3.fromRGB(Value.R*255, Value.G*255, relPos*255) end
					UpdateColor()
				end
			end)
		end
		
		setupInteraction(RBar, "R"); setupInteraction(GBar, "G"); setupInteraction(BBar, "B")
		UpdateColor()
		
		PickerFrame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				IsOpen = not IsOpen
				ColorContainer.Visible = IsOpen
				ColorContainer.Size = IsOpen and UDim2.new(1, 0, 0, 150) or UDim2.new(1, 0, 0, 0)
			end
		end)
		
		local ColorPickerObject = {}
		function ColorPickerObject:Set(newValue) Value = newValue; UpdateColor() end
		function ColorPickerObject:Get() return Value end
		return ColorPickerObject
	end
	
	-- KEYBIND (COM BOTÃO VIRTUAL MOBILE)
	function Tab:Keybind(config)
		config = config or {}
		local Value = config.Default or Enum.KeyCode.E
		local Callback = config.Callback or function() end
		local IsBinding = false
		
		local KeybindFrame = Instance.new("Frame")
		KeybindFrame.Size = UDim2.new(1, -24, 0, 50)
		KeybindFrame.BackgroundColor3 = Theme.ComponentBg
		KeybindFrame.Parent = page
		Instance.new("UICorner", KeybindFrame).CornerRadius = UDim.new(0, 8)
		
		local Label = Instance.new("TextLabel")
		Label.BackgroundTransparency = 1
		Label.Size = UDim2.new(1, -100, 1, 0)
		Label.Position = UDim2.new(0, 15, 0, 0)
		Label.Font = Enum.Font.Gotham
		Label.TextSize = 14
		Label.TextColor3 = Theme.Text
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Text = config.Name or "Keybind"
		Label.Parent = KeybindFrame
		
		local KeyButton = Instance.new("TextButton")
		KeyButton.Size = UDim2.new(0, 60, 0, 26)
		KeyButton.Position = UDim2.new(1, -75, 0.5, -13)
		KeyButton.BackgroundColor3 = Theme.ComponentHover
		KeyButton.Font = Enum.Font.GothamBold
		KeyButton.TextSize = 12
		KeyButton.TextColor3 = Theme.Accent
		KeyButton.Text = isMobile and "MOBILE" or Value.Name
		KeyButton.Parent = KeybindFrame
		Instance.new("UICorner", KeyButton).CornerRadius = UDim.new(0, 6)
		
		-- Botão Virtual na tela se for Mobile
		if isMobile then
			local ScreenGui = Instance.new("ScreenGui")
			ScreenGui.Name = "LuminaVirtualKeybind_" .. Label.Text
			ScreenGui.ResetOnSpawn = false
			ScreenGui.Parent = CoreGui
			
			local VirtualBtn = Instance.new("TextButton")
			VirtualBtn.Size = UDim2.new(0, 50, 0, 50)
			VirtualBtn.Position = UDim2.new(0.8, 0, 0.7, 0) -- Lado direito da tela
			VirtualBtn.BackgroundColor3 = Theme.ComponentBg
			VirtualBtn.Font = Enum.Font.GothamBold
			VirtualBtn.TextSize = 14
			VirtualBtn.TextColor3 = Theme.Accent
			VirtualBtn.Text = Label.Text
			VirtualBtn.Parent = ScreenGui
			Instance.new("UICorner", VirtualBtn).CornerRadius = UDim.new(1, 0)
			
			VirtualBtn.MouseButton1Click:Connect(Callback)
		end
		
		if not isMobile then
			KeyButton.MouseButton1Click:Connect(function()
				if IsBinding then return end
				IsBinding = true
				KeyButton.Text = "..."
				
				local connection
				connection = UserInputService.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.Keyboard then
						if input.KeyCode == Enum.KeyCode.Escape then
							IsBinding = false; KeyButton.Text = Value.Name; connection:Disconnect(); return
						end
						Value = input.KeyCode; KeyButton.Text = Value.Name
						IsBinding = false; connection:Disconnect()
					end
				end)
			end)
			
			UserInputService.InputBegan:Connect(function(input, processed)
				if not processed and input.KeyCode == Value and not IsBinding then Callback() end
			end)
		end
		
		local KeybindObject = {}
		function KeybindObject:Set(newValue) Value = newValue; if not isMobile then KeyButton.Text = Value.Name end end
		function KeybindObject:Get() return Value end
		return KeybindObject
	end
	
	return Tab
end

function Library:SelectTab(tab)
	if not tab or not tab.Button then return end
	onTabClicked(tab.Button)
end

-- ============================================================
-- SISTEMA DE MONITORAMENTO E INICIALIZAÇÃO
-- ============================================================

local function setupMonitoring()
	for _, conn in ipairs(monitoringConnections) do
		if conn then conn:Disconnect() end
	end
	monitoringConnections = {}
	
	setupSettingsShieldMonitor()
	
	if HubBarContainer and isValidElement(HubBarContainer) then
		local function connectButton(button)
			if button:GetAttribute("LuminaConnected") then return end
			button:SetAttribute("LuminaConnected", true)
			button.MouseButton1Click:Connect(function() task.defer(function() onTabClicked(button) end) end)
		end
		
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then connectButton(child) end
		end
		
		table.insert(monitoringConnections, HubBarContainer.ChildAdded:Connect(function(child)
			if child:IsA("TextButton") then
				connectButton(child)
				if child:GetAttribute("LuminaTab") then adjustHubBarWidth(true) end
			end
		end))
		
		table.insert(monitoringConnections, HubBarContainer.ChildRemoved:Connect(function(child)
			if child:IsA("TextButton") and child:GetAttribute("LuminaTab") then
				if activeTab == child then activeTab = nil end
				adjustHubBarWidth(true)
			end
		end))
	end
	
	table.insert(monitoringConnections, CoreGui.DescendantAdded:Connect(function(descendant)
		if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
			setupSettingsShieldMonitor()
		elseif descendant.Name == "HubBar" and descendant:IsA("ImageLabel") then
			HubBar = descendant; task.wait(0.2); adjustHubBarWidth(true)
		elseif descendant.Name == "HubBarContainer" then
			HubBarContainer = descendant; setupMonitoring(); task.wait(0.3); adjustHubBarWidth(true)
		elseif descendant.Name == "PageViewInnerFrame" then
			PageViewInnerFrame = descendant
		end
	end))
end

task.spawn(function()
	systemReady = initializeSystem()
	if systemReady then
		setupMonitoring()
		task.wait(0.5)
		adjustHubBarWidth(true)
	end
end)

return Library
