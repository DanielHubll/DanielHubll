    selection2.TextSize = 17
    selection2.TextTransparency = 1
    selection2.BorderSizePixel = 0
    selection2.ZIndex = 2
    selection2.TextWrapped = true
    selection2.Parent = selector
    
    -- Função para atualizar visual
    local function updateVisual(value)
        if value then
            selection1.TextTransparency = 1
            selection2.TextTransparency = 0
        else
            selection1.TextTransparency = 0
            selection2.TextTransparency = 1
        end
    end
    
    -- Configurar estado inicial
    updateVisual(state)
    if default then
        callback(state)
    end
    
    -- Conectar eventos
    local function toggle()
        state = not state
        updateVisual(state)
        callback(state)
    end
    
    leftButton.MouseButton1Click:Connect(toggle)
    rightButton.MouseButton1Click:Connect(toggle)
    autoSelect.MouseButton1Click:Connect(toggle)
    
    -- Guardar referências
    table.insert(self.Elements, {
        Type = "Toggle",
        Frame = mainFrame,
        State = function() return state end,
        SetState = function(val)
            state = val
            updateVisual(state)
            callback(state)
        end
    })
    
    return self
end

-- ============================================================
-- GERENCIADOR DE UI (HUBBAR CONTROLLER)
-- ============================================================
local UIManager = {}
UIManager.__index = UIManager

function UIManager.new()
    local self = setmetatable({}, UIManager)
    
    self.Windows = {}
    self.HubBarContainer = nil
    self.PageViewInnerFrame = nil
    self.HubBar = nil
    self.SettingsShield = nil
    self.Initialized = false
    
    -- Aguardar objetos necessários
    self:WaitForContainers()
    
    -- Inicializar sistemas
    self:InitHubBarSystem()
    self:InitSettingsShieldMonitor()
    
    self.Initialized = true
    
    return self
end

function UIManager:WaitForContainers()
    -- Aguardar HubBarContainer
    self.HubBarContainer = waitForObject(CoreGui, "HubBarContainer", 10)
    if not self.HubBarContainer then
        warn("[UILibrary] HubBarContainer não encontrado!")
        return
    end
    
    -- Aguardar PageViewInnerFrame
    self.PageViewInnerFrame = waitForObject(CoreGui, "PageViewInnerFrame", 10)
    if not self.PageViewInnerFrame then
        warn("[UILibrary] PageViewInnerFrame não encontrado!")
        return
    end
    
    -- Aguardar HubBar
    self.HubBar = waitForObject(CoreGui, "HubBar", 5)
end

function UIManager:SelectWindow(window)
    if not self.HubBarContainer then return end
    
    -- Desselecionar todos os botões
    for _, win in ipairs(self.Windows) do
        if win.TabSelection then
            win.TabSelection.Visible = false
        end
        if win.IconLabel then
            win.IconLabel.TextTransparency = 0.5
        end
        if win.TitleLabel then
            win.TitleLabel.TextTransparency = 0.5
        end
        if win.Page then
            win.Page.Visible = false
        end
    end
    
    -- Selecionar a window clicada
    if window.TabSelection then
        window.TabSelection.Visible = true
    end
    if window.IconLabel then
        window.IconLabel.TextTransparency = 0
    end
    if window.TitleLabel then
        window.TitleLabel.TextTransparency = 0
    end
    if window.Page then
        window.Page.Visible = true
    end
end

function UIManager:DeselectAll()
    for _, win in ipairs(self.Windows) do
        if win.TabSelection then
            win.TabSelection.Visible = false
        end
        if win.IconLabel then
            win.IconLabel.TextTransparency = 0.5
        end
        if win.TitleLabel then
            win.TitleLabel.TextTransparency = 0.5
        end
        if win.Page then
            win.Page.Visible = false
        end
    end
end

function UIManager:AdjustHubBarWidth()
    if not self.HubBar then return end
    if not self.HubBar:IsA("GuiObject") then return end
    
    local buttonCount = #self.Windows
    local baseWidth = 800
    local widthPerButton = 100
    
    if buttonCount > 5 then
        local extraButtons = buttonCount - 5
        local newWidth = baseWidth - (widthPerButton * extraButtons)
        if newWidth < 300 then newWidth = 300 end
        
        local currentSize = self.HubBar.Size
        self.HubBar.Size = UDim2.new(0, newWidth, currentSize.Y.Scale, currentSize.Y.Offset)
    else
        local currentSize = self.HubBar.Size
        self.HubBar.Size = UDim2.new(0, baseWidth, currentSize.Y.Scale, currentSize.Y.Offset)
    end
end

function UIManager:InitHubBarSystem()
    if not self.HubBarContainer then return end
    
    -- Conectar eventos de clique para windows já existentes
    self.HubBarContainer.ChildAdded:Connect(function(child)
        if child:IsA("TextButton") then
            -- Encontrar a window correspondente
            for _, win in ipairs(self.Windows) do
                if win.Button == child then
                    child.MouseButton1Click:Connect(function()
                        self:SelectWindow(win)
                    end)
                    break
                end
            end
            task.wait(0.1)
            self:AdjustHubBarWidth()
        end
    end)
    
    self.HubBarContainer.ChildRemoved:Connect(function(child)
        if child:IsA("TextButton") then
            task.wait(0.1)
            self:AdjustHubBarWidth()
        end
    end)
end

function UIManager:InitSettingsShieldMonitor()
    local function monitor()
        self.SettingsShield = findDescendant(CoreGui, "SettingsShield")
        
        if self.SettingsShield and self.SettingsShield:IsA("ImageButton") then
            if self.SettingsShield.Visible == false then
                self:DeselectAll()
            end
            
            local connection
            connection = self.SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
                if self.SettingsShield.Visible == false then
                    self:DeselectAll()
                end
            end)
            
            self.SettingsShield.AncestryChanged:Connect(function(_, parent)
                if not parent then
                    connection:Disconnect()
                    task.wait(0.5)
                    monitor()
                end
            end)
        else
            task.wait(1)
            monitor()
        end
    end
    
    monitor()
    
    -- Também monitorar quando SettingsShield for criado
    CoreGui.DescendantAdded:Connect(function(descendant)
        if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
            monitor()
        end
    end)
end

-- ============================================================
-- FUNÇÃO PÚBLICA: CreateWindow
-- ============================================================
function UILibrary.CreateWindow(name, icon)
    if not UILibrary.__manager then
        UILibrary.__manager = UIManager.new()
    end
    
    local manager = UILibrary.__manager
    
    if not manager.HubBarContainer or not manager.PageViewInnerFrame then
        warn("[UILibrary] Containers não encontrados. Tentando novamente...")
        manager:WaitForContainers()
    end
    
    if not manager.HubBarContainer or not manager.PageViewInnerFrame then
        error("[UILibrary] Não foi possível encontrar os containers necessários!")
    end
    
    local window = Window.new(name, icon, manager.HubBarContainer, manager.PageViewInnerFrame)
    table.insert(manager.Windows, window)
    
    -- Conectar clique
    if window.Button then
        window.Button.MouseButton1Click:Connect(function()
            manager:SelectWindow(window)
        end)
    end
    
    -- Ajustar largura da HubBar
    task.wait(0.1)
    manager:AdjustHubBarWidth()
    
    return window
end

