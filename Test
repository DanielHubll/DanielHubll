    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -120, 1, 0)
    titleLabel.Parent = keybindFrame
    
    -- Botão de keybind
    local keyButton = Instance.new("TextButton")
    keyButton.Name = "KeyButton"
    keyButton.Text = default.Name
    keyButton.TextColor3 = COLORS.Text
    keyButton.FontFace = TYPOGRAPHY.Body
    keyButton.TextSize = 13
    keyButton.BackgroundColor3 = COLORS.SurfaceLight
    keyButton.Size = UDim2.new(0, 100, 0, 32)
    keyButton.AutoButtonColor = false
    keyButton.Parent = keybindFrame
    
    addCorner(keyButton, ROUNDING.Small)
    
    -- Variáveis
    local currentKey = default
    local isBinding = false
    
    -- Função de atualização
    local function updateKey(key)
        currentKey = key
        keyButton.Text = key.Name
        callback(key)
        
        if flag then
            if saveSystem and saveSystem.SetFlag then
                saveSystem.SetFlag(flag, key.Name)
            end
        end
    end
    
    -- Binding
    keyButton.MouseButton1Click:Connect(function()
        isBinding = true
        keyButton.Text = "..."
        keyButton.BackgroundColor3 = COLORS.Accent
    end)
    
    -- Detectar input
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if isBinding and input.UserInputType == Enum.UserInputType.Keyboard and not gameProcessed then
            isBinding = false
            keyButton.BackgroundColor3 = COLORS.SurfaceLight
            updateKey(input.KeyCode)
        elseif not isBinding and input.KeyCode == currentKey and not gameProcessed then
            callback(currentKey, true) -- true = pressed
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if not isBinding and input.KeyCode == currentKey then
            callback(currentKey, false) -- false = released
        end
    end)
    
    local KeybindComponent = {
        Instance = keybindFrame,
        Button = keyButton,
        Set = function(self, key)
            updateKey(key)
        end,
        Get = function(self)
            return currentKey
        end
    }
    
    return KeybindComponent
end

