                ZIndex = 14,
                Parent = row
            })

            local selBtn = Utility.Create("TextButton", {
                BackgroundColor3 = config.Theme.SurfaceDark,
                BorderSizePixel = 0,
                Position = UDim2.new(0.45, 4, 0.5, -12),
                Size = UDim2.new(0.55, -16, 0, 24),
                Font = config.Theme.FontRegular,
                Text = tostring(selected) .. "  ▾",
                TextColor3 = config.Theme.TextPrimary,
                TextSize = 11,
                ZIndex = 14,
                Parent = row
            })
            Utility.RoundCorner(selBtn, 4)
            Utility.Stroke(selBtn, config.Theme.Border)

            -- Dropdown list (rendered outside the row)
            local dropList = Utility.Create("Frame", {
                BackgroundColor3 = config.Theme.Surface,
                BorderSizePixel = 0,
                Size = UDim2.new(0, selBtn.Size.X.Scale * ContentArea.AbsoluteSize.X, 0, 0),
                ZIndex = 50,
                ClipsDescendants = true,
                Visible = false,
                Parent = ScreenGui
            })
            Utility.RoundCorner(dropList, 5)
            Utility.Stroke(dropList, config.Theme.Accent)

            local dropLayout = Utility.Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = dropList
            })

            local function closeDropdown()
                isOpen = false
                Utility.Tween(dropList, { Size = UDim2.new(0, dropList.AbsoluteSize.X, 0, 0) }, 0.15)
                task.wait(0.15)
                dropList.Visible = false
            end

            local function buildItems()
                for _, child in ipairs(dropList:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                for i, opt in ipairs(options) do
                    local item = Utility.Create("TextButton", {
                        BackgroundColor3 = opt == selected and config.Theme.AccentSubtle or Color3.fromRGB(0,0,0),
                        BackgroundTransparency = opt == selected and 0 or 1,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 28),
                        Font = config.Theme.FontRegular,
                        Text = "  " .. tostring(opt),
                        TextColor3 = opt == selected and config.Theme.Accent or config.Theme.TextPrimary,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        LayoutOrder = i,
                        ZIndex = 51,
                        Parent = dropList
                    })
                    item.MouseButton1Click:Connect(function()
                        selected = opt
                        selBtn.Text = tostring(opt) .. "  ▾"
                        closeDropdown()
                        if callback then callback(opt) end
                        buildItems()
                    end)
                end
            end
            buildItems()

            selBtn.MouseButton1Click:Connect(function()
                if isOpen then
                    closeDropdown()
                else
                    isOpen = true
                    -- Position dropdown below button
                    local abs = selBtn.AbsolutePosition
                    local sz = selBtn.AbsoluteSize
                    local itemH = 28
                    local totalH = math.min(#options, 6) * itemH
                    dropList.Position = UDim2.new(0, abs.X, 0, abs.Y + sz.Y + 4)
                    dropList.Size = UDim2.new(0, sz.X, 0, 0)
                    dropList.Visible = true
                    Utility.Tween(dropList, { Size = UDim2.new(0, sz.X, 0, totalH) }, 0.2, Enum.EasingStyle.Back)
                end
            end)

            -- Close on outside click
            UserInputService.InputBegan:Connect(function(input)
                if isOpen and (input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch) then
                    task.wait(0.01)
                    if isOpen then closeDropdown() end
                end
            end)

            local Element = { _row = row, Value = selected }
            function Element:Set(v)
                selected = v
                selBtn.Text = tostring(v) .. "  ▾"
                buildItems()
            end
            function Element:Get() return selected end
            function Element:Refresh(newOpts)
                options = newOpts
                buildItems()
            end
            table.insert(Tab.Elements, Element)
            return Element
        end

