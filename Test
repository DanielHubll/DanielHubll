		Value = Color3.fromRGB(channelVals.R, channelVals.G, channelVals.B)
		Preview.BackgroundColor3 = Value
		if not skipCb then Callback(Value) end
	end

	for _, ch in ipairs(channels) do
		local chName, chVal = ch[1], ch[2]

		local Row = Instance.new("Frame")
		Row.BackgroundTransparency = 1
		Row.Size = UDim2.new(1, 0, 0, 28)
		Row.LayoutOrder = _ 
		Row.Parent = Panel

