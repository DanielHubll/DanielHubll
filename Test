		Label.BackgroundTransparency = 1
		Label.Size = UDim2.new(1, -80, 1, 0)
		Label.Position = UDim2.new(0, 15, 0, 0)
		Label.Font = Enum.Font.Gotham
		Label.TextSize = isMobile and 13 or 14
