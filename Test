		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Text = Name
		Label.TextWrapped = true
		Label.Parent = ToggleFrame

		-- Toggle switch com tamanho aumentado para mobile
		local switchWidth = isMobile and 50 or 44
		local switchHeight = isMobile and 28 or 24
		local circleSize = isMobile and 22 or 18

		local ToggleButton = Instance.new("Frame")
		ToggleButton.Size = UDim2.new(0, switchWidth, 0, switchHeight)
		ToggleButton.Position = UDim2.new(1, -(switchWidth + 15), 0.5, -(switchHeight / 2))
		ToggleButton.BackgroundColor3 = Value and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(60, 60, 60)
		ToggleButton.BorderSizePixel = 0
		ToggleButton.Parent = ToggleFrame

		local ToggleButtonCorner = Instance.new("UICorner")
		ToggleButtonCorner.CornerRadius = UDim.new(1, 0)
		ToggleButtonCorner.Parent = ToggleButton

		local circleOffset = (switchHeight - circleSize) / 2
		local Circle = Instance.new("Frame")
		Circle.Size = UDim2.new(0, circleSize, 0, circleSize)
		Circle.Position = Value and UDim2.new(1, -(circleSize + circleOffset), 0.5, -(circleSize / 2)) or UDim2.new(0, circleOffset, 0.5, -(circleSize / 2))
		Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		Circle.BorderSizePixel = 0
		Circle.Parent = ToggleButton

		local CircleCorner = Instance.new("UICorner")
		CircleCorner.CornerRadius = UDim.new(1, 0)
		CircleCorner.Parent = Circle

		local function UpdateVisual()
			local goalColor = Value and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(60, 60, 60)
			local goalPosition = Value and UDim2.new(1, -(circleSize + circleOffset), 0.5, -(circleSize / 2)) or UDim2.new(0, circleOffset, 0.5, -(circleSize / 2))

			TweenService:Create(ToggleButton, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
				BackgroundColor3 = goalColor
			}):Play()

			TweenService:Create(Circle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
				Position = goalPosition
			}):Play()
		end

		local function ToggleValue()
			Value = not Value
			UpdateVisual()
			pcall(Callback, Value)

			if Flag then
				getgenv().Flags = getgenv().Flags or {}
				getgenv().Flags[Flag] = Value
			end
		end

		-- Funciona tanto com mouse quanto touch
		ToggleFrame.MouseButton1Click:Connect(ToggleValue)

		local ToggleObject = {}

		function ToggleObject:Set(newValue)
			Value = newValue
			UpdateVisual()
			pcall(Callback, Value)

			if Flag then
				getgenv().Flags = getgenv().Flags or {}
				getgenv().Flags[Flag] = Value
			end
		end

		function ToggleObject:Get()
			return Value
		end

		return ToggleObject
	end

