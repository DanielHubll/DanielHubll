-- TAB:ADDINPUT  (número com + / − e digitação direta)
-- ============================================================
--[[
  Tab:AddInput({
      Name     = "Velocidade",
      Default  = 16,
      Min      = 0,
      Max      = 999,
      Step     = 1,
      Suffix   = "",
      Callback = function(v) end,
  })
  API:
    input.Value
    input:Set(42)
]]
function Tab:AddInput(config)
	config = config or {}
	local Name     = config.Name     or "Input"
	local Min      = config.Min      -- nil = sem limite
	local Max      = config.Max      -- nil = sem limite
	local Step     = config.Step     or 1
	local Suffix   = config.Suffix   or ""
	local Callback = config.Callback or function() end
	local Value    = config.Default  or 0

	local tw = TweenInfo.new(0.1)

	local function clampVal(v)
		if Min and v < Min then v = Min end
		if Max and v > Max then v = Max end
		return v
	end

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))

	-- container dos controles
	local Controls = Instance.new("Frame")
	Controls.BackgroundTransparency = 1
	Controls.Size = UDim2.new(0, 130, 0, 30)
	Controls.Position = UDim2.new(1, -140, 0.5, -15)
	Controls.ZIndex = 3
	Controls.Parent = Frame

	-- botão −
	local BtnMinus = Instance.new("TextButton")
	BtnMinus.Size = UDim2.new(0, 28, 0, 30)
	BtnMinus.Position = UDim2.new(0, 0, 0, 0)
	BtnMinus.BackgroundColor3 = Color3.fromRGB(50, 52, 56)
	BtnMinus.BorderSizePixel = 0
	BtnMinus.Text = "−"
	BtnMinus.TextColor3 = Color3.fromRGB(255, 255, 255)
	BtnMinus.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
	BtnMinus.TextSize = 18
	BtnMinus.ZIndex = 4
	BtnMinus.AutoButtonColor = false
	Instance.new("UICorner").Parent = BtnMinus
	BtnMinus.Parent = Controls

	-- caixa de texto numérica
	local NumBox = Instance.new("TextBox")
	NumBox.Size = UDim2.new(1, -60, 1, 0)
	NumBox.Position = UDim2.new(0, 32, 0, 0)
	NumBox.BackgroundColor3 = Color3.fromRGB(36, 38, 40)
	NumBox.BorderSizePixel = 0
	NumBox.Text = tostring(Value) .. Suffix
	NumBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	NumBox.PlaceholderColor3 = Color3.fromRGB(140, 140, 140)
	NumBox.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
	NumBox.TextSize = 14
	NumBox.ClearTextOnFocus = true
	NumBox.ZIndex = 4
	Instance.new("UICorner").Parent = NumBox
	local NumStroke = Instance.new("UIStroke")
	NumStroke.Color = Color3.fromRGB(255, 255, 255)
	NumStroke.Transparency = 0.7
	NumStroke.Parent = NumBox
	NumBox.Parent = Controls

	-- botão +
	local BtnPlus = Instance.new("TextButton")
	BtnPlus.Size = UDim2.new(0, 28, 0, 30)
	BtnPlus.Position = UDim2.new(1, -28, 0, 0)
	BtnPlus.BackgroundColor3 = Color3.fromRGB(50, 52, 56)
	BtnPlus.BorderSizePixel = 0
	BtnPlus.Text = "+"
	BtnPlus.TextColor3 = Color3.fromRGB(255, 255, 255)
	BtnPlus.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
	BtnPlus.TextSize = 18
	BtnPlus.ZIndex = 4
	BtnPlus.AutoButtonColor = false
	Instance.new("UICorner").Parent = BtnPlus
	BtnPlus.Parent = Controls

	local function setVal(v, skipCb)
		v = clampVal(v)
		-- arredonda ao step
		local mult = 1 / Step
		v = math.round(v * mult) / mult
		Value = v
		NumBox.Text = tostring(v) .. Suffix
		if not skipCb then Callback(v) end
	end

	for _, btn in ipairs({ BtnMinus, BtnPlus }) do
		btn.MouseEnter:Connect(function()
			TweenService:Create(btn, tw, { BackgroundColor3 = Color3.fromRGB(70, 73, 80) }):Play()
		end)
		btn.MouseLeave:Connect(function()
			TweenService:Create(btn, tw, { BackgroundColor3 = Color3.fromRGB(50, 52, 56) }):Play()
		end)
	end

	BtnMinus.MouseButton1Click:Connect(function() setVal(Value - Step) end)
	BtnPlus.MouseButton1Click:Connect(function()  setVal(Value + Step) end)

	NumBox.Focused:Connect(function()
		TweenService:Create(NumStroke, tw, { Transparency = 0.3 }):Play()
	end)
	NumBox.FocusLost:Connect(function(enter)
		TweenService:Create(NumStroke, tw, { Transparency = 0.7 }):Play()
		local typed = tonumber(NumBox.Text:match("%-?%d+%.?%d*"))
		if typed then
			setVal(typed)
		else
			NumBox.Text = tostring(Value) .. Suffix
		end
	end)

	local obj = { Frame = Frame, Value = Value }
	function obj:Set(v)
		setVal(v, true)
		self.Value = Value
	end
	return obj
end

