-- ============================================================

function Tab:AddDropdown(config)
	config = config or {}
	local Name = config.Name or "Dropdown"
	local Options = config.Options or {}
	local Default = config.Default or (Options[1] or "")
	local Callback = config.Callback or function() end

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))
	Frame.Size = UDim2.new(1, 0, 0, 50)
	Frame.ClipsDescendants = true

	local Selector = Instance.new("ImageButton")
	Selector.AutoButtonColor = false
	Selector.BackgroundTransparency = 1
	Selector.ZIndex = 2
	Selector.AnchorPoint = Vector2.new(1, 0)
	Selector.Size = UDim2.new(0.6, 0, 0, 50)
	Selector.Name = "Selector"
	Selector.Position = UDim2.new(1, 0, 0, 0)
	Selector.Parent = Frame

	local CurrentLabel = Instance.new("TextLabel")
	CurrentLabel.ZIndex = 3
	CurrentLabel.TextSize = 17
	CurrentLabel.AnchorPoint = Vector2.new(0.5, 0.5)
	CurrentLabel.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
	CurrentLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	CurrentLabel.BackgroundTransparency = 1
	CurrentLabel.Size = UDim2.new(1, -30, 1, 0)
	CurrentLabel.Text = Default
	CurrentLabel.Name = "CurrentLabel"
	CurrentLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
	CurrentLabel.Parent = Selector

	local Arrow = Instance.new("TextLabel")
	Arrow.ZIndex = 3
	Arrow.TextSize = 14
	Arrow.AnchorPoint = Vector2.new(1, 0.5)
	Arrow.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
	Arrow.TextColor3 = Color3.fromRGB(255, 255, 255)
	Arrow.BackgroundTransparency = 1
	Arrow.Size = UDim2.new(0, 20, 0, 20)
	Arrow.Text = "▼"
	Arrow.Name = "Arrow"
	Arrow.Position = UDim2.new(1, -5, 0.5, 0)
	Arrow.Parent = Selector

	local OptionsFrame = Instance.new("Frame")
	OptionsFrame.ZIndex = 4
	OptionsFrame.BorderSizePixel = 0
	OptionsFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
	OptionsFrame.Size = UDim2.new(0.6, 0, 0, #Options * 40)
	OptionsFrame.Name = "OptionsFrame"
	OptionsFrame.AnchorPoint = Vector2.new(1, 0)
	OptionsFrame.Position = UDim2.new(1, 0, 0, 50)
	OptionsFrame.Visible = false
	OptionsFrame.Parent = Frame

	local OptionsCorner = Instance.new("UICorner")
	OptionsCorner.Parent = OptionsFrame

	local OptionsLayout = Instance.new("UIListLayout")
	OptionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	OptionsLayout.Parent = OptionsFrame

	local value = Default
	local open = false

	local function closeDropdown()
		open = false
		Arrow.Text = "▼"
		OptionsFrame.Visible = false
		Frame.Size = UDim2.new(1, 0, 0, 50)
		Frame.ClipsDescendants = true
	end

	local function openDropdown()
		open = true
		Arrow.Text = "▲"
		OptionsFrame.Visible = true
		Frame.ClipsDescendants = false
		Frame.Size = UDim2.new(1, 0, 0, 50 + #Options * 40)
	end

	for i, opt in ipairs(Options) do
		local OptionBtn = Instance.new("TextButton")
		OptionBtn.ZIndex = 5
		OptionBtn.BackgroundTransparency = 1
		OptionBtn.Size = UDim2.new(1, 0, 0, 40)
		OptionBtn.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
		OptionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		OptionBtn.TextSize = 16
		OptionBtn.Text = opt
		OptionBtn.Name = opt
		OptionBtn.LayoutOrder = i
		OptionBtn.Parent = OptionsFrame

		OptionBtn.MouseButton1Click:Connect(function()
			value = opt
			CurrentLabel.Text = opt
			Callback(value)
			closeDropdown()
		end)
	end

	Selector.MouseButton1Click:Connect(function()
		if open then closeDropdown() else openDropdown() end
	end)

	local dropdownObj = {}
	function dropdownObj:Set(opt) 
		if table.find(Options, opt) then
			value = opt
			CurrentLabel.Text = opt
			Callback(value)
		end
	end
	function dropdownObj:Get() return value end
	return dropdownObj
end

