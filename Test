    -- Minimize
    local _origSize = cfg.Size
    MinBtn.MouseButton1Click:Connect(function()
        Win._min = not Win._min
        if Win._min then
            Sidebar.Visible = false
            ContentArea.Visible = false
            U.Tween(Main, { Size = UDim2.new(_origSize.X.Scale, _origSize.X.Offset, 0, 48) }, 0.25, Enum.EasingStyle.Back)
        else
