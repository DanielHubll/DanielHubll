                TabBar.Visible = true
                ContentArea.Visible = true
                Utility.Tween(MainFrame, { Size = config.Size }, 0.3, Enum.EasingStyle.Back)
            end
        end)
    end

    -- Close logic
    if CloseBtn then
        CloseBtn.MouseButton1Click:Connect(function()
            Utility.Tween(MainFrame, { BackgroundTransparency = 1, Size = UDim2.new(0, config.Size.X.Offset, 0, 0) }, 0.2)
            task.wait(0.2)
            ScreenGui:Destroy()
        end)
    end

    -- Toggle visibility keybind
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == config.Keybind then
            Window.Visible = not Window.Visible
            MainFrame.Visible = Window.Visible
        end
    end)

    -- ── AddTab ───────────────────────────────────────────────
    function Window:AddTab(name, icon)
        local Tab = {}
        Tab.Name = name
        Tab.Elements = {}

        local isFirst = #Window.Tabs == 0

        -- Tab Button
        local TabBtn = Utility.Create("TextButton", {
            Name = "Tab_" .. name,
            BackgroundColor3 = isFirst and config.Theme.AccentSubtle or Color3.fromRGB(0,0,0),
            BackgroundTransparency = isFirst and 0 or 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, 34),
            Font = config.Theme.FontSemibold,
            Text = (icon and icon .. "  " or "") .. name,
            TextColor3 = isFirst and config.Theme.Accent or config.Theme.TextSecondary,
            TextSize = 12,
            LayoutOrder = #Window.Tabs + 1,
            ZIndex = 13,
            Parent = TabBar
        })
        Utility.RoundCorner(TabBtn, 5)

        -- Active indicator line
        local ActiveIndicator = Utility.Create("Frame", {
            BackgroundColor3 = config.Theme.Accent,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 0, 0.1, 0),
            Size = UDim2.new(0, isFirst and 3 or 0, 0.8, 0),
            ZIndex = 14,
            Parent = TabBtn
        })
        Utility.RoundCorner(ActiveIndicator, 2)

        -- Tab Content ScrollFrame
        local TabContent = Utility.Create("ScrollingFrame", {
            Name = "Content_" .. name,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = config.Theme.Accent,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            Visible = isFirst,
            ZIndex = 12,
            Parent = ContentArea
        })
        Utility.Create("UIListLayout", {
            Padding = UDim.new(0, 5),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = TabContent
        })
        Utility.Create("UIPadding", {
            PaddingTop = UDim.new(0, 10),
            PaddingLeft = UDim.new(0, 10),
            PaddingRight = UDim.new(0, 10),
            PaddingBottom = UDim.new(0, 10),
            Parent = TabContent
        })

        -- Auto-resize canvas
        local listLayout = TabContent:FindFirstChildOfClass("UIListLayout")
        listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            TabContent.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 20)
        end)

        if isFirst then Window.ActiveTab = Tab end

        -- Tab switch logic
        TabBtn.MouseButton1Click:Connect(function()
            if Window.ActiveTab == Tab then return end

            -- Hide old
            if Window.ActiveTab then
                Window.ActiveTab._Content.Visible = false
                Window.ActiveTab._Btn.BackgroundTransparency = 1
                Utility.Tween(Window.ActiveTab._Btn, {
                    TextColor3 = config.Theme.TextSecondary,
                }, 0.15)
                Utility.Tween(Window.ActiveTab._Indicator, {
                    Size = UDim2.new(0, 0, 0.8, 0)
                }, 0.15)
            end

            -- Show new
            TabContent.Visible = true
            Window.ActiveTab = Tab
            Utility.Tween(TabBtn, {
                TextColor3 = config.Theme.Accent,
                BackgroundTransparency = 0,
                BackgroundColor3 = config.Theme.AccentSubtle
            }, 0.15)
            Utility.Tween(ActiveIndicator, {
                Size = UDim2.new(0, 3, 0.8, 0)
            }, 0.2, Enum.EasingStyle.Back)
        end)

        Tab._Btn = TabBtn
        Tab._Content = TabContent
        Tab._Indicator = ActiveIndicator
        Tab._Layout = listLayout
        Tab._LayoutOrder = 0

        local function nextOrder()
            Tab._LayoutOrder = Tab._LayoutOrder + 1
            return Tab._LayoutOrder
        end

        -- ────────────────────────────────────────────────────
        -- ELEMENTS
        -- ────────────────────────────────────────────────────

        local function BaseRow(height)
            local row = Utility.Create("Frame", {
                BackgroundColor3 = config.Theme.Surface,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, height or 38),
                LayoutOrder = nextOrder(),
                ZIndex = 13,
                Parent = TabContent
            })
            Utility.RoundCorner(row, 5)
            Utility.Stroke(row, config.Theme.Border)
            return row
        end

