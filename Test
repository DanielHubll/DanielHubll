-- ═══════════════════════════════════════════════════════════════
--  VRCoreLib - UI Library para Roblox VR CoreGui
--  Uso: local VRCoreLib = loadstring(script)()
--  Autor: @uniquadev (adaptado)
-- ═══════════════════════════════════════════════════════════════

local VRCoreLib = {}
VRCoreLib.__index = VRCoreLib

-- Serviços
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

-- Estado interno
local Library = {
    Tabs = {},
    HubBarContainer = nil,
    PageViewInnerFrame = nil,
    HubBar = nil,
    SettingsShield = nil,
    Initialized = false,
    TabCount = 0,
    BASE_WIDTH = 800,
    WIDTH_PER_BUTTON = 100,
}

-- ═══════════════════════════════════════════════════════════════
--  UTILIDADES
-- ═══════════════════════════════════════════════════════════════

local function findDescendant(parent, name)
    for _, v in ipairs(parent:GetDescendants()) do
        if v.Name == name then
            return v
        end
    end
    return nil
end

local function waitForDescendant(parent, name, timeout)
    timeout = timeout or 10
    local found = findDescendant(parent, name)
    if found then return found end

    local startTime = tick()
    while tick() - startTime < timeout do
        task.wait(0.5)
        found = findDescendant(parent, name)
        if found then return found end
    end
    return nil
end

-- ═══════════════════════════════════════════════════════════════
--  INICIALIZAÇÃO DA LIB
-- ═══════════════════════════════════════════════════════════════

function VRCoreLib:Init()
    if Library.Initialized then
        print("[VRCoreLib] Já inicializado!")
        return self
    end

    print("[VRCoreLib] Inicializando...")

    -- Buscar elementos do CoreGui
    Library.HubBarContainer = waitForDescendant(CoreGui, "HubBarContainer", 15)
    Library.PageViewInnerFrame = waitForDescendant(CoreGui, "PageViewInnerFrame", 15)

    if not Library.HubBarContainer then
        warn("[VRCoreLib] ERRO: HubBarContainer não encontrado no CoreGui!")
        return nil
    end

    if not Library.PageViewInnerFrame then
        warn("[VRCoreLib] ERRO: PageViewInnerFrame não encontrado no CoreGui!")
        return nil
    end

    Library.Initialized = true
    print("[VRCoreLib] Inicializado com sucesso!")

    -- Configurar sistema de seleção de abas
    self:_SetupTabSystem()
    -- Configurar monitoramento do SettingsShield
    self:_SetupSettingsShieldMonitor()
    -- Configurar ajuste automático do HubBar
    self:_SetupHubBarAdjustment()

    return self
end

-- ═══════════════════════════════════════════════════════════════
--  SISTEMA DE ABAS
-- ═══════════════════════════════════════════════════════════════

local function deselectButton(button)
    local tabSelection = button:FindFirstChild("TabSelection")
    local tabLabel = button:FindFirstChild("TabLabel")

    if tabSelection then tabSelection.Visible = false end

    if tabLabel then
        local icon = tabLabel:FindFirstChild("Icon")
        local title = tabLabel:FindFirstChild("Title")
        if icon then icon.TextTransparency = 0.5 end
        if title then title.TextTransparency = 0.5 end
    end
end

local function selectButton(button)
    local tabSelection = button:FindFirstChild("TabSelection")
    local tabLabel = button:FindFirstChild("TabLabel")

    if tabSelection then tabSelection.Visible = true end

    if tabLabel then
        local icon = tabLabel:FindFirstChild("Icon")
        local title = tabLabel:FindFirstChild("Title")
        if icon then icon.TextTransparency = 0 end
        if title then title.TextTransparency = 0 end
    end
end

local function hideAllPages()
    if not Library.PageViewInnerFrame then return end
    for _, child in ipairs(Library.PageViewInnerFrame:GetChildren()) do
        if child:IsA("Frame") then
            child.Visible = false
        end
    end
end

local function getPageForButton(button)
    if not Library.PageViewInnerFrame then return nil end
    for _, child in ipairs(Library.PageViewInnerFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name == button.Name then
            return child
        end
    end
    return nil
end

function VRCoreLib:_OnTabClicked(clickedButton)
    -- Controlar visual dos botões
    for _, child in ipairs(Library.HubBarContainer:GetChildren()) do
        if child:IsA("TextButton") then
            if child == clickedButton then
                selectButton(child)
            else
                deselectButton(child)
            end
        end
    end

    -- Controlar visibilidade dos frames
    hideAllPages()

    local correspondingPage = getPageForButton(clickedButton)
    if correspondingPage then
        correspondingPage.Visible = true
    end
end

function VRCoreLib:_SetupTabSystem()
    -- Conectar cliques em botões existentes
    for _, child in ipairs(Library.HubBarContainer:GetChildren()) do
        if child:IsA("TextButton") then
            child.MouseButton1Click:Connect(function()
                self:_OnTabClicked(child)
            end)
        end
    end

    -- Monitorar novos botões
    Library.HubBarContainer.ChildAdded:Connect(function(newChild)
        if newChild:IsA("TextButton") then
            newChild.MouseButton1Click:Connect(function()
                self:_OnTabClicked(newChild)
            end)
        end
    end)
end

-- ═══════════════════════════════════════════════════════════════
--  SETTINGS SHIELD MONITOR
-- ═══════════════════════════════════════════════════════════════

function VRCoreLib:_SetupSettingsShieldMonitor()
    local self = self

    local function deselectAll()
        if Library.HubBarContainer then
            for _, child in ipairs(Library.HubBarContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    deselectButton(child)
                end
            end
        end
        hideAllPages()
    end

    local function monitor()
        local shield = waitForDescendant(CoreGui, "SettingsShield", 30)

        if shield and shield:IsA("ImageButton") then
            if shield.Visible == false then
                deselectAll()
            end

            local conn
            conn = shield:GetPropertyChangedSignal("Visible"):Connect(function()
                if shield.Visible == false then
                    deselectAll()
                end
            end)

            shield.AncestryChanged:Connect(function(_, parent)
                if not parent then
                    conn:Disconnect()
                    task.wait(0.5)
                    monitor()
                end
            end)
        end
    end

    task.spawn(monitor)

    CoreGui.DescendantAdded:Connect(function(desc)
        if desc.Name == "SettingsShield" and desc:IsA("ImageButton") then
            monitor()
        end
    end)
end

-- ═══════════════════════════════════════════════════════════════
--  AJUSTE AUTOMÁTICO DO HUBBAR
-- ═══════════════════════════════════════════════════════════════

function VRCoreLib:_SetupHubBarAdjustment()
    local function countButtons()
        local count = 0
        if Library.HubBarContainer then
            for _, child in ipairs(Library.HubBarContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    count = count + 1
                end
            end
        end
        return count
    end

    local function adjust()
        local hubBar = findDescendant(CoreGui, "HubBar")
        if not hubBar then return end

        local buttonCount = countButtons()
        if buttonCount > 5 then
            local extra = buttonCount - 5
            local newWidth = Library.BASE_WIDTH - (Library.WIDTH_PER_BUTTON * extra)
            if newWidth < 300 then newWidth = 300 end
            local cs = hubBar.Size
            hubBar.Size = UDim2.new(0, newWidth, cs.Y.Scale, cs.Y.Offset)
        else
            local cs = hubBar.Size
            hubBar.Size = UDim2.new(0, Library.BASE_WIDTH, cs.Y.Scale, cs.Y.Offset)
        end
    end

    -- Ajuste inicial + monitoramento
    task.spawn(function()
        local hubBar = waitForDescendant(CoreGui, "HubBar", 15)
        if hubBar then
            adjust()

            Library.HubBarContainer.ChildAdded:Connect(function(child)
                if child:IsA("TextButton") then
                    task.wait(0.1)
                    adjust()
                end
            end)

            Library.HubBarContainer.ChildRemoved:Connect(function(child)
                if child:IsA("TextButton") then
                    task.wait(0.1)
                    adjust()
                end
            end)
        end
    end)
end

