function TabObject:CreateDropdown(config)
    -- config = { Name = "Mode", Options = {"Option1", "Option2"}, Default = 1, Callback = function(opt) end }
    if type(config) == "string" then
        config = { Name = config, Options = {"None"}, Default = 1, Callback = function() end }
    end

    self.ElementCount = self.ElementCount + 1
    local order = self.ElementCount * 10

    local container = createElementContainer(self.Page, order, 50)
    container.Name = config.Name or "Dropdown_" .. order

    local label = createElementLabel(container, config.Name or "Dropdown")

    -- Selector
    local selector = Instance.new("ImageButton", container)
    selector.AutoButtonColor = false
    selector.BackgroundTransparency = 1
    selector.ZIndex = 2
    selector.AnchorPoint = Vector2.new(1, 0.5)
    selector.Size = UDim2.new(0.6, 0, 0, 50)
    selector.Name = "Selector"
    selector.Position = UDim2.new(1, 0, 0.5, 0)

    local leftBtn = Instance.new("ImageButton", selector)
    leftBtn.BackgroundTransparency = 1
    leftBtn.Selectable = false
    leftBtn.ZIndex = 3
    leftBtn.AnchorPoint = Vector2.new(0, 0.5)
    leftBtn.Size = UDim2.new(0, 32, 0, 50)
    leftBtn.Position = UDim2.new(0, 0, 0.5, 0)

    local leftIcon = Instance.new("ImageLabel", leftBtn)
    leftIcon.ZIndex = 4
    leftIcon.ImageColor3 = Color3.fromRGB(205, 205, 205)
    leftIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    leftIcon.Image = "rbxasset://textures/ui/Settings/Slider/Left.png"
    leftIcon.Size = UDim2.new(0, 18, 0, 30)
    leftIcon.BackgroundTransparency = 1
    leftIcon.Position = UDim2.new(0.5, 0, 0.5, 0)

    local rightBtn = Instance.new("ImageButton", selector)
    rightBtn.BackgroundTransparency = 1
    rightBtn.Selectable = false
    rightBtn.ZIndex = 3
    rightBtn.AnchorPoint = Vector2.new(1, 0.5)
    rightBtn.Size = UDim2.new(0, 32, 0, 50)
    rightBtn.Position = UDim2.new(1, 0, 0.5, 0)

    local rightIcon = Instance.new("ImageLabel", rightBtn)
    rightIcon.ZIndex = 4
    rightIcon.ImageColor3 = Color3.fromRGB(205, 205, 205)
    rightIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    rightIcon.Image = "rbxasset://textures/ui/Settings/Slider/Right.png"
    rightIcon.Size = UDim2.new(0, 18, 0, 30)
    rightIcon.BackgroundTransparency = 1
    rightIcon.Position = UDim2.new(0.5, 0, 0.5, 0)

    -- Option display
    local optionLabel = Instance.new("TextLabel", selector)
    optionLabel.TextWrapped = true
    optionLabel.ZIndex = 2
    optionLabel.BorderSizePixel = 0
    optionLabel.TextSize = 17
    optionLabel.FontFace = Font.new(
        "rbxasset://fonts/families/BuilderSans.json",
        Enum.FontWeight.Regular, Enum.FontStyle.Normal
    )
    optionLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    optionLabel.BackgroundTransparency = 1
    optionLabel.Size = UDim2.new(1, -64, 1, 0)
    optionLabel.Position = UDim2.new(0, 32, 0, 0)
    optionLabel.Name = "OptionLabel"

    -- Estado
    local options = config.Options or {"None"}
    local currentIndex = config.Default or 1
    local callback = config.Callback or function() end

    local function updateDisplay()
        if currentIndex < 1 then currentIndex = #options end
        if currentIndex > #options then currentIndex = 1 end
        optionLabel.Text = options[currentIndex] or "None"
    end

    updateDisplay()

    leftBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex - 1
        if currentIndex < 1 then currentIndex = #options end
        updateDisplay()
        callback(options[currentIndex], currentIndex)
    end)

    rightBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex + 1
        if currentIndex > #options then currentIndex = 1 end
        updateDisplay()
        callback(options[currentIndex], currentIndex)
    end)

    local dropdownApi = {
        Element = container,
        Set = function(self, index)
            currentIndex = index
            updateDisplay()
            callback(options[currentIndex], currentIndex)
        end,
        Get = function(self)
            return options[currentIndex], currentIndex
        end,
        SetOptions = function(self, newOptions)
            options = newOptions
            currentIndex = 1
            updateDisplay()
        end,
        SetCallback = function(self, newCallback)
            callback = newCallback
        end,
        Destroy = function(self)
            container:Destroy()
        end,
    }

    return dropdownApi
end

