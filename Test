                Position=UDim2.new(0,10,0,5),Size=UDim2.new(1,-20,0,14),
                Font=Theme.FontSemi,Text=text,TextColor3=Theme.TextSecondary,
                TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=14,Parent=r})

            local box=U.New("TextBox",{BackgroundColor3=Theme.SurfaceDark,BorderSizePixel=0,
                Position=UDim2.new(0,8,0,22),Size=UDim2.new(1,-16,0,H-28),
                Font=Theme.FontReg,Text="",TextColor3=Theme.TextPrimary,
                TextSize=isMobile and 13 or 11,
                PlaceholderText=placeholder or "...",PlaceholderColor3=Theme.TextDisabled,
                ClearTextOnFocus=clearOnFocus or false,ZIndex=14,Parent=r})
            U.Corner(box,4)
            local sk=U.Stroke(box,Theme.Border)
            box.Focused:Connect(function() U.Tween(sk,{Color=Theme.Accent},0.15) end)
            box.FocusLost:Connect(function(enter)
                U.Tween(sk,{Color=Theme.Border},0.15)
                if cb then cb(box.Text,enter) end
            end)

            local E={_row=r,_box=box}
            function E:Get() return box.Text end
            function E:Set(t) box.Text=t end
            return E
        end

        -- ─────────────────────────────────────────────────
        -- AddProgressBar
        -- ─────────────────────────────────────────────────
        function tab:AddProgressBar(text, default, barColor)
            local val=default or 0
            barColor=barColor or Theme.Accent
            local H=ROWH+8
            local r=Row(H)

            local hf=U.New("Frame",{BackgroundTransparency=1,
                Size=UDim2.new(1,-16,0,18),Position=UDim2.new(0,8,0,4),ZIndex=14,Parent=r})
            U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0.75,0,1,0),
                Font=Theme.FontSemi,Text=text,TextColor3=Theme.TextPrimary,
                TextSize=isMobile and 12 or 10,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=14,Parent=hf})
            local pctL=U.New("TextLabel",{BackgroundTransparency=1,
                Size=UDim2.new(0.25,0,1,0),Position=UDim2.new(0.75,0,0,0),
                Font=Theme.FontMono,Text=math.floor(val).."%",TextColor3=barColor,
                TextSize=isMobile and 12 or 10,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=14,Parent=hf})

            local trk=U.New("Frame",{BackgroundColor3=Theme.SliderTrack,BorderSizePixel=0,
                Position=UDim2.new(0,8,0,26),Size=UDim2.new(1,-16,0,isMobile and 10 or 8),
                ZIndex=14,Parent=r})
            U.Corner(trk,5)
            local fill=U.New("Frame",{BackgroundColor3=barColor,BorderSizePixel=0,
                Size=UDim2.new(math.clamp(val/100,0,1),0,1,0),ZIndex=15,Parent=trk})
            U.Corner(fill,5)

            local E={_row=r}
            function E:Set(v)
                v=math.clamp(v,0,100); val=v
                pctL.Text=math.floor(v).."%"
                U.Tween(fill,{Size=UDim2.new(v/100,0,1,0)},0.3,Enum.EasingStyle.Quad)
            end
            function E:Get() return val end
            return E
        end

        -- ─────────────────────────────────────────────────
        -- AddStats
        -- ─────────────────────────────────────────────────
        function tab:AddStats(items)
            local cols=math.min(#items,3)
            local r=Row(54); r.Size=UDim2.new(1,0,0,54)
            for i,item in ipairs(items) do
                local cf=U.New("Frame",{BackgroundColor3=Theme.SurfaceDark,BorderSizePixel=0,
                    Position=UDim2.new((i-1)/cols,4,0,4),
                    Size=UDim2.new(1/cols,-8,1,-8),ZIndex=14,Parent=r})
                U.Corner(cf,5)
                U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,4),
                    Size=UDim2.new(1,0,0,20),Font=Theme.FontMono,Text=tostring(item[2] or "—"),
                    TextColor3=item[3] or Theme.Accent,TextSize=isMobile and 16 or 14,ZIndex=15,Parent=cf})
                U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,0,0,24),
                    Size=UDim2.new(1,0,0,16),Font=Theme.FontReg,Text=tostring(item[1] or ""),
                    TextColor3=Theme.TextSecondary,TextSize=9,ZIndex=15,Parent=cf})
            end
            return {_row=r}
        end

        -- ─────────────────────────────────────────────────
        -- AddScrollingList
        -- ─────────────────────────────────────────────────
        function tab:AddScrollingList(text, items, cb)
            local sel=nil; local iH=isMobile and 32 or 26
            local totalH = isMobile and 150 or 120
            local r=Row(totalH); r.Size=UDim2.new(1,0,0,totalH)

            if text then
                U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,8,0,4),
                    Size=UDim2.new(1,-16,0,14),Font=Theme.FontSemi,Text=text,
                    TextColor3=Theme.TextSecondary,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,
                    ZIndex=14,Parent=r})
            end

            local lf=U.New("ScrollingFrame",{BackgroundColor3=Theme.SurfaceDark,BorderSizePixel=0,
                Position=UDim2.new(0,8,0,text and 20 or 4),
                Size=UDim2.new(1,-16,1,text and -24 or -8),
                ScrollBarThickness=3,ScrollBarImageColor3=Theme.Accent,
                CanvasSize=UDim2.new(0,0,0,#items*iH),ZIndex=14,Parent=r})
            U.Corner(lf,4)
            U.New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Parent=lf})

            local btns={}
            for i,item in ipairs(items) do
                local b=U.New("TextButton",{BackgroundTransparency=1,BorderSizePixel=0,
                    Size=UDim2.new(1,0,0,iH),Font=Theme.FontReg,
                    Text="  "..tostring(item),TextColor3=Theme.TextPrimary,
                    TextSize=isMobile and 13 or 11,TextXAlignment=Enum.TextXAlignment.Left,
                    LayoutOrder=i,ZIndex=15,Parent=lf})
                btns[i]=b
                b.MouseButton1Click:Connect(function()
                    sel=item
                    for _,bb in ipairs(btns) do
                        U.Tween(bb,{BackgroundTransparency=1,TextColor3=Theme.TextPrimary},0.1)
                    end
                    U.Tween(b,{BackgroundTransparency=0,BackgroundColor3=Theme.AccentSubtle,TextColor3=Theme.Accent},0.1)
                    if cb then cb(item) end
                end)
            end

            local E={_row=r}
            function E:Get() return sel end
            return E
        end

        return tab
    end

    -- ──────────────────────────────────────────────────────
    -- Win:Notify
    -- ──────────────────────────────────────────────────────
    function Win:Notify(msg, ntype, dur)
        dur=dur or 3; ntype=ntype or "info"
        Win._nc+=1
        local colors={success=Theme.Success,warning=Theme.Warning,error=Theme.Error,info=Theme.Info}
        local icons ={success="✓",warning="⚠",error="✕",info="ℹ"}
        local c=colors[ntype] or Theme.Info
        local ic=icons[ntype] or "ℹ"

        local n=U.New("Frame",{BackgroundColor3=Theme.Surface,BorderSizePixel=0,
            Size=UDim2.new(1,0,0,0),ClipsDescendants=true,
            LayoutOrder=Win._nc,ZIndex=200,Parent=NotifStack})
        U.Corner(n,6); U.Stroke(n,Theme.Border)

        U.New("Frame",{BackgroundColor3=c,BorderSizePixel=0,Size=UDim2.new(0,3,1,0),ZIndex=201,Parent=n})

        local ic2=U.New("Frame",{BackgroundColor3=c,BackgroundTransparency=0.8,BorderSizePixel=0,
            Size=UDim2.new(0,24,0,24),Position=UDim2.new(0,12,0.5,-12),ZIndex=201,Parent=n})
        U.Corner(ic2,6)
        U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
            Font=Theme.Font,Text=ic,TextColor3=c,TextSize=12,ZIndex=202,Parent=ic2})

        U.New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,44,0.5,-8),
            Size=UDim2.new(1,-56,0,16),Font=Theme.FontReg,Text=msg,
            TextColor3=Theme.TextPrimary,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=201,Parent=n})

        local pb=U.New("Frame",{BackgroundColor3=c,BackgroundTransparency=0.5,BorderSizePixel=0,
            Position=UDim2.new(0,3,1,-2),Size=UDim2.new(1,-6,0,2),ZIndex=202,Parent=n})
        U.Corner(pb,2)

        U.Tween(n,{Size=UDim2.new(1,0,0,44)},0.28,Enum.EasingStyle.Back)
        U.Tween(pb,{Size=UDim2.new(0,0,0,2)},dur-0.3,Enum.EasingStyle.Linear)

        task.delay(dur,function()
            U.Tween(n,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},0.2)
            task.delay(0.22,function() pcall(function() n:Destroy() end) end)
        end)
    end

    function Win:SetWatermark(text)
        WMFrame.Visible=true; WMText.Text=text
    end
    function Win:UpdateWatermark(text)
        WMText.Text=text
    end
    function Win:Toggle()
        Win._visible=not Win._visible; Main.Visible=Win._visible
    end
    function Win:Destroy()
        pcall(function() SG:Destroy() end)
    end

    -- Notif de boas-vindas para confirmar que carregou
    task.delay(0.5,function()
        Win:Notify("RobloxUI carregado! (" .. (isMobile and "Mobile" or "PC") .. ")", "success", 4)
    end)

    return Win
end

return RobloxUI
