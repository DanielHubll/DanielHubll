-- Players.akskkskakjda.PlayerGui.ScreenGui.Slider.Slider.LocalScript
local function C_5()
	local script = LMG2L["LocalScript_5"];
	-- Script local para o ImageButton "Slider"	


	local Slider = script.Parent	
	local LeftButton = Slider:WaitForChild("LeftButton")	
	local RightButton = Slider:WaitForChild("RightButton")	
	local StepsContainer = Slider:WaitForChild("StepsContainer")	
	
	-- Cores	
	local ACTIVE_COLOR = Color3.fromRGB(255, 255, 255) -- Branco	
	local INACTIVE_COLOR = Color3.fromRGB(57, 59, 61) -- Cinza escuro	
	
	-- Coletar todos os Steps e seus Fillers	
	local steps = {}	
	local fillers = {}	
	
	for i = 1, 10 do	
	    local step = StepsContainer:FindFirstChild("Step" .. i)	
	    if step then	
	        step.BackgroundColor3 = INACTIVE_COLOR -- Inicializa step como inativo	
	        table.insert(steps, step)	
	        	
	        -- Procura o Filler dentro do Step	
	        local filler = step:FindFirstChild("Filler")	
	        if filler then	
	            filler.BackgroundColor3 = INACTIVE_COLOR -- Inicializa filler como inativo	
	            fillers[i] = filler	
	        else	
	            print("Aviso: Filler não encontrado no Step" .. i)	
	        end	
	    end	
	end	
	
	-- Inicializa visibilidade dos botões	
	LeftButton.Visible = false -- Começa sem nenhum ativo, então LeftButton invisível	
	RightButton.Visible = true -- Pode aumentar, então RightButton visível	
	
	-- Função para encontrar o último step ativo	
	local function GetLastActiveStep()	
	    for i = #steps, 1, -1 do	
	        if steps[i].BackgroundColor3 == ACTIVE_COLOR then	
	            return i	
	        end	
	    end	
	    return 0 -- Nenhum ativo	
	end	
	
	-- Função para atualizar visibilidade dos botões	
	local function UpdateButtonsVisibility()	
	    local lastActive = GetLastActiveStep()	
	    	
	    -- Se todos os steps estiverem ativos (10), esconde RightButton	
	    if lastActive >= #steps then	
	        RightButton.Visible = false	
	    else	
	        RightButton.Visible = true	
	    end	
	    	
	    -- Se nenhum step estiver ativo (0), esconde LeftButton	
	    if lastActive <= 0 then	
	        LeftButton.Visible = false	
	    else	
	        LeftButton.Visible = true	
	    end	
	end	
	
	-- Função para ativar um step e seu filler	
	local function ActivateStep(index)	
	    if index >= 1 and index <= #steps then	
	        steps[index].BackgroundColor3 = ACTIVE_COLOR	
	        	
	        -- Ativa o Filler se existir	
	        if fillers[index] then	
	            fillers[index].BackgroundColor3 = ACTIVE_COLOR	
	        end	
	    end	
	end	
	
	-- Função para desativar um step e seu filler	
	local function DeactivateStep(index)	
	    if index >= 1 and index <= #steps then	
	        steps[index].BackgroundColor3 = INACTIVE_COLOR	
	        	
	        -- Desativa o Filler se existir	
	        if fillers[index] then	
	            fillers[index].BackgroundColor3 = INACTIVE_COLOR	
	        end	
	    end	
	end	
	
	-- Função para aumentar o slider	
	local function IncreaseSlider()	
	    local lastActive = GetLastActiveStep()	
	    	
	    if lastActive < #steps then	
	        -- Ativa o próximo step e seu filler	
	        ActivateStep(lastActive + 1)	
	        	
	        -- Atualiza visibilidade dos botões	
	        UpdateButtonsVisibility()	
	    end	
	end	
	
	-- Função para diminuir o slider	
	local function DecreaseSlider()	
	    local lastActive = GetLastActiveStep()	
	    	
	    if lastActive > 0 then	
	        -- Desativa o último step ativo e seu filler (de trás para frente)	
	        DeactivateStep(lastActive)	
	        	
	        -- Atualiza visibilidade dos botões	
	        UpdateButtonsVisibility()	
	    end	
	end	
	
	-- Conectar os botões	
