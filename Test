local Tab = {}
Tab.__index = Tab

function Library:CreateTab(config)
	config = config or {}
	local Name = config.Name or ("Tab" .. (#Library.Tabs + 1))
	local Icon = config.Icon or "gear"

	-- Prevenção de abas duplicadas
	if Library._tabsByName[Name] then
		warn("[LuminaUI] Já existe uma aba chamada '" .. Name .. "'. Retornando a existente.")
		return Library._tabsByName[Name]
	end

	-- ---------------- BOTÃO NO HUBBAR ----------------
	local TabButton = Instance.new("TextButton")
	TabButton.Selectable = false
	TabButton.ZIndex = 3
	TabButton.BackgroundTransparency = 1
	TabButton.Size = UDim2.new(0.2, 0, 1, 0)
	TabButton.Text = ""
	TabButton.Name = Name
	TabButton:SetAttribute("Selected", false)
	TabButton.Parent = HubBarContainer

	local TabSelection = Instance.new("ImageLabel")
	TabSelection.ZIndex = 3
	TabSelection.BorderSizePixel = 0
	TabSelection.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	TabSelection.Size = UDim2.new(1, -2, 0, 2)
	TabSelection.Visible = false
	TabSelection.Name = "TabSelection"
	TabSelection.Position = UDim2.new(0, 3, 1, -2)
	TabSelection.Parent = TabButton

	local TabLabel = Instance.new("Frame")
	TabLabel.ZIndex = 3
	TabLabel.BorderSizePixel = 0
	TabLabel.Size = UDim2.new(1, 0, 1, 0)
	TabLabel.Name = "TabLabel"
	TabLabel.BackgroundTransparency = 1
	TabLabel.Parent = TabButton

	local Layout = Instance.new("UIListLayout")
	Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	Layout.Padding = UDim.new(0, 10)
	Layout.VerticalAlignment = Enum.VerticalAlignment.Center
	Layout.SortOrder = Enum.SortOrder.LayoutOrder
	Layout.Name = "Layout"
	Layout.FillDirection = Enum.FillDirection.Horizontal
	Layout.Parent = TabLabel

	local IconLabel = Instance.new("TextLabel")
	IconLabel.TextWrapped = true
	IconLabel.ZIndex = 3
	IconLabel.TextTransparency = 0.5
	IconLabel.TextScaled = true
	IconLabel.FontFace = Font.new("rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
	IconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	IconLabel.BackgroundTransparency = 1
	IconLabel.Size = UDim2.new(0, 24, 0, 24)
	IconLabel.Text = Icon
	IconLabel.Name = "Icon"
	IconLabel.Position = UDim2.new(0, 10, 0.5, -18)
	IconLabel.Parent = TabLabel

	local AspectRatioConstraint = Instance.new("UIAspectRatioConstraint")
	AspectRatioConstraint.Name = "AspectRatioConstraint"
	AspectRatioConstraint.Parent = IconLabel

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.ZIndex = 3
	TitleLabel.TextSize = 19
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
	TitleLabel.TextTransparency = 0.5
	TitleLabel.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
	TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Text = Name
	TitleLabel.AutomaticSize = Enum.AutomaticSize.XY
	TitleLabel.Name = "Title"
	TitleLabel.Position = UDim2.new(1.2, 5, 0, -2)
	TitleLabel.Parent = TabLabel

	bindTabButtonEvents(TabButton)

	-- ---------------- PÁGINA (CONTEÚDO DA ABA) ----------------
	local Page = Instance.new("Frame")
	Page.ZIndex = 5
	Page.AutomaticSize = Enum.AutomaticSize.Y
	Page.Size = UDim2.new(1, 0, 0, 0)
	Page.Position = UDim2.new(0, 0, 0, 0)
	Page.Name = Name
	Page.BackgroundTransparency = 1
	Page.SelectionGroup = true
	Page.Visible = false -- começa desselecionada/oculta por padrão
	Page.Parent = PageViewInnerFrame

	local PagePadding = Instance.new("UIPadding")
	PagePadding.PaddingRight = UDim.new(0, 11)
	PagePadding.PaddingLeft = UDim.new(0, 12)
	PagePadding.Parent = Page

	local RowListLayout = Instance.new("UIListLayout")
	RowListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	RowListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	RowListLayout.Name = "RowListLayout"
	RowListLayout.Parent = Page

	-- ---------------- OBJETO TAB ----------------
	local self = setmetatable({
		Name = Name,
		Button = TabButton,
		Page = Page,
		_layoutOrder = 0,
	}, Tab)

	Library.Tabs[#Library.Tabs + 1] = self
	Library._tabsByName[Name] = self

	adjustHubBarWidth()

	return self
end

function Library:SelectTab(nameOrTab)
	local tabObj = nameOrTab
	if type(nameOrTab) == "string" then
		tabObj = Library._tabsByName[nameOrTab]
	end
	if tabObj and tabObj.Button then
		selectTabInternal(tabObj.Button)
	end
end

local function nextOrder(tabObj)
	tabObj._layoutOrder = tabObj._layoutOrder + 1
	return tabObj._layoutOrder
end

