LuminaUI - Biblioteca de UI via HubBar (CoreGui)
Uso:
local Library = loadstring(game:HttpGet("SUA_URL"))()
local Tab = Library:CreateTab({ Name = "Settings", Icon = "gear" })
Tab:AddSection("Player")
Tab:AddToggle({...})
Tab:AddToggle({ Options = {"Head","Torso","Arms"}, ... })  -- multi-estado
Tab:AddMultiDropdown({...})                                 -- multi-seleção
Tab:AddDropdown({...})
Tab:AddSlider({...})
Tab:AddButton({...})
Tab:AddSeparator()
]=]

local Library = {}
Library.__index = Library
Library.Tabs = {}
Library._tabsByName = {}

-- ================= SERVIÇOS =================
local CoreGui          = game:GetService("CoreGui")
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- ================= UTIL =================
local function findDescendant(parent, name)
	for _, v in ipairs(parent:GetDescendants()) do
		if v.Name == name then return v end
	end
	return nil
end

local function waitForDescendant(parent, name, timeout)
	timeout = timeout or 15
	local start = os.clock()
	local obj = findDescendant(parent, name)
	while not obj and (os.clock() - start) < timeout do
		task.wait(0.1)
		obj = findDescendant(parent, name)
	end
	return obj
end

-- ================= ELEMENTOS BASE DO COREGUI =================
local RobloxGui        = findDescendant(CoreGui, "RobloxGui")
local HubBarContainer  = waitForDescendant(CoreGui, "HubBarContainer")
local PageViewInnerFrame = waitForDescendant(CoreGui, "PageViewInnerFrame")

if not RobloxGui then
	warn("[LuminaUI] RobloxGui não encontrado!")
	return setmetatable({}, Library)
end
if not HubBarContainer or not PageViewInnerFrame then
	warn("[LuminaUI] HubBarContainer/PageViewInnerFrame não encontrados!")
	return setmetatable({}, Library)
end

-- ============================================================
-- SISTEMA DE AJUSTE AUTOMÁTICO DO HUBBAR
-- ============================================================
local HubBar = nil
local BASE_WIDTH      = 800
local WIDTH_PER_BUTTON = 100

local function countButtons()
	local count = 0
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then count += 1 end
	end
	return count
end

local function adjustHubBarWidth()
	if not (HubBar and HubBar:IsA("GuiObject")) then return end
	local n = countButtons()
	local w = BASE_WIDTH
	if n > 5 then w = math.max(300, BASE_WIDTH - WIDTH_PER_BUTTON * (n - 5)) end
	local s = HubBar.Size
	HubBar.Size = UDim2.new(0, w, s.Y.Scale, s.Y.Offset)
end

local function setupHubBar()
	HubBar = findDescendant(CoreGui, "HubBar")
	if HubBar and HubBar:IsA("ImageLabel") then
		adjustHubBarWidth()
		HubBarContainer.ChildAdded:Connect(function(c)
			if c:IsA("TextButton") then task.wait(0.1) adjustHubBarWidth() end
		end)
		HubBarContainer.ChildRemoved:Connect(function(c)
			if c:IsA("TextButton") then task.wait(0.1) adjustHubBarWidth() end
		end)
		task.spawn(function()
			while true do
				task.wait(2)
				if HubBar and HubBar.Parent then
					adjustHubBarWidth()
				else
					HubBar = nil
					setupHubBar()
					break
				end
			end
		end)
	else
		task.delay(1, setupHubBar)
	end
end
setupHubBar()

CoreGui.DescendantAdded:Connect(function(d)
	if d.Name == "HubBar" and d:IsA("ImageLabel") and not HubBar then
		setupHubBar()
	end
end)

-- ============================================================
-- SISTEMA DE SELEÇÃO / DESSELEÇÃO DE ABAS
-- ============================================================
local function deselectButton(button)
	button:SetAttribute("Selected", false)
	local ts = button:FindFirstChild("TabSelection")
	local tl = button:FindFirstChild("TabLabel")
	if ts then ts.Visible = false end
	if tl then
		local ic = tl:FindFirstChild("Icon")
		local ti = tl:FindFirstChild("Title")
		if ic then ic.TextTransparency = 0.5 end
		if ti then ti.TextTransparency = 0.5 end
	end
end

local function selectButtonVisual(button)
	button:SetAttribute("Selected", true)
	local ts = button:FindFirstChild("TabSelection")
	local tl = button:FindFirstChild("TabLabel")
	if ts then ts.Visible = true end
	if tl then
		local ic = tl:FindFirstChild("Icon")
		local ti = tl:FindFirstChild("Title")
		if ic then ic.TextTransparency = 0 end
		if ti then ti.TextTransparency = 0 end
	end
end

local function hideAllPages()
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") then child.Visible = false end
	end
end

local function deselectAllButtons()
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then deselectButton(child) end
	end
end

local function getPageForButton(button)
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name == button.Name then return child end
	end
	return nil
end

local function selectTabInternal(clickedButton)
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			if child == clickedButton then selectButtonVisual(child)
			else deselectButton(child) end
		end
	end
	hideAllPages()
	local page = getPageForButton(clickedButton)
	if page then page.Visible = true end
end

local function bindTabButtonEvents(button)
	button.MouseButton1Click:Connect(function()
		selectTabInternal(button)
	end)
end

for _, child in ipairs(HubBarContainer:GetChildren()) do
	if child:IsA("TextButton") then bindTabButtonEvents(child) end
end
HubBarContainer.ChildAdded:Connect(function(c)
	if c:IsA("TextButton") then bindTabButtonEvents(c) end
end)

-- ============================================================
-- MONITORAMENTO DO SETTINGS SHIELD
-- ============================================================
local function monitorSettingsShield()
	local shield = findDescendant(CoreGui, "SettingsShield")
	if shield and shield:IsA("ImageButton") then
		if not shield.Visible then deselectAllButtons() hideAllPages() end
		local conn
		conn = shield:GetPropertyChangedSignal("Visible"):Connect(function()
			if not shield.Visible then deselectAllButtons() hideAllPages() end
		end)
		shield.AncestryChanged:Connect(function(_, parent)
			if not parent then
				conn:Disconnect()
				task.wait(0.5)
				monitorSettingsShield()
			end
		end)
	else
		task.wait(1)
		monitorSettingsShield()
	end
end
monitorSettingsShield()

CoreGui.DescendantAdded:Connect(function(d)
	if d.Name == "SettingsShield" and d:IsA("ImageButton") then
		monitorSettingsShield()
	end
end)

