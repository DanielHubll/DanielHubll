--[[
  Tab:AddKeybind({
      Name     = "Toggle Menu",
      Default  = Enum.KeyCode.RightShift,
      Callback = function(key) end,   -- dispara quando a tecla capturada é pressionada
      OnChange = function(key) end,   -- dispara quando o bind muda
  })
  API:
    kb.Key            -- Enum.KeyCode atual
    kb:Set(Enum.KeyCode.F)
]]
function Tab:AddKeybind(config)
	config = config or {}
	local Name     = config.Name     or "Keybind"
	local Callback = config.Callback or function() end
	local OnChange = config.OnChange or function() end
	local Key      = config.Default  or Enum.KeyCode.RightShift

	local listening = false
	local tw = TweenInfo.new(0.1)

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))

	local KeyBtn = Instance.new("TextButton")
	KeyBtn.Size = UDim2.new(0, 110, 0, 30)
	KeyBtn.Position = UDim2.new(1, -120, 0.5, -15)
	KeyBtn.BackgroundColor3 = Color3.fromRGB(44, 46, 52)
	KeyBtn.BorderSizePixel = 0
	KeyBtn.Text = Key.Name
	KeyBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
	KeyBtn.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
	KeyBtn.TextSize = 14
	KeyBtn.ZIndex = 3
	KeyBtn.AutoButtonColor = false
	KeyBtn.Name = "KeyBtn"
	Instance.new("UICorner").Parent = KeyBtn
	local KeyStroke = Instance.new("UIStroke")
	KeyStroke.Color = Color3.fromRGB(255, 255, 255)
	KeyStroke.Transparency = 0.7
	KeyStroke.Parent = KeyBtn
	KeyBtn.Parent = Frame

	KeyBtn.MouseEnter:Connect(function()
		TweenService:Create(KeyBtn, tw, { BackgroundColor3 = Color3.fromRGB(60, 63, 70) }):Play()
	end)
	KeyBtn.MouseLeave:Connect(function()
		if not listening then
			TweenService:Create(KeyBtn, tw, { BackgroundColor3 = Color3.fromRGB(44, 46, 52) }):Play()
		end
	end)

	KeyBtn.MouseButton1Click:Connect(function()
		if listening then return end
		listening = true
		KeyBtn.Text = "..."
		TweenService:Create(KeyBtn, tw, { BackgroundColor3 = Color3.fromRGB(99, 102, 241) }):Play()
		TweenService:Create(KeyStroke, tw, { Transparency = 0.3 }):Play()
	end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if not listening then
			-- tecla capturada → dispara callback do bind
			if input.KeyCode == Key then
				Callback(Key)
			end
			return
		end
		-- modo de escuta
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		if input.KeyCode == Enum.KeyCode.Escape then
			-- cancela
			listening = false
			KeyBtn.Text = Key.Name
			TweenService:Create(KeyBtn, tw, { BackgroundColor3 = Color3.fromRGB(44, 46, 52) }):Play()
			TweenService:Create(KeyStroke, tw, { Transparency = 0.7 }):Play()
			return
		end
		Key = input.KeyCode
		listening = false
		KeyBtn.Text = Key.Name
		TweenService:Create(KeyBtn, tw, { BackgroundColor3 = Color3.fromRGB(44, 46, 52) }):Play()
		TweenService:Create(KeyStroke, tw, { Transparency = 0.7 }):Play()
		OnChange(Key)
	end)

	local obj = { Frame = Frame, Key = Key }
	function obj:Set(keyCode)
		Key = keyCode
		KeyBtn.Text = Key.Name
		self.Key = Key
		OnChange(Key)
	end
	return obj
end

