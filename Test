-- ================= UTIL =================
local function findDescendant(parent, name)
for _, v in ipairs(parent:GetDescendants()) do
if v.Name == name then
return v
end
end
return nil
end

local function waitForDescendant(parent, name, timeout)
timeout = timeout or 15
local start = os.clock()
local obj = findDescendant(parent, name)
while not obj and (os.clock() - start) < timeout do
task.wait(0.1)
obj = findDescendant(parent, name)
end
return obj
end

