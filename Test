        -- ─────────────────────────────────────────────────
        -- AddSlider
        -- ─────────────────────────────────────────────────
        function tab:AddSlider(text, min, max, default, cb, suffix)
            suffix = suffix or ""
            local val = math.clamp(default or min, min, max)
            local H = ROWH + 18
            local r = Row(H)

            -- header
            local hf = U.New("Frame",{BackgroundTransparency=1,
                Size=UDim2.new(1,-16,0,20),Position=UDim2.new(0,8,0,6),ZIndex=14,Parent=r})
            U.New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0.7,0,1,0),
                Font=Theme.FontSemi,Text=text,TextColor3=Theme.TextPrimary,
                TextSize=isMobile and 13 or 11,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=14,Parent=hf})
            local valLbl = U.New("TextLabel",{BackgroundTransparency=1,
                Size=UDim2.new(0.3,0,1,0),Position=UDim2.new(0.7,0,0,0),
                Font=Theme.FontMono,Text=tostring(val)..suffix,TextColor3=Theme.Accent,
                TextSize=isMobile and 13 or 11,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=14,Parent=hf})

            -- track
            local track = U.New("Frame",{BackgroundColor3=Theme.SliderTrack,BorderSizePixel=0,
                Size=UDim2.new(1,-16,0,isMobile and 8 or 6),
                Position=UDim2.new(0,8,0,33),ZIndex=14,Parent=r})
            U.Corner(track,4)

            local pct=(val-min)/(max-min)
            local fill=U.New("Frame",{BackgroundColor3=Theme.SliderFill,BorderSizePixel=0,
                Size=UDim2.new(pct,0,1,0),ZIndex=15,Parent=track})
            U.Corner(fill,4)
            U.New("UIGradient",{Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromRGB(180,70,0)),
                ColorSequenceKeypoint.new(1,Color3.fromRGB(255,160,50)),
            }),Parent=fill})

            local thumbSz = isMobile and 18 or 14
            local thumb=U.New("Frame",{BackgroundColor3=Color3.new(1,1,1),BorderSizePixel=0,
                Size=UDim2.new(0,thumbSz,0,thumbSz),
                Position=UDim2.new(pct,-thumbSz/2,0.5,-thumbSz/2),ZIndex=16,Parent=track})
            U.Corner(thumb,10)
            U.Stroke(thumb,Theme.Accent,2)

            local dragging=false
            local function upd(pos)
                local ax=track.AbsolutePosition.X
                local sw=track.AbsoluteSize.X
                local p=math.clamp((pos.X-ax)/sw,0,1)
                local v=math.floor(min+(max-min)*p+0.5)
                val=v; valLbl.Text=tostring(v)..suffix
                U.Tween(fill,{Size=UDim2.new(p,0,1,0)},0.05)
                U.Tween(thumb,{Position=UDim2.new(p,-thumbSz/2,0.5,-thumbSz/2)},0.05)
                if cb then cb(v) end
            end

            track.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    dragging=true; upd(i.Position)
                end
            end)
            if UserInputService then
                UserInputService.InputChanged:Connect(function(i)
                    if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                        upd(i.Position)
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        dragging=false
                    end
                end)
            end

            local E={_row=r}
            function E:Set(v)
                v=math.clamp(v,min,max); val=v
                local p=(v-min)/(max-min)
                valLbl.Text=tostring(v)..suffix
                fill.Size=UDim2.new(p,0,1,0)
                thumb.Position=UDim2.new(p,-thumbSz/2,0.5,-thumbSz/2)
            end
            function E:Get() return val end
            return E
        end

