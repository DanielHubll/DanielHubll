function Library:CreateDropdown(tab, config)
    config = config or {}
    local title = config.Title or "Dropdown"
    local options = config.Options or {}
    local default = config.Default or ""
    local callback = config.Callback or function() end
    local flag = config.Flag or nil
    
    local page = tab.Page
    if not page or not page.Parent then return end
    
    -- Container
    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.Name = "Dropdown_" .. title
    dropdownFrame.BackgroundColor3 = COLORS.Surface
    dropdownFrame.Size = UDim2.new(1, -24, 0, 50)
    dropdownFrame.ClipsDescendants = false
    dropdownFrame.Parent = page
    
    addCorner(dropdownFrame, ROUNDING.Large)
    addStroke(dropdownFrame)
    
    -- Padding
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 16)
    padding.PaddingRight = UDim.new(0, 16)
    padding.Parent = dropdownFrame
    
    -- Layout
    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 12)
    layout.Parent = dropdownFrame
    
    -- Título
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Text = title
    titleLabel.TextColor3 = COLORS.Text
    titleLabel.FontFace = TYPOGRAPHY.Body
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -160, 1, 0)
    titleLabel.Parent = dropdownFrame
    
    -- Botão do dropdown
    local dropButton = Instance.new("TextButton")
    dropButton.Name = "DropButton"
    dropButton.Text = default ~= "" and default or "Select..."
    dropButton.TextColor3 = COLORS.Text
    dropButton.FontFace = TYPOGRAPHY.Body
    dropButton.TextSize = 13
    dropButton.BackgroundColor3 = COLORS.SurfaceLight
    dropButton.Size = UDim2.new(0, 140, 0, 32)
    dropButton.TextXAlignment = Enum.TextXAlignment.Left
    dropButton.AutoButtonColor = false
    dropButton.Parent = dropdownFrame
    
    addCorner(dropButton, ROUNDING.Small)
    
    -- Padding do texto
    local textPadding = Instance.new("UIPadding")
    textPadding.PaddingLeft = UDim.new(0, 10)
    textPadding.Parent = dropButton
    
    -- Ícone de seta
    local arrowIcon = Instance.new("TextLabel")
    arrowIcon.Name = "Arrow"
    arrowIcon.Text = "▼"
    arrowIcon.TextColor3 = COLORS.TextSecondary
    arrowIcon.FontFace = TYPOGRAPHY.Body
    arrowIcon.TextSize = 10
    arrowIcon.BackgroundTransparency = 1
    arrowIcon.Size = UDim2.new(0, 20, 0, 20)
    arrowIcon.Position = UDim2.new(1, -25, 0.5, -10)
    arrowIcon.Parent = dropButton
    
    -- Container de opções
    local optionsFrame = Instance.new("Frame")
    optionsFrame.Name = "Options"
    optionsFrame.BackgroundColor3 = COLORS.SurfaceLight
    optionsFrame.Size = UDim2.new(1, 0, 0, 0)
    optionsFrame.Position = UDim2.new(0, 0, 1, 5)
    optionsFrame.Visible = false
    optionsFrame.ClipsDescendants = true
    optionsFrame.ZIndex = 100
    optionsFrame.Parent = dropButton
    
    addCorner(optionsFrame, ROUNDING.Small)
    
    -- Layout das opções
    local optionsLayout = Instance.new("UIListLayout")
    optionsLayout.FillDirection = Enum.FillDirection.Vertical
    optionsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    optionsLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    optionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optionsLayout.Parent = optionsFrame
    
    -- Variáveis
    local isOpen = false
    local selectedOption = default
    local optionButtons = {}
    
    -- Função para criar opções
    local function createOptions()
        -- Limpar opções existentes
        for _, btn in pairs(optionButtons) do
            btn:Destroy()
        end
        optionButtons = {}
        
        for i, option in ipairs(options) do
            local optionBtn = Instance.new("TextButton")
            optionBtn.Name = "Option_" .. option
            optionBtn.Text = option
            optionBtn.TextColor3 = COLORS.Text
            optionBtn.FontFace = TYPOGRAPHY.Body
            optionBtn.TextSize = 13
            optionBtn.BackgroundColor3 = option == selectedOption and COLORS.Accent or COLORS.SurfaceLight
            optionBtn.Size = UDim2.new(1, 0, 0, 30)
            optionBtn.AutoButtonColor = false
            optionBtn.ZIndex = 101
            optionBtn.TextXAlignment = Enum.TextXAlignment.Left
            optionBtn.Parent = optionsFrame
            
            -- Padding
            local optPadding = Instance.new("UIPadding")
            optPadding.PaddingLeft = UDim.new(0, 10)
            optPadding.Parent = optionBtn
            
            -- Hover
            optionBtn.MouseEnter:Connect(function()
                if option ~= selectedOption then
                    createTween(optionBtn, {BackgroundColor3 = COLORS.AccentDark}, 0.1):Play()
                end
            end)
            
            optionBtn.MouseLeave:Connect(function()
                if option ~= selectedOption then
                    createTween(optionBtn, {BackgroundColor3 = COLORS.SurfaceLight}, 0.1):Play()
                end
            end)
            
            -- Clique
            optionBtn.MouseButton1Click:Connect(function()
                selectedOption = option
                dropButton.Text = option
                
                -- Atualizar visual de todas as opções
                for _, btn in pairs(optionButtons) do
                    btn.BackgroundColor3 = btn.Name == "Option_" .. option and COLORS.Accent or COLORS.SurfaceLight
                end
                
                -- Fechar dropdown
                closeDropdown()
                
                -- Callback
                callback(option)
                
                -- Flag
                if flag then
                    if saveSystem and saveSystem.SetFlag then
                        saveSystem.SetFlag(flag, option)
                    end
                end
            end)
            
            table.insert(optionButtons, optionBtn)
        end
        
        -- Atualizar tamanho
        optionsFrame.Size = UDim2.new(1, 0, 0, #options * 30)
    end
    
    -- Função para abrir dropdown
    local function openDropdown()
        if isOpen then return end
        isOpen = true
        optionsFrame.Visible = true
        
        -- Altura automática
        local pageBottom = page.AbsolutePosition.Y + page.AbsoluteSize.Y
        local dropdownBottom = dropButton.AbsolutePosition.Y + dropButton.AbsoluteSize.Y + (#options * 30) + 10
        
        if dropdownBottom > pageBottom then
            -- Abrir para cima
            optionsFrame.Position = UDim2.new(0, 0, 0, -(#options * 30 + 5))
        else
            optionsFrame.Position = UDim2.new(0, 0, 1, 5)
        end
        
        createTween(arrowIcon, {Rotation = 180}, 0.2):Play()
    end
    
    -- Função para fechar dropdown
    local function closeDropdown()
        if not isOpen then return end
        isOpen = false
        optionsFrame.Visible = false
        createTween(arrowIcon, {Rotation = 0}, 0.2):Play()
    end
    
    -- Alternar dropdown
    dropButton.MouseButton1Click:Connect(function()
        if isOpen then
            closeDropdown()
        else
            openDropdown()
        end
    end)
    
    -- Fechar ao clicar fora
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
            local mousePos = UserInputService:GetMouseLocation()
            local dropBounds = dropButton.AbsolutePosition
            local dropSize = dropButton.AbsoluteSize
            local optsSize = optionsFrame.AbsoluteSize
            
            local inDropdown = mousePos.X >= dropBounds.X and mousePos.X <= dropBounds.X + dropSize.X
                and mousePos.Y >= dropBounds.Y - optsSize.Y and mousePos.Y <= dropBounds.Y + dropSize.Y + optsSize.Y
            
            if not inDropdown then
                closeDropdown()
            end
        end
    end)
    
    -- Criar opções
    createOptions()
    
    -- Atualizar opções
    local function updateOptions(newOptions)
        options = newOptions
        createOptions()
    end
    
    local DropdownComponent = {
        Instance = dropdownFrame,
        Button = dropButton,
        Options = optionsFrame,
        SetOptions = function(self, newOptions)
            updateOptions(newOptions)
        end,
        Get = function(self)
            return selectedOption
        end,
        Set = function(self, value)
            if table.find(options, value) then
                selectedOption = value
                dropButton.Text = value
                for _, btn in pairs(optionButtons) do
                    btn.BackgroundColor3 = btn.Name == "Option_" .. value and COLORS.Accent or COLORS.SurfaceLight
                end
            end
        end
    }
    
    return DropdownComponent
end

