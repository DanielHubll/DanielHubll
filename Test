		Label.Position = UDim2.new(0, 15, 0, isMobile and 10 or 8)
		Label.Font = Enum.Font.Gotham
		Label.TextSize = isMobile and 12 or 14
		Label.TextColor3 = Color3.fromRGB(200, 200, 200)
