		local function UpdateVisual()
			TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Value and Theme.Accent or Theme.ComponentHover}):Play()
			TweenService:Create(Circle, TweenInfo.new(0.2), {Position = Value and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)}):Play()
		end
		
		local function ToggleValue()
			Value = not Value
			UpdateVisual()
			Callback(Value)
			if Flag then getgenv().Flags = getgenv().Flags or {}; getgenv().Flags[Flag] = Value end
		end
		
		ToggleButton.MouseButton1Click:Connect(ToggleValue)
		ToggleFrame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				ToggleValue()
			end
		end)
		
		local ToggleObject = {}
		function ToggleObject:Set(newValue) Value = newValue; UpdateVisual(); Callback(Value) end
		function ToggleObject:Get() return Value end
		return ToggleObject
	end
	
