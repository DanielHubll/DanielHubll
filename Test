-- ============================================================

local function deselectButton(button)
button:SetAttribute("Selected", false)
local tabSelection = button:FindFirstChild("TabSelection")
local tabLabel = button:FindFirstChild("TabLabel")

if tabSelection then tabSelection.Visible = false end  
if tabLabel then  
	local icon = tabLabel:FindFirstChild("Icon")  
	local title = tabLabel:FindFirstChild("Title")  
	if icon then icon.TextTransparency = 0.5 end  
	if title then title.TextTransparency = 0.5 end  
end

end

local function selectButtonVisual(button)
button:SetAttribute("Selected", true)
local tabSelection = button:FindFirstChild("TabSelection")
local tabLabel = button:FindFirstChild("TabLabel")

if tabSelection then tabSelection.Visible = true end  
if tabLabel then  
	local icon = tabLabel:FindFirstChild("Icon")  
	local title = tabLabel:FindFirstChild("Title")  
	if icon then icon.TextTransparency = 0 end  
	if title then title.TextTransparency = 0 end  
end

end

local function hideAllPages()
for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
if child:IsA("Frame") then child.Visible = false end
end
end

local function deselectAllButtons()
for _, child in ipairs(HubBarContainer:GetChildren()) do
if child:IsA("TextButton") then deselectButton(child) end
end
end

local function getPageForButton(button)
for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
if child:IsA("Frame") and child.Name == button.Name then return child end
end
return nil
end

local function selectTabInternal(clickedButton)
for _, child in ipairs(HubBarContainer:GetChildren()) do
if child:IsA("TextButton") then
if child == clickedButton then
selectButtonVisual(child)
else
deselectButton(child)
end
end
end

hideAllPages()  

local page = getPageForButton(clickedButton)  
if page then page.Visible = true end

end

local function bindTabButtonEvents(button)
button.MouseButton1Click:Connect(function() selectTabInternal(button) end)
end

for _, child in ipairs(HubBarContainer:GetChildren()) do
if child:IsA("TextButton") then bindTabButtonEvents(child) end
end

HubBarContainer.ChildAdded:Connect(function(newChild)
if newChild:IsA("TextButton") then bindTabButtonEvents(newChild) end
end)

