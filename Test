function Library:CreateSlider(tab, config)
    config = config or {}
    local title = config.Title or "Slider"
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or 50
    local suffix = config.Suffix or ""
    local callback = config.Callback or function() end
    local flag = config.Flag or nil
    
    local page = tab.Page
    if not page or not page.Parent then return end
    
    -- Container
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Name = "Slider_" .. title
    sliderFrame.BackgroundColor3 = COLORS.Surface
    sliderFrame.Size = UDim2.new(1, -24, 0, 80)
    sliderFrame.Parent = page
    
    addCorner(sliderFrame, ROUNDING.Large)
    addStroke(sliderFrame)
    
    -- Padding
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 16)
    padding.PaddingRight = UDim.new(0, 16)
    padding.PaddingTop = UDim.new(0, 12)
    padding.PaddingBottom = UDim.new(0, 12)
    padding.Parent = sliderFrame
    
    -- Header (título + valor)
    local headerFrame = Instance.new("Frame")
    headerFrame.Name = "Header"
    headerFrame.BackgroundTransparency = 1
    headerFrame.Size = UDim2.new(1, 0, 0, 20)
    headerFrame.Parent = sliderFrame
    
    local headerLayout = Instance.new("UIListLayout")
    headerLayout.FillDirection = Enum.FillDirection.Horizontal
    headerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    headerLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    headerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    headerLayout.Padding = UDim.new(0, 4)
    headerLayout.Parent = headerFrame
    
    -- Título
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Text = title
    titleLabel.TextColor3 = COLORS.Text
    titleLabel.FontFace = TYPOGRAPHY.Body
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -60, 0, 20)
    titleLabel.Parent = headerFrame
    
    -- Valor
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Name = "Value"
    valueLabel.Text = tostring(default) .. suffix
    valueLabel.TextColor3 = COLORS.Accent
    valueLabel.FontFace = TYPOGRAPHY.Body
    valueLabel.TextSize = 14
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.BackgroundTransparency = 1
    valueLabel.Size = UDim2.new(0, 60, 0, 20)
    valueLabel.Parent = headerFrame
    
    -- Slider container
    local sliderContainer = Instance.new("Frame")
    sliderContainer.Name = "SliderContainer"
    sliderContainer.BackgroundColor3 = COLORS.SurfaceLight
    sliderContainer.Size = UDim2.new(1, 0, 0, 6)
    sliderContainer.Position = UDim2.new(0, 0, 0, 36)
    sliderContainer.BorderSizePixel = 0
    sliderContainer.Parent = sliderFrame
    
    addCorner(sliderContainer, UDim.new(0, 3))
    
    -- Slider fill
    local sliderFill = Instance.new("Frame")
    sliderFill.Name = "Fill"
    sliderFill.BackgroundColor3 = COLORS.Accent
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderContainer
    
    addCorner(sliderFill, UDim.new(0, 3))
    
    -- Slider knob
    local sliderKnob = Instance.new("Frame")
    sliderKnob.Name = "Knob"
    sliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderKnob.Size = UDim2.new(0, 16, 0, 16)
    sliderKnob.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
    sliderKnob.Parent = sliderContainer
    
    addCorner(sliderKnob, UDim.new(1, 0))
    addStroke(sliderKnob, COLORS.Accent, 2)
    
    -- Variáveis de arrasto
    local isDragging = false
    local currentValue = default
    
    -- Função de atualização
    local function updateValue(value)
        -- Clampar valor
        value = math.clamp(value, min, max)
        
        -- Arredondar para inteiro se necessário
        if max - min > 1 then
            value = math.floor(value + 0.5)
        else
            value = math.floor(value * 100 + 0.5) / 100
        end
        
        if value ~= currentValue then
            currentValue = value
            local percent = (value - min) / (max - min)
            
            -- Atualizar fill
            sliderFill.Size = UDim2.new(percent, 0, 1, 0)
            
            -- Atualizar knob
            sliderKnob.Position = UDim2.new(percent, -8, 0.5, -8)
            
            -- Atualizar label
            valueLabel.Text = tostring(value) .. suffix
            
            -- Callback
            callback(value)
            
            -- Flag
            if flag then
                if saveSystem and saveSystem.SetFlag then
                    saveSystem.SetFlag(flag, value)
                end
            end
        end
    end
    
    -- Eventos de arrasto
    sliderKnob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
        end
    end)
    
    sliderContainer.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            local mousePos = UserInputService:GetMouseLocation()
            local sliderPos = sliderContainer.AbsolutePosition.X
            local sliderSize = sliderContainer.AbsoluteSize.X
            local relativeX = math.clamp((mousePos.X - sliderPos) / sliderSize, 0, 1)
            updateValue(min + (max - min) * relativeX)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local sliderPos = sliderContainer.AbsolutePosition.X
            local sliderSize = sliderContainer.AbsoluteSize.X
            local relativeX = math.clamp((input.Position.X - sliderPos) / sliderSize, 0, 1)
            updateValue(min + (max - min) * relativeX)
        end
    end)
    
    -- Métodos públicos
    local SliderComponent = {
        Instance = sliderFrame,
        Fill = sliderFill,
        Knob = sliderKnob,
        Set = function(self, value)
            updateValue(value)
        end,
        Get = function(self)
            return currentValue
        end
    }
    
    return SliderComponent
end

