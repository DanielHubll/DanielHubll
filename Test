					UpdateDropdown()
					Callback(Value)
					
					if Flag then
						getgenv().Flags = getgenv().Flags or {}
						getgenv().Flags[Flag] = Value
					end
					
					BuildOptions()
				end)
			end
		end
		
		BuildOptions()
		
		DropdownFrame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				IsOpen = not IsOpen
				UpdateDropdown()
			end
		end)
		
		local DropdownObject = {}
		
		function DropdownObject:Set(newValue)
			if table.find(Options, newValue) then
				Value = newValue
				Label.Text = Name .. ": " .. Value
				Callback(Value)
				
				if Flag then
					getgenv().Flags = getgenv().Flags or {}
					getgenv().Flags[Flag] = Value
				end
				
				BuildOptions()
			end
		end
		
		function DropdownObject:Get()
			return Value
		end
		
		function DropdownObject:Refresh(newOptions)
			Options = newOptions
			Value = ""
			Label.Text = Name
			BuildOptions()
		end
		
		return DropdownObject
	end
	
