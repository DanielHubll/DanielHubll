        -- ── AddSlider ─────────────────────────────────────────
        function Tab:AddSlider(text, min, max, default, callback, suffix)
            suffix = suffix or ""
            local value = default or min
            local row = BaseRow(54)
            row.Size = UDim2.new(1, 0, 0, 54)

            -- Header row
            local headerFrame = Utility.Create("Frame", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -16, 0, 24),
                Position = UDim2.new(0, 8, 0, 6),
                ZIndex = 14,
                Parent = row
            })

            Utility.Create("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(0.7, 0, 1, 0),
                Font = config.Theme.FontSemibold,
                Text = text,
                TextColor3 = config.Theme.TextPrimary,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 14,
                Parent = headerFrame
            })

            local valueLabel = Utility.Create("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(0.3, 0, 1, 0),
                Position = UDim2.new(0.7, 0, 0, 0),
                Font = config.Theme.FontMono,
                Text = tostring(value) .. suffix,
                TextColor3 = config.Theme.Accent,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 14,
                Parent = headerFrame
            })

            -- Track
            local trackFrame = Utility.Create("Frame", {
                BackgroundColor3 = config.Theme.SliderTrack,
                BorderSizePixel = 0,
                Size = UDim2.new(1, -16, 0, 6),
                Position = UDim2.new(0, 8, 0, 36),
                ZIndex = 14,
                Parent = row
            })
            Utility.RoundCorner(trackFrame, 4)

            -- Fill
            local fillPercent = (value - min) / (max - min)
            local fillBar = Utility.Create("Frame", {
                BackgroundColor3 = config.Theme.SliderFill,
                BorderSizePixel = 0,
                Size = UDim2.new(fillPercent, 0, 1, 0),
                ZIndex = 15,
                Parent = trackFrame
            })
            Utility.RoundCorner(fillBar, 4)

            -- Gradient on fill
            Utility.Create("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(200,80,0)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255,160,50)),
                }),
                Parent = fillBar
            })

            -- Thumb
            local thumb = Utility.Create("Frame", {
                BackgroundColor3 = config.Theme.SliderThumb,
                BorderSizePixel = 0,
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(fillPercent, -7, 0.5, -7),
                ZIndex = 16,
                Parent = trackFrame
            })
            Utility.RoundCorner(thumb, 10)
            Utility.Create("UIStroke", {
                Color = config.Theme.Accent,
                Thickness = 2,
                Parent = thumb
            })

            -- Drag logic
            local dragging = false
            local function updateSlider(inputPos)
                local abs = trackFrame.AbsolutePosition
                local sizeX = trackFrame.AbsoluteSize.X
                local pct = math.clamp((inputPos.X - abs.X) / sizeX, 0, 1)
                local rounded = math.floor(min + (max - min) * pct + 0.5)
                value = rounded
                valueLabel.Text = tostring(rounded) .. suffix
                Utility.Tween(fillBar, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
                Utility.Tween(thumb, { Position = UDim2.new(pct, -7, 0.5, -7) }, 0.05)
                if callback then callback(rounded) end
            end

            trackFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    updateSlider(input.Position)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (
                    input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch
                ) then
                    updateSlider(input.Position)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)

            local Element = { _row = row, Value = value }
            function Element:Set(v)
                v = math.clamp(v, min, max)
                value = v
                local pct = (v - min) / (max - min)
                valueLabel.Text = tostring(v) .. suffix
                fillBar.Size = UDim2.new(pct, 0, 1, 0)
                thumb.Position = UDim2.new(pct, -7, 0.5, -7)
            end
            function Element:Get() return value end
            table.insert(Tab.Elements, Element)
            return Element
        end

        -- ── AddDropdown ───────────────────────────────────────
        function Tab:AddDropdown(text, options, default, callback)
            local selected = default or options[1]
            local isOpen = false
            local row = BaseRow(38)

            local label = Utility.Create("TextLabel", {
