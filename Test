local Window = {}
Window.__index = Window

function Window.new(name, icon, hubBarContainer, pageViewInnerFrame)
    local self = setmetatable({}, Window)
    
    self.Name = name or "MyTab"
    self.Icon = icon or "gear"
    self.HubBarContainer = hubBarContainer
    self.PageViewInnerFrame = pageViewInnerFrame
    self.Elements = {}
    self.LayoutOrder = 0
    
    -- Criar botão na HubBar
    self:CreateHubButton()
    
    -- Criar página no PageViewInnerFrame
    self:CreatePage()
    
    return self
end

