function Tab:AddButton(config)
	config = config or {}
	local Name     = config.Name     or "Button"
	local Callback = config.Callback or function() end

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))

	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(0, 90, 0, 30)
	Btn.Position = UDim2.new(1, -100, 0.5, -15)
	Btn.BackgroundColor3 = Color3.fromRGB(99, 102, 241)
	Btn.BorderSizePixel = 0
	Btn.Text = Name
	Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	Btn.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
	Btn.TextSize = 15
	Btn.ZIndex = 3
	Btn.AutoButtonColor = false
	Btn.Name = "Button"
	Instance.new("UICorner").Parent = Btn
	Btn.Parent = Frame

	-- esconde o título duplicado (o botão já tem o texto)
	local titleLabel = Frame:FindFirstChild("Title")
	if titleLabel then titleLabel.Text = config.Description or "" end

	local tw = TweenInfo.new(0.1)
	Btn.MouseEnter:Connect(function()
		TweenService:Create(Btn, tw, { BackgroundColor3 = Color3.fromRGB(120, 122, 255) }):Play()
	end)
	Btn.MouseLeave:Connect(function()
		TweenService:Create(Btn, tw, { BackgroundColor3 = Color3.fromRGB(99, 102, 241) }):Play()
	end)
	Btn.MouseButton1Click:Connect(function()
		Callback()
	end)

	return { Frame = Frame, Button = Btn }
end

-- ============================================================
-- TAB:ADDTOGGLE  (on/off  OU  multi-estado com Options)
-- ============================================================
--[[
  On/Off clássico:
    Tab:AddToggle({ Name="God Mode", Default=false, Callback=function(v) end })

  Multi-estado (ciclo de opções):
    Tab:AddToggle({
        Name     = "Hitbox Part",
        Options  = { "Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg" },
        Default  = "Head",      -- string ou índice numérico
        Callback = function(v) print(v) end,
    })

  API:
    toggle.Value           -- valor atual
    toggle:Set(value)      -- define sem disparar callback
]]
function Tab:AddToggle(config)
	config = config or {}
	local Name     = config.Name     or "Toggle"
	local Callback = config.Callback or function() end
	local Options  = config.Options  -- nil → on/off

	local isMulti = Options ~= nil and #Options > 0
	local Value, currentIndex

	if isMulti then
		currentIndex = 1
		if config.Default then
			if type(config.Default) == "number" then
				currentIndex = math.clamp(config.Default, 1, #Options)
			elseif type(config.Default) == "string" then
				for i, v in ipairs(Options) do
					if v == config.Default then currentIndex = i break end
				end
			end
		end
		Value = Options[currentIndex]
	else
		Value = config.Default == true
	end

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))
	local tw = TweenInfo.new(0.15, Enum.EasingStyle.Quad)

	if isMulti then
		-- ── MULTI-ESTADO ─────────────────────────────────────────────
		local ControlFrame = Instance.new("Frame")
		ControlFrame.BackgroundTransparency = 1
		ControlFrame.Size = UDim2.new(0, 180, 1, 0)
		ControlFrame.Position = UDim2.new(1, -190, 0, 0)
		ControlFrame.ZIndex = 3
		ControlFrame.Parent = Frame

		local BtnLeft = Instance.new("TextButton")
		BtnLeft.Size = UDim2.new(0, 28, 0, 28)
		BtnLeft.Position = UDim2.new(0, 0, 0.5, -14)
		BtnLeft.BackgroundColor3 = Color3.fromRGB(50, 52, 56)
		BtnLeft.BorderSizePixel = 0
		BtnLeft.Text = "<"
		BtnLeft.TextColor3 = Color3.fromRGB(255, 255, 255)
		BtnLeft.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
		BtnLeft.TextSize = 16
		BtnLeft.ZIndex = 4
		BtnLeft.AutoButtonColor = false
		Instance.new("UICorner").Parent = BtnLeft
		BtnLeft.Parent = ControlFrame

		local ValueLabel = Instance.new("TextLabel")
		ValueLabel.Size = UDim2.new(1, -64, 1, 0)
		ValueLabel.Position = UDim2.new(0, 32, 0, 0)
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		ValueLabel.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
		ValueLabel.TextSize = 15
		ValueLabel.Text = Value
		ValueLabel.ZIndex = 4
		ValueLabel.Name = "ValueLabel"
		ValueLabel.Parent = ControlFrame

		local BtnRight = Instance.new("TextButton")
		BtnRight.Size = UDim2.new(0, 28, 0, 28)
		BtnRight.Position = UDim2.new(1, -28, 0.5, -14)
		BtnRight.BackgroundColor3 = Color3.fromRGB(50, 52, 56)
		BtnRight.BorderSizePixel = 0
		BtnRight.Text = ">"
		BtnRight.TextColor3 = Color3.fromRGB(255, 255, 255)
		BtnRight.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
		BtnRight.TextSize = 16
		BtnRight.ZIndex = 4
		BtnRight.AutoButtonColor = false
		Instance.new("UICorner").Parent = BtnRight
		BtnRight.Parent = ControlFrame

		local function updateMulti(skipCb)
			Value = Options[currentIndex]
			ValueLabel.Text = Value
			if not skipCb then Callback(Value) end
		end

		BtnLeft.MouseButton1Click:Connect(function()
			currentIndex = currentIndex - 1
			if currentIndex < 1 then currentIndex = #Options end
			updateMulti()
		end)
		BtnRight.MouseButton1Click:Connect(function()
			currentIndex = currentIndex + 1
			if currentIndex > #Options then currentIndex = 1 end
			updateMulti()
		end)

		for _, btn in ipairs({ BtnLeft, BtnRight }) do
			btn.MouseEnter:Connect(function()
				TweenService:Create(btn, tw, { BackgroundColor3 = Color3.fromRGB(70, 73, 80) }):Play()
			end)
			btn.MouseLeave:Connect(function()
				TweenService:Create(btn, tw, { BackgroundColor3 = Color3.fromRGB(50, 52, 56) }):Play()
			end)
		end

		local obj = { Frame = Frame, Value = Value }
		function obj:Set(v)
			if type(v) == "string" then
				for i, opt in ipairs(Options) do
					if opt == v then currentIndex = i break end
				end
			elseif type(v) == "number" then
				currentIndex = math.clamp(v, 1, #Options)
			end
			updateMulti(true)
			self.Value = Value
		end
		return obj

	else
		-- ── ON / OFF ──────────────────────────────────────────────────
		local ToggleHolder = Instance.new("Frame")
		ToggleHolder.BackgroundTransparency = 1
		ToggleHolder.Size = UDim2.new(0, 44, 0, 24)
		ToggleHolder.Position = UDim2.new(1, -54, 0.5, -12)
		ToggleHolder.ZIndex = 3
		ToggleHolder.Parent = Frame

		local Track = Instance.new("Frame")
		Track.Size = UDim2.new(1, 0, 1, 0)
		Track.BorderSizePixel = 0
		Track.BackgroundColor3 = Value and Color3.fromRGB(99, 102, 241) or Color3.fromRGB(70, 73, 80)
		Track.ZIndex = 3
		Instance.new("UICorner").Parent = Track
		Track.Parent = ToggleHolder

		local Knob = Instance.new("Frame")
		Knob.Size = UDim2.new(0, 18, 0, 18)
		Knob.Position = Value and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
		Knob.BorderSizePixel = 0
		Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		Knob.ZIndex = 4
		Instance.new("UICorner").Parent = Knob
		Knob.Parent = Track

		local function setToggle(state, skipCb)
			Value = state
			TweenService:Create(Track, tw, {
				BackgroundColor3 = state and Color3.fromRGB(99, 102, 241) or Color3.fromRGB(70, 73, 80)
			}):Play()
			TweenService:Create(Knob, tw, {
				Position = state and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
			}):Play()
			if not skipCb then Callback(state) end
		end

		Frame.MouseButton1Click:Connect(function()
			setToggle(not Value)
		end)

		local obj = { Frame = Frame, Value = Value }
		function obj:Set(v)
			setToggle(v == true, true)
			self.Value = v
		end
		return obj
	end
end

