	local currentState = Default and "On" or "Off"

	local function updateVisual()
		if currentState == "On" then
			Selection1.Visible = false
			Selection2.Visible = true
		else
			Selection1.Visible = true
			Selection2.Visible = false
		end
	end
	updateVisual()

	local function SetOn()
		if currentState ~= "On" then
			currentState = "On"
			updateVisual()
			Callback(true)
		end
	end

	local function SetOff()
		if currentState ~= "Off" then
			currentState = "Off"
			updateVisual()
			Callback(false)
		end
	end

	RightButton.MouseButton1Click:Connect(SetOn)
	LeftButton.MouseButton1Click:Connect(SetOff)
	AutoSelectButton.MouseButton1Click:Connect(function()
		if currentState == "Off" then SetOn() else SetOff() end
	end)

	if Default then
		Callback(true)
	end

	return {
		Frame = Frame,
		Set = function(_, value)
			if value then SetOn() else SetOff() end
		end,
	}
end

