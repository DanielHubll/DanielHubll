-- ============================================================
-- UTILITÁRIOS
-- ============================================================
local function findDescendant(parent, name)
    for _, v in ipairs(parent:GetDescendants()) do
        if v.Name == name then
            return v
        end
    end
    return nil
end

local function waitForObject(parent, name, timeout)
    timeout = timeout or 10
    local start = tick()
    while tick() - start < timeout do
        local obj = findDescendant(parent, name)
        if obj then
            return obj
        end
        task.wait(0.1)
    end
    return nil
end

