			local t = channelVals[chName] / 255
			local refs = sliderRefs[chName]
			refs.fill.Size = UDim2.new(t, 0, 1, 0)
			refs.handle.Position = UDim2.new(t, 0, 0.5, 0)
			refs.valLabel.Text = tostring(channelVals[chName])
		end
		rebuildColor(true)
		self.Value = Value
	end
	return obj
end

