        local currentStep = math.clamp(defaultStep or 0, 0, 10)

        local SliderFrame = Instance.new("ImageButton", PageFrame)
        SliderFrame.BorderSizePixel = 0
        SliderFrame.SliceCenter = Rect.new(2, 2, 18, 18)
