			local on = Selected[optName]
			CheckMark.Visible = on
			CheckBg.BackgroundColor3 = on and Color3.fromRGB(99, 102, 241) or Color3.fromRGB(55, 58, 65)
			updatePreview()
			Callback(getSelectedList())
		end)

		Row.MouseEnter:Connect(function()
			Row.BackgroundColor3 = Color3.fromRGB(50, 53, 60)
