    leftBtn.BackgroundTransparency = 1
    leftBtn.Selectable = false
    leftBtn.ZIndex = 3
    leftBtn.AnchorPoint = Vector2.new(0, 0.5)
    leftBtn.Size = UDim2.new(0, 32, 0, 50)
    leftBtn.Name = "LeftButton"
    leftBtn.Position = UDim2.new(0, 0, 0.5, 0)

    local leftIcon = Instance.new("ImageLabel", leftBtn)
    leftIcon.ZIndex = 4
    leftIcon.ImageColor3 = Color3.fromRGB(205, 205, 205)
    leftIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    leftIcon.Image = "rbxasset://textures/ui/Settings/Slider/Left.png"
    leftIcon.Size = UDim2.new(0, 18, 0, 30)
    leftIcon.BackgroundTransparency = 1
    leftIcon.Position = UDim2.new(0.5, 0, 0.5, 0)

    -- Right Button
    local rightBtn = Instance.new("ImageButton", selector)
    rightBtn.BackgroundTransparency = 1
    rightBtn.Selectable = false
    rightBtn.ZIndex = 3
    rightBtn.AnchorPoint = Vector2.new(1, 0.5)
    rightBtn.Size = UDim2.new(0, 32, 0, 50)
    rightBtn.Name = "RightButton"
    rightBtn.Position = UDim2.new(1, 0, 0.5, 0)

    local rightIcon = Instance.new("ImageLabel", rightBtn)
    rightIcon.ZIndex = 4
    rightIcon.ImageColor3 = Color3.fromRGB(205, 205, 205)
    rightIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    rightIcon.Image = "rbxasset://textures/ui/Settings/Slider/Right.png"
    rightIcon.Size = UDim2.new(0, 18, 0, 30)
    rightIcon.BackgroundTransparency = 1
    rightIcon.Position = UDim2.new(0.5, 0, 0.5, 0)

    -- AutoSelectButton (middle click area)
    local autoBtn = Instance.new("ImageButton", selector)
    autoBtn.BackgroundTransparency = 1
    autoBtn.Selectable = false
    autoBtn.ZIndex = 2
    autoBtn.Size = UDim2.new(1, -64, 1, 0)
    autoBtn.Name = "AutoSelectButton"
    autoBtn.Position = UDim2.new(0, 32, 0, 0)

    -- Selection Labels
    local sel1 = Instance.new("TextLabel", selector)
    sel1.TextWrapped = true
    sel1.ZIndex = 2
    sel1.BorderSizePixel = 0
    sel1.TextSize = 17
    sel1.FontFace = Font.new(
        "rbxasset://fonts/families/BuilderSans.json",
        Enum.FontWeight.Regular, Enum.FontStyle.Normal
    )
    sel1.TextColor3 = Color3.fromRGB(255, 255, 255)
    sel1.BackgroundTransparency = 1
    sel1.Size = UDim2.new(1, -64, 1, 0)
    sel1.Text = "Off"
    sel1.Name = "Selection1"
    sel1.Position = UDim2.new(0, 32, 0, 0)

    local sel2 = Instance.new("TextLabel", selector)
    sel2.TextWrapped = true
    sel2.ZIndex = 2
    sel2.BorderSizePixel = 0
    sel2.TextSize = 17
    sel2.FontFace = Font.new(
        "rbxasset://fonts/families/BuilderSans.json",
        Enum.FontWeight.Regular, Enum.FontStyle.Normal
    )
    sel2.TextColor3 = Color3.fromRGB(255, 255, 255)
    sel2.BackgroundTransparency = 1
    sel2.Size = UDim2.new(1, -64, 1, 0)
    sel2.Text = "On"
    sel2.Name = "Selection2"
    sel2.Position = UDim2.new(0, 96, 0, 0)

    -- Estado
    local state = config.Default or false
    local callback = config.Callback or function() end

    local function updateVisual()
        if state then
            sel1.TextTransparency = 1
            sel2.TextTransparency = 0
        else
            sel1.TextTransparency = 0
            sel2.TextTransparency = 1
        end
    end

    updateVisual()

    -- Click no meio (toggle)
    autoBtn.MouseButton1Click:Connect(function()
        state = not state
        updateVisual()
        callback(state)
    end)

    -- Left = Off
    leftBtn.MouseButton1Click:Connect(function()
        state = false
        updateVisual()
        callback(state)
    end)

    -- Right = On
    rightBtn.MouseButton1Click:Connect(function()
        state = true
        updateVisual()
        callback(state)
    end)

    -- Retornar API do toggle
    local toggleApi = {
        Element = container,
        Set = function(self, value)
            state = value
            updateVisual()
            callback(state)
        end,
        Get = function(self)
            return state
        end,
        SetCallback = function(self, newCallback)
            callback = newCallback
        end,
        Destroy = function(self)
            container:Destroy()
        end,
    }

    return toggleApi
end

