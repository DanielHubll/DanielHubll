		Label.Text = Name
		Label.Parent = SliderFrame

		local ValueLabel = Instance.new("TextLabel")
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.Size = UDim2.new(0, 70, 0, 20)
		ValueLabel.Position = UDim2.new(1, -80, 0, isMobile and 10 or 8)
		ValueLabel.Font = Enum.Font.GothamBold
		ValueLabel.TextSize = isMobile and 12 or 14
		ValueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
		ValueLabel.Text = string.format("%." .. Decimals .. "f", Value) .. Suffix
		ValueLabel.Parent = SliderFrame

		-- Barra do slider com tamanho maior para mobile
		local barHeight = isMobile and 10 or 6
		local barY = isMobile and 42 or 38

		local SliderBar = Instance.new("Frame")
		SliderBar.Size = UDim2.new(1, -30, 0, barHeight)
		SliderBar.Position = UDim2.new(0, 15, 0, barY)
		SliderBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
		SliderBar.BorderSizePixel = 0
		SliderBar.Parent = SliderFrame

		local SliderBarCorner = Instance.new("UICorner")
		SliderBarCorner.CornerRadius = UDim.new(1, 0)
		SliderBarCorner.Parent = SliderBar

		local Fill = Instance.new("Frame")
		Fill.Size = UDim2.new((Value - Min) / (Max - Min), 0, 1, 0)
		Fill.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
		Fill.BorderSizePixel = 0
		Fill.Parent = SliderBar

		local FillCorner = Instance.new("UICorner")
		FillCorner.CornerRadius = UDim.new(1, 0)
		FillCorner.Parent = Fill

		-- Círculo (thumb) com tamanho maior para mobile
		local thumbSize = isMobile and 22 or 14
		local Circle = Instance.new("Frame")
		Circle.Size = UDim2.new(0, thumbSize, 0, thumbSize)
		Circle.Position = UDim2.new((Value - Min) / (Max - Min), -(thumbSize / 2), 0.5, -(thumbSize / 2))
		Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		Circle.BorderSizePixel = 0
		Circle.ZIndex = 3
		Circle.Parent = SliderBar

		local CircleCorner = Instance.new("UICorner")
		CircleCorner.CornerRadius = UDim.new(1, 0)
		CircleCorner.Parent = Circle

		-- Shadow no thumb
		local CircleShadow = Instance.new("UIStroke")
		CircleShadow.Color = Color3.fromRGB(0, 0, 0)
		CircleShadow.Transparency = 0.7
		CircleShadow.Thickness = 2
		CircleShadow.Parent = Circle

		-- HIT AREA INVISÍVEL — Área de toque maior para mobile
		local hitAreaPadding = isMobile and 15 or 8
		local HitArea = Instance.new("TextButton")
		HitArea.Name = "HitArea"
		HitArea.Size = UDim2.new(1, 0, 1, hitAreaPadding * 2)
		HitArea.Position = UDim2.new(0, 0, 0.5, -hitAreaPadding - (barHeight / 2))
		HitArea.BackgroundTransparency = 1
		HitArea.Text = ""
		HitArea.ZIndex = 4
		HitArea.AutoButtonColor = false
		HitArea.Parent = SliderBar

		local function UpdateVisual()
			local percent = (Value - Min) / (Max - Min)
			Fill.Size = UDim2.new(percent, 0, 1, 0)
			Circle.Position = UDim2.new(percent, -(thumbSize / 2), 0.5, -(thumbSize / 2))
			ValueLabel.Text = string.format("%." .. Decimals .. "f", Value) .. Suffix
		end

		local function SetValueFromPosition(xPos)
			local barSize = SliderBar.AbsoluteSize.X
			local barPos = SliderBar.AbsolutePosition.X
			local relativePos = math.clamp((xPos - barPos) / barSize, 0, 1)

			Value = Min + (Max - Min) * relativePos
			Value = math.floor(Value * (10 ^ Decimals) + 0.5) / (10 ^ Decimals)
			Value = math.clamp(Value, Min, Max)

			UpdateVisual()
			pcall(Callback, Value)

			if Flag then
				getgenv().Flags = getgenv().Flags or {}
				getgenv().Flags[Flag] = Value
			end
		end

		-- Input handling unificado para mouse e touch
		HitArea.InputBegan:Connect(function(input)
			if isClickInput(input) then
				Dragging = true
				SetValueFromPosition(input.Position.X)

				-- Efeito visual: thumb aumenta
				TweenService:Create(Circle, TweenInfo.new(0.1), {
					Size = UDim2.new(0, thumbSize + 4, 0, thumbSize + 4),
					Position = UDim2.new((Value - Min) / (Max - Min), -((thumbSize + 4) / 2), 0.5, -((thumbSize + 4) / 2))
				}):Play()
			end
		end)

		HitArea.InputEnded:Connect(function(input)
			if isClickInput(input) then
				Dragging = false
				-- Efeito visual: thumb volta ao normal
				TweenService:Create(Circle, TweenInfo.new(0.1), {
					Size = UDim2.new(0, thumbSize, 0, thumbSize),
					Position = UDim2.new((Value - Min) / (Max - Min), -(thumbSize / 2), 0.5, -(thumbSize / 2))
				}):Play()
			end
		end)

		-- Suporte a drag contínuo (mouse movement + touch movement)
		UserInputService.InputChanged:Connect(function(input)
			if Dragging then
				if input.UserInputType == Enum.UserInputType.MouseMovement or
				   input.UserInputType == Enum.UserInputType.Touch then
					SetValueFromPosition(input.Position.X)
				end
			end
		end)

		-- Fallback: parar drag se input acabar
		UserInputService.InputEnded:Connect(function(input)
			if isClickInput(input) and Dragging then
				Dragging = false
				TweenService:Create(Circle, TweenInfo.new(0.1), {
					Size = UDim2.new(0, thumbSize, 0, thumbSize),
				}):Play()
			end
		end)

		local SliderObject = {}

		function SliderObject:Set(newValue)
			Value = math.clamp(newValue, Min, Max)
			UpdateVisual()
			pcall(Callback, Value)

			if Flag then
				getgenv().Flags = getgenv().Flags or {}
				getgenv().Flags[Flag] = Value
			end
		end

		function SliderObject:Get()
			return Value
		end

		return SliderObject
	end

