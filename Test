--  MÉTODOS GLOBAIS DA LIB
-- ═══════════════════════════════════════════════════════════════

function VRCoreLib:Destroy()
    for _, tab in pairs(Library.Tabs) do
        if tab.Button then tab.Button:Destroy() end
        if tab.Page then tab.Page:Destroy() end
    end
    Library.Tabs = {}
    Library.TabCount = 0
    print("[VRCoreLib] Destruído!")
end

function VRCoreLib:GetTab(name)
    for key, tab in pairs(Library.Tabs) do
        if tab.Name == name then
            return tab
        end
    end
    return nil
end

function VRCoreLib:SelectTab(name)
    for key, tab in pairs(Library.Tabs) do
        if tab.Name == name then
            self:_OnTabClicked(tab.Button)
            return true
        end
    end
    return false
end

function VRCoreLib:GetVersion()
    return "VRCoreLib v1.0.0"
end

