local TabObject = {}
TabObject.__index = TabObject

function VRCoreLib:CreateTab(config)
    -- config = { Name = "Settings", Icon = "gear" }
    if type(config) == "string" then
        config = { Name = config, Icon = "gear" }
    end

    assert(Library.Initialized, "[VRCoreLib] Chame :Init() antes de criar tabs!")
    assert(config.Name, "[VRCoreLib] Tab precisa de um nome!")

    Library.TabCount = Library.TabCount + 1
    local tabName = config.Name
    local tabIcon = config.Icon or "gear"
    local uniqueName = tabName .. "_VRCoreTab_" .. Library.TabCount

    -- ─── Criar o Botão no HubBar ───
    local button = Instance.new("TextButton", Library.HubBarContainer)
    button.Selectable = false
    button.ZIndex = 3
    button.BackgroundTransparency = 1
    button.Size = UDim2.new(0.2, 0, 1, 0)
    button.Text = ""
    button.Name = uniqueName

    local tabSelection = Instance.new("ImageLabel", button)
    tabSelection.ZIndex = 3
    tabSelection.BorderSizePixel = 0
    tabSelection.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    tabSelection.Size = UDim2.new(1, -2, 0, 2)
    tabSelection.Visible = false
    tabSelection.Name = "TabSelection"
    tabSelection.Position = UDim2.new(0, 3, 1, -2)

    local tabLabel = Instance.new("Frame", button)
    tabLabel.ZIndex = 3
    tabLabel.BorderSizePixel = 0
    tabLabel.Size = UDim2.new(1, 0, 1, 0)
    tabLabel.Name = "TabLabel"
    tabLabel.BackgroundTransparency = 1

    local layout = Instance.new("UIListLayout", tabLabel)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Padding = UDim.new(0, 10)
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Name = "Layout"
    layout.FillDirection = Enum.FillDirection.Horizontal

    local iconLabel = Instance.new("TextLabel", tabLabel)
    iconLabel.TextWrapped = true
    iconLabel.ZIndex = 3
    iconLabel.TextTransparency = 0.5
    iconLabel.TextScaled = true
    iconLabel.FontFace = Font.new(
        "rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json",
        Enum.FontWeight.Regular, Enum.FontStyle.Normal
    )
    iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Size = UDim2.new(0, 24, 0, 24)
    iconLabel.Text = tabIcon
    iconLabel.Name = "Icon"

    local aspectRatio = Instance.new("UIAspectRatioConstraint", iconLabel)

    local titleLabel = Instance.new("TextLabel", tabLabel)
    titleLabel.ZIndex = 3
    titleLabel.TextSize = 19
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextTransparency = 0.5
    titleLabel.FontFace = Font.new(
        "rbxasset://fonts/families/BuilderSans.json",
        Enum.FontWeight.Medium, Enum.FontStyle.Normal
    )
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = tabName
    titleLabel.AutomaticSize = Enum.AutomaticSize.XY
    titleLabel.Name = "Title"

    -- ─── Criar o Frame (Page) no PageViewInnerFrame ───
    local page = Instance.new("Frame", Library.PageViewInnerFrame)
    page.ZIndex = 5
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.Size = UDim2.new(1, 0, 0, 0)
    page.Position = UDim2.new(0, 0, 0, 0)
    page.Name = uniqueName
    page.BackgroundTransparency = 1
    page.SelectionGroup = true
    page.Visible = false

    local pagePadding = Instance.new("UIPadding", page)
    pagePadding.PaddingRight = UDim.new(0, 11)
    pagePadding.PaddingLeft = UDim.new(0, 12)

    local pageLayout = Instance.new("UIListLayout", page)
    pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pageLayout.Padding = UDim.new(0, 6)
    pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pageLayout.Name = "RowListLayout"

    -- ─── Criar Tab Object ───
    local tab = setmetatable({}, TabObject)
    tab.Name = tabName
    tab.Button = button
    tab.Page = page
    tab.ElementCount = 0

    Library.Tabs[uniqueName] = tab

    -- Conectar clique
    button.MouseButton1Click:Connect(function()
        VRCoreLib:_OnTabClicked(button)
    end)

    print(string.format("[VRCoreLib] Tab '%s' criada!", tabName))

    return tab
end

