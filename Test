--[[
  Tab:AddSlider({
      Name     = "Speed",
      Min      = 0,
      Max      = 100,
      Default  = 16,
      Decimals = 0,           -- casas decimais (padrão 0)
      Suffix   = "",          -- ex: "%", "studs"
      Callback = function(v) end,
  })
  API:
    slider.Value
    slider:Set(value)
]]
function Tab:AddSlider(config)
	config = config or {}
	local Name     = config.Name     or "Slider"
	local Min      = config.Min      or 0
	local Max      = config.Max      or 100
	local Decimals = config.Decimals or 0
	local Suffix   = config.Suffix   or ""
	local Callback = config.Callback or function() end
	local Value    = math.clamp(config.Default or Min, Min, Max)

	local function fmt(v)
		return string.format("%." .. Decimals .. "f", v) .. Suffix
	end

	local Frame = createBaseContainer(self.Page, Name, nextOrder(self))
	Frame.Size = UDim2.new(1, 0, 0, 60)

	-- valor atual (canto direito)
	local ValueLabel = Instance.new("TextLabel")
	ValueLabel.BackgroundTransparency = 1
	ValueLabel.Size = UDim2.new(0, 60, 0, 20)
	ValueLabel.Position = UDim2.new(1, -68, 0, 6)
	ValueLabel.Text = fmt(Value)
	ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
	ValueLabel.TextColor3 = Color3.fromRGB(180, 180, 255)
	ValueLabel.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
	ValueLabel.TextSize = 15
	ValueLabel.ZIndex = 3
	ValueLabel.Parent = Frame

	-- trilho
	local TrailBg = Instance.new("Frame")
	TrailBg.Size = UDim2.new(1, -20, 0, 6)
	TrailBg.Position = UDim2.new(0, 10, 1, -16)
	TrailBg.BackgroundColor3 = Color3.fromRGB(55, 58, 65)
	TrailBg.BorderSizePixel = 0
	TrailBg.ZIndex = 3
	Instance.new("UICorner").Parent = TrailBg
	TrailBg.Parent = Frame

	local function ratio() return (Value - Min) / (Max - Min) end

	local TrailFill = Instance.new("Frame")
	TrailFill.Size = UDim2.new(ratio(), 0, 1, 0)
	TrailFill.BackgroundColor3 = Color3.fromRGB(99, 102, 241)
	TrailFill.BorderSizePixel = 0
	TrailFill.ZIndex = 4
	Instance.new("UICorner").Parent = TrailFill
	TrailFill.Parent = TrailBg

	local Handle = Instance.new("Frame")
	Handle.Size = UDim2.new(0, 14, 0, 14)
	Handle.AnchorPoint = Vector2.new(0.5, 0.5)
	Handle.Position = UDim2.new(ratio(), 0, 0.5, 0)
	Handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	Handle.BorderSizePixel = 0
	Handle.ZIndex = 5
	Instance.new("UICorner").Parent = Handle
	Handle.Parent = TrailBg

	local dragging = false

	local function applyX(absX)
		local tbPos  = TrailBg.AbsolutePosition.X
		local tbSize = TrailBg.AbsoluteSize.X
		local t = math.clamp((absX - tbPos) / tbSize, 0, 1)
		local raw = Min + (Max - Min) * t
		local mult = 10 ^ Decimals
		Value = math.round(raw * mult) / mult
		Value = math.clamp(Value, Min, Max)
		TrailFill.Size = UDim2.new(t, 0, 1, 0)
		Handle.Position = UDim2.new(t, 0, 0.5, 0)
		ValueLabel.Text = fmt(Value)
		Callback(Value)
	end

	TrailBg.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			applyX(i.Position.X)
		end
	end)
	UserInputService.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			applyX(i.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	local obj = { Frame = Frame, Value = Value }
	function obj:Set(v)
		Value = math.clamp(v, Min, Max)
		local t = (Value - Min) / (Max - Min)
		TrailFill.Size = UDim2.new(t, 0, 1, 0)
		Handle.Position = UDim2.new(t, 0, 0.5, 0)
		ValueLabel.Text = fmt(Value)
		self.Value = Value
	end
	return obj
end

