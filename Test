			SliderLabel.Font = Enum.Font.GothamBold
			SliderLabel.TextSize = isMobile and 11 or 12
			SliderLabel.TextColor3 = color
			SliderLabel.Text = name
			SliderLabel.ZIndex = 16
			SliderLabel.Parent = SliderFrame

			local ValueDisplay = Instance.new("TextLabel")
			ValueDisplay.BackgroundTransparency = 1
			ValueDisplay.Size = UDim2.new(0, 35, 1, 0)
			ValueDisplay.Position = UDim2.new(1, -35, 0, 0)
			ValueDisplay.Font = Enum.Font.Gotham
			ValueDisplay.TextSize = isMobile and 10 or 11
			ValueDisplay.TextColor3 = Color3.fromRGB(180, 180, 180)
			ValueDisplay.TextXAlignment = Enum.TextXAlignment.Right
			ValueDisplay.ZIndex = 16
			ValueDisplay.Parent = SliderFrame

			local barHeight = isMobile and 8 or 4
			local SliderBar = Instance.new("Frame")
			SliderBar.Size = UDim2.new(1, -65, 0, barHeight)
			SliderBar.Position = UDim2.new(0, 28, 0.5, -(barHeight / 2))
			SliderBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			SliderBar.BorderSizePixel = 0
			SliderBar.ZIndex = 16
			SliderBar.Parent = SliderFrame

			local BarCorner = Instance.new("UICorner")
			BarCorner.CornerRadius = UDim.new(1, 0)
			BarCorner.Parent = SliderBar

			local Fill = Instance.new("Frame")
			Fill.Size = UDim2.new(0, 0, 1, 0)
			Fill.BackgroundColor3 = color
			Fill.BorderSizePixel = 0
			Fill.ZIndex = 16
			Fill.Parent = SliderBar

			local FillCorner = Instance.new("UICorner")
			FillCorner.CornerRadius = UDim.new(1, 0)
			FillCorner.Parent = Fill

			-- Hit area para touch
			local HitArea = Instance.new("TextButton")
			HitArea.Size = UDim2.new(1, 0, 1, isMobile and 20 or 12)
			HitArea.Position = UDim2.new(0, 0, 0.5, -(isMobile and 10 or 6))
			HitArea.BackgroundTransparency = 1
			HitArea.Text = ""
			HitArea.ZIndex = 17
			HitArea.AutoButtonColor = false
			HitArea.Parent = SliderBar

			return SliderBar, Fill, ValueDisplay, HitArea
		end

		local RBar, RFill, RValue, RHit = createColorSlider(ColorContainer, "R", Color3.fromRGB(255, 80, 80), isMobile and 52 or 50)
		local GBar, GFill, GValue, GHit = createColorSlider(ColorContainer, "G", Color3.fromRGB(80, 255, 80), isMobile and 97 or 90)
		local BBar, BFill, BValue, BHit = createColorSlider(ColorContainer, "B", Color3.fromRGB(80, 80, 255), isMobile and 142 or 130)

		local function UpdateColorSliders()
			RFill.Size = UDim2.new(Value.R, 0, 1, 0)
			GFill.Size = UDim2.new(Value.G, 0, 1, 0)
			BFill.Size = UDim2.new(Value.B, 0, 1, 0)
			RValue.Text = tostring(math.floor(Value.R * 255))
			GValue.Text = tostring(math.floor(Value.G * 255))
			BValue.Text = tostring(math.floor(Value.B * 255))
			ColorPreview.BackgroundColor3 = Value
			HexInput.Text = "#" .. string.format("%02X%02X%02X", math.floor(Value.R * 255), math.floor(Value.G * 255), math.floor(Value.B * 255))
		end

		UpdateColorSliders()

		local function UpdateColor()
			pcall(Callback, Value)
			UpdateColorSliders()

			if Flag then
				getgenv().Flags = getgenv().Flags or {}
				getgenv().Flags[Flag] = Value
			end
		end

		HexInput.FocusLost:Connect(function()
			local hex = HexInput.Text:gsub("#", ""):gsub("[^%x]", "")
			if #hex == 6 then
				local r = tonumber(hex:sub(1,2), 16) or 255
				local g = tonumber(hex:sub(3,4), 16) or 255
				local b = tonumber(hex:sub(5,6), 16) or 255
				Value = Color3.fromRGB(r, g, b)
				UpdateColor()
			end
		end)

		local function setupSliderInteraction(hitArea, bar, component)
			local dragging = false

			local function setFromPosition(xPos)
				local barSize = bar.AbsoluteSize.X
				local barPos = bar.AbsolutePosition.X
				local relativePos = math.clamp((xPos - barPos) / barSize, 0, 1)

				if component == "R" then Value = Color3.fromRGB(relativePos, Value.G, Value.B)
				elseif component == "G" then Value = Color3.fromRGB(Value.R, relativePos, Value.B)
				elseif component == "B" then Value = Color3.fromRGB(Value.R, Value.G, relativePos) end

				UpdateColor()
			end

			hitArea.InputBegan:Connect(function(input)
				if isClickInput(input) then
					dragging = true
					setFromPosition(input.Position.X)
				end
			end)

			hitArea.InputEnded:Connect(function(input)
				if isClickInput(input) then
					dragging = false
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging then
					if input.UserInputType == Enum.UserInputType.MouseMovement or
					   input.UserInputType == Enum.UserInputType.Touch then
						setFromPosition(input.Position.X)
					end
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if isClickInput(input) and dragging then
					dragging = false
				end
			end)
		end

		setupSliderInteraction(RHit, RBar, "R")
		setupSliderInteraction(GHit, GBar, "G")
		setupSliderInteraction(BHit, BBar, "B")

		-- Abrir/fechar colorpicker
		PickerFrame.MouseButton1Click:Connect(function()
			IsOpen = not IsOpen
			ColorContainer.Visible = IsOpen
			if IsOpen then
				TweenService:Create(ColorContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
					Size = UDim2.new(1, 0, 0, containerHeight)
				}):Play()
			else
				local tween = TweenService:Create(ColorContainer, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
					Size = UDim2.new(1, 0, 0, 0)
				})
				tween:Play()
				tween.Completed:Connect(function()
					if not IsOpen then
						ColorContainer.Visible = false
					end
				end)
			end
		end)

		local ColorPickerObject = {}

		function ColorPickerObject:Set(newValue)
			Value = newValue
			UpdateColor()
		end

		function ColorPickerObject:Get()
			return Value
		end

		return ColorPickerObject
	end

	-- ============================================================
	-- KEYBIND (Mobile + PC)
	-- ============================================================
	function Tab:Keybind(config)
		config = config or {}

		local Name = config.Name or "Keybind"
		local Default = config.Default or Enum.KeyCode.E
		local Callback = config.Callback or function() end
		local Flag = config.Flag or nil

		local Value = Default
		local IsBinding = false

		local KeybindFrame = Instance.new("Frame")
		KeybindFrame.Name = Name
		KeybindFrame.Size = UDim2.new(1, -24, 0, isMobile and 52 or 50)
		KeybindFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		KeybindFrame.BorderSizePixel = 0
		KeybindFrame.Parent = page

		local Corner = Instance.new("UICorner")
		Corner.CornerRadius = UDim.new(0, 10)
		Corner.Parent = KeybindFrame

		local Label = Instance.new("TextLabel")
		Label.BackgroundTransparency = 1
		Label.Size = UDim2.new(1, -110, 1, 0)
		Label.Position = UDim2.new(0, 15, 0, 0)
		Label.Font = Enum.Font.Gotham
		Label.TextSize = isMobile and 12 or 14
		Label.TextColor3 = Color3.fromRGB(200, 200, 200)
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Text = Name
		Label.TextWrapped = true
		Label.Parent = KeybindFrame

		local buttonWidth = isMobile and 70 or 60
		local KeyButton = Instance.new("TextButton")
		KeyButton.Size = UDim2.new(0, buttonWidth, 0, isMobile and 30 or 26)
		KeyButton.Position = UDim2.new(1, -(buttonWidth + 15), 0.5, -(isMobile and 15 or 13))
		KeyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
		KeyButton.BorderSizePixel = 0
		KeyButton.Font = Enum.Font.GothamBold
		KeyButton.TextSize = isMobile and 11 or 12
		KeyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		KeyButton.Text = Value.Name
		KeyButton.AutoButtonColor = false
		KeyButton.Parent = KeybindFrame

		local KeyCorner = Instance.new("UICorner")
		KeyCorner.CornerRadius = UDim.new(0, 6)
		KeyCorner.Parent = KeyButton

		local KeyStroke = Instance.new("UIStroke")
		KeyStroke.Color = Color3.fromRGB(60, 60, 60)
		KeyStroke.Thickness = 1
		KeyStroke.Transparency = 0.5
		KeyStroke.Parent = KeyButton

		KeyButton.MouseButton1Click:Connect(function()
			if IsBinding then return end
			IsBinding = true
			KeyButton.Text = "..."
			KeyButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			KeyStroke.Color = Color3.fromRGB(0, 170, 100)
			KeyStroke.Transparency = 0

			local connection
			connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
				if input.UserInputType == Enum.UserInputType.Keyboard then
					if input.KeyCode == Enum.KeyCode.Escape then
						IsBinding = false
						KeyButton.Text = Value.Name
						KeyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
						KeyStroke.Transparency = 0.5
						KeyStroke.Color = Color3.fromRGB(60, 60, 60)
						connection:Disconnect()
						return
					end

					Value = input.KeyCode
					KeyButton.Text = Value.Name
					IsBinding = false
					KeyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
					KeyStroke.Transparency = 0.5
					KeyStroke.Color = Color3.fromRGB(60, 60, 60)
					connection:Disconnect()

					if Flag then
						getgenv().Flags = getgenv().Flags or {}
						getgenv().Flags[Flag] = Value
					end
				end
			end)
		end)

		-- Monitor global para ativar callback
		UserInputService.InputBegan:Connect(function(input, gameProcessed)
			if not gameProcessed then
				if input.KeyCode == Value and not IsBinding then
					pcall(Callback)
				end
			end
		end)

		local KeybindObject = {}

		function KeybindObject:Set(newValue)
			Value = newValue
			KeyButton.Text = Value.Name

			if Flag then
				getgenv().Flags = getgenv().Flags or {}
				getgenv().Flags[Flag] = Value
			end
		end

		function KeybindObject:Get()
			return Value
		end

		return KeybindObject
	end

