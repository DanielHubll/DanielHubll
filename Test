	currentIndex = currentIndex + 1  
	if currentIndex > #Options then currentIndex = 1 end  
	updateVisual()  
end)  

AutoSelectButton.MouseButton1Click:Connect(function()  
	currentIndex = currentIndex + 1  
	if currentIndex > #Options then currentIndex = 1 end  
	updateVisual()  
end)  

