local Library = {}

-- Serviços
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

-- Variáveis do sistema
local HubBarContainer = nil
local PageViewInnerFrame = nil
local HubBar = nil
local SettingsShield = nil
local tabs = {}
local activeTab = nil

-- Configurações CORRIGIDAS
local BASE_WIDTH = 800
local BUTTON_WIDTH = 100  -- Largura base de cada botão
local MIN_WIDTH = 500     -- Largura mínima do HubBar
local MAX_WIDTH = 1000    -- Largura máxima do HubBar

-- ============================================================
-- FUNÇÕES UTILITÁRIAS
-- ============================================================

local function findDescendant(parent, name)
	for _, v in ipairs(parent:GetDescendants()) do
		if v.Name == name then
			return v
		end
	end
	return nil
end

local function waitForElement(parent, name, timeout)
	timeout = timeout or 10
	local startTime = tick()
	local attempts = 0
	
	while tick() - startTime < timeout do
		attempts = attempts + 1
		local element = findDescendant(parent, name)
		if element then
			return element
		end
		
		-- Espera progressiva para evitar sobrecarga
		local waitTime = math.min(0.1 * attempts, 0.5)
		task.wait(waitTime)
	end
	
	return nil
end

-- ============================================================
-- SISTEMA DE INICIALIZAÇÃO
-- ============================================================

local function initializeSystem()
	-- Aguardar elementos principais
	HubBarContainer = waitForElement(CoreGui, "HubBarContainer", 15)
	PageViewInnerFrame = waitForElement(CoreGui, "PageViewInnerFrame", 15)
	
	if not HubBarContainer or not PageViewInnerFrame then
		warn("[Library] Não foi possível encontrar os elementos principais do CoreGui")
		return false
	end
	
	print("[Library] Sistema inicializado com sucesso!")
	return true
end

-- ============================================================
-- SISTEMA DE HUBBAR - CORRIGIDO
-- ============================================================

local function countButtons()
	local count = 0
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") or child:IsA("ImageButton") then
				count = count + 1
			end
		end
	end
	return count
end

local function adjustHubBarWidth()
	if not HubBar then
		HubBar = findDescendant(CoreGui, "HubBar")
		if not HubBar then
			return
		end
	end
	
	-- Verificar se o HubBar ainda é válido
	if not HubBar:IsDescendantOf(game) then
		HubBar = nil
		return
	end
	
	local buttonCount = countButtons()
	
	-- CORREÇÃO: A largura deve AUMENTAR com mais botões, não diminuir
	local newWidth
	if buttonCount <= 1 then
		newWidth = BASE_WIDTH
	else
		-- Calcula largura base + espaço para cada botão adicional
		newWidth = BASE_WIDTH + (BUTTON_WIDTH * (buttonCount - 1))
	end
	
	-- Limitar entre mínimo e máximo
	if newWidth < MIN_WIDTH then
		newWidth = MIN_WIDTH
	elseif newWidth > MAX_WIDTH then
		newWidth = MAX_WIDTH
	end
	
	-- Aplicar nova largura mantendo a altura atual
	local currentSize = HubBar.Size
	HubBar.Size = UDim2.new(0, newWidth, currentSize.Y.Scale, currentSize.Y.Offset)
	
	-- Ajustar o tamanho dos botões para se adaptarem ao novo tamanho
	adjustButtonSizes(buttonCount)
	
	print(string.format("[Library] HubBar ajustado: %d botões, largura: %d", buttonCount, newWidth))
end

local function adjustButtonSizes(buttonCount)
	if not HubBarContainer or buttonCount <= 0 then return end
	
	local buttonWidth = 1 / buttonCount  -- Distribuir igualmente
	
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") or child:IsA("ImageButton") then
			child.Size = UDim2.new(buttonWidth, 0, 1, 0)
		end
	end
end

-- ============================================================
-- SISTEMA DE SELEÇÃO VISUAL
-- ============================================================

local function deselectButton(button)
	if not button or not button:IsDescendantOf(game) then return end
	
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")
	
	if tabSelection then
		tabSelection.Visible = false
	end
	
	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0.5 end
		if title then title.TextTransparency = 0.5 end
	end
end

local function selectButton(button)
	if not button or not button:IsDescendantOf(game) then return end
	
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")
	
	if tabSelection then
		tabSelection.Visible = true
	end
	
	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0 end
		if title then title.TextTransparency = 0 end
	end
end

-- ============================================================
-- SISTEMA DE PÁGINAS
-- ============================================================

local function getPageForButton(button)
	if not PageViewInnerFrame or not button then return nil end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name == button.Name then
			return child
		end
	end
	return nil
end

local function hideAllPages()
	if not PageViewInnerFrame then return end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") then
			child.Visible = false
		end
	end
end

local function showPage(page)
	if not page then return end
	hideAllPages()
	page.Visible = true
end

local function onTabClicked(clickedButton)
	if not clickedButton or not clickedButton:IsDescendantOf(game) then return end
	
	-- Controlar visual dos botões
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") or child:IsA("ImageButton") then
				if child == clickedButton then
					selectButton(child)
				else
					deselectButton(child)
				end
			end
		end
	end
	
	-- Controlar visibilidade dos frames
	local correspondingPage = getPageForButton(clickedButton)
	if correspondingPage then
		showPage(correspondingPage)
		activeTab = clickedButton
		print("[Library] Aba ativada: " .. clickedButton.Name)
	else
		warn("[Library] Página não encontrada para: " .. clickedButton.Name)
		-- Tentar criar a página se não existir
		local newPage = createPage(clickedButton.Name)
		if newPage then
			showPage(newPage)
		end
	end
end

-- ============================================================
-- SISTEMA DE SETTINGS SHIELD - CORRIGIDO
-- ============================================================

local settingsShieldConnection = nil
local isResetting = false

local function deselectAllButtons()
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") or child:IsA("ImageButton") then
				deselectButton(child)
			end
		end
	end
	activeTab = nil
end

local function setupSettingsShieldMonitor()
	-- Limpar conexão anterior se existir
	if settingsShieldConnection then
		settingsShieldConnection:Disconnect()
		settingsShieldConnection = nil
	end
	
	SettingsShield = findDescendant(CoreGui, "SettingsShield")
	
	if SettingsShield and SettingsShield:IsA("ImageButton") then
		print("[Library] SettingsShield encontrado! Monitorando...")
		
		-- Estado inicial
		if not SettingsShield.Visible then
			deselectAllButtons()
			hideAllPages()
		end
		
		-- Monitorar mudanças de visibilidade
		settingsShieldConnection = SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
			if isResetting then return end
			
			if not SettingsShield.Visible then
				print("[Library] SettingsShield fechado - Desselecionando todas as abas")
				deselectAllButtons()
				hideAllPages()
			else
				-- Quando abrir, restaurar a última aba ativa
				if activeTab and activeTab:IsDescendantOf(game) then
					task.wait(0.1)
					onTabClicked(activeTab)
				end
			end
		end)
		
		-- Monitorar se o SettingsShield for removido/recriado
		SettingsShield.AncestryChanged:Connect(function(_, parent)
			if not parent and not isResetting then
				print("[Library] SettingsShield removido - Reiniciando monitor...")
				task.wait(0.5)
				setupSettingsShieldMonitor()
			end
		end)
	else
		print("[Library] SettingsShield não encontrado - Tentando novamente em 1s...")
		task.wait(1)
		setupSettingsShieldMonitor()
	end
end

-- ============================================================
-- SISTEMA DE RESET PARA EVITAR BUGS
-- ============================================================

local function safeReset()
	isResetting = true
	
	-- Resetar estado
	deselectAllButtons()
	hideAllPages()
	
	-- Redefinir HubBar
	HubBar = findDescendant(CoreGui, "HubBar")
	if HubBar then
		adjustHubBarWidth()
	end
	
	isResetting = false
end

-- ============================================================
-- CRIAÇÃO DE BOTÃO NO HUBBAR
-- ============================================================

local function createHubBarButton(name, icon)
	if not HubBarContainer then
		warn("[Library] HubBarContainer não encontrado")
		return nil
	end
	
	local button = Instance.new("TextButton")
	button.Name = name
	button.Selectable = false
	button.ZIndex = 3
	button.BackgroundTransparency = 1
	button.Text = ""
	button.Parent = HubBarContainer
	
	-- Calcular tamanho baseado no número de botões
	local buttonCount = countButtons()
	local buttonWidth = 1 / math.max(buttonCount, 1)
	button.Size = UDim2.new(buttonWidth, 0, 1, 0)
	
	-- TabSelection (indicador visual de seleção)
	local tabSelection = Instance.new("ImageLabel")
	tabSelection.Name = "TabSelection"
	tabSelection.ZIndex = 3
	tabSelection.BorderSizePixel = 0
	tabSelection.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	tabSelection.Size = UDim2.new(1, -2, 0, 2)
	tabSelection.Visible = false
	tabSelection.Position = UDim2.new(0, 3, 1, -2)
	tabSelection.Parent = button
	
	-- TabLabel (container do ícone e título)
	local tabLabel = Instance.new("Frame")
	tabLabel.Name = "TabLabel"
	tabLabel.ZIndex = 3
	tabLabel.BorderSizePixel = 0
	tabLabel.Size = UDim2.new(1, 0, 1, 0)
	tabLabel.BackgroundTransparency = 1
	tabLabel.Parent = button
	
	-- Layout
	local layout = Instance.new("UIListLayout")
	layout.Name = "Layout"
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Padding = UDim.new(0, 10)
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.Parent = tabLabel
	
	-- Ícone
	local iconLabel = Instance.new("TextLabel")
	iconLabel.Name = "Icon"
	iconLabel.TextWrapped = true
	iconLabel.ZIndex = 3
	iconLabel.TextTransparency = 0.5
	iconLabel.TextScaled = true
	iconLabel.FontFace = Font.new(
		"rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json",
		Enum.FontWeight.Regular,
		Enum.FontStyle.Normal
	)
	iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Size = UDim2.new(0, 24, 0, 24)
	iconLabel.Text = icon or "gear"
	iconLabel.Position = UDim2.new(0, 10, 0.5, -18)
	iconLabel.Parent = tabLabel
	
	local aspectRatio = Instance.new("UIAspectRatioConstraint")
	aspectRatio.Name = "AspectRatioConstraint"
	aspectRatio.Parent = iconLabel
	
	-- Título
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.ZIndex = 3
	titleLabel.TextSize = 19
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTransparency = 0.5
	titleLabel.FontFace = Font.new(
		"rbxasset://fonts/families/BuilderSans.json",
		Enum.FontWeight.Medium,
		Enum.FontStyle.Normal
	)
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = name
	titleLabel.AutomaticSize = Enum.AutomaticSize.XY
	titleLabel.Position = UDim2.new(1.2, 5, 0, -2)
	titleLabel.Parent = tabLabel
	
	-- Conectar clique
	button.MouseButton1Click:Connect(function()
		onTabClicked(button)
	end)
	
	return button
end

-- ============================================================
-- CRIAÇÃO DE PÁGINA (FRAME)
-- ============================================================

local function createPage(name)
	if not PageViewInnerFrame then
		warn("[Library] PageViewInnerFrame não encontrado")
		return nil
	end
	
	local page = Instance.new("Frame")
	page.Name = name
	page.ZIndex = 5
	page.AutomaticSize = Enum.AutomaticSize.Y
	page.Size = UDim2.new(1, 0, 0, 1174)
	page.Position = UDim2.new(0, 0, 0, 0)
	page.BackgroundTransparency = 1
	page.SelectionGroup = true
	page.Visible = false
	page.Parent = PageViewInnerFrame
	
	-- UIPadding
	local padding = Instance.new("UIPadding")
	padding.PaddingRight = UDim.new(0, 11)
	padding.PaddingLeft = UDim.new(0, 12)
	padding.Parent = page
	
	-- RowListLayout
	local layout = Instance.new("UIListLayout")
	layout.Name = "RowListLayout"
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = page
	
	return page
end

-- ============================================================
-- API PÚBLICA
-- ============================================================

function Library:CreateTab(config)
	config = config or {}
	local tabName = config.Name or "Tab"
	local tabIcon = config.Icon or "gear"
	
	-- Criar botão no HubBar
	local button = createHubBarButton(tabName, tabIcon)
	if not button then
		warn("[Library] Falha ao criar botão para tab: " .. tabName)
		return nil
	end
	
	-- Criar página correspondente
	local page = createPage(tabName)
	if not page then
		warn("[Library] Falha ao criar página para tab: " .. tabName)
		return nil
	end
	
	-- Criar objeto Tab
	local Tab = {
		Name = tabName,
		Icon = tabIcon,
		Button = button,
		Page = page,
		-- Placeholders para componentes futuros
		Toggle = nil,
		Slider = nil,
		Textbox = nil,
		Dropdown = nil,
		ColorPicker = nil,
		Keybind = nil,
		Label = nil,
		Paragraph = nil,
		Section = nil
	}
	
	-- Adicionar à lista de tabs
	table.insert(tabs, Tab)
	
	-- Se for a primeira tab, selecionar automaticamente
	if #tabs == 1 then
		task.wait(0.1)
		onTabClicked(button)
	end
	
	-- Ajustar largura do HubBar e tamanho dos botões
	task.wait(0.1)
	adjustHubBarWidth()
	
	print(string.format("[Library] Tab criada: %s (Ícone: %s)", tabName, tabIcon))
	
	return Tab
end

function Library:GetTabs()
	return tabs
end

function Library:GetActiveTab()
	return activeTab
end

-- Função para forçar atualização do layout
function Library:RefreshLayout()
	adjustHubBarWidth()
end

-- ============================================================
-- INICIALIZAÇÃO AUTOMÁTICA
-- ============================================================

local systemReady = false

task.spawn(function()
	systemReady = initializeSystem()
	
	if systemReady then
		-- Configurar monitoramento do SettingsShield
		setupSettingsShieldMonitor()
		
		-- Configurar ajuste automático do HubBar quando botões são adicionados/removidos
		if HubBarContainer then
			HubBarContainer.ChildAdded:Connect(function(child)
				if child:IsA("TextButton") or child:IsA("ImageButton") then
					task.wait(0.1)
					adjustHubBarWidth()
				end
			end)
			
			HubBarContainer.ChildRemoved:Connect(function(child)
				if child:IsA("TextButton") or child:IsA("ImageButton") then
					task.wait(0.1)
					adjustHubBarWidth()
				end
			end)
		end
		
		-- Monitorar adição de novos elementos no CoreGui
		CoreGui.DescendantAdded:Connect(function(descendant)
			if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
				task.wait(0.1)
				setupSettingsShieldMonitor()
			elseif descendant.Name == "HubBar" and descendant:IsA("ImageLabel") then
				HubBar = descendant
				task.wait(0.1)
				adjustHubBarWidth()
			end
		end)
		
		-- Sistema de heartbeat para manter o layout correto
		RunService.Heartbeat:Connect(function()
			-- Verificar periodicamente se o HubBar ainda está correto
			if not HubBar or not HubBar:IsDescendantOf(game) then
				HubBar = findDescendant(CoreGui, "HubBar")
				if HubBar then
					adjustHubBarWidth()
				end
			end
		end)
		
		print("[Library] Pronta para uso!")
	else
		warn("[Library] Falha na inicialização. Tente novamente mais tarde.")
	end
end)

-- ============================================================
-- RETORNO
-- ============================================================

return Library
