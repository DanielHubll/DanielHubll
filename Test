-- Helper para criar o container de um elemento (a "row" com fundo)
local function createElementContainer(parent, layoutOrder, height)
    height = height or 50

    local container = Instance.new("ImageButton", parent)
    container.Active = false
    container.BorderSizePixel = 0
    container.SliceCenter = Rect.new(2, 2, 18, 18)
    container.ScaleType = Enum.ScaleType.Slice
    container.AutoButtonColor = false
    container.ImageTransparency = 1
    container.BackgroundTransparency = 1
    container.BackgroundColor3 = Color3.fromRGB(36, 38, 40)
    container.ImageColor3 = Color3.fromRGB(36, 38, 40)
    container.Selectable = false
    container.ZIndex = 2
    container.Image = "rbxasset://textures/ui/VR/rectBackgroundWhite.png"
    container.Size = UDim2.new(0, 200, 0, height)
    container.LayoutOrder = layoutOrder
    container.Name = "Element_" .. layoutOrder

    local corner = Instance.new("UICorner", container)

    return container
end

-- Helper para criar label de título do elemento
local function createElementLabel(parent, text)
    local label = Instance.new("TextLabel", parent)
    label.TextWrapped = true
    label.ZIndex = 2
    label.TextSize = 17
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.FontFace = Font.new(
        "rbxasset://fonts/families/BuilderSans.json",
        Enum.FontWeight.Medium, Enum.FontStyle.Normal
    )
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.4, -20, 1, 0)
    label.Text = text
    label.AutomaticSize = Enum.AutomaticSize.Y
    label.Name = "Label"
    label.Position = UDim2.new(0, 10, 0, 0)

    local padding = Instance.new("UIPadding", label)
    padding.PaddingTop = UDim.new(0, 10)
    padding.PaddingBottom = UDim.new(0, 10)

    return label
end

