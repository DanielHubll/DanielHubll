local Library = {}

-- Serviços
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

-- Variáveis do sistema
local HubBarContainer = nil
local PageViewInnerFrame = nil
local HubBar = nil
local SettingsShield = nil
local tabs = {}
local activeTab = nil

-- Configurações CORRIGIDAS
local BASE_WIDTH = 800
local MIN_WIDTH = 300
local WIDTH_PER_BUTTON = 90  -- Reduzido para caber mais botões
local MAX_BUTTONS_DEFAULT = 5  -- Máximo de botões sem reduzir

-- ============================================================
-- FUNÇÕES UTILITÁRIAS
-- ============================================================

local function findDescendant(parent, name)
	for _, v in ipairs(parent:GetDescendants()) do
		if v.Name == name then
			return v
		end
	end
	return nil
end

local function waitForElement(parent, name, timeout)
	timeout = timeout or 10
	local startTime = tick()
	
	while tick() - startTime < timeout do
		local element = findDescendant(parent, name)
		if element then
			return element
		end
		task.wait(0.1)
	end
	
	return nil
end

-- ============================================================
-- SISTEMA DE INICIALIZAÇÃO
-- ============================================================

local function initializeSystem()
	-- Aguardar elementos principais
	HubBarContainer = waitForElement(CoreGui, "HubBarContainer", 15)
	PageViewInnerFrame = waitForElement(CoreGui, "PageViewInnerFrame", 15)
	HubBar = waitForElement(CoreGui, "HubBar", 15)
	
	if not HubBarContainer or not PageViewInnerFrame or not HubBar then
		warn("[Library] Não foi possível encontrar os elementos principais do CoreGui")
		return false
	end
	
	print("[Library] Sistema inicializado com sucesso!")
	return true
end

-- ============================================================
-- SISTEMA DE HUBBAR CORRIGIDO
-- ============================================================

local function countButtons()
	local count = 0
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") and child:IsDescendantOf(HubBarContainer) then
				count = count + 1
			end
		end
	end
	return count
end

-- Função para obter a largura total disponível do HubBar
local function getHubBarTotalWidth()
	if not HubBar or not HubBar:IsA("GuiObject") then
		return BASE_WIDTH
	end
	
	-- Verificar se o HubBar tem um tamanho definido pelo Roblox
	local absoluteSize = HubBar.AbsoluteSize
	if absoluteSize.X > 0 then
		return absoluteSize.X
	end
	
	return BASE_WIDTH
end

-- Função para calcular a largura ideal baseada no número de botões
local function calculateIdealWidth(buttonCount)
	if buttonCount <= MAX_BUTTONS_DEFAULT then
		return BASE_WIDTH
	end
	
	-- Cálculo mais preciso: espaço total = base + (botões extras * largura por botão)
	local extraButtons = buttonCount - MAX_BUTTONS_DEFAULT
	local additionalWidth = extraButtons * WIDTH_PER_BUTTON
	
	-- Se o HubBar original já for maior que o base, usar como referência
	local currentWidth = getHubBarTotalWidth()
	local baseReference = math.max(BASE_WIDTH, currentWidth)
	
	local idealWidth = baseReference + additionalWidth
	
	-- Limitar tamanho mínimo e máximo
	idealWidth = math.max(MIN_WIDTH, idealWidth)
	idealWidth = math.min(idealWidth, 2000) -- Limite máximo para não ficar muito grande
	
	return idealWidth
end

local function adjustHubBarWidth()
	if not HubBar or not HubBar:IsA("GuiObject") then
		HubBar = findDescendant(CoreGui, "HubBar")
		if not HubBar then
			return
		end
	end
	
	-- Verificar se o HubBar ainda é válido
	if not HubBar.Parent then
		HubBar = nil
		return
	end
	
	local buttonCount = countButtons()
	local idealWidth = calculateIdealWidth(buttonCount)
	
	-- Obter tamanho atual para comparação
	local currentSize = HubBar.Size
	local currentAbsoluteWidth = HubBar.AbsoluteSize.X
	
	-- Só ajustar se a diferença for significativa (evitar ajustes desnecessários)
	if math.abs(currentAbsoluteWidth - idealWidth) > 5 then
		-- Manter a escala Y e ajustar apenas o offset X
		HubBar.Size = UDim2.new(0, idealWidth, currentSize.Y.Scale, currentSize.Y.Offset)
		
		-- Também ajustar o HubBarContainer se necessário
		if HubBarContainer and HubBarContainer:IsA("GuiObject") then
			local containerSize = HubBarContainer.Size
			HubBarContainer.Size = UDim2.new(0, idealWidth, containerSize.Y.Scale, containerSize.Y.Offset)
		end
		
		print(string.format("[Library] HubBar ajustado: %d botões -> Largura: %dpx", buttonCount, idealWidth))
	end
end

-- Função para forçar o recálculo após mudanças
local function forceRecalculate()
	task.wait(0.05) -- Pequena espera para garantir que os elementos foram criados
	adjustHubBarWidth()
	
	-- Segundo ajuste após um tempo para garantir
	task.delay(0.5, function()
		adjustHubBarWidth()
	end)
end

-- ============================================================
-- SISTEMA DE SELEÇÃO VISUAL
-- ============================================================

local function deselectButton(button)
	if not button or not button.Parent then return end
	
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")
	
	if tabSelection then
		tabSelection.Visible = false
	end
	
	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0.5 end
		if title then title.TextTransparency = 0.5 end
	end
end

local function selectButton(button)
	if not button or not button.Parent then return end
	
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")
	
	if tabSelection then
		tabSelection.Visible = true
	end
	
	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0 end
		if title then title.TextTransparency = 0 end
	end
end

-- ============================================================
-- SISTEMA DE PÁGINAS
-- ============================================================

local function getPageForButton(button)
	if not PageViewInnerFrame then return nil end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name == button.Name then
			return child
		end
	end
	return nil
end

local function hideAllPages()
	if not PageViewInnerFrame then return end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") then
			child.Visible = false
		end
	end
end

local function showPage(page)
	if not page then return end
	hideAllPages()
	page.Visible = true
end

local function onTabClicked(clickedButton)
	if not clickedButton or not clickedButton.Parent then return end
	
	-- Controlar visual dos botões
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			if child == clickedButton then
				selectButton(child)
			else
				deselectButton(child)
			end
		end
	end
	
	-- Controlar visibilidade dos frames
	local correspondingPage = getPageForButton(clickedButton)
	if correspondingPage then
		showPage(correspondingPage)
		activeTab = clickedButton
	else
		warn("[Library] Página não encontrada para: " .. clickedButton.Name)
	end
end

-- ============================================================
-- SISTEMA DE SETTINGS SHIELD
-- ============================================================

local function deselectAllButtons()
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				deselectButton(child)
			end
		end
	end
	activeTab = nil
end

local function setupSettingsShieldMonitor()
	SettingsShield = findDescendant(CoreGui, "SettingsShield")
	
	if SettingsShield and SettingsShield:IsA("ImageButton") then
		print("[Library] SettingsShield encontrado! Monitorando...")
		
		if SettingsShield.Visible == false then
			deselectAllButtons()
			hideAllPages()
		end
		
		local connection
		connection = SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
			if SettingsShield.Visible == false then
				print("[Library] SettingsShield fechado - Desselecionando todas as abas")
				deselectAllButtons()
				hideAllPages()
			elseif SettingsShield.Visible == true then
				-- Quando o SettingsShield abrir, verificar se precisa reajustar
				forceRecalculate()
			end
		end)
		
		SettingsShield.AncestryChanged:Connect(function(_, parent)
			if not parent then
				print("[Library] SettingsShield removido - Procurando novamente...")
				connection:Disconnect()
				task.wait(0.5)
				setupSettingsShieldMonitor()
			end
		end)
	else
		print("[Library] SettingsShield não encontrado - Tentando em 1s...")
		task.wait(1)
		setupSettingsShieldMonitor()
	end
end

-- ============================================================
-- CRIAÇÃO DE BOTÃO NO HUBBAR
-- ============================================================

local function createHubBarButton(name, icon)
	if not HubBarContainer then
		warn("[Library] HubBarContainer não encontrado!")
		return nil
	end
	
	local button = Instance.new("TextButton")
	button.Name = name
	button.Selectable = false
	button.ZIndex = 3
	button.BackgroundTransparency = 1
	button.Size = UDim2.new(0, 100, 1, 0) -- Largura fixa para cada botão
	button.Text = ""
	button.Parent = HubBarContainer
	
	-- TabSelection (indicador visual de seleção)
	local tabSelection = Instance.new("ImageLabel")
	tabSelection.Name = "TabSelection"
	tabSelection.ZIndex = 3
	tabSelection.BorderSizePixel = 0
	tabSelection.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	tabSelection.Size = UDim2.new(1, -4, 0, 2)
	tabSelection.Visible = false
	tabSelection.Position = UDim2.new(0, 2, 1, -2)
	tabSelection.Parent = button
	
	-- TabLabel (container do ícone e título)
	local tabLabel = Instance.new("Frame")
	tabLabel.Name = "TabLabel"
	tabLabel.ZIndex = 3
	tabLabel.BorderSizePixel = 0
	tabLabel.Size = UDim2.new(1, 0, 1, 0)
	tabLabel.BackgroundTransparency = 1
	tabLabel.Parent = button
	
	-- Layout
	local layout = Instance.new("UIListLayout")
	layout.Name = "Layout"
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Padding = UDim.new(0, 8)
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.Parent = tabLabel
	
	-- Ícone
	local iconLabel = Instance.new("TextLabel")
	iconLabel.Name = "Icon"
	iconLabel.TextWrapped = true
	iconLabel.ZIndex = 3
	iconLabel.TextTransparency = 0.5
	iconLabel.TextScaled = true
	iconLabel.FontFace = Font.new(
		"rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json",
		Enum.FontWeight.Regular,
		Enum.FontStyle.Normal
	)
	iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Size = UDim2.new(0, 20, 0, 20)
	iconLabel.Text = icon or "gear"
	iconLabel.Parent = tabLabel
	
	local aspectRatio = Instance.new("UIAspectRatioConstraint")
	aspectRatio.Name = "AspectRatioConstraint"
	aspectRatio.Parent = iconLabel
	
	-- Título
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.ZIndex = 3
	titleLabel.TextSize = 16
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTransparency = 0.5
	titleLabel.FontFace = Font.new(
		"rbxasset://fonts/families/BuilderSans.json",
		Enum.FontWeight.Medium,
		Enum.FontStyle.Normal
	)
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = name
	titleLabel.AutomaticSize = Enum.AutomaticSize.XY
	titleLabel.Parent = tabLabel
	
	-- Conectar clique
	button.MouseButton1Click:Connect(function()
		onTabClicked(button)
	end)
	
	return button
end

-- ============================================================
-- CRIAÇÃO DE PÁGINA (FRAME)
-- ============================================================

local function createPage(name)
	if not PageViewInnerFrame then
		warn("[Library] PageViewInnerFrame não encontrado!")
		return nil
	end
	
	local page = Instance.new("Frame")
	page.Name = name
	page.ZIndex = 5
	page.AutomaticSize = Enum.AutomaticSize.Y
	page.Size = UDim2.new(1, 0, 0, 0)
	page.Position = UDim2.new(0, 0, 0, 0)
	page.BackgroundTransparency = 1
	page.SelectionGroup = true
	page.Visible = false
	page.Parent = PageViewInnerFrame
	
	-- UIPadding
	local padding = Instance.new("UIPadding")
	padding.PaddingRight = UDim.new(0, 12)
	padding.PaddingLeft = UDim.new(0, 12)
	padding.PaddingTop = UDim.new(0, 8)
	padding.PaddingBottom = UDim.new(0, 8)
	padding.Parent = page
	
	-- UIListLayout para organizar componentes futuros
	local layout = Instance.new("UIListLayout")
	layout.Name = "ContentLayout"
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, 4)
	layout.Parent = page
	
	return page
end

-- ============================================================
-- API PÚBLICA
-- ============================================================

function Library:CreateTab(config)
	config = config or {}
	local tabName = config.Name or "Tab"
	local tabIcon = config.Icon or "gear"
	
	-- Verificar se já existe uma tab com esse nome
	for _, existingTab in ipairs(tabs) do
		if existingTab.Name == tabName then
			warn("[Library] Já existe uma tab com o nome: " .. tabName)
			return existingTab
		end
	end
	
	-- Criar botão no HubBar
	local button = createHubBarButton(tabName, tabIcon)
	if not button then
		warn("[Library] Falha ao criar botão para: " .. tabName)
		return nil
	end
	
	-- Criar página correspondente
	local page = createPage(tabName)
	if not page then
		warn("[Library] Falha ao criar página para: " .. tabName)
		button:Destroy()
		return nil
	end
	
	-- Criar objeto Tab
	local Tab = {
		Name = tabName,
		Icon = tabIcon,
		Button = button,
		Page = page,
		-- Placeholders para componentes futuros
		Toggle = nil,
		Button = nil,
		Slider = nil,
		Textbox = nil,
		Dropdown = nil,
		ColorPicker = nil,
		Keybind = nil,
		Label = nil,
		Paragraph = nil,
		Section = nil
	}
	
	-- Adicionar à lista de tabs
	table.insert(tabs, Tab)
	
	-- Se for a primeira tab, selecionar automaticamente
	if #tabs == 1 then
		task.wait(0.1) -- Pequena espera para garantir que está tudo pronto
		onTabClicked(button)
	end
	
	-- Ajustar largura do HubBar com delay para garantir
	forceRecalculate()
	
	print(string.format("[Library] Tab criada: %s (Ícone: %s) - Total: %d tabs", tabName, tabIcon, #tabs))
	
	return Tab
end

function Library:GetTabs()
	return tabs
end

function Library:GetActiveTab()
	return activeTab
end

function Library:RemoveTab(tabName)
	for i, tab in ipairs(tabs) do
		if tab.Name == tabName then
			-- Remover botão
			if tab.Button and tab.Button.Parent then
				tab.Button:Destroy()
			end
			
			-- Remover página
			if tab.Page and tab.Page.Parent then
				tab.Page:Destroy()
			end
			
			-- Remover da lista
			table.remove(tabs, i)
			
			-- Se era a tab ativa, desselecionar
			if activeTab and activeTab.Name == tabName then
				deselectAllButtons()
				hideAllPages()
			end
			
			-- Reajustar HubBar
			forceRecalculate()
			
			print("[Library] Tab removida: " .. tabName)
			return true
		end
	end
	
	warn("[Library] Tab não encontrada para remover: " .. tabName)
	return false
end

-- ============================================================
-- INICIALIZAÇÃO AUTOMÁTICA
-- ============================================================

local systemReady = false

task.spawn(function()
	systemReady = initializeSystem()
	
	if systemReady then
		-- Configurar monitoramento do SettingsShield
		setupSettingsShieldMonitor()
		
		-- Configurar ajuste automático do HubBar
		if HubBarContainer then
			HubBarContainer.ChildAdded:Connect(function(child)
				if child:IsA("TextButton") then
					forceRecalculate()
				end
			end)
			
			HubBarContainer.ChildRemoved:Connect(function(child)
				if child:IsA("TextButton") then
					forceRecalculate()
				end
			end)
		end
		
		-- Monitorar redimensionamento da janela
		if HubBar then
			HubBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
				-- Recalcular quando a janela for redimensionada
				task.wait(0.1)
				adjustHubBarWidth()
			end)
		end
		
		-- Monitorar adição de novos elementos no CoreGui
		CoreGui.DescendantAdded:Connect(function(descendant)
			if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
				setupSettingsShieldMonitor()
			elseif descendant.Name == "HubBar" and descendant:IsA("ImageLabel") then
				HubBar = descendant
				forceRecalculate()
			elseif descendant.Name == "HubBarContainer" then
				HubBarContainer = descendant
				forceRecalculate()
			elseif descendant.Name == "PageViewInnerFrame" then
				PageViewInnerFrame = descendant
			end
		end)
		
		-- Verificação periódica para garantir que o HubBar está correto
		task.spawn(function()
			while true do
				task.wait(3)
				if HubBar and HubBar.Parent then
					adjustHubBarWidth()
				else
					HubBar = findDescendant(CoreGui, "HubBar")
				end
			end
		end)
		
		print("[Library] Pronta para uso!")
	else
		warn("[Library] Falha na inicialização. Tente novamente mais tarde.")
	end
end)

-- ============================================================
-- RETORNO
-- ============================================================

return Library
