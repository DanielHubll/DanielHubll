-- ============================================================
-- SISTEMA PRINCIPAL: SELEÇÃO DE ABAS + CONTROLE DE FRAMES
-- ============================================================

local function getPageForButton(button)
	if not PageViewInnerFrame then return nil end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name == button.Name then
			return child
		end
	end
	return nil
end

local function deselectButton(button)
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")

	if tabSelection then
		tabSelection.Visible = false
	end

	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0.5 end
		if title then title.TextTransparency = 0.5 end
	end
end

local function selectButton(button)
	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")

	if tabSelection then
		tabSelection.Visible = true
	end

	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0 end
		if title then title.TextTransparency = 0 end
	end
end

local function hideAllPages()
	if not PageViewInnerFrame then return end
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") then
			child.Visible = false
		end
	end
end

local function onTabClicked(clickedButton)
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			if child == clickedButton then
				selectButton(child)
			else
				deselectButton(child)
			end
		end
	end

	hideAllPages()

	local correspondingPage = getPageForButton(clickedButton)
	if correspondingPage then
		correspondingPage.Visible = true
		print("[SISTEMA] Mostrando frame: " .. correspondingPage.Name)
	else
		print("[AVISO] Nenhum frame encontrado para o botão: " .. clickedButton.Name)
	end
end

for _, child in ipairs(HubBarContainer:GetChildren()) do
	if child:IsA("TextButton") then
		child.MouseButton1Click:Connect(function()
			onTabClicked(child)
		end)
	end
end

HubBarContainer.ChildAdded:Connect(function(newChild)
	if newChild:IsA("TextButton") then
		newChild.MouseButton1Click:Connect(function()
			onTabClicked(newChild)
		end)
	end
end)


-- ============================================================
-- SISTEMA DO SETTINGS SHIELD
-- ============================================================

local function deselectAllButtons()
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				deselectButton(child)
			end
		end
	end
end

local function monitorSettingsShield()
	local SettingsShield = findDescendant(CoreGui, "SettingsShield")
	
	if SettingsShield and SettingsShield:IsA("ImageButton") then
		print("[SISTEMA] SettingsShield encontrado! Monitorando...")
		
		if SettingsShield.Visible == false then
			deselectAllButtons()
			hideAllPages()
		end
		
		local connection
		connection = SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
			if SettingsShield.Visible == false then
				print("[SISTEMA] SettingsShield ficou invisível - Desselecionando todos")
				deselectAllButtons()
				hideAllPages()
			end
		end)
		
		SettingsShield.AncestryChanged:Connect(function(_, parent)
			if not parent then
				print("[SISTEMA] SettingsShield removido - Procurando novamente...")
				connection:Disconnect()
				task.wait(0.5)
				monitorSettingsShield()
			end
		end)
	else
		print("[SISTEMA] SettingsShield não encontrado - Tentando em 1s...")
		task.wait(1)
		monitorSettingsShield()
	end
end

monitorSettingsShield()

CoreGui.DescendantAdded:Connect(function(descendant)
	if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
		print("[SISTEMA] SettingsShield detectado!")
		monitorSettingsShield()
	end
end)


-- ============================================================
-- SISTEMA DE AJUSTE AUTOMÁTICO DO HUBBAR
-- ============================================================

local HubBar = nil
local BASE_WIDTH = 800
local WIDTH_PER_BUTTON = 100

local function countButtons()
	local count = 0
	if HubBarContainer then
		for _, child in ipairs(HubBarContainer:GetChildren()) do
			if child:IsA("TextButton") then
				count = count + 1
			end
		end
	end
	return count
end

local function adjustHubBarWidth()
	local buttonCount = countButtons()
	
	if HubBar and HubBar:IsA("GuiObject") then
		if buttonCount > 5 then
			local extraButtons = buttonCount - 5
			local newWidth = BASE_WIDTH - (WIDTH_PER_BUTTON * extraButtons)
			if newWidth < 300 then newWidth = 300 end
			
			local currentSize = HubBar.Size
			HubBar.Size = UDim2.new(0, newWidth, currentSize.Y.Scale, currentSize.Y.Offset)
			print(string.format("[SISTEMA] HubBar: %d botões -> Largura: %d", buttonCount, newWidth))
		else
			local currentSize = HubBar.Size
			HubBar.Size = UDim2.new(0, BASE_WIDTH, currentSize.Y.Scale, currentSize.Y.Offset)
		end
	end
end

local function setupHubBar()
	HubBar = findDescendant(CoreGui, "HubBar")
	
	if HubBar and HubBar:IsA("ImageLabel") then
		print("[SISTEMA] HubBar encontrado!")
		adjustHubBarWidth()
		
		if HubBarContainer then
			HubBarContainer.ChildAdded:Connect(function(child)
				if child:IsA("TextButton") then
					task.wait(0.1)
					adjustHubBarWidth()
				end
			end)
			
			HubBarContainer.ChildRemoved:Connect(function(child)
				if child:IsA("TextButton") then
					task.wait(0.1)
					adjustHubBarWidth()
				end
			end)
		end
		
		task.spawn(function()
			while true do
				task.wait(2)
				if HubBar and HubBar.Parent then
					adjustHubBarWidth()
				else
					HubBar = nil
					setupHubBar()
					break
				end
			end
		end)
	else
		task.wait(1)
		setupHubBar()
	end
end

setupHubBar()

CoreGui.DescendantAdded:Connect(function(descendant)
	if descendant.Name == "HubBar" and descendant:IsA("ImageLabel") and not HubBar then
		print("[SISTEMA] HubBar detectado!")
		setupHubBar()
	end
end)

