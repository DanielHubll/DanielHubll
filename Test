    hexLabel.TextSize = 11
    hexLabel.BackgroundTransparency = 1
    hexLabel.Size = UDim2.new(0, 70, 0, 14)
    hexLabel.Position = UDim2.new(0, 0, 1, -18)
    hexLabel.TextXAlignment = Enum.TextXAlignment.Center
    hexLabel.Parent = colorPreview
    
    -- Variáveis
    local currentColor = default
    
    -- Função de atualização
    local function updateColor(color)
        currentColor = color
        colorPreview.BackgroundColor3 = color
        hexLabel.Text = string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
        callback(color)
        
        if flag then
            if saveSystem and saveSystem.SetFlag then
                saveSystem.SetFlag(flag, {color.R, color.G, color.B})
            end
        end
    end
    
    -- Criar popup de seleção de cores (simplificado)
    colorPreview.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Criar popup
            local popup = Instance.new("Frame")
            popup.Name = "ColorPopup"
            popup.BackgroundColor3 = COLORS.Background
            popup.Size = UDim2.new(0, 200, 0, 200)
            popup.Position = UDim2.new(0.5, 0, 0.5, 0)
            popup.AnchorPoint = Vector2.new(0.5, 0.5)
            popup.ZIndex = 1000
            popup.Parent = page
            
            addCorner(popup, ROUNDING.Medium)
            addStroke(popup)
            
            -- Background para fechar
            local bgClose = Instance.new("TextButton")
            bgClose.Name = "BackgroundClose"
            bgClose.Text = ""
            bgClose.BackgroundTransparency = 1
            bgClose.Size = UDim2.new(1, 0, 1, 0)
            bgClose.ZIndex = -1
            bgClose.Parent = popup
            
            -- Cores predefinidas
            local presetColors = {
                Color3.fromRGB(99, 102, 241),
                Color3.fromRGB(255, 99, 132),
                Color3.fromRGB(52, 211, 153),
                Color3.fromRGB(251, 191, 36),
                Color3.fromRGB(255, 255, 255),
                Color3.fromRGB(0, 0, 0),
                Color3.fromRGB(239, 68, 68),
                Color3.fromRGB(168, 85, 247),
                Color3.fromRGB(59, 130, 246)
            }
            
            -- Grid de cores
            local grid = Instance.new("UIGridLayout")
            grid.CellSize = UDim2.new(0, 40, 0, 40)
            grid.CellPadding = UDim2.new(0, 8, 0, 8)
            grid.HorizontalAlignment = Enum.HorizontalAlignment.Center
            grid.VerticalAlignment = Enum.VerticalAlignment.Center
            grid.Parent = popup
            
            -- Criar botões de cor
            for _, color in ipairs(presetColors) do
                local colorBtn = Instance.new("TextButton")
                colorBtn.Text = ""
                colorBtn.BackgroundColor3 = color
                colorBtn.AutoButtonColor = false
                colorBtn.ZIndex = 1001
                colorBtn.Parent = popup
                
                addCorner(colorBtn, UDim.new(1, 0))
                addStroke(colorBtn, Color3.fromRGB(255, 255, 255), 1)
                
                colorBtn.MouseButton1Click:Connect(function()
                    updateColor(color)
                    popup:Destroy()
                end)
            end
            
            -- Fechar ao clicar fora
            bgClose.MouseButton1Click:Connect(function()
                popup:Destroy()
            end)
        end
    end)
    
    local ColorPickerComponent = {
        Instance = colorFrame,
        Preview = colorPreview,
        Set = function(self, color)
            updateColor(color)
        end,
        Get = function(self)
            return currentColor
        end
    }
    
    return ColorPickerComponent
end

