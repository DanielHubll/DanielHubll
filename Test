local Library = {}
Library.__index = Library
Library.Tabs = {}
Library._tabsByName = {}

-- ================= SERVIÇOS =================
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

-- ================= UTIL =================
local function findDescendant(parent, name)
	for _, v in ipairs(parent:GetDescendants()) do
		if v.Name == name then
			return v
		end
	end
	return nil
end

local function waitForDescendant(parent, name, timeout)
	timeout = timeout or 15
	local start = os.clock()
	local obj = findDescendant(parent, name)
	while not obj and (os.clock() - start) < timeout do
		task.wait(0.1)
		obj = findDescendant(parent, name)
	end
	return obj
end

-- ================= ELEMENTOS BASE DO COREGUI =================
local RobloxGui = findDescendant(CoreGui, "RobloxGui")
local HubBarContainer = waitForDescendant(CoreGui, "HubBarContainer")
local PageViewInnerFrame = waitForDescendant(CoreGui, "PageViewInnerFrame")

if not RobloxGui then
	warn("[LuminaUI] RobloxGui não encontrado!")
	return setmetatable({}, Library)
end
if not HubBarContainer or not PageViewInnerFrame then
	warn("[LuminaUI] HubBarContainer/PageViewInnerFrame não encontrados!")
	return setmetatable({}, Library)
end

-- ============================================================
-- SISTEMA DE AJUSTE AUTOMÁTICO DO HUBBAR (largura dinâmica)
-- ============================================================

local HubBar = nil
local BASE_WIDTH = 800
local WIDTH_PER_BUTTON = 100
local MIN_WIDTH = 300
local IDEAL_BUTTONS = 5

local function countButtons()
	local count = 0
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			count = count + 1
		end
	end
	return count
end

-- ✅ FIX 2: largura proporcional ao nº de botões, sem partir sempre de 800
local function adjustHubBarWidth()
	if not (HubBar and HubBar:IsA("GuiObject")) then return end

	local buttonCount = countButtons()
	local newWidth

	if buttonCount <= IDEAL_BUTTONS then
		newWidth = WIDTH_PER_BUTTON * math.max(buttonCount, 1)
	else
		newWidth = math.max(MIN_WIDTH, BASE_WIDTH - (WIDTH_PER_BUTTON * (buttonCount - IDEAL_BUTTONS)))
	end

	local currentSize = HubBar.Size
	HubBar.Size = UDim2.new(0, newWidth, currentSize.Y.Scale, currentSize.Y.Offset)
	print(string.format("[LuminaUI] HubBar: %d botões -> Largura: %d", buttonCount, newWidth))
end

local function setupHubBar()
	HubBar = findDescendant(CoreGui, "HubBar")

	if HubBar and HubBar:IsA("ImageLabel") then
		print("[LuminaUI] HubBar encontrado!")

		-- ✅ FIX 3: esconde durante o ajuste para evitar deformação visual
		HubBar.Visible = false

		-- ✅ FIX 1: força largura mínima antes de calcular o valor real
		HubBar.Size = UDim2.new(0, 1, HubBar.Size.Y.Scale, HubBar.Size.Y.Offset)
		adjustHubBarWidth()

		task.wait() -- aguarda 1 frame
		HubBar.Visible = true -- mostra já com o tamanho correto

		HubBarContainer.ChildAdded:Connect(function(child)
			if child:IsA("TextButton") then
				task.wait(0.1)
				adjustHubBarWidth()
			end
		end)

		HubBarContainer.ChildRemoved:Connect(function(child)
			if child:IsA("TextButton") then
				task.wait(0.1)
				adjustHubBarWidth()
			end
		end)

		task.spawn(function()
			while true do
				task.wait(2)
				if HubBar and HubBar.Parent then
					adjustHubBarWidth()
				else
					HubBar = nil
					setupHubBar()
					break
				end
			end
		end)
	else
		task.delay(1, setupHubBar)
	end
end
setupHubBar()

CoreGui.DescendantAdded:Connect(function(descendant)
	if descendant.Name == "HubBar" and descendant:IsA("ImageLabel") and not HubBar then
		print("[LuminaUI] HubBar detectado dinamicamente!")
		setupHubBar()
	end
end)

-- ============================================================
-- SISTEMA DE SELEÇÃO / DESSELEÇÃO DE ABAS (via atributos)
-- ============================================================

local function deselectButton(button)
	button:SetAttribute("Selected", false)

	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")

	if tabSelection then
		tabSelection.Visible = false
	end

	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0.5 end
		if title then title.TextTransparency = 0.5 end
	end
end

local function selectButtonVisual(button)
	button:SetAttribute("Selected", true)

	local tabSelection = button:FindFirstChild("TabSelection")
	local tabLabel = button:FindFirstChild("TabLabel")

	if tabSelection then
		tabSelection.Visible = true
	end

	if tabLabel then
		local icon = tabLabel:FindFirstChild("Icon")
		local title = tabLabel:FindFirstChild("Title")
		if icon then icon.TextTransparency = 0 end
		if title then title.TextTransparency = 0 end
	end
end

local function hideAllPages()
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") then
			child.Visible = false
		end
	end
end

local function deselectAllButtons()
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			deselectButton(child)
		end
	end
end

local function getPageForButton(button)
	for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name == button.Name then
			return child
		end
	end
	return nil
end

local function selectTabInternal(clickedButton)
	for _, child in ipairs(HubBarContainer:GetChildren()) do
		if child:IsA("TextButton") then
			if child == clickedButton then
				selectButtonVisual(child)
			else
				deselectButton(child)
			end
		end
	end

	hideAllPages()

	local page = getPageForButton(clickedButton)
	if page then
		page.Visible = true
		print("[LuminaUI] Aba selecionada: " .. page.Name)
	end
end

local function bindTabButtonEvents(button)
	button.MouseButton1Click:Connect(function()
		selectTabInternal(button)
	end)
end

for _, child in ipairs(HubBarContainer:GetChildren()) do
	if child:IsA("TextButton") then
		bindTabButtonEvents(child)
	end
end

HubBarContainer.ChildAdded:Connect(function(newChild)
	if newChild:IsA("TextButton") then
		bindTabButtonEvents(newChild)
	end
end)

-- ============================================================
-- MONITORAMENTO DO SETTINGS SHIELD
-- ============================================================

local function monitorSettingsShield()
	local SettingsShield = findDescendant(CoreGui, "SettingsShield")

	if SettingsShield and SettingsShield:IsA("ImageButton") then
		print("[LuminaUI] SettingsShield encontrado! Monitorando...")

		if SettingsShield.Visible == false then
			deselectAllButtons()
			hideAllPages()
		end

		local connection
		connection = SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
			if SettingsShield.Visible == false then
				deselectAllButtons()
				hideAllPages()
			end
		end)

		SettingsShield.AncestryChanged:Connect(function(_, parent)
			if not parent then
				connection:Disconnect()
				task.wait(0.5)
				monitorSettingsShield()
			end
		end)
	else
		task.wait(1)
		monitorSettingsShield()
	end
end
monitorSettingsShield()

CoreGui.DescendantAdded:Connect(function(descendant)
	if descendant.Name == "SettingsShield" and descendant:IsA("ImageButton") then
		monitorSettingsShield()
	end
end)

