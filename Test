        config = { Name = config, Default = false, Callback = function() end }
    end

    self.ElementCount = self.ElementCount + 1
    local order = self.ElementCount * 10

    local container = createElementContainer(self.Page, order, 50)
    container.Name = config.Name or "Toggle_" .. order

    local label = createElementLabel(container, config.Name or "Toggle")

    -- Selector Frame
    local selector = Instance.new("ImageButton", container)
    selector.AutoButtonColor = false
    selector.BackgroundTransparency = 1
    selector.ZIndex = 2
    selector.AnchorPoint = Vector2.new(1, 0.5)
    selector.Size = UDim2.new(0.6, 0, 0, 50)
    selector.Name = "Selector"
    selector.Position = UDim2.new(1, 0, 0.5, 0)

    -- Left Button
