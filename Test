	end)
	
	-- Efeito Click
	buttonInner.MouseButton1Down:Connect(function()
		buttonInner.BackgroundColor3 = PRESSED_BG
		buttonBorder.Transparency = 0.5
	end)
	
	buttonInner.MouseButton1Up:Connect(function()
		buttonInner.BackgroundColor3 = HOVER_BG
		buttonBorder.Transparency = 0.3
	end)
	
	-- Ação do clique
	buttonInner.MouseButton1Click:Connect(function()
		print("Button clicked!")
		print("Button Teste foi pressionado!")
	end)
	
	print("Sistema de Button iniciado!")
end


