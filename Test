		-- trilho
		local TrailBg = Instance.new("Frame")
		TrailBg.Size = UDim2.new(1, -56, 0, 6)
		TrailBg.Position = UDim2.new(0, 20, 0.5, -3)
		TrailBg.BackgroundColor3 = Color3.fromRGB(55, 58, 65)
		TrailBg.BorderSizePixel = 0
		TrailBg.ZIndex = 11
		Instance.new("UICorner").Parent = TrailBg
		TrailBg.Parent = Row

		local function ratio255(v) return v / 255 end

		local TrailFill = Instance.new("Frame")
		TrailFill.Size = UDim2.new(ratio255(chVal), 0, 1, 0)
		TrailFill.BackgroundColor3 = channelColors[chName]
		TrailFill.BorderSizePixel = 0
		TrailFill.ZIndex = 12
		Instance.new("UICorner").Parent = TrailFill
		TrailFill.Parent = TrailBg

		local Handle = Instance.new("Frame")
		Handle.Size = UDim2.new(0, 12, 0, 12)
		Handle.AnchorPoint = Vector2.new(0.5, 0.5)
		Handle.Position = UDim2.new(ratio255(chVal), 0, 0.5, 0)
		Handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		Handle.BorderSizePixel = 0
		Handle.ZIndex = 13
		Instance.new("UICorner").Parent = Handle
		Handle.Parent = TrailBg

		-- valor numérico
		local ChValLabel = Instance.new("TextLabel")
		ChValLabel.BackgroundTransparency = 1
		ChValLabel.Size = UDim2.new(0, 32, 1, 0)
		ChValLabel.Position = UDim2.new(1, -32, 0, 0)
		ChValLabel.Text = tostring(chVal)
		ChValLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
		ChValLabel.FontFace = Font.new("rbxasset://fonts/families/BuilderSans.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
		ChValLabel.TextSize = 13
		ChValLabel.ZIndex = 11
		ChValLabel.TextXAlignment = Enum.TextXAlignment.Right
		ChValLabel.Parent = Row

		sliderRefs[chName] = { fill = TrailFill, handle = Handle, valLabel = ChValLabel }

		local dragging = false
		local function applyDrag(absX)
			local t = math.clamp((absX - TrailBg.AbsolutePosition.X) / TrailBg.AbsoluteSize.X, 0, 1)
			local v = math.round(t * 255)
			channelVals[chName] = v
			TrailFill.Size = UDim2.new(t, 0, 1, 0)
			Handle.Position = UDim2.new(t, 0, 0.5, 0)
			ChValLabel.Text = tostring(v)
			rebuildColor()
		end

		TrailBg.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				applyDrag(i.Position.X)
			end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
				applyDrag(i.Position.X)
			end
		end)
		UserInputService.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end

	local function openPanel()  isOpen = true  Panel.Visible = true  Arrow.Text = "▲" end
	local function closePanel() isOpen = false Panel.Visible = false Arrow.Text = "▼" end

	Header.MouseButton1Click:Connect(function()
		if isOpen then closePanel() else openPanel() end
	end)

	local obj = { Wrapper = Wrapper, Value = Value }
	function obj:Set(color)
		channelVals.R = math.round(color.R * 255)
		channelVals.G = math.round(color.G * 255)
		channelVals.B = math.round(color.B * 255)
