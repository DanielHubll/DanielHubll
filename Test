    -- Close
    CloseBtn.MouseButton1Click:Connect(function()
        U.Tween(Main, { BackgroundTransparency = 1, Size = UDim2.new(0,_origSize.X.Offset,0,0) }, 0.2)
        task.delay(0.22, function() pcall(function() SG:Destroy() end) end)
