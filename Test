local Library = {}

-- Serviços Principais
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Função auxiliar para varredura profunda de elementos
local function findDescendant(parent, name)
    for _, v in ipairs(parent:GetDescendants()) do
        if v.Name == name then
            return v
        end
    end
    return nil
end

-- Contêineres nativos do Roblox do menu CoreGui
local HubBarContainer = findDescendant(CoreGui, "HubBarContainer")
local PageViewInnerFrame = findDescendant(CoreGui, "PageViewInnerFrame")

-- ============================================================
-- SISTEMA 1: REDIMENSIONAMENTO DINÂMICO DO HUBBAR
-- ============================================================
local HubBar = nil
local BASE_WIDTH = 800
local WIDTH_PER_BUTTON = 100

local function countButtons()
    local count = 0
    if HubBarContainer then
        for _, child in ipairs(HubBarContainer:GetChildren()) do
            if child:IsA("TextButton") then
                count = count + 1
            end
        end
    end
    return count
end

local function adjustHubBarWidth()
    local buttonCount = countButtons()
    if HubBar and HubBar:IsA("GuiObject") then
        -- Se passar de 5 botões na barra, começa a reduzir proporcionalmente
        if buttonCount > 5 then
            local extraButtons = buttonCount - 5
            local newWidth = BASE_WIDTH - (WIDTH_PER_BUTTON * extraButtons)
            if newWidth < 300 then newWidth = 300 end -- Trava de segurança mínima
            HubBar.Size = UDim2.new(0, newWidth, HubBar.Size.Y.Scale, HubBar.Size.Y.Offset)
        else
            HubBar.Size = UDim2.new(0, BASE_WIDTH, HubBar.Size.Y.Scale, HubBar.Size.Y.Offset)
        end
    end
end

-- Loop persistente agressivo (Roblox recria o HubBar em tempo de execução)
task.spawn(function()
    while true do
        task.wait(0.2)
        if not HubBar or not HubBar.Parent then
            HubBar = findDescendant(CoreGui, "HubBar")
        end
        if HubBar then
            adjustHubBarWidth()
        end
    end
end)

-- Captura instantânea de recriação via CoreGui
CoreGui.DescendantAdded:Connect(function(v)
    if v.Name == "HubBar" and v:IsA("ImageLabel") then
        HubBar = v
        adjustHubBarWidth()
    end
end)

-- Conexões de contagem quando botões entram/saem
if HubBarContainer then
    HubBarContainer.ChildAdded:Connect(function(child)
        if child:IsA("TextButton") then task.wait(0.1) adjustHubBarWidth() end
    end)
    HubBarContainer.ChildRemoved:Connect(function(child)
        if child:IsA("TextButton") then task.wait(0.1) adjustHubBarWidth() end
    end)
end

-- ============================================================
-- SISTEMA 2: GERENCIAMENTO DE ABAS E ANTI-MULTI SELEÇÃO GLOBAL
-- ============================================================
local CurrentSelectedTab = nil

local function deselectButton(button)
    if not button then return end
    local tabSelection = button:FindFirstChild("TabSelection")
    local tabLabel = button:FindFirstChild("TabLabel")
    if tabSelection then tabSelection.Visible = false end
    if tabLabel then
        local icon = tabLabel:FindFirstChild("Icon")
        local title = tabLabel:FindFirstChild("Title")
        if icon then icon.TextTransparency = 0.5 end
        if title then title.TextTransparency = 0.5 end
    end
end

local function selectButton(button)
    if not button then return end
    local tabSelection = button:FindFirstChild("TabSelection")
    local tabLabel = button:FindFirstChild("TabLabel")
    if tabSelection then tabSelection.Visible = true end
    if tabLabel then
        local icon = tabLabel:FindFirstChild("Icon")
        local title = tabLabel:FindFirstChild("Title")
        if icon then icon.TextTransparency = 0 end
        if title then title.TextTransparency = 0 end
    end
end

local function hideAllPages()
    if not PageViewInnerFrame then return end
    for _, child in ipairs(PageViewInnerFrame:GetChildren()) do
        if child:IsA("Frame") then child.Visible = false end
    end
end

local function selectTab(tab)
    if CurrentSelectedTab and CurrentSelectedTab ~= tab then
        deselectButton(CurrentSelectedTab)
    end

    CurrentSelectedTab = tab
    selectButton(tab)
    hideAllPages()

    if PageViewInnerFrame then
        local page = PageViewInnerFrame:FindFirstChild(tab.Name)
        if page then
            page.Visible = true
        end
    end
end

-- Escuta global de cliques (Varre botões da Library, Roblox e outros scripts)
if HubBarContainer then
    for _, child in ipairs(HubBarContainer:GetChildren()) do
        if child:IsA("TextButton") then
            child.MouseButton1Click:Connect(function()
                selectTab(child)
            end)
        end
    end

    HubBarContainer.ChildAdded:Connect(function(child)
        if child:IsA("TextButton") then
            child.MouseButton1Click:Connect(function()
                selectTab(child)
            end)
        end
    end)
end

-- ============================================================
-- SISTEMA 3: SINAL DE FECHAMENTO (SettingsShield)
-- ============================================================
local function monitorSettingsShield()
    local SettingsShield = findDescendant(CoreGui, "SettingsShield")
    if SettingsShield and SettingsShield:IsA("ImageButton") then
        if SettingsShield.Visible == false then
            if CurrentSelectedTab then deselectButton(CurrentSelectedTab) end
            hideAllPages()
        end
        SettingsShield:GetPropertyChangedSignal("Visible"):Connect(function()
            if SettingsShield.Visible == false then
                if CurrentSelectedTab then deselectButton(CurrentSelectedTab) end
                hideAllPages()
            end
        end)
    else
        task.wait(1)
        monitorSettingsShield()
    end
end
task.spawn(monitorSettingsShield)

