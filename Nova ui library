            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Parent = page,
        })

        local pageLayout = Instance.new("UIListLayout")
        pageLayout.Padding = UDim.new(0, 10)
        pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        pageLayout.Parent = pageScroll

        -- Botão da tab na sidebar
        local tabButton = Utils.Create("TextButton", {
            Name = "Tab_" .. tabName,
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Theme.BackgroundLight,
            BackgroundTransparency = 1,
            Text = "",
            AutoButtonColor = false,
            Parent = tabsContainer,
        })
        Utils.RoundCorners(tabButton, 8)

        local tabIcon = Utils.Create("TextLabel", {
            Size = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(0, 10, 0.5, -12),
            BackgroundTransparency = 1,
            Text = icon,
            TextColor3 = Theme.TextDim,
            TextSize = 14,
            Font = Enum.Font.GothamBold,
            Parent = tabButton,
        })

        local tabLabel = Utils.Create("TextLabel", {
            Size = UDim2.new(1, -50, 1, 0),
            Position = UDim2.new(0, 40, 0, 0),
            BackgroundTransparency = 1,
            Text = tabName,
            TextColor3 = Theme.TextDim,
            TextSize = 13,
            Font = Enum.Font.GothamMedium,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = tabButton,
        })

        local tabIndicator = Utils.Create("Frame", {
            Size = UDim2.new(0, 3, 0, 0),
            Position = UDim2.new(0, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5),
            BackgroundColor3 = Theme.Accent,
            Parent = tabButton,
        })
        Utils.RoundCorners(tabIndicator, 4)

        local tabData = {
            button = tabButton,
            page = page,
            indicator = tabIndicator,
            label = tabLabel,
            icon = tabIcon,
        }
        table.insert(tabs, tabData)

        -- Selecionar tab
        local function selectTab()
            for _, t in ipairs(tabs) do
                t.page.Visible = false
                Utils.Tween(t.indicator, 0.2, nil, nil, {Size = UDim2.new(0, 3, 0, 0)})
                Utils.Tween(t.label, 0.2, nil, nil, {TextColor3 = Theme.TextDim})
                Utils.Tween(t.icon, 0.2, nil, nil, {TextColor3 = Theme.TextDim})
                Utils.Tween(t.button, 0.2, nil, nil, {BackgroundColor3 = Theme.BackgroundLight, BackgroundTransparency = 1})
