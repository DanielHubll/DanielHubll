                local optBtn = Make("TextButton", { Size = UDim2.new(1, 0, 0, 34), Text = "  " .. optName, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, AutoButtonColor = false, ZIndex = 101, LayoutOrder = i, Parent = dropFrame })
                optBtn.MouseButton1Click:Connect(function()
                    selected = optVal; valLabel.Text = optName; pcall(callback, optVal, optName); isOpen = false;
                    Tween(chevron, 0.2, { Rotation = 0 }); Tween(dropFrame, 0.2, { Size = UDim2.new(1, -28, 0, 0) })
                    task.delay(0.2, function() dropFrame.Visible = false; row.Size = UDim2.new(1, 0, 0, 48) end)
                end)
