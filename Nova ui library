        -- ═══ MULTI TOGGLE ═══
        function sec:AddMultiToggle(text, options, cb)
            cb = cb or function() end
            local states = {}
            for _, o in ipairs(options) do states[o] = false end

            local wrap = New("Frame", {
                Size = UDim2.new(1, -12, 0, 22 + (#options * 26)),
                Position = UDim2.new(0, 6, 0, 0),
                BackgroundTransparency = 1,
                LayoutOrder = sec.N,
                Parent = sec.Frame
            })
            sec.N = sec.N + 1

            New("TextLabel", {
                Size = UDim2.new(1, -8, 0, 16),
                Position = UDim2.new(0, 4, 0, 2),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 12,
                Font = Cfg.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = wrap
            })

            local boxes = {}

            for i, opt in ipairs(options) do
                local row = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0, 0, 0, 20 + (i-1) * 24),
                    BackgroundTransparency = 1,
                    Parent = wrap
                })

                local box = New("Frame", {
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(0, 10, 0.5, -8),
                    BackgroundColor3 = Theme.ToggleOff,
                    Parent = row
                })
                Rnd(box, Cfg.RadiusXs)
                Str(box, Theme.Border, 1)

                local check = Icons.Check(box, 10, Theme.Bg)
                check.Position = UDim2.new(0.5, -5, 0.5, -5)
                check.Visible = false
                boxes[opt] = {box = box, check = check}

                New("TextLabel", {
                    Size = UDim2.new(1, -36, 1, 0),
                    Position = UDim2.new(0, 32, 0, 0),
                    BackgroundTransparency = 1,
                    Text = opt,
                    TextColor3 = Theme.TextSec,
                    TextSize = 11,
                    Font = Cfg.Font,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = row
                })

                local btn = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = row
                })

                btn.MouseButton1Click:Connect(function()
                    states[opt] = not states[opt]
                    local st = states[opt]
                    Tw(box, {BackgroundColor3 = st and Theme.Accent or Theme.ToggleOff}, 0.15)
                    Tw(box:FindFirstChild("UIStroke"), {Color = st and Theme.Accent or Theme.Border}, 0.15)
                    check.Visible = st
                    task.spawn(cb, states, opt)
                end)
            end

            return {
                GetStates = function() return states end,
                SetState = function(_, opt, val)
                    states[opt] = val
                    local b = boxes[opt]
                    if b then
                        Tw(b.box, {BackgroundColor3 = val and Theme.Accent or Theme.ToggleOff}, 0.15)
                        b.check.Visible = val
                    end
                end
            }
        end

