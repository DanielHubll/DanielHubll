-- CONNECTION TRACKER
-- ═══════════════════════════════════════════════════════════════════
local AllConnections = {}

local function Track(conn)
    table.insert(AllConnections, conn)
    return conn
end

local function DisconnectAll()
    for _, c in ipairs(AllConnections) do
        if c and c.Connected then
            c:Disconnect()
        end
    end
    AllConnections = {}
end

