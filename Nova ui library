			})
			Corner(Card, 12)
			Stroke(Card, Theme.Border, 1)
			Pad(Card, IsMobile and 10 or 14, IsMobile and 10 or 14, IsMobile and 10 or 14, IsMobile and 10 or 14)

			New("TextLabel", {
				Text = title or "Seção",
				Font = FontBold,
				TextSize = IsMobile and 13 or 14,
				TextColor3 = Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -30, 0, 18),
				Parent = Card,
			})
			New("TextLabel", {
				Text = desc or "Clique para expandir ou recolher",
				Font = FontRegular,
				TextSize = IsMobile and 11 or 12,
				TextColor3 = Theme.SubText,
				TextXAlignment = Enum.TextXAlignment.Left,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -30, 0, 16),
				Position = UDim2.new(0, 0, 0, 20),
				Parent = Card,
			})

			local Chevron = New("ImageLabel", {
				Image = GetIcon("chevron-down"),
				ImageColor3 = Theme.SubText,
				BackgroundTransparency = 1,
				Size = UDim2.new(0, 16, 0, 16),
				Position = UDim2.new(1, -16, 0, 2),
				Parent = Card,
			})

			local InnerHolder = New("Frame", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				Position = UDim2.new(0, 0, 0, IsMobile and 38 or 44),
				Parent = Card,
			})
			New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = InnerHolder })

			local Click = New("TextButton", {
				Text = "",
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, IsMobile and 38 or 44),
				ZIndex = 5,
				Parent = Card,
			})

			Click.MouseButton1Click:Connect(function()
				expanded = not expanded
				Tween(Chevron, { Rotation = expanded and 180 or 0 }, 0.2)
				if expanded then
					task.wait()
					Tween(Card, { Size = UDim2.new(1, 0, 0, (IsMobile and 38 or 44) + InnerHolder.AbsoluteSize.Y + 14) }, 0.2)
				else
					Tween(Card, { Size = UDim2.new(1, 0, 0, IsMobile and 54 or 60) }, 0.2)
				end
			end)

			local Section = { Holder = InnerHolder }
			return Section
		end

		----------------------------------------------------------------
		function Tab:CreateLabel(text)
			local Card = New("Frame", {
				BackgroundColor3 = Theme.Card,
				Size = UDim2.new(1, 0, 0, IsMobile and 80 or 100),
				LayoutOrder = nextOrder(),
				Parent = Grid,
			})
			Corner(Card, 12)
			Stroke(Card, Theme.Border, 1)
			Pad(Card, IsMobile and 10 or 14, IsMobile and 10 or 14, IsMobile and 10 or 14, IsMobile and 10 or 14)
			New("TextLabel", {
				Text = text or "",
				Font = FontRegular,
				TextSize = IsMobile and 12 or 13,
				TextColor3 = Theme.SubText,
				TextWrapped = true,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Top,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 1, 0),
				Parent = Card,
			})
			return Card
		end

		-- register tab switching
		TabButton.MouseButton1Click:Connect(function()
			CloseDropdown()
			for _, t in pairs(Window.Tabs) do
				t.Page.Visible = false
				Tween(t.Button, { BackgroundTransparency = 1 }, 0.15)
				local lbl = t.Button:FindFirstChild("Label")
				local ic = t.Button:FindFirstChild("Icon")
				if lbl then lbl.TextColor3 = Theme.SubText end
				if ic then ic.ImageColor3 = Theme.SubText end
			end
			Page.Visible = true
			Tween(TabButton, { BackgroundTransparency = 0.85 }, 0.15)
			local lbl = TabButton:FindFirstChild("Label")
			local ic = TabButton:FindFirstChild("Icon")
			if lbl then lbl.TextColor3 = Theme.Text end
			if ic then ic.ImageColor3 = Theme.AccentLight end
		end)

		Window.Tabs[#Window.Tabs + 1] = Tab
		if not firstTab then
			firstTab = Tab
		end

		return Tab
	end

	-- select first tab automatically after creation
	task.defer(function()
		if firstTab then
			firstTab.Page.Visible = true
			Tween(firstTab.Button, { BackgroundTransparency = 0.85 }, 0.01)
			local lbl = firstTab.Button:FindFirstChild("Label")
			local ic = firstTab.Button:FindFirstChild("Icon")
			if lbl then lbl.TextColor3 = Theme.Text end
			if ic then ic.ImageColor3 = Theme.AccentLight end
		end
	end)

	if SearchBox then
		SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
			local query = SearchBox.Text:lower()
			for _, t in ipairs(Window.Tabs) do
				if t.Page.Visible then
					for _, card in ipairs(t.Grid:GetChildren()) do
						if card:IsA("Frame") then
							local titleLbl = card:FindFirstChildWhichIsA("TextLabel")
							if titleLbl then
								local match = query == "" or titleLbl.Text:lower():find(query, 1, true)
								card.Visible = match and true or false
							end
						end
					end
				end
			end
		end)
	end

	return Window
end

