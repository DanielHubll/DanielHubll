                        if chDragging then
                            updateCh(input.Position.X)
                        end
                    end)
                    UserInputService.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            chDragging = false
                        end
                    end)

                    sliders[i] = {fill = chFill, label = chValue}
                end

                colorPreview.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        colorPopup.Visible = not colorPopup.Visible
                    end
                end)

                return {
                    Set = function(self, color)
                        currentColor = color
                        values = {math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)}
                        colorPreview.BackgroundColor3 = color
                        for i, s in ipairs(sliders) do
                            s.fill.Size = UDim2.new(values[i]/255, 0, 1, 0)
                            s.label.Text = tostring(values[i])
                        end
                        task.spawn(callback, color)
                    end,
                    Get = function(self)
                        return currentColor
                    end,
                }
            end

            -- ──────────────────────────────
            --  LABEL
            -- ──────────────────────────────
            function Section:AddLabel(config)
                local lConfig = type(config) == "string" and {Text = config} or config or {}
                local text = lConfig.Text or "Label"
                local size = lConfig.Size or 13
                local color = lConfig.Color or Theme.TextDim
                local bold = lConfig.Bold or false

                local label = Utils.Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, size + 6),
                    BackgroundTransparency = 1,
                    Text = text,
                    TextColor3 = color,
                    TextSize = size,
                    Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    Parent = sectionContent,
                })

                return {
                    Set = function(self, newText)
                        label.Text = newText
                    end,
                }
            end

            -- ──────────────────────────────
            --  SEPARATOR
            -- ──────────────────────────────
            function Section:AddSeparator()
                local sep = Utils.Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = Theme.SectionBorder,
                    Parent = sectionContent,
                })
            end

            return Section
        end

        return Tab
    end

    Window.ScreenGui = ScreenGui

    return Window
end

