-- UTILITY MODULE
-- ═══════════════════════════════════════════════════════════════════
local Utility = {}
Utility.Connections = {}
Utility.Instances = {}

--- Cria uma instância com propriedades
function Utility.CreateInstance(className, properties, parent)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        if prop ~= "Parent" then
            instance[prop] = value
        end
    end
    if parent then
        instance.Parent = parent
    elseif properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    table.insert(Utility.Instances, instance)
    return instance
end

--- Conecta um evento e armazena a conexão
function Utility.Connect(event, callback, tag)
    local connection = event:Connect(callback)
    table.insert(Utility.Connections, {
        Connection = connection,
        Tag = tag or "default"
    })
    return connection
end

--- Desconecta todas as conexões de uma tag
function Utility.DisconnectAll(tag)
    for i = #Utility.Connections, 1, -1 do
        local conn = Utility.Connections[i]
        if conn.Tag == tag or not tag then
            conn.Connection:Disconnect()
            table.remove(Utility.Connections, i)
        end
    end
end

--- Destrói todas as instâncias criadas
function Utility.DestroyAll()
    for _, instance in ipairs(Utility.Instances) do
        if instance and instance.Parent then
            instance:Destroy()
        end
    end
    Utility.Instances = {}
    Utility.DisconnectAll()
end

--- Debounce system
function Utility.Debounce(func, delay)
    local lastCall = 0
    return function(...)
        local now = tick()
        if now - lastCall >= delay then
            lastCall = now
            return func(...)
        end
    end
end

--- Throttle system
function Utility.Throttle(func, limit)
    local lastRun = 0
    return function(...)
        local now = tick()
        if now - lastRun >= limit then
            lastRun = now
            return func(...)
        end
    end
end

--- Gera um ID único
function Utility.GenerateId()
    return HttpService:GenerateGUID(false):sub(1, 8)
end

--- Verifica se é dispositivo mobile
function Utility.IsMobile()
    return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

--- Obtém o viewport size atual
function Utility.GetViewportSize()
    return Camera.ViewportSize
end

--- Clamp de posição dentro da tela
function Utility.ClampToScreen(position, size)
    local viewport = Utility.GetViewportSize()
    local x = math.clamp(position.X, 0, math.max(0, viewport.X - size.X))
    local y = math.clamp(position.Y, 0, math.max(0, viewport.Y - size.Y))
    return UDim2.fromOffset(x, y)
end

-- ═══════════════════════════════════════════════════════════════════
-- TWEEN ENGINE (Wrapper otimizado)
-- ═══════════════════════════════════════════════════════════════════
local TweenEngine = {}
TweenEngine.ActiveTweens = {}

--- Cria uma animação tween suave
function TweenEngine.Create(instance, duration, properties, style, direction, easing)
    if not instance or not instance.Parent then return end

    -- Cancela tweens anteriores do mesmo objeto
    local key = tostring(instance) .. "_" .. table.concat(table.sort and {} or {}, "")
    if TweenEngine.ActiveTweens[key] then
        TweenEngine.ActiveTweens[key]:Cancel()
    end

    local tweenInfo = TweenInfo.new(
        duration or 0.3,
        style or Enum.EasingStyle.Quint,
        direction or Enum.EasingDirection.Out,
        0,
        false,
        0
    )

    -- Usa easing custom se fornecido
    if easing then
        tweenInfo = TweenInfo.new(
            duration or 0.3,
            easing.Style or Enum.EasingStyle.Quint,
            easing.Direction or Enum.EasingDirection.Out,
            easing.RepeatCount or 0,
            easing.Reverses or false,
            easing.DelayTime or 0
        )
    end

    local tween = TweenService:Create(instance, tweenInfo, properties)
    TweenEngine.ActiveTweens[key] = tween

    tween:Play()

    tween.Completed:Connect(function()
        TweenEngine.ActiveTweens[key] = nil
    end)

    return tween
end

--- Animação de entrada (fade + scale)
function TweenEngine.FadeIn(instance, duration)
    instance.Visible = true
    instance.BackgroundTransparency = 1
    TweenEngine.Create(instance, duration or 0.3, {
        BackgroundTransparency = 0
    })
end

--- Animação de saída (fade)
function TweenEngine.FadeOut(instance, duration)
    local tween = TweenEngine.Create(instance, duration or 0.25, {
        BackgroundTransparency = 1
    })
    if tween then
        tween.Completed:Connect(function()
            instance.Visible = false
        end)
    end
end

--- Animação de escala (bounce)
function TweenEngine.ScaleIn(instance, duration)
    instance.Visible = true
    instance.Size = UDim2.fromScale(0.9, 0.9)
    instance.BackgroundTransparency = 1
    TweenEngine.Create(instance, duration or 0.35, {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 0
    })
end

--- Hover effect
function TweenEngine.Hover(instance, originalColor, hoverColor, duration)
    TweenEngine.Create(instance, duration or 0.15, {
        BackgroundColor3 = hoverColor
    })
end

--- Click/Press effect
function TweenEngine.Press(instance, originalSize, duration)
    local pressedSize = UDim2.new(
        originalSize.X.Scale * 0.95, originalSize.X.Offset * 0.95,
        originalSize.Y.Scale * 0.95, originalSize.Y.Offset * 0.95
    )
    TweenEngine.Create(instance, duration or 0.1, {
        Size = pressedSize
    })
end

--- Release effect (volta ao tamanho original)
function TweenEngine.Release(instance, originalSize, duration)
    TweenEngine.Create(instance, duration or 0.2, {
        Size = originalSize
    })
end

