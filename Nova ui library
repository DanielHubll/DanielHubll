            -- ──────────────────────────────
            --  SLIDER
            -- ──────────────────────────────
            function Section:AddSlider(config)
                local sConfig = config or {}
                local sName = sConfig.Name or "Slider"
                local min = sConfig.Min or 0
                local max = sConfig.Max or 100
                local default = sConfig.Default or min
                local suffix = sConfig.Suffix or ""
                local callback = sConfig.Callback or function() end

                local value = default

                local holder = Utils.Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 48),
                    BackgroundTransparency = 1,
                    Parent = sectionContent,
                })

                local sLabel = Utils.Create("TextLabel", {
                    Size = UDim2.new(1, -60, 0, 16),
                    BackgroundTransparency = 1,
                    Text = sName,
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    Font = Enum.Font.GothamMedium,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder,
                })

                local valueLabel = Utils.Create("TextLabel", {
                    Size = UDim2.new(0, 55, 0, 16),
                    Position = UDim2.new(1, -55, 0, 0),
                    BackgroundTransparency = 1,
                    Text = value .. suffix,
                    TextColor3 = Theme.Accent,
                    TextSize = 12,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = holder,
                })

                local track = Utils.Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 6),
                    Position = UDim2.new(0, 0, 0, 26),
                    BackgroundColor3 = Theme.SliderTrack,
                    Parent = holder,
                })
                Utils.RoundCorners(track, 3)

                local fill = Utils.Create("Frame", {
                    Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = Theme.SliderFill,
                    Parent = track,
                })
                Utils.RoundCorners(fill, 3)

                local thumb = Utils.Create("Frame", {
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7),
                    BackgroundColor3 = Theme.SliderThumb,
                    ZIndex = 2,
                    Parent = track,
                })
                Utils.RoundCorners(thumb, 7)
                Utils.AddStroke(thumb, Theme.Accent, 2)

                local dragging = false

                local clickArea = Utils.Create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 20),
                    Position = UDim2.new(0, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = holder,
                })

                local function updateSlider(inputX)
                    local rel = math.clamp((inputX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    value = math.floor(min + (max - min) * rel)
                    fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
                    thumb.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
                    valueLabel.Text = value .. suffix
                    task.spawn(callback, value)
                end

                clickArea.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or
                       input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        updateSlider(input.Position.X)
                    end
                end)

                clickArea.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
                       input.UserInputType == Enum.UserInputType.Touch) then
                        updateSlider(input.Position.X)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or
                       input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)

                thumb.MouseEnter:Connect(function()
                    Utils.Tween(thumb, 0.15, nil, nil, {Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new((value - min) / (max - min), -9, 0.5, -9)})
                end)
                thumb.MouseLeave:Connect(function()
                    if not dragging then
                        Utils.Tween(thumb, 0.15, nil, nil, {Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)})
                    end
                end)

                task.spawn(callback, value)

                return {
                    Set = function(self, val)
                        value = math.clamp(val, min, max)
                        fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
                        thumb.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
                        valueLabel.Text = value .. suffix
                        task.spawn(callback, value)
                    end,
                    Get = function(self)
                        return value
                    end,
                }
            end

