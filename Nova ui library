function Library:Notify(config)
    local title = config.Title or "Notificação"
    local text = config.Text or ""
    local duration = config.Duration or 5
    local notifType = config.Type or "info" -- info, success, warning, danger

    local typeColors = {
        info = Theme.Info,
        success = Theme.Success,
        warning = Theme.Warning,
        danger = Theme.Danger,
    }
    local accent = typeColors[notifType] or Theme.Info

    local notif = Utils.Create("Frame", {
        Name = "Notification",
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundColor3 = Theme.BackgroundLight,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
    })
    Utils.RoundCorners(notif, 10)
    Utils.AddStroke(notif, Theme.SectionBorder, 1)

    local accentBar = Utils.Create("Frame", {
        Size = UDim2.new(0, 3, 1, -16),
        Position = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = accent,
        Parent = notif,
    })
    Utils.RoundCorners(accentBar, 4)

    local icon = Utils.Create("TextLabel", {
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(0, 20, 0, 12),
        BackgroundTransparency = 1,
        Text = notifType == "success" and "✓" or notifType == "danger" and "✕" or notifType == "warning" and "⚠" or "ℹ",
        TextColor3 = accent,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        Parent = notif,
    })

    local titleLabel = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -50, 0, 18),
        Position = UDim2.new(0, 48, 0, 10),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notif,
    })

    local descLabel = Utils.Create("TextLabel", {
        Size = UDim2.new(1, -50, 0, 16),
        Position = UDim2.new(0, 48, 0, 30),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.TextDim,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = notif,
    })

    local progressBar = Utils.Create("Frame", {
        Size = UDim2.new(1, -16, 0, 3),
        Position = UDim2.new(0, 8, 1, -10),
        BackgroundColor3 = Theme.SliderTrack,
        Parent = notif,
    })
    Utils.RoundCorners(progressBar, 4)

    local progressFill = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accent,
        Parent = progressBar,
    })
    Utils.RoundCorners(progressFill, 4)

    local closeBtn = Utils.Create("TextButton", {
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -28, 0, 8),
        BackgroundTransparency = 1,
        Text = "✕",
        TextColor3 = Theme.TextDark,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        Parent = notif,
    })

    notif.Parent = NotificationHolder

    -- Animação de entrada
    Utils.Tween(notif, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
        BackgroundTransparency = 0
    })

    -- Barra de progresso
    Utils.Tween(progressFill, duration, Enum.EasingStyle.Linear, Enum.EasingDirection.In, {
        Size = UDim2.new(0, 0, 1, 0)
    })

    local function dismiss()
        Utils.Tween(notif, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In, {
            BackgroundTransparency = 1,
            Size = UDim2.new(0.8, 0, 0, 0),
        })
        task.delay(0.35, function()
            notif:Destroy()
        end)
    end

    closeBtn.MouseButton1Click:Connect(dismiss)
    task.delay(duration, dismiss)
end

