			local Track = New("Frame", { BackgroundColor3 = Theme.Border, Size = UDim2.new(1, 0, 0, 6), Position = UDim2.new(0, 0, 1, -10), Parent = Card })
			Corner(Track, 3)
			local Fill = New("Frame", { BackgroundColor3 = Theme.Accent, Size = UDim2.new((value - min) / (max - min), 0, 1, 0), Parent = Track })
			Corner(Fill, 3)
			local Knob = New("Frame", { BackgroundColor3 = Color3.new(1, 1, 1), Size = UDim2.new(0, 14, 0, 14), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0), Parent = Track })
			Corner(Knob, 7)

			local dragging = false
			local function update(posX)
				local rel = math.clamp((posX - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
				value = math.floor(min + (max - min) * rel)
				Fill.Size = UDim2.new(rel, 0, 1, 0); Knob.Position = UDim2.new(rel, 0, 0.5, 0)
				ValueLabel.Text = tostring(value) .. (cfg.Suffix or "")
				if cfg.Flag then Library.Flags[cfg.Flag] = value end
				if cfg.Callback then task.spawn(cfg.Callback, value) end
			end

			Track.InputBegan:Connect(function(input) if input.UserInputType.Name:find("MouseButton1") or input.UserInputType.Name:find("Touch") then dragging = true update(input.Position.X) end end)
			UserInputService.InputEnded:Connect(function(input) if input.UserInputType.Name:find("MouseButton1") or input.UserInputType.Name:find("Touch") then dragging = false end end)
			UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType.Name:find("MouseMovement") or input.UserInputType.Name:find("Touch")) then update(input.Position.X) end end)
			return {}
		end

		function Tab:CreateDropdown(cfg)
			local options, selected = cfg.Options or {}, cfg.Default or cfg.Options[1] or ""
			local Card = BaseCard(cfg.Title or "Dropdown", cfg.Desc or "")
			
			local Box = New("TextButton", { Text = "", AutoButtonColor = false, BackgroundColor3 = Theme.Panel, Size = UDim2.new(1, 0, 0, 32), Position = UDim2.new(0, 0, 1, -32), Parent = Card })
			Corner(Box, 8) Stroke(Box, Theme.Border, 1)
			local Label = New("TextLabel", { Text = selected, Font = FontRegular, TextSize = 13, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Size = UDim2.new(1, -34, 1, 0), Position = UDim2.new(0, 10, 0, 0), Parent = Box })
			local Chevron = New("ImageLabel", { Image = GetIcon("chevron-down"), ImageColor3 = Theme.SubText, BackgroundTransparency = 1, Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(1, -24, 0.5, -7), Parent = Box })

			-- O SEGREDO PARA NÃO CORTAR O DROPDOWN: O ListFrame vai direto para o Gui principal e atualiza a posição via RenderStepped.
			local ListFrame = New("Frame", {
				BackgroundColor3 = Theme.Panel,
				Visible = false,
				ZIndex = 100,
				Parent = Window.Gui,
			})
			Corner(ListFrame, 8) Stroke(ListFrame, Theme.Border, 1)
			local ListScroll = New("ScrollingFrame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollBarThickness = 2, BorderSizePixel = 0, ZIndex = 100, Parent = ListFrame })
			New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Parent = ListScroll })

			local open, conn = false, nil
			local function close()
				open = false; ListFrame.Visible = false
				Tween(Chevron, {Rotation = 0}, 0.2)
				if conn then conn:Disconnect(); conn = nil end
			end

			for i, opt in ipairs(options) do
				local OptBtn = New("TextButton", { Text = "", AutoButtonColor = false, BackgroundColor3 = Theme.Panel, Size = UDim2.new(1, 0, 0, 30), LayoutOrder = i, ZIndex = 100, Parent = ListScroll })
				New("TextLabel", { Text = opt, Font = FontRegular, TextSize = 13, TextColor3 = (opt == selected) and Theme.AccentLight or Theme.SubText, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Size = UDim2.new(1, -20, 1, 0), Position = UDim2.new(0, 10, 0, 0), ZIndex = 100, Parent = OptBtn })
				OptBtn.MouseButton1Click:Connect(function()
					selected = opt; Label.Text = opt; close()
					if cfg.Flag then Library.Flags[cfg.Flag] = selected end
					if cfg.Callback then task.spawn(cfg.Callback, selected) end
				end)
			end

			Box.MouseButton1Click:Connect(function()
				open = not open
				if open then
					ListFrame.Visible = true
					Tween(Chevron, {Rotation = 180}, 0.2)
					conn = RunService.RenderStepped:Connect(function()
						if not Box or not Box.Parent then close() return end
						ListFrame.Size = UDim2.new(0, Box.AbsoluteSize.X, 0, math.min(#options * 30, 150))
						ListFrame.Position = UDim2.new(0, Box.AbsolutePosition.X, 0, Box.AbsolutePosition.Y + Box.AbsoluteSize.Y + 4)
					end)
				else
					close()
				end
			end)
			return {}
		end

		function Tab:CreateMultiSelect(cfg)
			local options, selectedSet = cfg.Options or {}, {}
			for _, v in ipairs(cfg.Default or {}) do selectedSet[v] = true end
			local Card = BaseCard(cfg.Title or "Multi-Select", cfg.Desc or "")
			local ChipsHolder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 32), Position = UDim2.new(0, 0, 1, -32), Parent = Card })
			New("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 6), Parent = ChipsHolder })

			for _, opt in ipairs(options) do
				local Chip = New("TextButton", { Text = "", AutoButtonColor = false, BackgroundColor3 = selectedSet[opt] and Theme.Accent or Theme.Panel, Size = UDim2.new(0, 0, 1, 0), AutomaticSize = Enum.AutomaticSize.X, Parent = ChipsHolder })
				Corner(Chip, 8); Pad(Chip, 0, 0, 12, 12)
				local strk = not selectedSet[opt] and Stroke(Chip, Theme.Border, 1) or nil
				
				local Row = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0, 0, 1, 0), AutomaticSize = Enum.AutomaticSize.X, Parent = Chip })
				New("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 4), Parent = Row })
				local Lbl = New("TextLabel", { Text = opt, Font = FontSemi, TextSize = 12, TextColor3 = selectedSet[opt] and Color3.new(1, 1, 1) or Theme.SubText, BackgroundTransparency = 1, Size = UDim2.new(0, 0, 1, 0), AutomaticSize = Enum.AutomaticSize.X, Parent = Row })
				local Chk = New("ImageLabel", { Image = GetIcon("check"), ImageColor3 = Color3.new(1, 1, 1), BackgroundTransparency = 1, Size = UDim2.new(0, 12, 0, 12), Visible = selectedSet[opt], Parent = Row })

				Chip.MouseButton1Click:Connect(function()
					selectedSet[opt] = not selectedSet[opt]
					Tween(Chip, { BackgroundColor3 = selectedSet[opt] and Theme.Accent or Theme.Panel }, 0.12)
					Lbl.TextColor3 = selectedSet[opt] and Color3.new(1, 1, 1) or Theme.SubText
					Chk.Visible = selectedSet[opt]
					if selectedSet[opt] then if strk then strk:Destroy() strk = nil end else strk = Stroke(Chip, Theme.Border, 1) end
					if cfg.Callback then task.spawn(cfg.Callback, selectedSet) end
				end)
			end
			return {}
		end

		function Tab:CreateKeybind(cfg)
			local currentKey, listening = cfg.Default or Enum.KeyCode.Unknown, false
			local Card = BaseCard(cfg.Title or "Keybind", cfg.Desc or "")
			local KeyBox = New("TextButton", { Text = "", AutoButtonColor = false, BackgroundColor3 = Theme.Panel, Size = UDim2.new(1, -34, 0, 32), Position = UDim2.new(0, 0, 1, -32), Parent = Card })
			Corner(KeyBox, 8) Stroke(KeyBox, Theme.Border, 1)
			local KeyLabel = New("TextLabel", { Text = currentKey ~= Enum.KeyCode.Unknown and currentKey.Name or "Nenhuma", Font = FontSemi, TextSize = 13, TextColor3 = Theme.Text, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Parent = KeyBox })

			local ClearBtn = New("TextButton", { Text = "", BackgroundColor3 = Theme.Panel, Size = UDim2.new(0, 28, 0, 32), Position = UDim2.new(1, -28, 1, -32), Parent = Card })
			Corner(ClearBtn, 8) Stroke(ClearBtn, Theme.Border, 1)
			New("ImageLabel", { Image = GetIcon("x"), ImageColor3 = Theme.SubText, BackgroundTransparency = 1, Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(0.5, -6, 0.5, -6), Parent = ClearBtn })

			KeyBox.MouseButton1Click:Connect(function() listening = true; KeyLabel.Text = "..." end)
			ClearBtn.MouseButton1Click:Connect(function() currentKey = Enum.KeyCode.Unknown; KeyLabel.Text = "Nenhuma" end)

			UserInputService.InputBegan:Connect(function(input, gpe)
				if listening and input.UserInputType == Enum.UserInputType.Keyboard then
					currentKey = input.KeyCode; KeyLabel.Text = currentKey.Name; listening = false
					if cfg.Callback then task.spawn(cfg.Callback, currentKey) end
				elseif not gpe and not listening and cfg.Triggered and input.KeyCode == currentKey then
					task.spawn(cfg.Triggered)
				end
			end)
			return {}
		end

		function Tab:CreateColorPicker(cfg)
			local color = cfg.Default or Color3.fromRGB(159, 95, 255)
			local Card = BaseCard(cfg.Title or "Color Picker", cfg.Desc or "")
			local Swatch = New("Frame", { BackgroundColor3 = color, Size = UDim2.new(0, 40, 0, 32), Position = UDim2.new(0, 0, 1, -32), Parent = Card })
			Corner(Swatch, 8) Stroke(Swatch, Theme.Border, 1)
			local HexBox = New("TextBox", { Text = string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255), Font = FontRegular, TextSize = 13, TextColor3 = Theme.Text, ClearTextOnFocus = false, BackgroundColor3 = Theme.Panel, Size = UDim2.new(1, -50, 0, 32), Position = UDim2.new(0, 50, 1, -32), Parent = Card })
			Corner(HexBox, 8) Stroke(HexBox, Theme.Border, 1) Pad(HexBox, 0, 0, 10, 10)

			HexBox.FocusLost:Connect(function()
				local hex = HexBox.Text:gsub("#", "")
				if #hex == 6 then
					pcall(function()
						local c = Color3.fromRGB(tonumber(hex:sub(1, 2), 16), tonumber(hex:sub(3, 4), 16), tonumber(hex:sub(5, 6), 16))
						Swatch.BackgroundColor3 = c; color = c
						if cfg.Callback then task.spawn(cfg.Callback, c) end
					end)
				end
			end)
			return {}
		end

		function Tab:CreateSection(title, desc)
			local expanded = false
			-- Secções sempre ocupam 100% da largura (`fullWidth = true`) e se expandem verticalmente sem bugar as demais!
			local Card = BaseCard(title, desc, 60, true)
			Card.ClipsDescendants = true

			local Chevron = New("ImageLabel", { Image = GetIcon("chevron-down"), ImageColor3 = Theme.SubText, BackgroundTransparency = 1, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -16, 0, 2), Parent = Card })
			local InnerHolder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, Position = UDim2.new(0, 0, 0, 44), Parent = Card })
			New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = InnerHolder })

			local Click = New("TextButton", { Text = "", BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 44), ZIndex = 5, Parent = Card })

			Click.MouseButton1Click:Connect(function()
				expanded = not expanded
				Tween(Chevron, { Rotation = expanded and 180 or 0 }, 0.2)
				Tween(Card, { Size = UDim2.new(1, 0, 0, expanded and (44 + InnerHolder.AbsoluteSize.Y + 14) or 60) }, 0.2)
			end)

			return { Holder = InnerHolder }
		end

		TabButton.MouseButton1Click:Connect(function()
			for _, t in pairs(Window.Tabs) do
				t.Page.Visible = false; Tween(t.Button, { BackgroundTransparency = 1 }, 0.15)
				local lbl, ic = t.Button:FindFirstChild("Label"), t.Button:FindFirstChild("Icon")
				if lbl then lbl.TextColor3 = Theme.SubText end; if ic then ic.ImageColor3 = Theme.SubText end
			end
			Page.Visible = true; Tween(TabButton, { BackgroundTransparency = 0.85 }, 0.15)
			local lbl, ic = TabButton:FindFirstChild("Label"), TabButton:FindFirstChild("Icon")
			if lbl then lbl.TextColor3 = Theme.Text end; if ic then ic.ImageColor3 = Theme.AccentLight end
		end)

		Window.Tabs[#Window.Tabs + 1] = Tab
		if not firstTab then firstTab = Tab end
		return Tab
	end

	task.defer(function()
		if firstTab then
			firstTab.Page.Visible = true; Tween(firstTab.Button, { BackgroundTransparency = 0.85 }, 0.01)
			local lbl, ic = firstTab.Button:FindFirstChild("Label"), firstTab.Button:FindFirstChild("Icon")
			if lbl then lbl.TextColor3 = Theme.Text end; if ic then ic.ImageColor3 = Theme.AccentLight end
		end
	end)

	return Window
end

return Library
