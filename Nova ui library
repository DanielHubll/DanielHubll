    -- ═══════════════════════════════════════════════════════════════
    -- INPUT NUMÉRICO
    -- ═══════════════════════════════════════════════════════════════
    function sectionAPI:AddNumberInput(options)
        local config = {
            Name = options.Name or "Number",
            Min = options.Min or 0,
            Max = options.Max or 999,
            Default = options.Default or 0,
            Step = options.Step or 1,
            Callback = options.Callback or function() end,
            Searchable = true,
        }

        local row = createComponentRow(48, "NumberInput_" .. config.Name)
        local value = config.Default

        Utility.CreateInstance("TextLabel", {
            Size = UDim2.new(0.5, 0, 1, 0),
            Position = UDim2.new(0, 14, 0, 0),
            Text = config.Name,
            Font = Enum.Font.Gotham,
            TextSize = 13,
            TextColor3 = theme.PrimaryText,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            Parent = row
        })

        -- Container dos botões e input
        local controlFrame = Utility.CreateInstance("Frame", {
            Size = UDim2.fromOffset(120, 32),
            Position = UDim2.new(1, -134, 0.5, -16),
            BackgroundColor3 = theme.InputBackground,
            Parent = row
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 8), Parent = controlFrame })

        -- Botão menos
        local minusBtn = Utility.CreateInstance("TextButton", {
            Size = UDim2.fromOffset(32, 32),
            Position = UDim2.new(0, 0, 0, 0),
            Text = "−",
            Font = Enum.Font.GothamBold,
            TextSize = 16,
            TextColor3 = theme.Accent,
            BackgroundTransparency = 1,
            Parent = controlFrame
        })

        -- Display de valor
        local valueDisplay = Utility.CreateInstance("TextBox", {
            Size = UDim2.new(1, -64, 1, 0),
            Position = UDim2.new(0, 32, 0, 0),
            Text = tostring(value),
            Font = Enum.Font.GothamMedium,
            TextSize = 13,
            TextColor3 = theme.PrimaryText,
            TextXAlignment = Enum.TextXAlignment.Center,
            BackgroundTransparency = 1,
            Parent = controlFrame
        })

        -- Botão mais
        local plusBtn = Utility.CreateInstance("TextButton", {
            Size = UDim2.fromOffset(32, 32),
            Position = UDim2.new(1, -32, 0, 0),
            Text = "+",
            Font = Enum.Font.GothamBold,
            TextSize = 16,
            TextColor3 = theme.Accent,
            BackgroundTransparency = 1,
            Parent = controlFrame
        })

        local function updateValue(newVal)
            value = math.clamp(tonumber(newVal) or config.Default, config.Min, config.Max)
            valueDisplay.Text = tostring(value)
            config.Callback(value)
            self.Config:Set("NumberInput_" .. config.Name, value)
        end

        minusBtn.MouseButton1Click:Connect(function()
            updateValue(value - config.Step)
        end)

        plusBtn.MouseButton1Click:Connect(function()
            updateValue(value + config.Step)
        end)

        valueDisplay.FocusLost:Connect(function()
            updateValue(tonumber(valueDisplay.Text) or value)
        end)

        local component = { Name = config.Name, Container = row, Searchable = true, Type = "NumberInput", SetValue = updateValue, GetValue = function() return value end }
        table.insert(tabData.Components, component)
        table.insert(section.Components, component)

        addSeparator(row)
        return component
    end

