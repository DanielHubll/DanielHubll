                BackgroundTransparency = 1, 
                Parent = hdr 
            })
            Make("Frame", { Size = UDim2.new(1, -28, 0, 1), Position = UDim2.new(0, 14, 1, 0), BackgroundColor3 = Theme.Sep, Transparency = 0.5, Parent = hdr })
        end

        section.Container = sectionFrame
        section.Layout = secLayout

        secLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            sectionFrame.Size = UDim2.new(1, 0, 0, secLayout.AbsoluteContentSize.Y)
        end)
        task.defer(function() sectionFrame.Size = UDim2.new(1, 0, 0, secLayout.AbsoluteContentSize.Y) end)
        table.insert(tab.Sections, section)

        local nextOrder = 1
        local function getOrder() local o = nextOrder; nextOrder = nextOrder + 1; return o end

        local secAPI = {}

        -- BOTÃO
        function secAPI:AddButton(options)
            local opts = options or {}
