-- NOTIFICATION SYSTEM
-- ═══════════════════════════════════════════════════════════════════
local NotificationSystem = {}
NotificationSystem.Container = nil
NotificationSystem.ActiveNotifications = {}
NotificationSystem.MaxVisible = 5

function NotificationSystem.Init(parent)
    NotificationSystem.Container = Utility.CreateInstance("Frame", {
        Name = "NotificationContainer",
        Size = UDim2.new(0, 320, 1, 0),
        Position = UDim2.new(1, -330, 0, 10),
        AnchorPoint = Vector2.new(0, 0),
        BackgroundTransparency = 1,
        Parent = parent
    })

    local layout = Utility.CreateInstance("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Top,
        Parent = NotificationSystem.Container
    })
end

function NotificationSystem.Show(options)
    local config = {
        Title = options.Title or "Notification",
        Message = options.Message or "",
        Duration = options.Duration or 5,
        Type = options.Type or "Info", -- Info, Success, Warning, Error
        Icon = options.Icon or nil,
        Callback = options.Callback or nil,
    }

    -- Determina a cor baseada no tipo
    local typeColors = {
        Info = THEME.Blue,
        Success = THEME.Green,
        Warning = THEME.Orange,
        Error = THEME.Red,
    }
    local accentColor = typeColors[config.Type] or THEME.Accent

    -- Cria a notificação
    local notification = Utility.CreateInstance("Frame", {
        Name = "Notification_" .. Utility.GenerateId(),
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundColor3 = THEME.CardBackground,
        BackgroundTransparency = 0,
        Parent = NotificationSystem.Container
    })

    local corner = Utility.CreateInstance("UICorner", {
        CornerRadius = UDim.new(0, 12),
        Parent = notification
    })

    local stroke = Utility.CreateInstance("UIStroke", {
        Color = accentColor,
        Thickness = 1,
        Transparency = 0.7,
        Parent = notification
    })

    -- Barra de acento à esquerda
    local accent = Utility.CreateInstance("Frame", {
        Size = UDim2.new(0, 4, 1, -20),
        Position = UDim2.new(0, 8, 0, 10),
        BackgroundColor3 = accentColor,
        Parent = notification
    })
    Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 2), Parent = accent })

    -- Ícone
    if config.Icon then
        local icon = Utility.CreateInstance("ImageLabel", {
            Size = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(0, 20, 0, 12),
            Image = config.Icon,
            ImageColor3 = accentColor,
            BackgroundTransparency = 1,
            Parent = notification
        })
    end

    -- Título
    local iconOffset = config.Icon and 50 or 20
    local title = Utility.CreateInstance("TextLabel", {
        Size = UDim2.new(1, -60, 0, 20),
        Position = UDim2.new(0, iconOffset, 0, 10),
        Text = config.Title,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = THEME.PrimaryText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = notification
    })

    -- Mensagem
    local message = Utility.CreateInstance("TextLabel", {
        Size = UDim2.new(1, -60, 0, 18),
        Position = UDim2.new(0, iconOffset, 0, 32),
        Text = config.Message,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = THEME.SecondaryText,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        BackgroundTransparency = 1,
        Parent = notification
    })

    -- Botão fechar
    local closeBtn = Utility.CreateInstance("TextButton", {
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -30, 0, 8),
        Text = "✕",
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = THEME.SecondaryText,
        BackgroundTransparency = 1,
        Parent = notification
    })

    -- Barra de progresso (timer)
    local progressBar = Utility.CreateInstance("Frame", {
        Size = UDim2.new(1, -16, 0, 3),
        Position = UDim2.new(0, 8, 1, -8),
        BackgroundColor3 = accentColor,
        BackgroundTransparency = 0.3,
        Parent = notification
    })
    Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 2), Parent = progressBar })

    -- Animação de entrada
    notification.Position = UDim2.new(1, 50, 0, 0)
    TweenEngine.Create(notification, 0.4, {
        Position = UDim2.new(0, 0, 0, 0)
    })

    -- Auto-dismiss
    local dismissTween = TweenEngine.Create(progressBar, config.Duration, {
        Size = UDim2.new(0, 0, 0, 3)
    })

    -- Função de dismiss
    local function dismiss()
        TweenEngine.Create(notification, 0.3, {
            Position = UDim2.new(1, 50, 0, 0),
            BackgroundTransparency = 1
        }).Completed:Connect(function()
            notification:Destroy()
        end)
    end

    closeBtn.MouseButton1Click:Connect(dismiss)
    dismissTween.Completed:Connect(dismiss)

    -- Callback
    notification.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if config.Callback then
                config.Callback()
            end
        end
    end)

    table.insert(NotificationSystem.ActiveNotifications, notification)
    return notification
end

