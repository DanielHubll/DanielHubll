    local iconLabel = Create("ImageLabel", {
        Size = UDim2.fromOffset(20, 20),
        Position = UDim2.new(0, 14, 0, 14),
        Image = typeIcons[notifType] or Icons.Zap,
        ImageColor3 = typeColors[notifType] or Theme.Accent,
        BackgroundTransparency = 1,
        ImageTransparency = 1,
        Parent = notifFrame
    })

    local titleLabel = Create("TextLabel", {
        Size = UDim2.new(1, -50, 0, 18),
        Position = UDim2.new(0, 42, 0, 12),
        Text = title or "Notification",
        TextColor3 = Theme.TextPrimary,
        TextTransparency = 1,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = notifFrame
    })

    local msgLabel = Create("TextLabel", {
        Size = UDim2.new(1, -50, 0, 16),
        Position = UDim2.new(0, 42, 0, 32),
        Text = message or "",
        TextColor3 = Theme.TextSecondary,
        TextTransparency = 1,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = notifFrame
    })

    local progressBar = Create("Frame", {
        Size = UDim2.new(1, -20, 0, 2),
        Position = UDim2.new(0, 10, 1, -10),
        BackgroundColor3 = Theme.SliderTrack,
        BackgroundTransparency = 1,
        Parent = notifFrame
    })
    AddCorner(progressBar, 2)

    local progressFill = Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = typeColors[notifType] or Theme.Accent,
        BackgroundTransparency = 1,
        Parent = progressBar
    })
    AddCorner(progressFill, 2)

    -- Animate in (iOS style spring)
    notifFrame.Size = UDim2.new(1, 40, 0, 70)
    notifFrame.Position = UDim2.new(0, 40, 0, 0)

    SpringTween(notifFrame, 0.5)
    notifFrame:TweenSize(UDim2.new(1, 0, 0, 70), Enum.EasingDirection.Out, Enum.EasingStyle.Back, 0.5, true)
    notifFrame:TweenPosition(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Back, 0.5, true)

    Tween(notifFrame, 0.3, {BackgroundTransparency = 0})
    Tween(accentBar, 0.3, {BackgroundTransparency = 0})
    Tween(iconLabel, 0.4, {ImageTransparency = 0})
    Tween(titleLabel, 0.4, {TextTransparency = 0})
    Tween(msgLabel, 0.4, {TextTransparency = 0})
    Tween(progressBar, 0.4, {BackgroundTransparency = 0.5})
    Tween(progressFill, 0.4, {BackgroundTransparency = 0})

    -- Progress animation
    Tween(progressFill, duration, {
        Size = UDim2.new(0, 0, 1, 0)
    }, Enum.EasingStyle.Linear, Enum.EasingDirection.In)

    -- Auto dismiss
    task.delay(duration, function()
        Tween(notifFrame, 0.3, {BackgroundTransparency = 1})
        Tween(accentBar, 0.3, {BackgroundTransparency = 1})
        Tween(iconLabel, 0.3, {ImageTransparency = 1})
        Tween(titleLabel, 0.3, {TextTransparency = 1})
        Tween(msgLabel, 0.3, {TextTransparency = 1})
        Tween(progressBar, 0.3, {BackgroundTransparency = 1})
        Tween(progressFill, 0.3, {BackgroundTransparency = 1})

        notifFrame:TweenSize(UDim2.new(1, 40, 0, 70), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.3, true)
        notifFrame:TweenPosition(UDim2.new(0, 40, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.3, true)

        task.delay(0.35, function()
            notifFrame:Destroy()
        end)
    end)
end

