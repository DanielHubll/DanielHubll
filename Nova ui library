    -- Minimizar
    local minBtn = Make("TextButton", {
        Size = UDim2.fromOffset(24, 24),
        Position = UDim2.new(0, 0, 0, 0),
        Text = "",
        BackgroundColor3 = Color3.fromRGB(255, 189, 46),
        AutoButtonColor = false,
        Parent = ctrlFrame,
    })
    Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = minBtn })
    Make("Frame", {
        Size = UDim2.fromOffset(8, 2),
        Position = UDim2.new(0.5, -4, 0.5, -1),
        BackgroundColor3 = Color3.fromRGB(130, 95, 0),
        Parent = minBtn,
    })

    -- Fechar
    local closeBtn = Make("TextButton", {
        Size = UDim2.fromOffset(24, 24),
        Position = UDim2.new(0, 32, 0, 0),
        Text = "",
        BackgroundColor3 = Color3.fromRGB(255, 95, 87),
        AutoButtonColor = false,
        Parent = ctrlFrame,
    })
    Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = closeBtn })
    Make("Frame", {
        Size = UDim2.fromOffset(8, 2),
        Position = UDim2.new(0.5, -4, 0.5, -1),
        Rotation = 45,
        BackgroundColor3 = Color3.fromRGB(130, 20, 15),
        Parent = closeBtn,
    })
    Make("Frame", {
        Size = UDim2.fromOffset(8, 2),
        Position = UDim2.new(0.5, -4, 0.5, -1),
        Rotation = -45,
        BackgroundColor3 = Color3.fromRGB(130, 20, 15),
        Parent = closeBtn,
    })

    -- Hover nos botões de controle
