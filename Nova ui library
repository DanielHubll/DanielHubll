            Str(list, Theme.Border, 1)

            local listL = New("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = list
            })

            local function Populate()
                for _, c in pairs(list:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for i, opt in ipairs(options) do
                    local ob = New("TextButton", {
                        Size = UDim2.new(1, 0, 0, 28),
                        BackgroundTransparency = 1,
                        Text = "   " .. tostring(opt),
                        TextColor3 = opt == selected and Theme.Accent or Theme.TextSec,
                        TextSize = 11,
                        Font = opt == selected and Cfg.Bold or Cfg.Font,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        AutoButtonColor = false,
                        ZIndex = 31,
                        LayoutOrder = i,
                        Parent = list
                    })

                    if opt == selected then
                        local sDot = New("Frame", {
                            Size = UDim2.new(0, 4, 0, 4),
                            Position = UDim2.new(0, 8, 0.5, -2),
                            BackgroundColor3 = Theme.Accent,
                            ZIndex = 32,
                            Parent = ob
                        })
                        Rnd(sDot, UDim.new(1,0))
                    end

                    ob.MouseEnter:Connect(function()
                        Tw(ob, {BackgroundTransparency = 0.7, BackgroundColor3 = Theme.SurfaceHover}, 0.1)
                    end)
                    ob.MouseLeave:Connect(function()
                        Tw(ob, {BackgroundTransparency = 1}, 0.1)
                    end)
                    ob.MouseButton1Click:Connect(function()
                        selected = opt
                        selLbl.Text = tostring(selected)
                        open = false
                        Tw(list, {Size = UDim2.new(1,-8,0,0)}, 0.18)
                        Tw(wrap, {Size = UDim2.new(1,-12,0,50)}, 0.18)
                        task.delay(0.18, function() list.Visible = false end)
                        Populate()
                        task.spawn(cb, selected)
                    end)
                end
            end

            Populate()

            dropBtn.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    list.Visible = true
                    Populate()
                    local h = math.min(listL.AbsoluteContentSize.Y, 140)
                    Tw(list, {Size = UDim2.new(1,-8,0,h)}, 0.2)
                    Tw(wrap, {Size = UDim2.new(1,-12,0,52+h)}, 0.2)
                else
                    Tw(list, {Size = UDim2.new(1,-8,0,0)}, 0.18)
                    Tw(wrap, {Size = UDim2.new(1,-12,0,50)}, 0.18)
                    task.delay(0.18, function() list.Visible = false end)
                end
            end)

            return {
                SetValue = function(_, v) selected = v; selLbl.Text = tostring(v); task.spawn(cb, v) end,
                GetValue = function() return selected end,
                SetOptions = function(_, o) options = o; Populate() end
            }
        end

