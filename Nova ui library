local function CreateWindowButton(parent, text, xOffset, callback)
    local btn = Create("TextButton", {
        Size = UDim2.fromOffset(32, 32),
        Position = UDim2.new(0, xOffset, 0.5, -16),
        BackgroundColor3 = Color3.fromRGB(40, 40, 50),
        BackgroundTransparency = 0.6,
        Text = text,
        TextColor3 = Theme.TextSecondary,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        AutoButtonColor = false,
        Parent = parent
    })
    AddCorner(btn, 8)

    btn.MouseEnter:Connect(function()
        Tween(btn, 0.2, {BackgroundTransparency = 0.3, BackgroundColor3 = Color3.fromRGB(55, 55, 70)})
        Tween(btn, 0.2, {TextColor3 = Theme.TextPrimary})
    end)

    btn.MouseLeave:Connect(function()
        Tween(btn, 0.2, {BackgroundTransparency = 0.6, BackgroundColor3 = Color3.fromRGB(40, 40, 50)})
        Tween(btn, 0.2, {TextColor3 = Theme.TextSecondary})
    end)

    btn.MouseButton1Click:Connect(function()
        Ripple(btn, Theme.Accent)
        if callback then callback() end
    end)

    return btn
end

