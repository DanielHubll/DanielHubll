        BackgroundColor3 = Theme.InputBg,
        Parent = InputFrame
    })
    AddCorner(InputBg, 8)
    AddStroke(InputBg, Theme.Border, 0.5)

    local InputBox = Create("TextBox", {
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        PlaceholderText = placeholder or "Type here...",
        PlaceholderColor3 = Theme.TextMuted,
        Text = "",
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        BackgroundTransparency = 1,
        Parent = InputBg
    })

    local focusStroke = AddStroke(InputBg, Theme.Accent, 1.5)
    focusStroke.Transparency = 1

    InputBox.Focused:Connect(function()
        Tween(focusStroke, 0.3, {Transparency = 0})
        Tween(InputBg, 0.3, {BackgroundColor3 = Color3.fromRGB(28, 28, 40)})
        SpringTween(InputBg, 0.3)
    end)

    InputBox.FocusLost:Connect(function(enterPressed)
        Tween(focusStroke, 0.3, {Transparency = 1})
        Tween(InputBg, 0.3, {BackgroundColor3 = Theme.InputBg})
        if enterPressed and callback then
            callback(InputBox.Text)
        end
    end)

    return {
        Frame = InputFrame,
        Get = function() return InputBox.Text end,
        Set = function(text) InputBox.Text = text end,
        TextBox = InputBox
    }
end

-- Color Picker (Simplified)
local function CreateColorPicker(parent, title, defaultColor, callback, layoutOrder)
    defaultColor = defaultColor or Theme.Accent
    local currentColor = defaultColor

    local PickerFrame = Create("Frame", {
        Name = "ColorPicker_" .. title,
        Size = UDim2.new(1, 0, 0, 48),
        BackgroundTransparency = 1,
        LayoutOrder = layoutOrder or 0,
        Parent = parent
    })

    local PickerTitle = Create("TextLabel", {
        Size = UDim2.new(0.6, 0, 0, 18),
        Position = UDim2.new(0, 12, 0.5, -9),
        Text = title,
        TextColor3 = Theme.TextPrimary,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = PickerFrame
    })

    local ColorPreview = Create("TextButton", {
        Size = UDim2.fromOffset(36, 24),
        Position = UDim2.new(1, -50, 0.5, -12),
        BackgroundColor3 = defaultColor,
        AutoButtonColor = false,
        Parent = PickerFrame
    })
    AddCorner(ColorPreview, 6)
    AddStroke(ColorPreview, Theme.BorderLight, 1)

    local HexLabel = Create("TextLabel", {
        Size = UDim2.fromOffset(60, 16),
        Position = UDim2.new(1, -120, 0.5, -8),
        Text = "#" .. string.format("%02X%02X%02X",
            math.floor(defaultColor.R * 255),
            math.floor(defaultColor.G * 255),
            math.floor(defaultColor.B * 255)),
        TextColor3 = Theme.TextMuted,
        TextSize = 9,
        Font = Enum.Font.Code,
        BackgroundTransparency = 1,
        Parent = PickerFrame
    })

    -- Simple preset colors
    local presets = {
        Color3.fromRGB(99, 102, 241),
        Color3.fromRGB(239, 68, 68),
        Color3.fromRGB(34, 197, 94),
        Color3.fromRGB(250, 204, 21),
        Color3.fromRGB(168, 85, 247),
        Color3.fromRGB(236, 72, 153),
        Color3.fromRGB(6, 182, 212),
        Color3.fromRGB(249, 115, 22),
    }

    local PresetContainer = Create("Frame", {
        Size = UDim2.new(1, -24, 0, 0),
        Position = UDim2.new(0, 12, 1, 4),
        BackgroundTransparency = 1,
        Visible = false,
        ClipsDescendants = true,
        Parent = PickerFrame
    })

    local PresetLayout = Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        FillDirection = Enum.FillDirection.Horizontal,
        Padding = UDim.new(0, 4),
        Parent = PresetContainer
    })

    for i, color in ipairs(presets) do
        local PresetBtn = Create("TextButton", {
            Size = UDim2.fromOffset(24, 24),
            BackgroundColor3 = color,
            AutoButtonColor = false,
            LayoutOrder = i,
            Parent = PresetContainer
        })
        AddCorner(PresetBtn, 6)

        PresetBtn.MouseButton1Click:Connect(function()
            currentColor = color
            Tween(ColorPreview, 0.3, {BackgroundColor3 = color})
            HexLabel.Text = "#" .. string.format("%02X%02X%02X",
                math.floor(color.R * 255),
                math.floor(color.G * 255),
                math.floor(color.B * 255))
            SpringTween(ColorPreview, 0.3)
            if callback then callback(color) end
        end)

        PresetBtn.MouseEnter:Connect(function()
            SpringTween(PresetBtn, 0.2)
            Tween(PresetBtn, 0.15, {Size = UDim2.fromOffset(28, 28)})
        end)
        PresetBtn.MouseLeave:Connect(function()
            Tween(PresetBtn, 0.15, {Size = UDim2.fromOffset(24, 24)})
        end)
    end

    local isOpen = false
    ColorPreview.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            Tween(PickerFrame, 0.3, {Size = UDim2.new(1, 0, 0, 80)})
            PresetContainer.Visible = true
            Tween(PresetContainer, 0.3, {Size = UDim2.new(1, -24, 0, 28)})
        else
            Tween(PickerFrame, 0.3, {Size = UDim2.new(1, 0, 0, 48)})
            Tween(PresetContainer, 0.3, {Size = UDim2.new(1, -24, 0, 0)})
            task.delay(0.3, function() PresetContainer.Visible = false end)
        end
    end)

    return {
        Frame = PickerFrame,
        Get = function() return currentColor end,
        Set = function(color)
            currentColor = color
            Tween(ColorPreview, 0.3, {BackgroundColor3 = color})
        end
    }
end

