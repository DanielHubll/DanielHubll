        for _, child in pairs(ComponentsFrame:GetChildren()) do
            if child:IsA("Frame") then
                local name = child.Name:lower()
                local searchTag = child:GetAttribute("SearchTag") or ""
                searchTag = searchTag:lower()
                
                if query == "" or name:find(query) or searchTag:find(query) then
                    child.Visible = true
                else
                    child.Visible = false
                end
            end
        end
    end)
    
    -- ═══════════════════════════════════════
    -- DRAG / ARRASTAR A UI
    -- ═══════════════════════════════════════
    local dragging, dragInput, dragStart, startPos
    
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = TopBar.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
            TopBar.Position = newPos
            TabsFrame.Position = UDim2.new(
                newPos.X.Scale, newPos.X.Offset,
                newPos.Y.Scale, newPos.Y.Offset + 34
            )
            ComponentsFrame.Position = UDim2.new(
                newPos.X.Scale, newPos.X.Offset + 70,
                newPos.Y.Scale, newPos.Y.Offset + 34
            )
            SearchFrame.Position = UDim2.new(
                newPos.X.Scale, newPos.X.Offset + 76,
                newPos.Y.Scale, newPos.Y.Offset + 10
            )
            LowBar.Position = UDim2.new(
                newPos.X.Scale, newPos.X.Offset,
                newPos.Y.Scale, newPos.Y.Offset + 200
            )
        end
    end)
    
    return self
end

-- ═══════════════════════════════════════════════════════
-- FUNÇÃO: ADICIONAR TAB
-- ═══════════════════════════════════════════════════════
function Lumina:AddTab(config)
    config = config or {}
    
    local TabName = config.Name or "Tab " .. (self.TabCount + 1)
    local TabIcon = config.Icon or ""
    local TabOrder = self.TabCount
    
    self.TabCount = self.TabCount + 1
    
    local TabData = {
        Name = TabName,
        Components = {},
        Frame = nil,
        Button = nil,
    }
    
    -- ═══════════════════════════════════════
    -- BOTÃO DA TAB (na sidebar)
    -- ═══════════════════════════════════════
    local TabBtn = Instance.new("Frame")
    TabBtn.Name = "Tab_" .. TabName
    TabBtn.BackgroundColor3 = Theme.TabBg
    TabBtn.BorderSizePixel = 0
    TabBtn.Size = UDim2.new(1, 0, 0, 22)
    TabBtn.LayoutOrder = TabOrder
    TabBtn.Parent = self.TabsFrame
    
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 5)
    
    -- Ícone da tab
    local IconLabel = Instance.new("ImageLabel")
    IconLabel.Name = "IconTab"
    IconLabel.BackgroundColor3 = Color3.fromRGB(255,255,255)
    IconLabel.BackgroundTransparency = 1
    IconLabel.Image = TabIcon
    IconLabel.Size = UDim2.new(0, 18, 0, 18)
    IconLabel.Position = UDim2.new(0, 2, 0, 2)
    IconLabel.Parent = TabBtn
    
    -- Nome da tab
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Name = "NameTab"
    NameLabel.BackgroundColor3 = Color3.fromRGB(255,255,255)
    NameLabel.BackgroundTransparency = 1
    NameLabel.FontFace = Fonts.Body
    NameLabel.TextColor3 = Theme.TextPrimary
    NameLabel.TextScaled = true
    NameLabel.TextWrapped = true
    NameLabel.Size = UDim2.new(0, 30, 0, 14)
    NameLabel.Position = UDim2.new(0, 22, 0, 4)
    NameLabel.Text = TabName
    NameLabel.Parent = TabBtn
    
    -- Botão invisível pra clique
    local ClickBtn = Instance.new("TextButton")
    ClickBtn.Name = "ClickBtn"
    ClickBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
    ClickBtn.BackgroundTransparency = 1
    ClickBtn.BorderSizePixel = 0
    ClickBtn.Size = UDim2.new(1, 0, 1, 0)
    ClickBtn.Text = ""
    ClickBtn.Parent = TabBtn
    
    TabData.Button = TabBtn
    TabData.ClickBtn = ClickBtn
    
    -- ═══════════════════════════════════════
    -- SISTEMA DE SELEÇÃO DE TAB
    -- ═══════════════════════════════════════
    local function SelectTab()
        -- Desativa todas as tabs
        for _, tab in pairs(Tabs) do
            Tween(tab.Button, TweenInfo_.Normal, {
                BackgroundColor3 = Theme.TabBg
            })
            tab.Frame.Visible = false
        end
        
        -- Ativa a tab selecionada
        Tween(TabBtn, TweenInfo_.Normal, {
            BackgroundColor3 = Theme.TabActive
        })
        
        -- Limpa o container de componentes
        for _, child in pairs(self.ComponentsFrame:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        -- Recria o layout
        local Layout = self.ComponentsFrame:FindFirstChild("Layout")
        if not Layout then
            local newLayout = Instance.new("UIListLayout")
            newLayout.Name = "Layout"
            newLayout.Padding = UDim.new(0, 4)
            newLayout.SortOrder = Enum.SortOrder.LayoutOrder
            newLayout.Parent = self.ComponentsFrame
        end
        
        -- Renderiza os componentes da tab
        for _, comp in pairs(TabData.Components) do
            comp:Render(self.ComponentsFrame)
        end
        
        TabData.Frame = self.ComponentsFrame
        ActiveTab = TabData
    end
    
    ClickBtn.MouseButton1Click:Connect(SelectTab)
    
    -- Seleciona automaticamente se for a primeira tab
    if self.TabCount == 1 then
        task.defer(SelectTab)
    end
    
    table.insert(Tabs, TabData)
    
    -- ═══════════════════════════════════════
    -- API DA TAB (métodos para adicionar componentes)
    -- ═══════════════════════════════════════
    local TabAPI = {}
    TabAPI.__index = TabAPI
    TabAPI.TabData = TabData
    TabAPI.Library = self
    
    -- ═════════════════════════════════════
    -- COMPONENTE: LABEL (Texto simples)
    -- ═════════════════════════════════════
    function TabAPI:AddLabel(config)
        config = config or {}
        local comp = {}
        
        comp.Text = config.Text or "Label"
        comp.Size = config.Size or 14
        comp.Color = config.Color or Theme.TextPrimary
        comp.Font = config.Font or Fonts.Body
        comp.Order = #TabData.Components
        
        function comp:Render(parent)
            local Label = Instance.new("TextLabel")
            Label.Name = "Label_" .. comp.Text
            Label.BackgroundColor3 = Color3.fromRGB(255,255,255)
            Label.BackgroundTransparency = 1
            Label.FontFace = comp.Font
            Label.TextColor3 = comp.Color
            Label.TextSize = comp.Size
            Label.TextWrapped = true
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Size = UDim2.new(1, 0, 0, comp.Size + 8)
            Label.Text = comp.Text
            Label.LayoutOrder = comp.Order
            Label:SetAttribute("SearchTag", comp.Text)
            Label.Parent = parent
            
            comp.Instance = Label
            return Label
        end
        
        table.insert(TabData.Components, comp)
        if ActiveTab == TabData then comp:Render(self.ComponentsFrame) end
        return comp
    end
    
    -- ═════════════════════════════════════
    -- COMPONENTE: SECTION (Separador)
    -- ═════════════════════════════════════
    function TabAPI:AddSection(config)
        config = config or {}
        local comp = {}
        
        comp.Title = config.Title or ""
        comp.Order = #TabData.Components
        
        function comp:Render(parent)
            local Section = Instance.new("Frame")
            Section.Name = "Section_" .. comp.Title
            Section.BackgroundColor3 = Color3.fromRGB(255,255,255)
            Section.BackgroundTransparency = 1
            Section.Size = UDim2.new(1, 0, 0, 24)
            Section.LayoutOrder = comp.Order
            Section:SetAttribute("SearchTag", comp.Title)
            Section.Parent = parent
            
            -- Linha divisória
            local Divider = Instance.new("Frame")
            Divider.Name = "Divider"
            Divider.BackgroundColor3 = Theme.StrokeColor
            Divider.BorderSizePixel = 0
            Divider.Size = UDim2.new(1, 0, 0, 1)
            Divider.Position = UDim2.new(0, 0, 0.5, 0)
            Divider.Parent = Section
            
            if comp.Title ~= "" then
                local TitleBg = Instance.new("Frame")
                TitleBg.Name = "TitleBg"
                TitleBg.BackgroundColor3 = Theme.ComponentBg
                TitleBg.BorderSizePixel = 0
