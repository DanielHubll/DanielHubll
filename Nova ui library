    -- ═══════════════════════════════════════════════════════════════
    -- CHIPS COMPONENT
    -- ═══════════════════════════════════════════════════════════════
    function sectionAPI:AddChips(options)
        local config = {
            Options = options.Options or {},
            Default = options.Default or {},
            Callback = options.Callback or function() end,
            MultiSelect = options.MultiSelect ~= false,
            Searchable = true,
        }

        local row = createComponentRow(50, "Chips")
        local selected = {}
        for _, v in ipairs(config.Default) do selected[v] = true end

        local layout = Utility.CreateInstance("UIListLayout", {
            Padding = UDim.new(0, 6),
            FillDirection = Enum.FillDirection.Horizontal,
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Parent = row
        })

        Utility.CreateInstance("UIPadding", {
            PaddingLeft = UDim.new(0, 14),
            PaddingTop = UDim.new(0, 10),
            Parent = row
        })

        local chipElements = {}

        for _, option in ipairs(config.Options) do
            local isSelected = selected[option] or false

            local chip = Utility.CreateInstance("Frame", {
                Size = UDim2.fromOffset(0, 28),
                BackgroundColor3 = isSelected and theme.Accent or theme.InputBackground,
                LayoutOrder = #chipElements,
                Parent = row
            })
            Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = chip })

            local chipLabel = Utility.CreateInstance("TextLabel", {
                Size = UDim2.new(1, -20, 1, 0),
                Position = UDim2.new(0, 10, 0, 0),
                Text = option,
                Font = isSelected and Enum.Font.GothamBold or Enum.Font.Gotham,
                TextSize = 12,
                TextColor3 = isSelected and Color3.fromRGB(255,255,255) or theme.PrimaryText,
                BackgroundTransparency = 1,
                Parent = chip
            })

            -- Auto-size chip
            local textSize = game:GetService("TextService"):GetTextSize(
                option, 12, Enum.Font.Gotham, Vector2.new(200, 28)
            )
            chip.Size = UDim2.fromOffset(textSize.X + 20, 28)

            local chipBtn = Utility.CreateInstance("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                Text = "",
                BackgroundTransparency = 1,
                Parent = chip
            })

            chipBtn.MouseButton1Click:Connect(function()
                if config.MultiSelect then
                    selected[option] = not selected[option]
                else
                    selected = {}
                    selected[option] = true
                end

                -- Update visuals
                local isNowSelected = selected[option]
                TweenEngine.Create(chip, 0.2, {
                    BackgroundColor3 = isNowSelected and theme.Accent or theme.InputBackground
                })
                chipLabel.Font = isNowSelected and Enum.Font.GothamBold or Enum.Font.Gotham
                chipLabel.TextColor3 = isNowSelected and Color3.fromRGB(255,255,255) or theme.PrimaryText

                config.Callback(selected)
            end)

            table.insert(chipElements, chip)
        end

        local component = { Name = "Chips", Container = row, Searchable = true, Type = "Chips", GetSelected = function() return selected end }
        table.insert(tabData.Components, component)
        table.insert(section.Components, component)
        return component
    end

