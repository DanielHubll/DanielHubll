        if not self.Window or not self.Window.Parent then return end
        if breakpoint == "Mobile" then
            TweenEngine.Create(self.Window, 0.4, {
                Size = UDim2.new(0.95, 0, 0.85, 0),
                Position = UDim2.new(0.5, 0, 0.5, 0),
