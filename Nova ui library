    })
    AddCorner(ActiveIndicator, 4)

    local TabLabel = Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 10),
        Position = UDim2.new(0, 0, 1, -12),
        Text = name,
        TextColor3 = Theme.TextMuted,
        TextSize = 7,
        Font = Enum.Font.GothamMedium,
        BackgroundTransparency = 1,
        TextTransparency = 1,
        Parent = TabBtn
    })

    -- Content frame for this tab
    local Content = Create("ScrollingFrame", {
        Name = "Content_" .. name,
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        Visible = false,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent = nil -- will be set later
    })

    local ContentLayout = Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        Parent = Content
    })

    ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Content.CanvasSize = UDim2.new(0, 0, 0, ContentLayout.AbsoluteContentSize.Y + 20)
    end)

    -- Hover effects
    TabBtn.MouseEnter:Connect(function()
        if ActiveTab ~= name then
            Tween(TabBtn, 0.2, {BackgroundTransparency = 0.9, BackgroundColor3 = Theme.CardBg})
            Tween(TabIcon, 0.2, {ImageColor3 = Theme.TextSecondary})
        end
    end)

    TabBtn.MouseLeave:Connect(function()
        if ActiveTab ~= name then
            Tween(TabBtn, 0.2, {BackgroundTransparency = 1, BackgroundColor3 = Color3.fromRGB(255,255,255)})
            Tween(TabIcon, 0.2, {ImageColor3 = Theme.TextMuted})
        end
    end)

    -- Click to switch tab
    TabBtn.MouseButton1Click:Connect(function()
        if ActiveTab == name then return end
        Ripple(TabBtn, Theme.Accent)

        -- Deactivate old tab
        if ActiveTab and Tabs[ActiveTab] then
            local oldTab = Tabs[ActiveTab]
            Tween(oldTab.Button, 0.3, {BackgroundTransparency = 1})
            Tween(oldTab.Icon, 0.3, {ImageColor3 = Theme.TextMuted, Size = UDim2.fromOffset(22, 22)})
            Tween(oldTab.Indicator, 0.3, {BackgroundTransparency = 1, Size = UDim2.fromOffset(3, 24)})
            Tween(oldTab.Label, 0.3, {TextTransparency = 1, TextColor3 = Theme.TextMuted})
            if TabFrames[ActiveTab] then
                Tween(TabFrames[ActiveTab], 0.2, {BackgroundTransparency = 1})
                task.delay(0.2, function()
                    if TabFrames[ActiveTab] then
                        TabFrames[ActiveTab].Visible = false
                    end
                end)
            end
        end

        -- Activate new tab (iOS spring animation)
        ActiveTab = name
        SpringTween(TabBtn, 0.4)
        Tween(TabBtn, 0.3, {BackgroundTransparency = 0.85, BackgroundColor3 = Theme.Accent})
        Tween(TabIcon, 0.3, {ImageColor3 = Theme.AccentLight, Size = UDim2.fromOffset(24, 24)})
        Tween(ActiveIndicator, 0.3, {BackgroundTransparency = 0, Size = UDim2.fromOffset(3, 32)})
        Tween(TabLabel, 0.3, {TextTransparency = 0, TextColor3 = Theme.AccentLight})

        if TabFrames[name] then
            TabFrames[name].Visible = true
            TabFrames[name].BackgroundTransparency = 1
            Tween(TabFrames[name], 0.3, {BackgroundTransparency = 1})
        end
    end)

    tabData.Button = TabBtn
    tabData.Icon = TabIcon
    tabData.Indicator = ActiveIndicator
    tabData.Label = TabLabel
    tabData.Content = Content

    Tabs[name] = tabData
    TabFrames[name] = Content

    return tabData
end

