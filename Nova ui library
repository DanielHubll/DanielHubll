-- POPUP & CONFIRM DIALOG SYSTEM
-- ═══════════════════════════════════════════════════════════════════
local PopupSystem = {}

function PopupSystem.Show(options)
    local config = {
        Title = options.Title or "Alert",
        Message = options.Message or "",
        Buttons = options.Buttons or { {Text = "OK", Primary = true} },
        Callback = options.Callback or nil,
    }

    -- Overlay
    local overlay = Utility.CreateInstance("Frame", {
        Name = "PopupOverlay",
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = 100,
        Parent = options.Parent or PlayerGui
    })

    TweenEngine.Create(overlay, 0.2, { BackgroundTransparency = 0.6 })

    -- Container do popup
    local popup = Utility.CreateInstance("Frame", {
        Size = UDim2.new(0, 280, 0, 200),
        Position = UDim2.new(0.5, -140, 0.5, -100),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = THEME.CardBackground,
        ZIndex = 101,
        Parent = overlay
    })
    Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 16), Parent = popup })

    -- Scale animation in
    popup.Size = UDim2.new(0, 250, 0, 180)
    TweenEngine.Create(popup, 0.35, {
        Size = UDim2.new(0, 280, 0, 200)
    })

    -- Título
    Utility.CreateInstance("TextLabel", {
        Size = UDim2.new(1, -40, 0, 24),
        Position = UDim2.new(0, 20, 0, 20),
        Text = config.Title,
        Font = Enum.Font.GothamBold,
        TextSize = 17,
        TextColor3 = THEME.PrimaryText,
        TextXAlignment = Enum.TextXAlignment.Center,
        BackgroundTransparency = 1,
        ZIndex = 102,
        Parent = popup
    })

    -- Mensagem
    Utility.CreateInstance("TextLabel", {
        Size = UDim2.new(1, -40, 0, 50),
        Position = UDim2.new(0, 20, 0, 50),
        Text = config.Message,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = THEME.SecondaryText,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        BackgroundTransparency = 1,
        ZIndex = 102,
        Parent = popup
    })

    -- Separator
    Utility.CreateInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -50),
        BackgroundColor3 = THEME.Separator,
        BackgroundTransparency = 0.5,
        ZIndex = 102,
        Parent = popup
    })

    -- Botões
    local buttonCount = #config.Buttons
    local buttonWidth = (280 - 20) / buttonCount - 5

    for i, btnConfig in ipairs(config.Buttons) do
        local btn = Utility.CreateInstance("TextButton", {
            Size = UDim2.new(0, buttonWidth, 0, 40),
            Position = UDim2.new(0, 10 + (i-1) * (buttonWidth + 5), 1, -45),
            Text = btnConfig.Text or "Button",
            Font = btnConfig.Primary and Enum.Font.GothamBold or Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = btnConfig.Primary and THEME.Accent or THEME.SecondaryText,
            BackgroundColor3 = btnConfig.Primary and THEME.Accent or Color3.fromRGB(0,0,0),
            BackgroundTransparency = btnConfig.Primary and 0.9 or 1,
            ZIndex = 102,
            Parent = popup
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 8), Parent = btn })

        btn.MouseButton1Click:Connect(function()
            -- Fechar popup
            TweenEngine.Create(overlay, 0.2, { BackgroundTransparency = 1 })
            TweenEngine.Create(popup, 0.25, {
                Size = UDim2.new(0, 250, 0, 180),
            }).Completed:Connect(function()
                overlay:Destroy()
            end)

            if config.Callback then
                config.Callback(i, btnConfig.Text)
            end
        end)

        -- Hover animation
        btn.MouseEnter:Connect(function()
            TweenEngine.Create(btn, 0.15, { BackgroundTransparency = btnConfig.Primary and 0.8 or 0.9 })
        end)
        btn.MouseLeave:Connect(function()
            TweenEngine.Create(btn, 0.15, { BackgroundTransparency = btnConfig.Primary and 0.9 or 1 })
        end)
    end

    return overlay
end

function PopupSystem.Confirm(title, message, onConfirm, onCancel, parent)
    return PopupSystem.Show({
        Title = title,
        Message = message,
        Buttons = {
            { Text = "Cancelar", Primary = false },
            { Text = "Confirmar", Primary = true },
        },
        Callback = function(index)
            if index == 2 and onConfirm then
                onConfirm()
            elseif index == 1 and onCancel then
                onCancel()
            end
        end,
        Parent = parent
    })
end

