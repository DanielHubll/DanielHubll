        Position = UDim2.new(0, -5, 0, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 10,
        Parent = hueSlider
    })
    
    hueButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingHue = true
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWheel = false
            draggingHue = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if draggingWheel then
            local wheelPos = wheelFrame.AbsolutePosition
            local wheelSizeAbs = wheelFrame.AbsoluteSize
            local relX = (input.Position.X - wheelPos.X) / wheelSizeAbs.X
            local relY = (input.Position.Y - wheelPos.Y) / wheelSizeAbs.Y
            s = math.clamp(relX, 0, 1)
            v = 1 - math.clamp(relY, 0, 1)
            UpdateColorFromWheel()
        elseif draggingHue then
            local huePos = hueSlider.AbsolutePosition
            local hueSizeAbs = hueSlider.AbsoluteSize
            local relY = (input.Position.Y - huePos.Y) / hueSizeAbs.Y
            h = math.clamp(relY, 0, 1)
            UpdateColorFromWheel()
        end
    end)
    
    -- RGB Input handlers
    local function UpdateFromRGBInputs()
        local r = math.clamp(tonumber(container:FindFirstChild("RInput") and container.RInput.Text) or 0, 0, 255)
        local g = math.clamp(tonumber(container:FindFirstChild("GInput") and container.GInput.Text) or 0, 0, 255)
        local b = math.clamp(tonumber(container:FindFirstChild("BInput") and container.BInput.Text) or 0, 0, 255)
        currentColor = Color3.fromRGB(r, g, b)
        h, s, v = RGBToHSV(r, g, b)
        UpdateDisplay()
        callback(currentColor)
    end
    
    for _, child in pairs(container:GetChildren()) do
        if child:IsA("TextBox") and (child.Name == "RInput" or child.Name == "GInput" or child.Name == "BInput") then
            child.FocusLost:Connect(UpdateFromRGBInputs)
        end
    end
    
    -- Hex input handler
    hexInput.FocusLost:Connect(function()
        local hex = hexInput.Text:gsub("#", "")
        if #hex == 6 then
            local r = tonumber(hex:sub(1, 2), 16)
            local g = tonumber(hex:sub(3, 4), 16)
            local b = tonumber(hex:sub(5, 6), 16)
            if r and g and b then
                currentColor = Color3.fromRGB(r, g, b)
                h, s, v = RGBToHSV(r, g, b)
                UpdateDisplay()
                callback(currentColor)
            end
        end
    end)
    
    -- Initial display
    UpdateDisplay()
    
    return {
        GetColor = function() return currentColor end,
        SetColor = function(c)
            currentColor = c
            h, s, v = RGBToHSV(c.R * 255, c.G * 255, c.B * 255)
            UpdateDisplay()
            callback(currentColor)
        end,
        Container = container
    }
end

-- ═══════════════ RIPPLE EFFECT ═══════════════
local function AddRipple(button, color)
    button.ClipsDescendants = true
    
    local function createRipple(x, y)
        local ripple = New("Frame", {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0, x - button.AbsolutePosition.X, 0, y - button.AbsolutePosition.Y),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = color or Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 0.7,
            ZIndex = button.ZIndex + 1,
            Parent = button
        })
        Corner(ripple, UDim.new(1, 0))
        local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
        Tween(ripple, {
            Size = UDim2.new(0, maxSize, 0, maxSize)
        }, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        Tween(ripple, {
            BackgroundTransparency = 1
        }, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        task.delay(0.5, function()
            ripple:Destroy()
        end)
    end
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            createRipple(input.Position.X, input.Position.Y)
        elseif input.UserInputType == Enum.UserInputType.Touch then
            createRipple(input.Position.X, input.Position.Y)
        end
    end)
end

-- ═══════════════ DRAGGABLE ═══════════════
local function MakeDraggable(frame, dragHandle)
    dragHandle = dragHandle or frame
    local dragging, dragInput, dragStart, startPos

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

