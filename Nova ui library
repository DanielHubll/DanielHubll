function Library:AddTab(name, icon)
    local tab = {}
    tab.Name = name
    tab.Icon = icon
    tab.Order = self.TabCount
    self.TabCount = self.TabCount + 1

    local mob = Mobile()
    local tabW = icon and icon ~= "" and (mob and 52 or 58) or (mob and 80 or 110)

    -- Tab button
    tab.Btn = New("TextButton", {
        Size = UDim2.new(0, tabW, 1, -4),
        Position = UDim2.new(0, 0, 0, 2),
        BackgroundColor3 = Theme.BgDark,
        BackgroundTransparency = 1,
        AutoButtonColor = false,
        LayoutOrder = tab.Order,
        Parent = self.TabBar
    })
    Rnd(tab.Btn, Cfg.RadiusSm)

    -- Icon image
    if icon and icon ~= "" then
        tab.IconImg = New("ImageLabel", {
            Size = UDim2.new(0, 18, 0, 18),
            Position = UDim2.new(0.5, -9, 0.5, -9),
            BackgroundTransparency = 1,
            Image = icon,
            ImageColor3 = Theme.TextDim,
            ScaleType = Enum.ScaleType.Fit,
            Parent = tab.Btn
        })
    else
        tab.IconImg = nil
        tab.Btn.Text = name
        tab.Btn.TextColor3 = Theme.TextDim
        tab.Btn.TextSize = mob and 11 or 12
        tab.Btn.Font = Cfg.Font
        tab.Btn.TextTruncate = Enum.TextTruncate.AtEnd
    end

    -- Tooltip para tabs com ícone
    local tooltip = nil
    if icon and icon ~= "" then
        tooltip = New("Frame", {
            Size = UDim2.new(0, #name * 7 + 16, 0, 24),
            Position = UDim2.new(0.5, 0, 1, 6),
            AnchorPoint = Vector2.new(0.5, 0),
            BackgroundColor3 = Theme.SurfaceLight,
            Visible = false,
            ZIndex = 50,
            Parent = tab.Btn
        })
        Rnd(tooltip, Cfg.RadiusXs)
        Str(tooltip, Theme.Border, 1)
        New("TextLabel", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
