                TextWrapped = true,
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = FromRGB(255, 255, 255)
            })
            
            table.insert(Console.Messages, MessageLabel)
            
            if #Console.Messages > Console.MaxMessages then
                local oldMessage = table.remove(Console.Messages, 1)
                if oldMessage and oldMessage.Instance then
                    oldMessage:Clean()
                end
            end
            
            -- Auto-scroll para baixo
            MessageArea.Instance.CanvasPosition = Vector2New(0, MessageArea.Instance.CanvasSize.Y)
        end
        
        function Console:Clear()
            for _, msg in ipairs(Console.Messages) do
                if msg and msg.Instance then
                    msg:Clean()
                end
