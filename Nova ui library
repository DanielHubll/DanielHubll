                    Position = UDim2.new(0, 0, 0, 22),
                    BackgroundColor3 = Theme.Input,
                    Text = "",
                    AutoButtonColor = false,
                    Parent = holder,
                })
                Utils.RoundCorners(dropdownBtn, 8)
                Utils.AddStroke(dropdownBtn, Theme.InputBorder, 1)

                local selectedLabel = Utils.Create("TextLabel", {
                    Size = UDim2.new(1, -30, 1, 0),
                    Position = UDim2.new(0, 12, 0, 0),
                    BackgroundTransparency = 1,
                    Text = multi and (#selected > 0 and table.concat(selected, ", ") or "Selecione...") or (selected ~= "" and selected or "Selecione..."),
                    TextColor3 = Theme.TextDim,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = dropdownBtn,
                })

                local arrowIcon = Utils.Create("TextLabel", {
                    Size = UDim2.new(0, 20, 1, 0),
                    Position = UDim2.new(1, -25, 0, 0),
                    BackgroundTransparency = 1,
                    Text = "▼",
                    TextColor3 = Theme.TextDark,
                    TextSize = 10,
                    Font = Enum.Font.GothamBold,
                    Parent = dropdownBtn,
                })

                local listFrame = Utils.Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 1, 4),
                    BackgroundColor3 = Theme.BackgroundLight,
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 20,
                    Parent = dropdownBtn,
                })
                Utils.RoundCorners(listFrame, 8)
                Utils.AddStroke(listFrame, Theme.SectionBorder, 1)

                local listLayout = Instance.new("UIListLayout")
                listLayout.Padding = UDim.new(0, 2)
                listLayout.SortOrder = Enum.SortOrder.LayoutOrder
                listLayout.Parent = listFrame

                local listPadding = Instance.new("UIPadding")
                listPadding.PaddingTop = UDim.new(0, 4)
                listPadding.PaddingBottom = UDim.new(0, 4)
                listPadding.Parent = listFrame

                local optionButtons = {}

                local function updateDisplay()
                    if multi then
                        selectedLabel.Text = #selected > 0 and table.concat(selected, ", ") or "Selecione..."
                    else
                        selectedLabel.Text = selected ~= "" and selected or "Selecione..."
                    end
                end

                local function populateOptions()
                    for _, child in ipairs(listFrame:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end
                    optionButtons = {}

                    for _, option in ipairs(options) do
                        local isSelected
                        if multi then
                            isSelected = table.find(selected, option) ~= nil
                        else
                            isSelected = option == selected
                        end

                        local optBtn = Utils.Create("TextButton", {
                            Size = UDim2.new(1, -8, 0, 30),
                            BackgroundColor3 = isSelected and Theme.AccentDark or Theme.BackgroundLight,
                            BackgroundTransparency = isSelected and 0.3 or 1,
                            Text = "  " .. option,
                            TextColor3 = isSelected and Theme.Text or Theme.TextDim,
                            TextSize = 12,
                            Font = Enum.Font.Gotham,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            AutoButtonColor = false,
                            ZIndex = 21,
                            Parent = listFrame,
                        })
                        Utils.RoundCorners(optBtn, 6)
                        table.insert(optionButtons, optBtn)

                        optBtn.MouseEnter:Connect(function()
                            if not (multi and table.find(selected, option)) and not (not multi and option == selected) then
                                Utils.Tween(optBtn, 0.12, nil, nil, {BackgroundTransparency = 0.7, BackgroundColor3 = Theme.BackgroundLight})
                            end
                        end)
                        optBtn.MouseLeave:Connect(function()
                            if not (multi and table.find(selected, option)) and not (not multi and option == selected) then
                                Utils.Tween(optBtn, 0.12, nil, nil, {BackgroundTransparency = 1, BackgroundColor3 = Theme.BackgroundLight})
                            end
                        end)

                        optBtn.MouseButton1Click:Connect(function()
                            if multi then
                                local idx = table.find(selected, option)
                                if idx then
                                    table.remove(selected, idx)
                                else
                                    table.insert(selected, option)
                                end
                                updateDisplay()
                                populateOptions()
                                task.spawn(callback, selected)
                            else
                                selected = option
                                updateDisplay()
                                isOpen = false
                                listFrame.Visible = false
                                Utils.Tween(arrowIcon, 0.2, nil, nil, {Rotation = 0})
                                populateOptions()
                                task.spawn(callback, selected)
                            end
                        end)
                    end

                    listFrame.Size = UDim2.new(1, 0, 0, math.min(#options * 32 + 8, 160))
                end

                populateOptions()

                dropdownBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    listFrame.Visible = isOpen
                    Utils.Tween(arrowIcon, 0.2, nil, nil, {Rotation = isOpen and 180 or 0})
                end)

                return {
                    Set = function(self, val)
                        if multi then
                            selected = type(val) == "table" and val or {val}
                        else
                            selected = val
                        end
                        updateDisplay()
                        populateOptions()
                        task.spawn(callback, selected)
                    end,
                    Get = function(self)
                        return selected
                    end,
                    SetOptions = function(self, newOptions)
                        options = newOptions
                        populateOptions()
                    end,
                }
            end

