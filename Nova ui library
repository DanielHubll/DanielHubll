                Tw(swatch, {BackgroundColor3 = color}, 0.08)
                swatch:FindFirstChild("TextLabel").Text = ColorToHex(color)

                -- Determine text color on swatch
                local _, _, bv = RGBtoHSV(color)
                swatch:FindFirstChild("TextLabel").TextColor3 = bv > 0.5 and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)

                if not hexInput:IsFocused() then
                    hexInput.Text = ColorToHex(color)
                end
                if not rBox:IsFocused() then
                    rBox.Text = tostring(math.floor(color.R * 255))
                end
                if not gBox:IsFocused() then
