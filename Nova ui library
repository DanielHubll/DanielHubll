    AddStroke(OptionsContainer, Theme.Border, 0.5)

    local OptionsLayout = Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 0),
        Parent = OptionsContainer
    })

    -- Build option buttons
    for i, option in ipairs(options) do
        local OptionBtn = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 32),
            BackgroundColor3 = option == selected and Theme.Accent or Color3.fromRGB(255,255,255),
            BackgroundTransparency = option == selected and 0.8 or 1,
            Text = "  " .. option,
            TextColor3 = option == selected and Theme.AccentLight or Theme.TextSecondary,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
            LayoutOrder = i,
            Parent = OptionsContainer
        })

        OptionBtn.MouseEnter:Connect(function()
            Tween(OptionBtn, 0.15, {BackgroundTransparency = 0.8, BackgroundColor3 = Theme.Accent})
        end)
        OptionBtn.MouseLeave:Connect(function()
            if option ~= selected then
                Tween(OptionBtn, 0.15, {BackgroundTransparency = 1, BackgroundColor3 = Color3.fromRGB(255,255,255)})
            end
        end)

        OptionBtn.MouseButton1Click:Connect(function()
            selected = option
            SelectedLabel.Text = option

            -- Update all option buttons
            for _, child in ipairs(OptionsContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    if child.Text:find(option) then
                        Tween(child, 0.2, {BackgroundTransparency = 0.8, BackgroundColor3 = Theme.Accent, TextColor3 = Theme.AccentLight})
                    else
                        Tween(child, 0.2, {BackgroundTransparency = 1, BackgroundColor3 = Color3.fromRGB(255,255,255), TextColor3 = Theme.TextSecondary})
                    end
                end
            end

            -- Close dropdown
            isOpen = false
            Tween(OptionsContainer, 0.3, {Size = UDim2.new(1, -24, 0, 0)})
            Tween(DropdownFrame, 0.3, {Size = UDim2.new(1, 0, 0, 52)})
            Tween(ChevronLabel, 0.3, {Rotation = 0})

            if callback then callback(option) end
        end)
    end

    DropdownBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            local optionCount = #options
            local expandedHeight = 52 + (optionCount * 32) + 8
            SpringTween(DropdownFrame, 0.3)
            Tween(DropdownFrame, 0.3, {Size = UDim2.new(1, 0, 0, expandedHeight)})
            Tween(OptionsContainer, 0.3, {Size = UDim2.new(1, -24, 0, optionCount * 32)})
            OptionsContainer.Visible = true
            Tween(ChevronLabel, 0.3, {Rotation = 180})
        else
            Tween(DropdownFrame, 0.3, {Size = UDim2.new(1, 0, 0, 52)})
            Tween(OptionsContainer, 0.3, {Size = UDim2.new(1, -24, 0, 0)})
            Tween(ChevronLabel, 0.3, {Rotation = 0})
            task.delay(0.3, function()
                if not isOpen then OptionsContainer.Visible = false end
            end)
        end
    end)

    -- Hover
    DropdownBtn.MouseEnter:Connect(function()
        Tween(DropdownFrame, 0.2, {BackgroundColor3 = Theme.CardBgHover, BackgroundTransparency = 0.5})
    end)
    DropdownBtn.MouseLeave:Connect(function()
        Tween(DropdownFrame, 0.2, {BackgroundColor3 = Color3.fromRGB(255,255,255), BackgroundTransparency = 1})
    end)

    return {
        Frame = DropdownFrame,
        Set = function(option)
            selected = option
            SelectedLabel.Text = option
        end,
        Get = function() return selected end
    }
end

