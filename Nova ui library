		end

		function Tab:CreateSlider(cfg)
			local min, max, value = cfg.Min or 0, cfg.Max or 100, cfg.Default or 0
			local Card = BaseCard(cfg.Title or "Slider", cfg.Desc or "")
			local ValueTag = New("Frame", { BackgroundColor3 = Theme.Panel, Size = UDim2.new(0, 52, 0, 22), Position = UDim2.new(1, -52, 0, -2), Parent = Card })
			Corner(ValueTag, 6)
