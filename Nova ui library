        if listening then return end
        listening = true
        keyDisplay.Text = "..."
        keyDisplay.TextColor3 = Theme.Accent
        Utils.Tween(keyStroke, Animations.Fast, {Color = Theme.Accent})
        
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
