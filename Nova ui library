                    countLabel.Text = count .. " selecionados"
                    pcall(callback, selected)
                end)

                optBtn.MouseEnter:Connect(function()
                    Tween(optBtn, 0.1, { BackgroundColor3 = Theme.Input, BackgroundTransparency = 0.3 })
                end)
                optBtn.MouseLeave:Connect(function()
                    Tween(optBtn, 0.1, { BackgroundTransparency = 1 })
                end)
            end

            local clickBtn = Make("TextButton", {
                Size = UDim2.new(1, 0, 0, 48),
                Text = "",
                BackgroundTransparency = 1,
                ZIndex = 12,
                Parent = row,
            })

            clickBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    dropFrame.Visible = true
                    local h = math.min(#optList * 34, 170)
                    row.Size = UDim2.new(1, 0, 0, 48 + h + 6)
                    Tween(chevron, 0.2, { Rotation = 180 })
                    Tween(dropFrame, 0.25, { Size = UDim2.new(1, -28, 0, h) })
                else
                    Tween(chevron, 0.2, { Rotation = 0 })
                    Tween(dropFrame, 0.2, { Size = UDim2.new(1, -28, 0, 0) })
                    task.delay(0.2, function()
                        dropFrame.Visible = false
                        row.Size = UDim2.new(1, 0, 0, 48)
                    end)
                end
            end)

            Make("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 0, 47),
                BackgroundColor3 = Theme.Sep,
                Transparency = 0.5,
                Parent = row,
            })

            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)

            return {
                GetSelected = function() return selected end,
            }
        end

        -- ───────────────────────────────────────────────────────────
        -- BADGE
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddBadge(options)
            local opts = options or {}
            local text = opts.Text or "New"
            local color = opts.Color or Theme.Accent

            local ts = GetTextSize(text, 10, Enum.Font.GothamBold)
            local w = ts.X + 12

            local row = Make("Frame", {
                Size = UDim2.new(0, w + 28, 0, 32),
                BackgroundTransparency = 1,
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            local badge = Make("Frame", {
                Size = UDim2.fromOffset(w, 20),
                Position = UDim2.new(0, 14, 0.5, -10),
                BackgroundColor3 = color,
                BackgroundTransparency = 0.85,
                Parent = row,
            })
            Make("UICorner", { CornerRadius = UDim.new(0, 4), Parent = badge })

            Make("TextLabel", {
                Size = UDim2.new(1, -8, 1, 0),
                Position = UDim2.new(0, 4, 0, 0),
                Text = text,
                Font = Enum.Font.GothamBold,
                TextSize = 10,
                TextColor3 = color,
                BackgroundTransparency = 1,
                Parent = badge,
            })

            table.insert(section.Components, row)
            return row
        end

        -- ───────────────────────────────────────────────────────────
        -- CHIPS
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddChips(options)
            local opts = options or {}
            local optList = opts.Options or {}
            local defaults = opts.Default or {}
            local callback = opts.Callback or function() end
            local multi = opts.MultiSelect ~= false

            local selected = {}
            for _, v in ipairs(defaults) do selected[v] = true end

            local row = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 50),
                BackgroundTransparency = 1,
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            Make("UIPadding", {
                PaddingLeft = UDim.new(0, 14),
                PaddingTop = UDim.new(0, 10),
                Parent = row,
            })

            local chipLayout = Make("UIListLayout", {
                Padding = UDim.new(0, 6),
                FillDirection = Enum.FillDirection.Horizontal,
                SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center,
                Parent = row,
            })

            for _, option in ipairs(optList) do
                local isSel = selected[option] or false
                local ts = GetTextSize(option, 12, Enum.Font.Gotham)
                local chipW = ts.X + 20

                local chip = Make("Frame", {
                    Size = UDim2.fromOffset(chipW, 28),
                    BackgroundColor3 = isSel and Theme.Accent or Theme.Input,
                    LayoutOrder = #row:GetChildren(),
                    Parent = row,
                })
                Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = chip })

                local chipLabel = Make("TextLabel", {
                    Size = UDim2.new(1, -16, 1, 0),
                    Position = UDim2.new(0, 8, 0, 0),
                    Text = option,
                    Font = isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = isSel and Theme.White or Theme.Text,
                    BackgroundTransparency = 1,
                    Parent = chip,
                })

                local chipBtn = Make("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    BackgroundTransparency = 1,
                    Parent = chip,
                })

                chipBtn.MouseButton1Click:Connect(function()
                    if multi then
                        selected[option] = not selected[option]
                    else
                        selected = {}
                        selected[option] = true
                    end

                    local nowSel = selected[option]
                    Tween(chip, 0.2, {
                        BackgroundColor3 = nowSel and Theme.Accent or Theme.Input,
                    })
                    chipLabel.Font = nowSel and Enum.Font.GothamBold or Enum.Font.Gotham
                    chipLabel.TextColor3 = nowSel and Theme.White or Theme.Text

                    pcall(callback, selected)
                end)
            end

            chipLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                row.Size = UDim2.new(1, 0, 0, chipLayout.AbsoluteContentSize.Y + 20)
            end)

            table.insert(tab.Components, { SearchName = "Chips", Container = row })
            table.insert(section.Components, row)

            return {
                GetSelected = function() return selected end,
            }
        end

        return secAPI
    end

    return tabAPI
end

-- ═══════════════════════════════════════════════════════════════════
-- SELECT TAB
-- ═══════════════════════════════════════════════════════════════════
function Library:SelectTab(tabId)
    self._activeTabId = tabId

    for _, tab in ipairs(self._tabs) do
        local isActive = tab.Id == tabId

        Tween(tab.TabButton, 0.2, {
            BackgroundColor3 = isActive and Theme.Card or Theme.Bg,
            BackgroundTransparency = isActive and 0 or 1,
        })
        Tween(tab.TabLabel, 0.2, {
            TextColor3 = isActive and Theme.Accent or Theme.SubText,
        })

        -- Mostra/esconde seções
        for _, section in ipairs(tab.Sections) do
            if section.Container then
                section.Container.Visible = isActive
            end
        end
    end
end

-- ═══════════════════════════════════════════════════════════════════
-- DESTROY
-- ═══════════════════════════════════════════════════════════════════
function Library:Destroy()
    -- Reseta cursor se estiver na alça
    UserInputService.MouseIcon = ""
    
    for _, conn in ipairs(self._connections) do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
    self._connections = {}
    if self._screenGui then
        self._screenGui:Destroy()
    end
end

-- ═══════════════════════════════════════════════════════════════════
-- GLOBAL NOTIFICATION
-- ═══════════════════════════════════════════════════════════════════
Library.Notify = Notify
Library.Popup = ShowPopup

function Library.Confirm(title, msg, onYes, onNo, parentGui)
    return ShowPopup({
        Title = title,
        Message = msg,
        Buttons = {
            { Text = "Cancelar", Primary = false },
            { Text = "Confirmar", Primary = true },
        },
        Callback = function(idx)
            if idx == 2 and onYes then onYes() end
            if idx == 1 and onNo then onNo() end
        end,
    }, parentGui)
end

-- ═══════════════════════════════════════════════════════════════════
return Library
