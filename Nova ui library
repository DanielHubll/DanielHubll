            function Section:AddDropdown(config)
                local dConfig = config or {}
                local dName = dConfig.Name or "Dropdown"
                local options = dConfig.Options or {}
                local default = dConfig.Default or ""
                local callback = dConfig.Callback or function() end
                local multi = dConfig.Multi or false

                local selected = multi and {} or default
                local isOpen = false

                local holder = Utils.Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 36),
                    BackgroundTransparency = 1,
                    ClipsDescendants = false,
