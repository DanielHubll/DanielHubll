            local bgColor = style == "Filled" and Theme.Accent or style == "Danger" and Theme.Red or Theme.Input
            
            -- Ícone do botão
            if opts.Icon then
                local iconBtn = Icon(opts.Icon, 16, row)
                if iconBtn then
                    iconBtn.Position = UDim2.new(0, 14, 0.5, -8)
                end
                local btn = Make("TextButton", { Size = UDim2.new(1, -48, 0, 38), Position = UDim2.new(0, 38, 0, 5), Text = name, Font = Enum.Font.GothamSemibold, TextSize = 13, TextColor3 = style == "Default" and Theme.Text or Theme.White, BackgroundColor3 = bgColor, AutoButtonColor = false, Parent = row })
                Make("UICorner", { CornerRadius = UDim.new(0, 10), Parent = btn })
                btn.MouseButton1Click:Connect(function() Tween(btn, 0.08, { Size = UDim2.new(1, -54, 0, 36) }); task.delay(0.1, function() Tween(btn, 0.15, { Size = UDim2.new(1, -48, 0, 38) }) end); pcall(callback) end)
                btn.MouseEnter:Connect(function() Tween(btn, 0.12, { BackgroundTransparency = 0.2 }) end)
                btn.MouseLeave:Connect(function() Tween(btn, 0.12, { BackgroundTransparency = 0 }) end)
            else
                local btn = Make("TextButton", { Size = UDim2.new(1, -28, 0, 38), Position = UDim2.new(0, 14, 0, 5), Text = name, Font = Enum.Font.GothamSemibold, TextSize = 13, TextColor3 = style == "Default" and Theme.Text or Theme.White, BackgroundColor3 = bgColor, AutoButtonColor = false, Parent = row })
                Make("UICorner", { CornerRadius = UDim.new(0, 10), Parent = btn })
                btn.MouseButton1Click:Connect(function() Tween(btn, 0.08, { Size = UDim2.new(1, -34, 0, 36) }); task.delay(0.1, function() Tween(btn, 0.15, { Size = UDim2.new(1, -28, 0, 38) }) end); pcall(callback) end)
                btn.MouseEnter:Connect(function() Tween(btn, 0.12, { BackgroundTransparency = 0.2 }) end)
                btn.MouseLeave:Connect(function() Tween(btn, 0.12, { BackgroundTransparency = 0 }) end)
            end
            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)
            return row
        end

        -- TOGGLE
        function secAPI:AddToggle(options)
            local opts = options or {}
            local name = opts.Name or "Toggle"
            local default = opts.Default or false
            local callback = opts.Callback or function() end
            local isOn = default
            local row = Make("Frame", { Size = UDim2.new(1, 0, 0, 48), BackgroundTransparency = 1, LayoutOrder = getOrder(), Parent = sectionFrame })
            
            -- Ícone do toggle
            local iconOffset = 0
            if opts.Icon then
                Icon(opts.Icon, 18, row, nil)
                if row:FindFirstChild("Icon") then
                    row.Icon.Position = UDim2.new(0, 14, 0.5, -9)
                end
                iconOffset = 30
            end
            
            Make("TextLabel", { Size = UDim2.new(1, -80 - iconOffset, 1, 0), Position = UDim2.new(0, 14 + iconOffset, 0, 0), Text = name, Font = Enum.Font.Gotham, TextSize = 14, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = row })
            local toggleBg = Make("Frame", { Size = UDim2.fromOffset(50, 30), Position = UDim2.new(1, -64, 0.5, -15), BackgroundColor3 = isOn and Theme.ToggleOn or Theme.ToggleOff, Parent = row })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = toggleBg })
            
            -- Ícone on/off no toggle
            local toggleKnob = Make("Frame", { Size = UDim2.fromOffset(26, 26), Position = isOn and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13), BackgroundColor3 = Theme.White, Parent = toggleBg })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = toggleKnob })
            Make("UIStroke", { Color = Color3.new(0,0,0), Thickness = 0.5, Transparency = 0.85, Parent = toggleKnob })
            
            local clickArea = Make("TextButton", { Size = UDim2.fromOffset(54, 34), Position = UDim2.new(1, -66, 0.5, -17), Text = "", BackgroundTransparency = 1, Parent = row })
            local function setToggle(val, animate) 
                isOn = val; 
                local dur = (animate ~= false) and 0.2 or 0; 
                Tween(toggleBg, dur, { BackgroundColor3 = isOn and Theme.ToggleOn or Theme.ToggleOff }); 
                Tween(toggleKnob, dur, { Position = isOn and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13) }); 
                pcall(callback, isOn) 
            end
            clickArea.MouseButton1Click:Connect(function() setToggle(not isOn, true) end)
            row.MouseEnter:Connect(function() Tween(row, 0.12, { BackgroundColor3 = Theme.Input, BackgroundTransparency = 0.5 }) end)
            row.MouseLeave:Connect(function() Tween(row, 0.12, { BackgroundTransparency = 1 }) end)
            Make("Frame", { Size = UDim2.new(1, -28, 0, 1), Position = UDim2.new(0, 14, 1, -1), BackgroundColor3 = Theme.Sep, Transparency = 0.5, Parent = row })
            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)
            return { SetValue = function(v) setToggle(v, true) end, GetValue = function() return isOn end }
        end

        -- SLIDER
        function secAPI:AddSlider(options)
            local opts = options or {}
            local name = opts.Name or "Slider"
            local min = opts.Min or 0
            local max = opts.Max or 100
            local default = opts.Default or min
            local step = opts.Step or 1
            local suffix = opts.Suffix or ""
            local callback = opts.Callback or function() end
            local value = default
            local row = Make("Frame", { Size = UDim2.new(1, 0, 0, 68), BackgroundTransparency = 1, LayoutOrder = getOrder(), Parent = sectionFrame })
            
            -- Ícone do slider
            if opts.Icon then
                Icon(opts.Icon, 18, row)
                if row:FindFirstChild("Icon") then
                    row.Icon.Position = UDim2.new(0, 14, 0, 10)
                end
                Make("TextLabel", { Size = UDim2.new(0.5, -30, 0, 20), Position = UDim2.new(0, 40, 0, 8), Text = name, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = row })
            else
                Make("TextLabel", { Size = UDim2.new(0.5, 0, 0, 20), Position = UDim2.new(0, 14, 0, 8), Text = name, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = row })
            end
            
            local valLabel = Make("TextLabel", { Size = UDim2.new(0.4, -14, 0, 20), Position = UDim2.new(0.5, 0, 0, 8), Text = value .. suffix, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = Theme.Accent, TextXAlignment = Enum.TextXAlignment.Right, BackgroundTransparency = 1, Parent = row })
            local track = Make("Frame", { Size = UDim2.new(1, -28, 0, 6), Position = UDim2.new(0, 14, 0, 42), BackgroundColor3 = Theme.Input, Parent = row })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })
            local pct = (value - min) / math.max(1, max - min)
            local fill = Make("Frame", { Size = UDim2.new(pct, 0, 1, 0), BackgroundColor3 = Theme.Accent, Parent = track })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })
            local knob = Make("Frame", { Size = UDim2.fromOffset(20, 20), Position = UDim2.new(pct, -10, 0.5, -10), BackgroundColor3 = Theme.White, ZIndex = 2, Parent = track })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })
            Make("UIStroke", { Color = Color3.new(0,0,0), Thickness = 0.5, Transparency = 0.8, Parent = knob })
            local draggingSlider = false
            local function updateSlider(newVal) value = math.clamp(math.floor(newVal / step + 0.5) * step, min, max); local p = (value - min) / math.max(1, max - min); fill.Size = UDim2.new(p, 0, 1, 0); knob.Position = UDim2.new(p, -10, 0.5, -10); valLabel.Text = value .. suffix; pcall(callback, value) end
            track.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingSlider = true; local rel = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X; updateSlider(min + rel * (max - min)) end end)
            Track(UserInputService.InputChanged:Connect(function(input) if not draggingSlider then return end; if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1); updateSlider(min + rel * (max - min)) end end))
            Track(UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingSlider = false end end))
            knob.MouseEnter:Connect(function() Tween(knob, 0.12, { Size = UDim2.fromOffset(24, 24) }) end)
            knob.MouseLeave:Connect(function() Tween(knob, 0.12, { Size = UDim2.fromOffset(20, 20) }) end)
            Make("Frame", { Size = UDim2.new(1, -28, 0, 1), Position = UDim2.new(0, 14, 1, -1), BackgroundColor3 = Theme.Sep, Transparency = 0.5, Parent = row })
            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)
            return { SetValue = function(v) updateSlider(v) end, GetValue = function() return value end }
        end

        -- DROPDOWN
