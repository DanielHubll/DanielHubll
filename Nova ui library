		----------------------------------------------------------------
		function Tab:CreateSlider(cfg)
			cfg = cfg or {}
			local min, max = cfg.Min or 0, cfg.Max or 100
			local value = cfg.Default or min
			local suffix = cfg.Suffix or ""

			local Card = BaseCard(cfg.Title or "Slider", cfg.Desc or "")

			local ValueTag = New("Frame", {
				BackgroundColor3 = Theme.Panel,
				Size = UDim2.new(0, IsMobile and 44 or 52, 0, 22),
				Position = UDim2.new(1, -(IsMobile and 44 or 52), 0, -2),
				Parent = Card,
			})
			Corner(ValueTag, 6)
			local ValueLabel = New("TextLabel", {
				Text = tostring(value) .. suffix,
				Font = FontSemi,
				TextSize = IsMobile and 11 or 12,
				TextColor3 = Theme.Text,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 1, 0),
				Parent = ValueTag,
			})

			local trackH = IsMobile and 6 or 6
			local Track = New("Frame", {
				BackgroundColor3 = Theme.Border,
				Size = UDim2.new(1, 0, 0, trackH),
				Position = UDim2.new(0, 0, 1, -10),
				Parent = Card,
			})
			Corner(Track, 3)
			local Fill = New("Frame", {
				BackgroundColor3 = Theme.Accent,
				Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
				Parent = Track,
			})
			Corner(Fill, 3)
			local knobSize = IsMobile and 14 or 14
			local Knob = New("Frame", {
				BackgroundColor3 = Color3.new(1, 1, 1),
				Size = UDim2.new(0, knobSize, 0, knobSize),
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
				Parent = Track,
			})
			Corner(Knob, knobSize / 2)

			local Slider = {}
			local dragging = false

			local function update(inputPos)
				local rel = math.clamp((inputPos - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
				value = math.floor(min + (max - min) * rel)
				Fill.Size = UDim2.new(rel, 0, 1, 0)
				Knob.Position = UDim2.new(rel, 0, 0.5, 0)
				ValueLabel.Text = tostring(value) .. suffix
				if cfg.Flag then Library.Flags[cfg.Flag] = value end
				if cfg.Callback then task.spawn(cfg.Callback, value) end
			end

			Track.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					update(input.Position.X)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input.Position.X)
				end
			end)

			function Slider:Set(v)
				local rel = math.clamp((v - min) / (max - min), 0, 1)
				value = v
				Fill.Size = UDim2.new(rel, 0, 1, 0)
				Knob.Position = UDim2.new(rel, 0, 0.5, 0)
				ValueLabel.Text = tostring(value) .. suffix
			end

			if cfg.Flag then Library.Flags[cfg.Flag] = value end
			return Slider
		end

