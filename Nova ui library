        -- ═══ SLIDER ═══
        function section:AddSlider(text, min, max, default, callback, options)
            callback = callback or function() end
            options = options or {}
            min = min or 0
            max = max or 100
            default = default or min
            local value = default
            local decimals = options.Decimals or 0

            local frame = New("Frame", {
                Size = UDim2.new(1, -12, 0, 50),
                Position = UDim2.new(0, 6, 0, 0),
                BackgroundTransparency = 1,
                LayoutOrder = section.ItemOrder,
                Parent = section.Frame
            })
            section.ItemOrder = section.ItemOrder + 1

            local label = New("TextLabel", {
                Size = UDim2.new(1, -60, 0, 18),
                Position = UDim2.new(0, 4, 0, 2),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 13,
                Font = Config.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = frame
            })

            local valueLabel = New("TextLabel", {
                Size = UDim2.new(0, 55, 0, 18),
                Position = UDim2.new(1, -59, 0, 2),
                BackgroundTransparency = 1,
                Text = string.format("%." .. decimals .. "f", value),
                TextColor3 = Theme.TextDim,
                TextSize = 12,
                Font = Config.FontBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = frame
            })

            local sliderBg = New("Frame", {
                Size = UDim2.new(1, -8, 0, 8),
                Position = UDim2.new(0, 4, 0, 28),
                BackgroundColor3 = Theme.SliderBg,
                Parent = frame
            })
            Corner(sliderBg, UDim.new(1, 0))

            local sliderFill = New("Frame", {
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.SliderFill,
                Parent = sliderBg
            })
            Corner(sliderFill, UDim.new(1, 0))

            local sliderHandle = New("Frame", {
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7),
                BackgroundColor3 = Theme.Accent,
                Parent = sliderBg
            })
            Corner(sliderHandle, UDim.new(1, 0))
            Stroke(sliderHandle, Theme.Background, 2)

            local function SetValue(newVal)
                newVal = math.clamp(newVal, min, max)
                value = newVal
                local pct = (value - min) / (max - min)
                Tween(sliderFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.08)
                Tween(sliderHandle, {Position = UDim2.new(pct, -7, 0.5, -7)}, 0.08)
                valueLabel.Text = string.format("%." .. decimals .. "f", value)
                task.spawn(callback, value)
            end

            local sliderBtn = New("TextButton", {
                Size = UDim2.new(1, 10, 0, 20),
                Position = UDim2.new(0, -5, 0, 24),
                BackgroundTransparency = 1,
                Text = "",
                Parent = frame
            })

            local sliding = false

            sliderBtn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                end
            end)

            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)

            UIS.InputChanged:Connect(function(input)
                if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or
                    input.UserInputType == Enum.UserInputType.Touch) then
                    local rel = (input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
                    SetValue(min + (max - min) * math.clamp(rel, 0, 1))
                end
            end)

            SetValue(value)

            return {
                SetValue = function(self, v) SetValue(v) end,
                GetValue = function() return value end
            }
        end

        -- ═══ DROPDOWN ═══
        function section:AddDropdown(text, options, default, callback)
            callback = callback or function() end
            options = options or {}
            local selected = default or (options[1] and options[1]) or ""
            local isOpen = false

            local frame = New("Frame", {
                Size = UDim2.new(1, -12, 0, 50),
                Position = UDim2.new(0, 6, 0, 0),
                BackgroundTransparency = 1,
                LayoutOrder = section.ItemOrder,
                Parent = section.Frame
            })
            section.ItemOrder = section.ItemOrder + 1

            local label = New("TextLabel", {
                Size = UDim2.new(1, -8, 0, 16),
                Position = UDim2.new(0, 4, 0, 2),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 13,
                Font = Config.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = frame
            })

            local dropBtn = New("TextButton", {
                Size = UDim2.new(1, -8, 0, 28),
                Position = UDim2.new(0, 4, 0, 20),
                BackgroundColor3 = Theme.SurfaceLight,
                Text = "  " .. tostring(selected) .. "                              ▾",
                TextColor3 = Theme.Text,
                TextSize = 12,
                Font = Config.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                AutoButtonColor = false,
                Parent = frame
            })
            Corner(dropBtn, Config.SmallRadius)
            Stroke(dropBtn, Theme.Border, 1)

            -- Dropdown list
            local listFrame = New("Frame", {
                Size = UDim2.new(1, -8, 0, 0),
                Position = UDim2.new(0, 4, 0, 50),
                BackgroundColor3 = Theme.BackgroundLight,
                ClipsDescendants = true,
                ZIndex = 20,
                Visible = false,
                Parent = frame
            })
            Corner(listFrame, Config.SmallRadius)
            Stroke(listFrame, Theme.Border, 1)

            local listLayout = New("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = listFrame
            })

            listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                if isOpen then
                    listFrame.Size = UDim2.new(1, -8, 0, math.min(listLayout.AbsoluteContentSize.Y, 150))
                    frame.Size = UDim2.new(1, -12, 0, 52 + math.min(listLayout.AbsoluteContentSize.Y, 150))
                end
            end)

            local function PopulateList()
                for _, child in pairs(listFrame:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                for i, opt in ipairs(options) do
                    local optBtn = New("TextButton", {
                        Size = UDim2.new(1, 0, 0, 28),
                        BackgroundColor3 = Theme.BackgroundLight,
                        BackgroundTransparency = 1,
                        Text = "  " .. tostring(opt),
                        TextColor3 = opt == selected and Theme.Accent or Theme.TextDim,
                        TextSize = 12,
                        Font = opt == selected and Config.FontBold or Config.Font,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        AutoButtonColor = false,
                        ZIndex = 21,
                        LayoutOrder = i,
                        Parent = listFrame
                    })
                    optBtn.MouseEnter:Connect(function()
                        Tween(optBtn, {BackgroundTransparency = 0.7, BackgroundColor3 = Theme.SurfaceHover}, 0.1)
                    end)
                    optBtn.MouseLeave:Connect(function()
                        Tween(optBtn, {BackgroundTransparency = 1, BackgroundColor3 = Theme.BackgroundLight}, 0.1)
                    end)
                    optBtn.MouseButton1Click:Connect(function()
                        selected = opt
                        dropBtn.Text = "  " .. tostring(selected) .. "                              ▾"
                        isOpen = false
                        Tween(listFrame, {Size = UDim2.new(1, -8, 0, 0)}, 0.2)
                        Tween(frame, {Size = UDim2.new(1, -12, 0, 50)}, 0.2)
                        task.delay(0.2, function()
                            listFrame.Visible = false
                        end)
                        PopulateList()
                        task.spawn(callback, selected)
                    end)
                end
            end

            PopulateList()

            dropBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    listFrame.Visible = true
                    PopulateList()
                    local h = math.min(listLayout.AbsoluteContentSize.Y, 150)
                    Tween(listFrame, {Size = UDim2.new(1, -8, 0, h)}, 0.2)
                    Tween(frame, {Size = UDim2.new(1, -12, 0, 52 + h)}, 0.2)
                else
                    Tween(listFrame, {Size = UDim2.new(1, -8, 0, 0)}, 0.2)
                    Tween(frame, {Size = UDim2.new(1, -12, 0, 50)}, 0.2)
                    task.delay(0.2, function()
                        listFrame.Visible = false
                    end)
                end
            end)

            return {
                SetValue = function(self, v)
                    selected = v
                    dropBtn.Text = "  " .. tostring(selected) .. "                              ▾"
                    task.spawn(callback, selected)
                end,
                GetValue = function() return selected end,
                SetOptions = function(self, newOpts)
                    options = newOpts
                    PopulateList()
                end
            }
        end

