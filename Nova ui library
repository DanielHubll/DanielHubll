                    Tween(frame, {Size = UDim2.new(1, -12, 0, 50)}, 0.3)
                    Tween(wheelContainer, {Size = UDim2.new(1, 0, 0, 0)}, 0.3)
                    Tween(expandBtn, {Rotation = 0}, 0.2)
                end
            end)
            
            return {
                SetColor = function(self, c)
                    color = c
                    Tween(colorPreview, {BackgroundColor3 = color}, 0.15)
                    colorWheel.SetColor(c)
                    callback(c)
                end,
                GetColor = function() return color end,
                Expand = function() 
                    if not isExpanded then
                        isExpanded = true
                        Tween(frame, {Size = UDim2.new(1, -12, 0, 340)}, 0.3)
                        Tween(wheelContainer, {Size = UDim2.new(1, 0, 0, 290)}, 0.3)
                        Tween(expandBtn, {Rotation = 180}, 0.2)
                    end
                end,
                Collapse = function()
                    if isExpanded then
                        isExpanded = false
                        Tween(frame, {Size = UDim2.new(1, -12, 0, 50)}, 0.3)
                        Tween(wheelContainer, {Size = UDim2.new(1, 0, 0, 0)}, 0.3)
                        Tween(expandBtn, {Rotation = 0}, 0.2)
                    end
                end
            }
        end
        
        return section
    end
    
    return tab
end

