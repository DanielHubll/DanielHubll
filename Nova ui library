                            Position = UDim2.new(1, -20, 0.5, -7),
                            Image = ICONS.Check,
                            ImageColor3 = theme.Accent,
                            BackgroundTransparency = 1,
                            ZIndex = 52,
                            Parent = optBtn
                        })
                    end

                    optBtn.MouseButton1Click:Connect(function()
                        selectedValue = option
                        valueLabel.Text = optName
                        config.Callback(optValue, optName)
                        self.Config:Set("Dropdown_" .. config.Name, optName)
                        toggleDropdown() -- Fecha
                    end)

                    optBtn.MouseEnter:Connect(function()
                        TweenEngine.Create(optBtn, 0.1, { BackgroundTransparency = 0.5, BackgroundColor3 = theme.InputBackground })
                    end)
                    optBtn.MouseLeave:Connect(function()
                        TweenEngine.Create(optBtn, 0.1, { BackgroundTransparency = 1 })
                    end)

                    -- Separator entre opções
                    if i < #config.Options then
                        Utility.CreateInstance("Frame", {
                            Size = UDim2.new(1, -20, 0, 0.5),
                            Position = UDim2.new(0, 10, 1, -0.5),
                            BackgroundColor3 = theme.Separator,
                            BackgroundTransparency = 0.5,
                            ZIndex = 52,
                            Parent = optBtn
                        })
                    end
                end

                -- Anima abertura
                local targetHeight = math.min(#config.Options * 36, 180)
                row.Size = UDim2.new(1, 0, 0, 48 + targetHeight + 4)
                TweenEngine.Create(dropdownFrame, 0.25, {
                    Size = UDim2.new(1, -28, 0, targetHeight)
                })

                -- Scrolling se necessário
                if #config.Options > 5 then
                    local scroll = Utility.CreateInstance("ScrollingFrame", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        ScrollBarThickness = 2,
                        CanvasSize = UDim2.fromOffset(0, #config.Options * 36),
                        Parent = dropdownFrame
                    })
                end
            else
                -- Fechar
                if dropdownFrame then
                    TweenEngine.Create(dropdownFrame, 0.2, {
                        Size = UDim2.new(1, -28, 0, 0)
                    })
                    task.delay(0.2, function()
                        if dropdownFrame then dropdownFrame:Destroy() end
                        row.Size = UDim2.new(1, 0, 0, 48)
                    end)
                end
            end
        end

        clickArea.MouseButton1Click:Connect(toggleDropdown)

        -- Load saved
        local saved = self.Config:Get("Dropdown_" .. config.Name)
        if saved then
            valueLabel.Text = saved
            for _, opt in ipairs(config.Options) do
                local optName = type(opt) == "table" and opt.Name or tostring(opt)
                if optName == saved then
                    selectedValue = opt
                    break
                end
            end
        end

        local component = { Name = config.Name, Container = row, Searchable = true, Type = "Dropdown" }
        table.insert(tabData.Components, component)
        table.insert(section.Components, component)

        addSeparator(row)
        return component
    end

