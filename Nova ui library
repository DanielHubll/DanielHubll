            UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    svDragging = false
                end
            end)
            UIS.InputChanged:Connect(function(inp)
                if svDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                    local rx = (inp.Position.X - svFrame.AbsolutePosition.X) / svFrame.AbsoluteSize.X
                    local ry = (inp.Position.Y - svFrame.AbsolutePosition.Y) / svFrame.AbsoluteSize.Y
