                        Size = UDim2.new(1, 0, 0, 6),
                        Position = UDim2.new(0, 0, 0, 20),
                        BackgroundColor3 = Theme.SliderTrack,
                        ZIndex = 31,
                        Parent = sliderHolder,
                    })
                    Utils.RoundCorners(chTrack, 3)

                    local chFill = Utils.Create("Frame", {
                        Size = UDim2.new(values[i] / 255, 0, 1, 0),
                        BackgroundColor3 = channel == "R" and Color3.fromRGB(255, 80, 80) or channel == "G" and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(80, 80, 255),
                        ZIndex = 31,
                        Parent = chTrack,
                    })
                    Utils.RoundCorners(chFill, 3)

                    local chClick = Utils.Create("TextButton", {
                        Size = UDim2.new(1, 0, 0, 20),
                        Position = UDim2.new(0, 0, 0, 14),
                        BackgroundTransparency = 1,
                        Text = "",
                        ZIndex = 32,
                        Parent = sliderHolder,
                    })

                    local chDragging = false

                    local function updateCh(inputX)
                        local rel = math.clamp((inputX - chTrack.AbsolutePosition.X) / chTrack.AbsoluteSize.X, 0, 1)
                        values[i] = math.floor(rel * 255)
                        chFill.Size = UDim2.new(values[i] / 255, 0, 1, 0)
