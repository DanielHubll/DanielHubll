        Text = title,
        TextColor3 = Theme.TextPrimary,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = SliderFrame
    })

    local ValueLabel = Create("TextLabel", {
        Size = UDim2.new(0.3, -12, 0, 18),
        Position = UDim2.new(0.7, 0, 0, 8),
        Text = tostring(default) .. suffix,
        TextColor3 = Theme.AccentLight,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        BackgroundTransparency = 1,
        Parent = SliderFrame
    })

    local TrackBg = Create("Frame", {
        Size = UDim2.new(1, -24, 0, 6),
        Position = UDim2.new(0, 12, 0, 38),
        BackgroundColor3 = Theme.SliderTrack,
        Parent = SliderFrame
    })
    AddCorner(TrackBg, 3)

    local TrackFill = Create("Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        Parent = TrackBg
    })
    AddCorner(TrackFill, 3)
    AddGradient(TrackFill, Theme.AccentLight, Theme.Accent, 0)

    local Knob = Create("Frame", {
        Size = UDim2.fromOffset(18, 18),
        Position = UDim2.new((default - min) / (max - min), -9, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        ZIndex = 2,
        Parent = TrackBg
    })
    AddCorner(Knob, 99)
    AddStroke(Knob, Theme.Accent, 2)

    local KnobInner = Create("Frame", {
        Size = UDim2.fromOffset(6, 6),
        Position = UDim2.new(0.5, -3, 0.5, -3),
        BackgroundColor3 = Theme.Accent,
        Parent = Knob
    })
    AddCorner(KnobInner, 99)

    local SliderBtn = Create("TextButton", {
        Size = UDim2.new(1, -24, 0, 30),
        Position = UDim2.new(0, 12, 0, 30),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        Parent = SliderFrame
    })

    local dragging = false

    local function UpdateSlider(inputX)
        local trackSize = TrackBg.AbsoluteSize.X
        local trackPos = TrackBg.AbsolutePosition.X
        local relative = math.clamp((inputX - trackPos) / trackSize, 0, 1)
        value = math.floor(min + (max - min) * relative)

        local fillSize = (value - min) / (max - min)
        Tween(TrackFill, 0.1, {Size = UDim2.new(fillSize, 0, 1, 0)})
        Tween(Knob, 0.1, {Position = UDim2.new(fillSize, -9, 0.5, -9)})
        ValueLabel.Text = tostring(value) .. suffix

        if callback then callback(value) end
    end

    SliderBtn.MouseButton1Down:Connect(function()
        dragging = true
        SpringTween(Knob, 0.2)
        Tween(Knob, 0.15, {Size = UDim2.fromOffset(22, 22), Position = UDim2.new((value - min) / (max - min), -11, 0.5, -11)})
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            Tween(Knob, 0.15, {Size = UDim2.fromOffset(18, 18)})
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = input.Position and input.Position.X or Mouse.X
            UpdateSlider(pos)
        end
    end)

    SliderBtn.MouseButton1Click:Connect(function()
        UpdateSlider(Mouse.X)
    end)

    -- Hover
    SliderBtn.MouseEnter:Connect(function()
        Tween(Knob, 0.2, {Size = UDim2.fromOffset(20, 20)})
    end)
    SliderBtn.MouseLeave:Connect(function()
        if not dragging then
            Tween(Knob, 0.2, {Size = UDim2.fromOffset(18, 18)})
        end
    end)

    return {
        Frame = SliderFrame,
        Set = function(v)
            value = math.clamp(v, min, max)
            local fillSize = (value - min) / (max - min)
            Tween(TrackFill, 0.2, {Size = UDim2.new(fillSize, 0, 1, 0)})
            Tween(Knob, 0.2, {Position = UDim2.new(fillSize, -9, 0.5, -9)})
            ValueLabel.Text = tostring(value) .. suffix
        end,
        Get = function() return value end
    }
end

