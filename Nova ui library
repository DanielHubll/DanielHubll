function Library.Notify(title, msg, dur, ntype)
    if not Library.NotifContainer then return end
    dur = dur or 5
    local colors = {Info = Theme.Accent, Success = Theme.Success, Warning = Theme.Warning, Error = Theme.Danger}
    local accent = colors[ntype] or colors.Info

    local n = New("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Theme.BgLight,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 200,
        Parent = Library.NotifContainer
    })
    Rnd(n, Cfg.RadiusSm)
    Str(n, Theme.Border, 1)

    -- Accent bar
    local bar = New("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accent,
        Parent = n
    })
    Rnd(bar, Cfg.RadiusXs)

    -- Dot icon
    local dot = Icons.Circle(n, 8, accent)
    dot.Position = UDim2.new(0, 14, 0, 12)
    dot.ZIndex = 201

    New("TextLabel", {
        Size = UDim2.new(1, -50, 0, 16),
        Position = UDim2.new(0, 28, 0, 8),
        BackgroundTransparency = 1,
        Text = title or "",
        TextColor3 = Theme.Text,
        TextSize = 13,
        Font = Cfg.Bold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 201,
        Parent = n
    })

    local msgLbl = New("TextLabel", {
        Size = UDim2.new(1, -50, 0, 0),
        Position = UDim2.new(0, 28, 0, 26),
        BackgroundTransparency = 1,
        Text = msg or "",
        TextColor3 = Theme.TextSec,
        TextSize = 11,
        Font = Cfg.Light,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        ZIndex = 201,
        Parent = n
    })

    -- Close X icon button
    local closeFrame = New("TextButton", {
        Size = UDim2.new(0, 22, 0, 22),
        Position = UDim2.new(1, -28, 0, 6),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 202,
        Parent = n
    })
    Icons.Close(closeFrame, 8, Theme.TextDim)

    -- Progress
    local prog = New("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = accent,
        BackgroundTransparency = 0.4,
        ZIndex = 201,
        Parent = n
    })

    local h = 34 + (msgLbl.TextBounds.Y > 0 and msgLbl.TextBounds.Y + 8 or 0)
    Tw(n, {Size = UDim2.new(1, 0, 0, h), BackgroundTransparency = 0}, 0.3)

    local removed = false
    local startTime = tick()

    local function Remove()
        if removed then return end
        removed = true
        Tw(n, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.25)
        task.delay(0.25, function() n:Destroy() end)
    end

    closeFrame.MouseButton1Click:Connect(Remove)
    task.delay(dur, Remove)

    task.spawn(function()
        while not removed and n.Parent do
            local e = tick() - startTime
            local p = math.max(1 - (e / dur), 0)
            prog.Size = UDim2.new(p, 0, 0, 2)
            task.wait()
        end
    end)
end

