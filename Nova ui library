-- ═══════════════════════════════════════════
-- TWEEN HELPERS
-- ═══════════════════════════════════════════
local TweenInfo_ = {
    Fast   = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    Normal = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    Smooth = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
}

local function Tween(obj, info, props)
    local tween = TweenService:Create(obj, info or TweenInfo_.Normal, props)
    tween:Play()
    return tween
end

