-- ════════════════════════════════════════════
-- ██  WINDOW METHODS
-- ════════════════════════════════════════════
function Library:Toggle(state)
    if state == nil then
        state = not self.IsVisible
    end
    self.IsVisible = state
    if state then
        self.Main.Visible = true
        Tween(self.Main, {BackgroundTransparency = 0}, 0.25)
    else
        Tween(self.Main, {BackgroundTransparency = 1}, 0.2)
        task.delay(0.2, function()
            self.Main.Visible = false
        end)
    end
end

function Library:Minimize()
    self.IsMinimized = not self.IsMinimized
    if self.IsMinimized then
        Tween(self.ContentContainer, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.25)
        Tween(self.TabBarContainer, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.25)
    else
        local tabH = self.TabBarContainer.Size.Y.Offset
        Tween(self.ContentContainer, {Size = UDim2.new(1, 0, 1, -(40 + tabH + 4)), BackgroundTransparency = 0}, 0.25)
        Tween(self.TabBarContainer, {Size = UDim2.new(1, 0, 0, tabH), BackgroundTransparency = 0}, 0.25)
    end
end

function Library:SetTitle(title)
    self.Title = title
    for _, child in pairs(self.Main:GetDescendants()) do
        if child:IsA("TextLabel") and child.Name == "TitleLabel" then
            child.Text = title
        end
    end
end

function Library:SetAccent(color)
    Theme.Accent = color
    Theme.AccentDim = Color3.fromRGB(
        math.floor(color.R * 255 * 0.7),
        math.floor(color.G * 255 * 0.7),
        math.floor(color.B * 255 * 0.7)
    )
    Theme.SliderFill = color
end

