            InputPadding.PaddingLeft = UDim.new(0, 6)
            InputPadding.PaddingRight = UDim.new(0, 6)
            InputPadding.Parent = Input
            
            Input.FocusLost:Connect(function(enterPressed)
                comp.Value = Input.Text
                local success, err = pcall(comp.Callback, Input.Text, enterPressed)
                if not success then
                    warn("[Lumina] Erro no callback do textbox: " .. tostring(err))
                end
            end)
            
            comp.Instance = Frame
            comp.Input = Input
            return Frame
        end
        
        function comp:SetValue(value)
            comp.Value = value
            if comp.Input then
                comp.Input.Text = tostring(value)
            end
        end
        
        function comp:GetValue()
            return comp.Value
        end
        
        table.insert(TabData.Components, comp)
        if ActiveTab == TabData then comp:Render(self.ComponentsFrame) end
        return comp
    end
    
    -- ═════════════════════════════════════
    -- COMPONENTE: COLOR PICKER (Simples)
    -- ═════════════════════════════════════
    function TabAPI:AddColorPicker(config)
        config = config or {}
        local comp = {}
        
        comp.Text = config.Text or "Color"
        comp.Default = config.Default or Color3.fromRGB(100, 140, 255)
        comp.Callback = config.Callback or function() end
        comp.Order = #TabData.Components
        comp.Value = comp.Default
        
        function comp:Render(parent)
            local Frame = Instance.new("Frame")
            Frame.Name = "ColorPicker_" .. comp.Text
            Frame.BackgroundColor3 = Theme.TabBg
            Frame.BorderSizePixel = 0
            Frame.Size = UDim2.new(1, 0, 0, 28)
            Frame.LayoutOrder = comp.Order
            Frame:SetAttribute("SearchTag", comp.Text)
            Frame.Parent = parent
            
            Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 5)
            
            local NameLabel = Instance.new("TextLabel")
            NameLabel.Name = "Name"
            NameLabel.BackgroundColor3 = Color3.fromRGB(255,255,255)
            NameLabel.BackgroundTransparency = 1
            NameLabel.FontFace = Fonts.Body
            NameLabel.TextColor3 = Theme.TextPrimary
            NameLabel.TextSize = 10
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left
            NameLabel.Size = UDim2.new(1, -50, 1, 0)
            NameLabel.Position = UDim2.new(0, 8, 0, 0)
            NameLabel.Text = comp.Text
            NameLabel.Parent = Frame
            
            -- Preview da cor
            local ColorPreview = Instance.new("TextButton")
            ColorPreview.Name = "Preview"
            ColorPreview.BackgroundColor3 = comp.Value
            ColorPreview.BorderSizePixel = 0
            ColorPreview.Size = UDim2.new(0, 40, 0, 20)
            ColorPreview.Position = UDim2.new(1, -46, 0.5, -10)
            ColorPreview.Text = ""
            ColorPreview.AutoButtonColor = false
            ColorPreview.Parent = Frame
            
            Instance.new("UICorner", ColorPreview).CornerRadius = UDim.new(0, 4)
            
            local Stroke = Instance.new("UIStroke")
            Stroke.Color = Theme.StrokeColor
            Stroke.Thickness = 1
            Stroke.Parent = ColorPreview
            
            -- Ao clicar, cicla entre cores predefinidas (implementação simples)
            local colors = {
                Color3.fromRGB(255, 50, 50),
                Color3.fromRGB(50, 255, 50),
                Color3.fromRGB(50, 50, 255),
                Color3.fromRGB(255, 255, 50),
                Color3.fromRGB(255, 50, 255),
                Color3.fromRGB(50, 255, 255),
                Color3.fromRGB(255, 140, 0),
                Color3.fromRGB(100, 140, 255),
            }
            local colorIndex = 1
            
            ColorPreview.MouseButton1Click:Connect(function()
                colorIndex = colorIndex + 1
                if colorIndex > #colors then colorIndex = 1 end
                comp.Value = colors[colorIndex]
                Tween(ColorPreview, TweenInfo_.Normal, {BackgroundColor3 = comp.Value})
                local success, err = pcall(comp.Callback, comp.Value)
                if not success then
                    warn("[Lumina] Erro no callback do colorpicker: " .. tostring(err))
                end
            end)
            
            comp.Instance = Frame
            comp.ColorPreview = ColorPreview
            return Frame
        end
        
        function comp:SetValue(color)
            comp.Value = color
            if comp.ColorPreview then
                comp.ColorPreview.BackgroundColor3 = color
            end
        end
        
        function comp:GetValue()
            return comp.Value
        end
        
        table.insert(TabData.Components, comp)
        if ActiveTab == TabData then comp:Render(self.ComponentsFrame) end
        return comp
    end
    
    return TabAPI
end

