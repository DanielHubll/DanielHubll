    function TabAPI:AddSlider(config)
        config = config or {}
        local comp = {}
        
        comp.Text = config.Text or "Slider"
        comp.Min = config.Min or 0
        comp.Max = config.Max or 100
        comp.Default = config.Default or 50
        comp.Suffix = config.Suffix or ""
        comp.Callback = config.Callback or function() end
        comp.Order = #TabData.Components
        comp.Value = comp.Default
        
        function comp:Render(parent)
            local Frame = Instance.new("Frame")
            Frame.Name = "Slider_" .. comp.Text
            Frame.BackgroundColor3 = Theme.TabBg
            Frame.BorderSizePixel = 0
            Frame.Size = UDim2.new(1, 0, 0, 40)
            Frame.LayoutOrder = comp.Order
            Frame:SetAttribute("SearchTag", comp.Text)
            Frame.Parent = parent
            
            Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 5)
            
            -- Nome
            local NameLabel = Instance.new("TextLabel")
            NameLabel.Name = "Name"
            NameLabel.BackgroundColor3 = Color3.fromRGB(255,255,255)
            NameLabel.BackgroundTransparency = 1
            NameLabel.FontFace = Fonts.Body
            NameLabel.TextColor3 = Theme.TextPrimary
            NameLabel.TextSize = 10
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left
            NameLabel.Size = UDim2.new(0.6, 0, 0, 16)
            NameLabel.Position = UDim2.new(0, 8, 0, 4)
            NameLabel.Text = comp.Text
            NameLabel.Parent = Frame
            
            -- Valor
            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Name = "Value"
            ValueLabel.BackgroundColor3 = Color3.fromRGB(255,255,255)
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.FontFace = Fonts.Bold
            ValueLabel.TextColor3 = Theme.Accent
            ValueLabel.TextSize = 10
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.Size = UDim2.new(0.4, -8, 0, 16)
            ValueLabel.Position = UDim2.new(0.6, 0, 0, 4)
            ValueLabel.Text = tostring(comp.Value) .. comp.Suffix
            ValueLabel.Parent = Frame
            
            -- Barra do slider (background)
            local SliderBar = Instance.new("Frame")
            SliderBar.Name = "Bar"
            SliderBar.BackgroundColor3 = Theme.SliderBg
            SliderBar.BorderSizePixel = 0
            SliderBar.Size = UDim2.new(1, -16, 0, 6)
            SliderBar.Position = UDim2.new(0, 8, 0, 26)
            SliderBar.Parent = Frame
            
            Instance.new("UICorner", SliderBar).CornerRadius = UDim.new(1, 0)
            
            -- Preenchimento do slider
            local SliderFill = Instance.new("Frame")
            SliderFill.Name = "Fill"
            SliderFill.BackgroundColor3 = Theme.SliderFill
            SliderFill.BorderSizePixel = 0
            local fillPercent = (comp.Value - comp.Min) / (comp.Max - comp.Min)
            SliderFill.Size = UDim2.new(fillPercent, 0, 1, 0)
            SliderFill.Parent = SliderBar
            
            Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)
            
            -- Área de interação
            local ClickArea = Instance.new("TextButton")
            ClickArea.Name = "ClickArea"
            ClickArea.BackgroundColor3 = Color3.fromRGB(255,255,255)
            ClickArea.BackgroundTransparency = 1
            ClickArea.BorderSizePixel = 0
            ClickArea.Size = UDim2.new(1, -16, 0, 16)
            ClickArea.Position = UDim2.new(0, 8, 0, 22)
            ClickArea.Text = ""
            ClickArea.Parent = Frame
            
            local sliding = false
            
            local function UpdateSlider(input)
                local pos = input.Position.X
                local barPos = SliderBar.AbsolutePosition.X
                local barSize = SliderBar.AbsoluteSize.X
                local percent = math.clamp((pos - barPos) / barSize, 0, 1)
                local newValue = math.floor(comp.Min + (comp.Max - comp.Min) * percent + 0.5)
                
                comp.Value = newValue
                ValueLabel.Text = tostring(newValue) .. comp.Suffix
                SliderFill.Size = UDim2.new(percent, 0, 1, 0)
                
                local success, err = pcall(comp.Callback, newValue)
                if not success then
                    warn("[Lumina] Erro no callback do slider: " .. tostring(err))
                end
            end
            
            ClickArea.MouseButton1Down:Connect(function()
                sliding = true
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(input)
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)
            
            ClickArea.MouseButton1Click:Connect(function()
                -- clique simples também atualiza
            end)
            
            comp.Instance = Frame
            comp.SliderFill = SliderFill
            comp.ValueLabel = ValueLabel
            return Frame
        end
        
        function comp:SetValue(value)
            comp.Value = math.clamp(value, comp.Min, comp.Max)
            if comp.SliderFill then
                local percent = (comp.Value - comp.Min) / (comp.Max - comp.Min)
                comp.SliderFill.Size = UDim2.new(percent, 0, 1, 0)
            end
            if comp.ValueLabel then
                comp.ValueLabel.Text = tostring(comp.Value) .. comp.Suffix
            end
        end
        
        function comp:GetValue()
            return comp.Value
        end
        
        table.insert(TabData.Components, comp)
        if ActiveTab == TabData then comp:Render(self.ComponentsFrame) end
        return comp
    end
    
