        return order
    end

    -- Helper: cria row base para componentes
    local function createComponentRow(height, componentName)
        local row = Utility.CreateInstance("Frame", {
            Name = componentName or "Component",
            Size = UDim2.new(1, 0, 0, height or 44),
            BackgroundTransparency = 1,
            LayoutOrder = nextOrder(),
            Parent = section.Container
        })
        return row
    end

    -- Helper: separador entre componentes
    local function addSeparator(parent, order)
        local sep = Utility.CreateInstance("Frame", {
            Size = UDim2.new(1, -28, 0, 0.5),
            Position = UDim2.new(0, 14, 1, -0.5),
            BackgroundColor3 = theme.Separator,
            BackgroundTransparency = 0.5,
            Parent = parent
        })
        return sep
    end

