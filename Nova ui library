-- ═══════════════════════════════════════════════════════════════════
-- FUNÇÃO MÁGICA: Cria ImageLabel ou TextLabel baseado na config
-- ═══════════════════════════════════════════════════════════════════
local function Icon(id, size, parent, fallbackEmoji)
    local s = size or 16
    if type(s) == "number" then s = Vector2.new(s, s) end
    
    -- Se tem ID configurado, usa ImageLabel
    if id and id ~= "" and (id:find("rbxassetid://") or id:find("rbxasset://")) then
        local img = Instance.new("ImageLabel")
        img.Image = id
        img.Size = UDim2.fromOffset(s.X, s.Y)
        img.BackgroundTransparency = 1
        img.ScaleType = Enum.ScaleType.Fit
        img.Name = "Icon"
        if parent then img.Parent = parent end
        return img
    end
    
    -- Fallback: usa emoji
    if fallbackEmoji then
        local txt = Instance.new("TextLabel")
        txt.Text = fallbackEmoji
        txt.Size = UDim2.fromOffset(s.X, s.Y)
        txt.Font = Enum.Font.Gotham
        txt.TextSize = s.X * 0.8
        txt.BackgroundTransparency = 1
        txt.Name = "Icon"
        if parent then txt.Parent = parent end
        return txt
    end
    
    return nil
end

