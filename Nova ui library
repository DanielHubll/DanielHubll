	New("ImageLabel", { Image = GetIcon("x"), ImageColor3 = Theme.SubText, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Parent = closeBtn })

	New("TextLabel", { Text = config.Content or "", Font = FontRegular, TextSize = 13, TextColor3 = Theme.SubText, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = 2, Parent = card })

	local barBack = New("Frame", { BackgroundColor3 = Theme.Border, Size = UDim2.new(1, 0, 0, 3), LayoutOrder = 3, Parent = card })
	Corner(barBack, 4)
	local barFill = New("Frame", { BackgroundColor3 = Theme.Accent, Size = UDim2.new(1, 0, 1, 0), Parent = barBack })
	Corner(barFill, 4)

	Tween(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.35)
	Tween(barFill, { Size = UDim2.new(0, 0, 1, 0) }, config.Duration or 4, Enum.EasingStyle.Linear)

