        Position = UDim2.new(0, 8, 0.5, -8),
        Image = icon or ICONS.Home,
        ImageColor3 = theme.SecondaryText,
        BackgroundTransparency = 1,
        Parent = tabBtn
    })

    -- Tab text
    local tabText = Utility.CreateInstance("TextLabel", {
        Size = UDim2.new(0, 0, 1, 0),
        Position = UDim2.new(0, 28, 0, 0),
        Text = name,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = theme.SecondaryText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = tabBtn
    })

    -- Calcula tamanho do texto
    local textSizeService = game:GetService("TextService")
    local textSize = textSizeService:GetTextSize(name, 12, Enum.Font.GothamMedium, Vector2.new(200, 32))
    tabBtn.Size = UDim2.fromOffset(textSize.X + 36, 32)

    -- Tab interaction
    tabBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            self:SelectTab(tabId)
        end
    end)

    -- Hover
    tabBtn.MouseEnter:Connect(function()
        if self.ActiveTab ~= tabId then
            TweenEngine.Create(tabBtn, 0.15, { BackgroundTransparency = 0.7 })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if self.ActiveTab ~= tabId then
            TweenEngine.Create(tabBtn, 0.15, { BackgroundTransparency = 1 })
        end
    end)

    tab.Button = tabBtn
    tab.IconElement = tabIcon
    tab.TextElement = tabText

    table.insert(self.Tabs, tab)

    -- Seleciona automaticamente se é a primeira tab
    if #self.Tabs == 1 then
        self:SelectTab(tabId)
    end

    return self:CreateTabAPI(tab)
end

function iOSLib:SelectTab(tabId)
    local theme = self:GetTheme()
    self.ActiveTab = tabId

    -- Limpa o conteúdo
    for _, child in ipairs(self.TabContent:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextLabel") then
            TweenEngine.Create(child, 0.2, {
                BackgroundTransparency = 1,
                Size = UDim2.fromOffset(child.AbsoluteSize.X, 0)
            })
            task.delay(0.2, function()
                if child then child.Visible = false end
            end)
        end
    end

    -- Atualiza visual das tabs
    for _, tab in ipairs(self.Tabs) do
        local isActive = tab.Id == tabId
        TweenEngine.Create(tab.Button, 0.25, {
            BackgroundColor3 = isActive and theme.TabSelected or theme.TabBackground,
            BackgroundTransparency = isActive and 0 or 1
        })
        TweenEngine.Create(tab.IconElement, 0.25, {
            ImageColor3 = isActive and theme.Accent or theme.SecondaryText
        })
        TweenEngine.Create(tab.TextElement, 0.25, {
            TextColor3 = isActive and theme.Accent or theme.SecondaryText
        })

        -- Mostra/esconde seções
        for _, section in ipairs(tab.Sections) do
            if section.Container then
                section.Container.Visible = isActive
                if isActive then
                    TweenEngine.Create(section.Container, 0.3, {
                        BackgroundTransparency = 0
                    })
                end
            end
        end
    end

    self.Events:Emit("TabChanged", tabId)
end

function iOSLib:FilterContent(query)
    query = query:lower()
    for _, tab in ipairs(self.Tabs) do
        if tab.Id == self.ActiveTab then
            for _, component in ipairs(tab.Components) do
                if component.Searchable then
                    local matches = query == "" or
                        (component.Name and component.Name:lower():find(query))
                    if component.Container then
                        component.Container.Visible = matches
                    end
                end
            end
        end
    end
end

