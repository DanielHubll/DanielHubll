-- WINDOW CONTROL METHODS
-- ═══════════════════════════════════════════════════════════════════
function iOSLib:ToggleMinimize()
    self.IsMinimized = not self.IsMinimized

    if self.IsMinimized then
        -- Animação de minimizar (iOS style - shrink)
        TweenEngine.Create(self.ContentArea, 0.35, {
            Size = UDim2.new(1, 0, 0, 0),
            Position = UDim2.new(0, 0, 0, 48)
        })
        TweenEngine.Create(self.TabBar, 0.3, {
            Size = UDim2.new(1, 0, 0, 0)
        })
        TweenEngine.Create(self.Window, 0.4, {
            Size = UDim2.fromOffset(520, 48)
        })
    else
        -- Restaurar
        local isMobile = Utility.IsMobile()
        local windowSize = isMobile
            and UDim2.new(0.95, 0, 0.85, 0)
            or UDim2.fromOffset(520, 480)

        TweenEngine.Create(self.Window, 0.4, {
            Size = windowSize
        })
        task.delay(0.1, function()
            TweenEngine.Create(self.TabBar, 0.3, {
                Size = UDim2.new(1, 0, 0, 42)
            })
            TweenEngine.Create(self.ContentArea, 0.35, {
                Size = UDim2.new(1, 0, 1, -90),
                Position = UDim2.new(0, 0, 0, 90)
            })
        end)
    end

    self.Events:Emit("Minimized", self.IsMinimized)
end

function iOSLib:Close()
    -- Animação de fechar (iOS dismiss)
    TweenEngine.Create(self.Window, 0.4, {
        Size = UDim2.fromOffset(0, 0),
        BackgroundTransparency = 1
    })

    task.delay(0.4, function()
        self:Destroy()
    end)

    self.Events:Emit("Closed")
end

function iOSLib:Destroy()
    -- Desconecta todas as conexões
    self.Drag:Destroy()
    self.Events:Destroy()
    Utility.DisconnectAll("iOSLib")

    -- Destrói a ScreenGui
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end

    -- Remove da lista de janelas
    for i, win in ipairs(iOSLib.Windows) do
        if win == self then
            table.remove(iOSLib.Windows, i)
            break
        end
    end
end

