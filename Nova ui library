        BackgroundColor3 = default and Theme.ToggleOn or Theme.ToggleOff,
        Parent = frame
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = track})
    
    local thumb = Utils.Create("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = default and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Parent = track
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = thumb})
    
    local btn = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = frame
    })
    
    local state = default
    if default then callback(true) end
    
    btn.MouseEnter:Connect(function()
        Utils.Tween(frame, Animations.Fast, {BackgroundColor3 = Theme.CardHover})
    end)
    
    btn.MouseLeave:Connect(function()
        Utils.Tween(frame, Animations.Fast, {BackgroundColor3 = Theme.Card})
    end)
    
    btn.MouseButton1Click:Connect(function()
        state = not state
        
        if state then
            Utils.Tween(track, Animations.Medium, {BackgroundColor3 = Theme.ToggleOn})
            Utils.Tween(thumb, Animations.Bounce, {Position = UDim2.new(1, -21, 0.5, -9)})
        else
            Utils.Tween(track, Animations.Medium, {BackgroundColor3 = Theme.ToggleOff})
            Utils.Tween(thumb, Animations.Bounce, {Position = UDim2.new(0, 3, 0.5, -9)})
        end
        
        callback(state)
    end)
    
    return {
        Set = function(self, value)
            state = value
            if state then
                Utils.Tween(track, Animations.Medium, {BackgroundColor3 = Theme.ToggleOn})
                Utils.Tween(thumb, Animations.Bounce, {Position = UDim2.new(1, -21, 0.5, -9)})
            else
                Utils.Tween(track, Animations.Medium, {BackgroundColor3 = Theme.ToggleOff})
                Utils.Tween(thumb, Animations.Bounce, {Position = UDim2.new(0, 3, 0.5, -9)})
            end
            callback(state)
        end,
        Get = function() return state end,
        Frame = frame
    }
end

