    -- 🌟 SISTEMA DE BUSCA DE ELEMENTOS
    Library.SearchElements = function(self, Query)
        local Results = {}
        Query = Query:lower()
        
        for _, page in ipairs(Library.Pages) do
            for _, subpage in ipairs(page.SubPages) do
                for _, section in ipairs(subpage.Sections) do
                    if section.Name:lower():find(Query) then
                        table.insert(Results, {Type = "Section", Name = section.Name, Object = section})
                    end
                    
                    for _, element in ipairs(section.Elements) do
                        if element.Name and element.Name:lower():find(Query) then
                            table.insert(Results, {Type = element.Type, Name = element.Name, Object = element})
                        end
                    end
                end
            end
        end
        
        return Results
    end

    -- 🌟 SISTEMA DE AUTO-SAVE DE CONFIGS
    Library.AutoSave = function(self, Interval)
        Interval = Interval or 60 -- Salvar a cada 60 segundos
        
        task.spawn(function()
            while true do
                task.wait(Interval)
                local configName = "autosave_" .. os.date("%Y%m%d_%H%M%S")
                local configData = Library:GetConfig()
                writefile(Library.Folders.Configs .. "/" .. configName .. ".json", configData)
            end
        end)
    end

    -- 🌟 SISTEMA DE EXPORTAÇÃO DE TEMA
    Library.ExportTheme = function(self, ThemeName)
        ThemeName = ThemeName or "Custom_Theme"
        local themeData = HttpService:JSONEncode(Library.Theme)
        writefile(Library.Folders.Themes .. "/" .. ThemeName .. ".json", themeData)
        return true
    end

    Library.ImportTheme = function(self, ThemeName)
        local path = Library.Folders.Themes .. "/" .. ThemeName .. ".json"
        if isfile(path) then
            local themeData = HttpService:JSONDecode(readfile(path))
            for key, value in pairs(themeData) do
                if type(value) == "table" and value.R and value.G and value.B then
                    Library.Theme[key] = FromRGB(value.R * 255, value.G * 255, value.B * 255)
                end
            end
            Library:ChangeTheme("all", nil) -- Trigger update
            return true
        end
        return false
    end

