-- TAB API (Returned when AddTab is called)
-- ═══════════════════════════════════════════════════════════════════
function iOSLib:CreateTabAPI(tabData)
    local tabAPI = {}
    tabAPI._tab = tabData

    --- Adiciona uma seção dentro da tab
    function tabAPI:AddSection(title, icon)
        local theme = self:GetTheme()
        local sectionId = Utility.GenerateId()

        local sectionContainer = Utility.CreateInstance("Frame", {
            Name = "Section_" .. title,
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = theme.CardBackground,
            LayoutOrder = #tabData.Sections,
            Visible = tabData.Id == self.ActiveTab,
            Parent = self.TabContent
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 12), Parent = sectionContainer })

        -- Stroke sutil
        Utility.CreateInstance("UIStroke", {
            Color = theme.Separator,
            Thickness = 0.5,
            Transparency = 0.7,
            Parent = sectionContainer
        })

        local sectionLayout = Utility.CreateInstance("UIListLayout", {
            Padding = UDim.new(0, 0),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = sectionContainer
        })

        -- Título da seção (se houver)
        if title and title ~= "" then
            local headerFrame = Utility.CreateInstance("Frame", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundTransparency = 1,
                LayoutOrder = 0,
                Parent = sectionContainer
            })

            if icon then
                Utility.CreateInstance("ImageLabel", {
                    Size = UDim2.fromOffset(16, 16),
                    Position = UDim2.new(0, 14, 0.5, -8),
                    Image = icon,
                    ImageColor3 = theme.Accent,
                    BackgroundTransparency = 1,
                    Parent = headerFrame
                })
            end

            Utility.CreateInstance("TextLabel", {
                Size = UDim2.new(1, icon and -44 or -28, 1, 0),
                Position = UDim2.new(0, icon and 34 or 14, 0, 0),
                Text = title,
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = theme.SecondaryText,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Parent = headerFrame
            })

            -- Separator
            Utility.CreateInstance("Frame", {
                Size = UDim2.new(1, -28, 0, 0.5),
                Position = UDim2.new(0, 14, 1, 0),
                BackgroundColor3 = theme.Separator,
                BackgroundTransparency = 0.5,
                Parent = headerFrame
            })
        end

        local section = {
            Id = sectionId,
            Title = title,
            Container = sectionContainer,
            Layout = sectionLayout,
            Components = {},
            NextOrder = 1,
        }

        table.insert(tabData.Sections, section)

        -- Atualiza altura da seção
        sectionLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            sectionContainer.Size = UDim2.new(1, 0, 0, sectionLayout.AbsoluteContentSize.Y)
        end)

        return self:CreateSectionAPI(section, tabData)
    end

    return tabAPI
end

