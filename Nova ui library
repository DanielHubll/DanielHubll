		Tween(card, { Position = UDim2.new(1.2, 0, 0, 0) }, 0.3)
		task.delay(0.3, function() if card then card:Destroy() end end)
	end

	closeBtn.MouseButton1Click:Connect(dismiss)
	task.delay(config.Duration or 4, dismiss)
end

