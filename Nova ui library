                end
            end)
            
            -- Aplica valor inicial
            UpdateSwitch(comp.Value)
            
            comp.Instance = Frame
            comp.SwitchBg = SwitchBg
            comp.SwitchDot = SwitchDot
            comp.UpdateSwitch = UpdateSwitch
            return Frame
