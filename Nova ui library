    -- Activate
    local function Activate()
        for _, t in ipairs(self.Tabs) do
            t.Page.Visible = false
            Tw(t.Indicator, {BackgroundTransparency = 1, Size = UDim2.new(0.7,0,0,2)}, 0.18)
            Tw(t.Btn, {BackgroundTransparency = 1}, 0.18)
            if t.IconImg then
                Tw(t.IconImg, {ImageColor3 = Theme.TextDim}, 0.18)
            else
                Tw(t.Btn, {TextColor3 = Theme.TextDim}, 0.18)
            end
        end
        tab.Page.Visible = true
        Tw(tab.Indicator, {BackgroundTransparency = 0, Size = UDim2.new(0.8,0,0,2.5)}, 0.22)
        Tw(tab.Btn, {BackgroundTransparency = 0.8}, 0.22)
        if tab.IconImg then
            Tw(tab.IconImg, {ImageColor3 = Theme.Text}, 0.22)
        else
            Tw(tab.Btn, {TextColor3 = Theme.Text}, 0.22)
        end
        self.ActiveTab = tab
    end

    tab.Btn.MouseButton1Click:Connect(Activate)
    tab.Btn.MouseEnter:Connect(function()
        if self.ActiveTab ~= tab then
            Tw(tab.Btn, {BackgroundTransparency = 0.9}, 0.12)
        end
    end)
    tab.Btn.MouseLeave:Connect(function()
        if self.ActiveTab ~= tab then
            Tw(tab.Btn, {BackgroundTransparency = 1}, 0.12)
        end
    end)

    table.insert(self.Tabs, tab)
    if self.TabCount == 1 then task.delay(0.05, Activate) end

