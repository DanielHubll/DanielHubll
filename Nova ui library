    -- ═══════════════════════════════════════════════════════════════
    -- TOGGLE COMPONENT
    -- ═══════════════════════════════════════════════════════════════
    function sectionAPI:AddToggle(options)
        local config = {
            Name = options.Name or "Toggle",
            Icon = options.Icon or nil,
            Default = options.Default or false,
            Callback = options.Callback or function() end,
            Searchable = true,
        }

        local row = createComponentRow(48, "Toggle_" .. config.Name)
        local isOn = config.Default

        -- Label
        local iconOffset = config.Icon and 34 or 0
        if config.Icon then
            Utility.CreateInstance("ImageLabel", {
                Size = UDim2.fromOffset(18, 18),
                Position = UDim2.new(0, 14, 0.5, -9),
                Image = config.Icon,
                ImageColor3 = theme.Accent,
                BackgroundTransparency = 1,
                Parent = row
            })
        end

        Utility.CreateInstance("TextLabel", {
            Size = UDim2.new(1, -80 - iconOffset, 1, 0),
            Position = UDim2.new(0, 14 + iconOffset, 0, 0),
            Text = config.Name,
            Font = Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = theme.PrimaryText,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            Parent = row
        })

        -- Toggle switch (iOS style)
        local toggleBg = Utility.CreateInstance("Frame", {
            Size = UDim2.fromOffset(50, 30),
            Position = UDim2.new(1, -64, 0.5, -15),
            BackgroundColor3 = isOn and theme.ToggleOn or theme.ToggleOff,
            Parent = row
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = toggleBg })

        local toggleKnob = Utility.CreateInstance("Frame", {
            Size = UDim2.fromOffset(26, 26),
            Position = isOn and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            Parent = toggleBg
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = toggleKnob })

        -- Shadow no knob
        Utility.CreateInstance("UIStroke", {
            Color = Color3.fromRGB(0, 0, 0),
            Thickness = 0.5,
            Transparency = 0.85,
            Parent = toggleKnob
        })

        -- Toggle button (invisible)
        local toggleBtn = Utility.CreateInstance("TextButton", {
            Size = UDim2.fromOffset(50, 30),
            Position = UDim2.new(1, -64, 0.5, -15),
            Text = "",
            BackgroundTransparency = 1,
            Parent = row
        })

        local function setToggle(value, animate)
            isOn = value
            local dur = animate ~= false and 0.25 or 0
            TweenEngine.Create(toggleBg, dur, {
                BackgroundColor3 = isOn and theme.ToggleOn or theme.ToggleOff
            })
            TweenEngine.Create(toggleKnob, dur, {
                Position = isOn and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13)
            })
            config.Callback(isOn)

            -- Salva configuração
            self.Config:Set("Toggle_" .. config.Name, isOn)
        end

        -- Carrega valor salvo
        local savedValue = self.Config:Get("Toggle_" .. config.Name)
        if savedValue ~= nil then
            setToggle(savedValue, false)
        end

        toggleBtn.MouseButton1Click:Connect(function()
            setToggle(not isOn)
        end)

        -- Hover no row
        row.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                TweenEngine.Create(row, 0.15, { BackgroundTransparency = 0.7 })
            end
        end)
        row.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                TweenEngine.Create(row, 0.15, { BackgroundTransparency = 1 })
            end
        end)

        local component = { Name = config.Name, Container = row, Searchable = true, Type = "Toggle", SetValue = setToggle, GetValue = function() return isOn end }
        table.insert(tabData.Components, component)
        table.insert(section.Components, component)

        addSeparator(row)
        return component
    end

    -- ═══════════════════════════════════════════════════════════════
    -- SLIDER COMPONENT
    -- ═══════════════════════════════════════════════════════════════
    function sectionAPI:AddSlider(options)
        local config = {
            Name = options.Name or "Slider",
            Icon = options.Icon or nil,
            Min = options.Min or 0,
            Max = options.Max or 100,
            Default = options.Default or 50,
            Step = options.Step or 1,
            Suffix = options.Suffix or "",
            Callback = options.Callback or function() end,
            Searchable = true,
        }

        local row = createComponentRow(68, "Slider_" .. config.Name)
        local value = config.Default

        -- Label row
        local iconOffset = config.Icon and 20 or 0
        if config.Icon then
            Utility.CreateInstance("ImageLabel", {
                Size = UDim2.fromOffset(16, 16),
                Position = UDim2.new(0, 14, 0, 12),
                Image = config.Icon,
                ImageColor3 = theme.Accent,
                BackgroundTransparency = 1,
                Parent = row
            })
        end

        local label = Utility.CreateInstance("TextLabel", {
            Size = UDim2.new(0.5, -iconOffset, 0, 20),
            Position = UDim2.new(0, 14 + iconOffset, 0, 8),
            Text = config.Name,
            Font = Enum.Font.Gotham,
            TextSize = 13,
            TextColor3 = theme.PrimaryText,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            Parent = row
        })

        -- Value display
        local valueLabel = Utility.CreateInstance("TextLabel", {
            Size = UDim2.new(0.5, -14, 0, 20),
            Position = UDim2.new(0.5, 0, 0, 8),
            Text = value .. config.Suffix,
            Font = Enum.Font.GothamBold,
            TextSize = 13,
            TextColor3 = theme.Accent,
            TextXAlignment = Enum.TextXAlignment.Right,
            BackgroundTransparency = 1,
            Parent = row
        })

        -- Track
        local track = Utility.CreateInstance("Frame", {
            Size = UDim2.new(1, -28, 0, 6),
            Position = UDim2.new(0, 14, 0, 40),
            BackgroundColor3 = theme.InputBackground,
            Parent = row
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })

        -- Fill
        local fill = Utility.CreateInstance("Frame", {
            Size = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 1, 0),
            BackgroundColor3 = theme.Accent,
            Parent = track
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })

        -- Knob
        local knob = Utility.CreateInstance("Frame", {
            Size = UDim2.fromOffset(22, 22),
            Position = UDim2.new((value - config.Min) / (config.Max - config.Min), -11, 0.5, -11),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            ZIndex = 2,
            Parent = track
        })
        Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })
        Utility.CreateInstance("UIStroke", {
            Color = Color3.fromRGB(0, 0, 0),
            Thickness = 0.5,
            Transparency = 0.8,
            Parent = knob
        })

        -- Slider logic
        local dragging = false

        local function updateValue(newValue, animate)
            value = math.clamp(
                math.floor(newValue / config.Step + 0.5) * config.Step,
                config.Min, config.Max
            )
            local percent = (value - config.Min) / (config.Max - config.Min)
            local dur = animate and 0.1 or 0

            TweenEngine.Create(fill, dur, { Size = UDim2.new(percent, 0, 1, 0) })
            TweenEngine.Create(knob, dur, { Position = UDim2.new(percent, -11, 0.5, -11) })
            valueLabel.Text = value .. config.Suffix

            config.Callback(value)
            self.Config:Set("Slider_" .. config.Name, value)
        end

        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                local rel = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                local newVal = config.Min + rel * (config.Max - config.Min)
                updateValue(newVal, false)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
                input.UserInputType == Enum.UserInputType.Touch) then
                local rel = math.clamp(
                    (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X,
                    0, 1
                )
                local newVal = config.Min + rel * (config.Max - config.Min)
                updateValue(newVal, false)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)

        -- Knob hover
        knob.MouseEnter:Connect(function()
            TweenEngine.Create(knob, 0.15, { Size = UDim2.fromOffset(26, 26) })
        end)
        knob.MouseLeave:Connect(function()
            TweenEngine.Create(knob, 0.15, { Size = UDim2.fromOffset(22, 22) })
        end)

        -- Load saved
        local saved = self.Config:Get("Slider_" .. config.Name)
        if saved then updateValue(saved, false) end

        local component = { Name = config.Name, Container = row, Searchable = true, Type = "Slider", SetValue = function(v) updateValue(v, true) end, GetValue = function() return value end }
        table.insert(tabData.Components, component)
        table.insert(section.Components, component)

        addSeparator(row)
        return component
    end

