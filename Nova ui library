--- Envia uma notificação global
function iOSLib.Notify(options)
    return NotificationSystem.Show(options)
end

--- Mostra um popup de confirmação
function iOSLib.Confirm(title, message, onConfirm, onCancel, parent)
    return PopupSystem.Confirm(title, message, onConfirm, onCancel, parent)
end

--- Mostra um popup customizado
function iOSLib.Popup(options)
    return PopupSystem.Show(options)
end

--- Destrói todas as janelas
function iOSLib.DestroyAll()
    for _, win in ipairs(iOSLib.Windows) do
        win:Destroy()
    end
    iOSLib.Windows = {}
    Utility.DestroyAll()
end

--- Retorna se o dispositivo é mobile
function iOSLib.IsMobile()
    return Utility.IsMobile()
end

--- Obtém breakpoint responsivo atual
function iOSLib.GetBreakpoint()
    return ResponsiveSystem.GetCurrentBreakpoint()
end

