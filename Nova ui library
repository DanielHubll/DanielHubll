-- EVENT SYSTEM
-- ═══════════════════════════════════════════════════════════════════
local EventSystem = {}
EventSystem.__index = EventSystem

function EventSystem.new()
    local self = setmetatable({}, EventSystem)
    self.Listeners = {}
    return self
end

function EventSystem:On(eventName, callback)
    if not self.Listeners[eventName] then
        self.Listeners[eventName] = {}
    end
    local id = Utility.GenerateId()
    self.Listeners[eventName][id] = callback
    return id
end

function EventSystem:Emit(eventName, ...)
    if self.Listeners[eventName] then
        for _, callback in pairs(self.Listeners[eventName]) do
            task.spawn(callback, ...)
        end
    end
end

function EventSystem:Off(eventName, listenerId)
    if listenerId and self.Listeners[eventName] then
        self.Listeners[eventName][listenerId] = nil
    elseif eventName then
        self.Listeners[eventName] = nil
    end
end

function EventSystem:Destroy()
    self.Listeners = {}
end

-- ═══════════════════════════════════════════════════════════════════
-- DRAG SYSTEM (Avançado, funciona em PC e Mobile)
-- ═══════════════════════════════════════════════════════════════════
local DragSystem = {}
DragSystem.__index = DragSystem

function DragSystem.new(dragTarget, dragHandle, boundsCheck)
    local self = setmetatable({}, DragSystem)
    self.Target = dragTarget
    self.Handle = dragHandle or dragTarget
    self.Dragging = false
    self.DragStart = nil
    self.StartPosition = nil
    self.Connections = {}
    self.BoundsCheck = boundsCheck ~= false
    self.Velocity = Vector2.new(0, 0)
    self.LastPosition = nil
    self.LastTime = 0
    return self
end

function DragSystem:Enable()
    local target = self.Target
    local handle = self.Handle

    -- Input Begin (Mouse + Touch)
    local inputBegan = UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then

            local inputPos = input.Position
            local handleAbsPos = handle.AbsolutePosition
            local handleAbsSize = handle.AbsoluteSize

            -- Verifica se o clique está dentro do handle
            if inputPos.X >= handleAbsPos.X and inputPos.X <= handleAbsPos.X + handleAbsSize.X and
               inputPos.Y >= handleAbsPos.Y and inputPos.Y <= handleAbsPos.Y + handleAbsSize.Y then
                self.Dragging = true
                self.DragStart = inputPos
                self.StartPosition = UDim2.fromOffset(
                    target.AbsolutePosition.X,
                    target.AbsolutePosition.Y
                )
                self.LastPosition = inputPos
                self.LastTime = tick()
            end
        end
    end)
    table.insert(self.Connections, inputBegan)

    -- Input Changed (Drag movement)
    local inputChanged = UserInputService.InputChanged:Connect(function(input)
        if not self.Dragging then return end

        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then

            local delta = input.Position - self.DragStart
            local newPos = UDim2.fromOffset(
                self.StartPosition.X.Offset + delta.X,
                self.StartPosition.Y.Offset + delta.Y
            )

            -- Calcular velocidade
            local now = tick()
            local dt = now - self.LastTime
            if dt > 0 then
                self.Velocity = (input.Position - self.LastPosition) / dt
            end
            self.LastPosition = input.Position
            self.LastTime = now

            -- Aplicar bounds check
            if self.BoundsCheck then
                newPos = Utility.ClampToScreen(
                    Vector2.new(newPos.X.Offset, newPos.Y.Offset),
                    Vector2.new(target.AbsoluteSize.X, target.AbsoluteSize.Y)
                )
            end

            target.Position = newPos
        end
    end)
    table.insert(self.Connections, inputChanged)

    -- Input Ended
    local inputEnded = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            self.Dragging = false
            self.DragStart = nil
            self.StartPosition = nil
        end
    end)
    table.insert(self.Connections, inputEnded)

    -- Responsividade: Re-clamp ao redimensionar tela
    local cameraChanged = Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
        if target and target.Parent then
            local currentPos = Vector2.new(target.Position.X.Offset, target.Position.Y.Offset)
            local size = Vector2.new(target.AbsoluteSize.X, target.AbsoluteSize.Y)
            target.Position = Utility.ClampToScreen(currentPos, size)
        end
    end)
    table.insert(self.Connections, cameraChanged)
end

function DragSystem:Disable()
    for _, connection in ipairs(self.Connections) do
        connection:Disconnect()
    end
    self.Connections = {}
end

function DragSystem:Destroy()
    self:Disable()
end

-- ═══════════════════════════════════════════════════════════════════
-- CONFIGURATION SYSTEM (Save/Load)
-- ═══════════════════════════════════════════════════════════════════
local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem
ConfigSystem.Cache = {}

function ConfigSystem.new(name)
    local self = setmetatable({}, ConfigSystem)
    self.Name = name or "iOSLib_Config"
    self.Data = {}
    self.AutoSave = true
    return self
end

function ConfigSystem:Set(key, value)
    self.Data[key] = value
    ConfigSystem.Cache[key] = value
    if self.AutoSave then
        self:Save()
    end
end

function ConfigSystem:Get(key, default)
    if ConfigSystem.Cache[key] ~= nil then
        return ConfigSystem.Cache[key]
    end
    return self.Data[key] or default
end

function ConfigSystem:Save()
    local success, encoded = pcall(function()
        return HttpService:JSONEncode(self.Data)
    end)
    if success then
        -- Usa writefile se disponível (exploits), senão usa DataStore ou ignora
        if writefile then
            pcall(writefile, self.Name .. ".json", encoded)
        end
    end
end

function ConfigSystem:Load()
    if readfile and isfile then
        if isfile(self.Name .. ".json") then
            local success, data = pcall(function()
                local content = readfile(self.Name .. ".json")
                return HttpService:JSONDecode(content)
            end)
            if success and type(data) == "table" then
                self.Data = data
                ConfigSystem.Cache = data
                return true
            end
        end
    end
    return false
end

function ConfigSystem:Reset()
    self.Data = {}
    ConfigSystem.Cache = {}
    self:Save()
end

