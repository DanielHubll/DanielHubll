    end

    local searchBox = Make("TextBox", {
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 32, 0, 0),
        Text = "",
        PlaceholderText = "Buscar...",
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = Theme.Text,
        PlaceholderColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ClearTextOnFocus = false,
        Parent = searchBar,
    })
    self._searchBox = searchBox

    local scrollContent = Make("ScrollingFrame", {
        Name = "ScrollContent",
        Size = UDim2.new(1, -16, 1, -52),
        Position = UDim2.new(0, 8, 0, 48),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.SubText,
        CanvasSize = UDim2.fromOffset(0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        ElasticBehavior = Enum.ElasticBehavior.Never,
        Parent = contentArea,
    })
    self._scrollContent = scrollContent

    Make("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4), Parent = scrollContent })
    local contentLayout = Make("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder, Parent = scrollContent })
    self._contentLayout = contentLayout

    -- ─── DRAG SYSTEM ───
    local dragging = false
    local dragStart = nil
    local startPos = nil

    local function onInputBegan(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            local pos = input.Position
            local hAbs = header.AbsolutePosition
            local hSize = header.AbsoluteSize
            if pos.X >= hAbs.X and pos.X <= hAbs.X + hSize.X - 70 and pos.Y >= hAbs.Y and pos.Y <= hAbs.Y + hSize.Y then
                dragging = true
                dragStart = pos
                startPos = window.Position
            end
        end
    end

    local function onInputChanged(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            local newPos = ClampToScreen(
                Vector2.new(startPos.X.Offset + delta.X, startPos.Y.Offset + delta.Y),
                Vector2.new(window.AbsoluteSize.X, window.AbsoluteSize.Y)
            )
            window.Position = UDim2.fromOffset(newPos.X, newPos.Y)
        end
    end

    local function onInputEnded(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end

    table.insert(self._connections, UserInputService.InputBegan:Connect(onInputBegan))
    table.insert(self._connections, UserInputService.InputChanged:Connect(onInputChanged))
    table.insert(self._connections, UserInputService.InputEnded:Connect(onInputEnded))

    table.insert(self._connections,
        Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
            if window and window.Parent then
                local p = Vector2.new(window.Position.X.Offset, window.Position.Y.Offset)
                local s = Vector2.new(window.AbsoluteSize.X, window.AbsoluteSize.Y)
                local clamped = ClampToScreen(p, s)
                window.Position = UDim2.fromOffset(clamped.X, clamped.Y)
            end
        end)
    )

    -- ─── MINIMIZE ───
    minBtn.MouseButton1Click:Connect(function()
        self._minimized = not self._minimized
        if self._minimized then
            storedHeight = window.AbsoluteSize.Y
            Tween(contentArea, 0.3, { Size = UDim2.new(1, 0, 0, 0) })
            Tween(tabBar, 0.25, { Size = UDim2.new(1, 0, 0, 0) })
            Tween(window, 0.35, { Size = UDim2.fromOffset(window.AbsoluteSize.X, 48) })
        else
            Tween(window, 0.35, { Size = UDim2.fromOffset(window.AbsoluteSize.X, storedHeight) })
            task.delay(0.1, function()
                Tween(tabBar, 0.25, { Size = UDim2.new(1, 0, 0, 42) })
                Tween(contentArea, 0.3, { Size = UDim2.new(1, 0, 1, -90) })
            end)
        end
    end)

    -- ─── CLOSE ───
    closeBtn.MouseButton1Click:Connect(function()
        Tween(window, 0.35, { Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1 })
        task.delay(0.4, function() self:Destroy() end)
    end)

    -- ─── SEARCH SYSTEM ───
    local lastSearch = 0
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local now = tick()
        if now - lastSearch < 0.1 then return end
        lastSearch = now
        local query = searchBox.Text:lower()
        for _, tab in ipairs(self._tabs) do
            if tab.Id == self._activeTabId then
                for _, comp in ipairs(tab.Components) do
                    if comp.Container then
                        local matches = (query == "") or (comp.SearchName and comp.SearchName:lower():find(query, 1, true))
                        comp.Container.Visible = matches
                    end
                end
            end
        end
    end)

    Tween(window, 0.45, { Size = UDim2.fromOffset(startW, startH), BackgroundTransparency = 0 })

    table.insert(Library._windows, self)
    return self
end

function Library:AddTab(name, icon)
    local lib = self
    local tabId = #lib._tabs + 1

    local tab = {
        Id = tabId,
        Name = name or "Tab " .. tabId,
        Icon = icon,
        Sections = {},
        Components = {},
        TabButton = nil,
        TabIcon = nil,
        TabLabel = nil,
    }

    local textSize = GetTextSize(name, 12, Enum.Font.GothamMedium)
    local btnW = textSize.X + 36

    local tabBtn = Make("Frame", {
        Name = "Tab_" .. name,
        Size = UDim2.fromOffset(btnW, 32),
        BackgroundColor3 = Theme.Card,
        BackgroundTransparency = 1,
        LayoutOrder = tabId - 1,
        Parent = lib._tabScroll,
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 8), Parent = tabBtn })

    -- Ícone da tab
    local tabIconContainer = Make("Frame", {
        Size = UDim2.fromOffset(18, 18),
        Position = UDim2.new(0, 6, 0.5, -9),
        BackgroundTransparency = 1,
        Parent = tabBtn,
    })
    
    if icon and icon ~= "" and (icon:find("rbxassetid://") or icon:find("rbxasset://")) then
        Icon(icon, 18, tabIconContainer)
    else
        Icon(ICONS.TAB_DEFAULT, 18, tabIconContainer, icon or "📄")
    end
    tab.TabIcon = tabIconContainer

    local tabLabel = Make("TextLabel", {
        Size = UDim2.new(0, textSize.X + 4, 1, 0),
        Position = UDim2.new(0, 26, 0, 0),
        Text = name,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = tabBtn,
    })
    tab.TabLabel = tabLabel
    tab.TabButton = tabBtn

    tabBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            lib:SelectTab(tabId)
        end
    end)

    tabBtn.MouseEnter:Connect(function()
        if lib._activeTabId ~= tabId then Tween(tabBtn, 0.15, { BackgroundTransparency = 0.5 }) end
    end)
    tabBtn.MouseLeave:Connect(function()
        if lib._activeTabId ~= tabId then Tween(tabBtn, 0.15, { BackgroundTransparency = 1 }) end
    end)

    table.insert(lib._tabs, tab)
    if #lib._tabs == 1 then lib:SelectTab(tabId) end

    local tabAPI = {}

    function tabAPI:AddSection(title, iconEmoji)
        local section = { Title = title, Container = nil, Layout = nil, Components = {} }
        local sectionFrame = Make("Frame", { Name = "Section_" .. (title or ""), Size = UDim2.new(1, 0, 0, 0), BackgroundColor3 = Theme.Card, LayoutOrder = #tab.Sections, Visible = (tab.Id == lib._activeTabId), Parent = lib._scrollContent })
        Make("UICorner", { CornerRadius = UDim.new(0, 12), Parent = sectionFrame })
        Make("UIStroke", { Color = Theme.Sep, Thickness = 0.5, Transparency = 0.7, Parent = sectionFrame })

        local secLayout = Make("UIListLayout", { Padding = UDim.new(0, 0), SortOrder = Enum.SortOrder.LayoutOrder, Parent = sectionFrame })

        if title and title ~= "" then
            local hdr = Make("Frame", { Size = UDim2.new(1, 0, 0, 36), BackgroundTransparency = 1, LayoutOrder = 0, Parent = sectionFrame })
            
            -- Ícone da seção
            local iconOffset = 0
