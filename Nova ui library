        Position = UDim2.new(0, 0, 0, 90),
        BackgroundColor3 = Theme.Bg,
        ClipsDescendants = true,
        Parent = window,
    })
    self._contentArea = contentArea

    -- ─── SEARCH BAR ───
    local searchBar = Make("Frame", {
        Size = UDim2.new(1, -24, 0, 36),
        Position = UDim2.new(0, 12, 0, 8),
        BackgroundColor3 = Theme.Input,
        Parent = contentArea,
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 10), Parent = searchBar })

    Make("TextLabel", {
        Size = UDim2.fromOffset(16, 16),
        Position = UDim2.new(0, 10, 0.5, -8),
        Text = "🔍",
        Font = Enum.Font.Gotham,
        TextSize = 12,
        BackgroundTransparency = 1,
        Parent = searchBar,
    })

    local searchBox = Make("TextBox", {
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 32, 0, 0),
        Text = "",
        PlaceholderText = "Buscar...",
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = Theme.Text,
        PlaceholderColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ClearTextOnFocus = false,
        Parent = searchBar,
    })
    self._searchBox = searchBox

    -- ─── SCROLL CONTENT ───
    -- ✅ REMOVE EFEITO ELÁSTICO - ElasticBehavior.Never
    local scrollContent = Make("ScrollingFrame", {
        Name = "ScrollContent",
        Size = UDim2.new(1, -16, 1, -52),
        Position = UDim2.new(0, 8, 0, 48),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.SubText,
        CanvasSize = UDim2.fromOffset(0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        ElasticBehavior = Enum.ElasticBehavior.Never, -- 🚫 SEM EFEITO ELÁSTICO
        Parent = contentArea,
    })
    self._scrollContent = scrollContent

    Make("UIPadding", {
        PaddingTop = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 12),
        PaddingLeft = UDim.new(0, 4),
        PaddingRight = UDim.new(0, 4),
        Parent = scrollContent,
    })

    local contentLayout = Make("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = scrollContent,
    })
    self._contentLayout = contentLayout

    -- ─── DRAG SYSTEM ───
    local dragging = false
    local dragStart = nil
    local startPos = nil

    local function onInputBegan(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            local pos = input.Position
            local hAbs = header.AbsolutePosition
            local hSize = header.AbsoluteSize
            -- Não inicia drag se estiver nos botões de controle ou resize
            if pos.X >= hAbs.X and pos.X <= hAbs.X + hSize.X - 70 and
               pos.Y >= hAbs.Y and pos.Y <= hAbs.Y + hSize.Y then
                dragging = true
                dragStart = pos
                startPos = Vector2.new(window.Position.X.Offset, window.Position.Y.Offset)
            end
        end
    end

    local function onInputChanged(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            local newPos = ClampToScreen(
                Vector2.new(startPos.X + delta.X, startPos.Y + delta.Y),
                Vector2.new(window.AbsoluteSize.X, window.AbsoluteSize.Y)
            )
            window.Position = UDim2.fromOffset(newPos.X, newPos.Y)
        end
    end

    local function onInputEnded(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end

    table.insert(self._connections,
        UserInputService.InputBegan:Connect(onInputBegan))
    table.insert(self._connections,
        UserInputService.InputChanged:Connect(onInputChanged))
    table.insert(self._connections,
        UserInputService.InputEnded:Connect(onInputEnded))

    -- Re-clamp ao redimensionar tela
    table.insert(self._connections,
        Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
            if window and window.Parent then
                local p = Vector2.new(window.Position.X.Offset, window.Position.Y.Offset)
                local s = Vector2.new(window.AbsoluteSize.X, window.AbsoluteSize.Y)
                local clamped = ClampToScreen(p, s)
                window.Position = UDim2.fromOffset(clamped.X, clamped.Y)
            end
        end)
    )

    -- ─── MINIMIZE ───
    minBtn.MouseButton1Click:Connect(function()
        self._minimized = not self._minimized
        if self._minimized then
            Tween(contentArea, 0.3, { Size = UDim2.new(1, 0, 0, 0) })
            Tween(tabBar, 0.25, { Size = UDim2.new(1, 0, 0, 0) })
            Tween(window, 0.35, { Size = UDim2.fromOffset(window.AbsoluteSize.X, 48) })
        else
            local ws = mobile
                and UDim2.new(0.95, 0, 0.85, 0)
                or UDim2.fromOffset(window.AbsoluteSize.X, 480)
            Tween(window, 0.35, { Size = ws })
            task.delay(0.1, function()
                Tween(tabBar, 0.25, { Size = UDim2.new(1, 0, 0, 42) })
                Tween(contentArea, 0.3, { Size = UDim2.new(1, 0, 1, -90) })
            end)
        end
    end)

    -- ─── CLOSE ───
    closeBtn.MouseButton1Click:Connect(function()
        Tween(window, 0.35, { Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1 })
        task.delay(0.4, function()
            self:Destroy()
        end)
    end)

    -- ─── SEARCH ───
    local lastSearch = 0
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local now = tick()
        if now - lastSearch < 0.15 then return end
        lastSearch = now
        local query = searchBox.Text:lower()
        for _, tab in ipairs(self._tabs) do
            if tab.Id == self._activeTabId then
                for _, comp in ipairs(tab.Components) do
                    if comp.Container then
                        local matches = query == "" or
                            (comp.SearchName and comp.SearchName:lower():find(query, 1, true))
                        comp.Container.Visible = matches
                    end
                end
            end
        end
    end)

    -- ─── ANIMAÇÃO DE ABERTURA ───
    Tween(window, 0.45, { Size = winSize, BackgroundTransparency = 0 })

    table.insert(Library._windows, self)
    return self
end

-- ═══════════════════════════════════════════════════════════════════
-- ADD TAB
-- ═══════════════════════════════════════════════════════════════════
function Library:AddTab(name, icon)
    local lib = self
    local tabId = #lib._tabs + 1

    local tab = {
        Id = tabId,
        Name = name or "Tab " .. tabId,
        Icon = icon,
        Sections = {},
        Components = {},
        TabButton = nil,
        TabIcon = nil,
        TabLabel = nil,
    }

    -- Calcula tamanho do texto para o botão da tab
    local textSize = GetTextSize(name, 12, Enum.Font.GothamMedium)
    local btnW = textSize.X + 36

    -- Botão da tab
    local tabBtn = Make("Frame", {
        Name = "Tab_" .. name,
        Size = UDim2.fromOffset(btnW, 32),
        BackgroundColor3 = Theme.Card,
        BackgroundTransparency = 1,
        LayoutOrder = tabId - 1,
        Parent = lib._tabScroll,
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 8), Parent = tabBtn })

    -- Ícone da tab (emoji)
    local tabIconLabel = Make("TextLabel", {
        Size = UDim2.fromOffset(18, 18),
        Position = UDim2.new(0, 6, 0.5, -9),
        Text = icon or "📄",
        Font = Enum.Font.Gotham,
        TextSize = 14,
        BackgroundTransparency = 1,
        Parent = tabBtn,
    })
    tab.TabIcon = tabIconLabel

    -- Texto da tab
    local tabLabel = Make("TextLabel", {
        Size = UDim2.new(0, textSize.X + 4, 1, 0),
        Position = UDim2.new(0, 26, 0, 0),
        Text = name,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = tabBtn,
    })
    tab.TabLabel = tabLabel
    tab.TabButton = tabBtn

    -- Click para selecionar a tab
    tabBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            lib:SelectTab(tabId)
        end
    end)

    -- Hover
    tabBtn.MouseEnter:Connect(function()
        if lib._activeTabId ~= tabId then
            Tween(tabBtn, 0.15, { BackgroundTransparency = 0.5 })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if lib._activeTabId ~= tabId then
            Tween(tabBtn, 0.15, { BackgroundTransparency = 1 })
        end
    end)

    table.insert(lib._tabs, tab)

    -- Seleciona automaticamente a primeira tab
    if #lib._tabs == 1 then
        lib:SelectTab(tabId)
    end

    -- ─── Retorna API da Tab ───
    local tabAPI = {}

    function tabAPI:AddSection(title, iconEmoji)
        local section = {
            Title = title,
            Container = nil,
            Layout = nil,
            Components = {},
        }

        local sectionFrame = Make("Frame", {
            Name = "Section_" .. (title or ""),
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Theme.Card,
            LayoutOrder = #tab.Sections,
            Visible = (tab.Id == lib._activeTabId),
            Parent = lib._scrollContent,
        })
        Make("UICorner", { CornerRadius = UDim.new(0, 12), Parent = sectionFrame })
        Make("UIStroke", { Color = Theme.Sep, Thickness = 0.5, Transparency = 0.7, Parent = sectionFrame })

        local secLayout = Make("UIListLayout", {
            Padding = UDim.new(0, 0),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = sectionFrame,
        })

        -- Título da seção
        if title and title ~= "" then
            local hdr = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundTransparency = 1,
                LayoutOrder = 0,
                Parent = sectionFrame,
            })

            if iconEmoji then
                Make("TextLabel", {
                    Size = UDim2.fromOffset(18, 18),
                    Position = UDim2.new(0, 12, 0.5, -9),
                    Text = iconEmoji,
                    Font = Enum.Font.Gotham,
                    TextSize = 14,
                    BackgroundTransparency = 1,
                    Parent = hdr,
                })
            end

            Make("TextLabel", {
                Size = UDim2.new(1, iconEmoji and -40 or -28, 1, 0),
                Position = UDim2.new(0, iconEmoji and 34 or 14, 0, 0),
                Text = title,
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = Theme.SubText,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Parent = hdr,
            })

            Make("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 1, 0),
                BackgroundColor3 = Theme.Sep,
                Transparency = 0.5,
                Parent = hdr,
            })
        end

        section.Container = sectionFrame
        section.Layout = secLayout

        -- Atualiza altura automaticamente
        secLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            sectionFrame.Size = UDim2.new(1, 0, 0, secLayout.AbsoluteContentSize.Y)
        end)
        -- Força update inicial
        task.defer(function()
            sectionFrame.Size = UDim2.new(1, 0, 0, secLayout.AbsoluteContentSize.Y)
        end)

        table.insert(tab.Sections, section)

        local nextOrder = 1
        local function getOrder()
            local o = nextOrder
            nextOrder = nextOrder + 1
            return o
        end

        -- ═══════════════════════════════════════════════════════════
        -- SECTION API — Todos os Componentes
        -- ═══════════════════════════════════════════════════════════
        local secAPI = {}

        -- ───────────────────────────────────────────────────────────
        -- BUTTON
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddButton(options)
            local opts = options or {}
            local name = opts.Name or "Button"
            local callback = opts.Callback or function() end
            local style = opts.Style or "Default"

            local row = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 48),
                BackgroundTransparency = 1,
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            local bgColor = style == "Filled" and Theme.Accent
                or style == "Danger" and Theme.Red
                or Theme.Input

            local btn = Make("TextButton", {
                Size = UDim2.new(1, -28, 0, 38),
                Position = UDim2.new(0, 14, 0, 5),
                Text = name,
                Font = Enum.Font.GothamSemibold,
                TextSize = 13,
                TextColor3 = style == "Default" and Theme.Text or Theme.White,
                BackgroundColor3 = bgColor,
                AutoButtonColor = false,
                Parent = row,
            })
            Make("UICorner", { CornerRadius = UDim.new(0, 10), Parent = btn })

            btn.MouseButton1Click:Connect(function()
                Tween(btn, 0.08, { Size = UDim2.new(1, -34, 0, 36) })
                task.delay(0.1, function()
                    Tween(btn, 0.15, { Size = UDim2.new(1, -28, 0, 38) })
                end)
                pcall(callback)
            end)

            btn.MouseEnter:Connect(function()
                Tween(btn, 0.12, { BackgroundTransparency = 0.2 })
            end)
            btn.MouseLeave:Connect(function()
                Tween(btn, 0.12, { BackgroundTransparency = 0 })
            end)

            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)
            return row
        end

        -- ───────────────────────────────────────────────────────────
        -- TOGGLE
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddToggle(options)
            local opts = options or {}
            local name = opts.Name or "Toggle"
            local default = opts.Default or false
            local callback = opts.Callback or function() end

            local isOn = default

            local row = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 48),
                BackgroundTransparency = 1,
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            -- Label
            Make("TextLabel", {
                Size = UDim2.new(1, -80, 1, 0),
                Position = UDim2.new(0, 14, 0, 0),
                Text = name,
                Font = Enum.Font.Gotham,
                TextSize = 14,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Parent = row,
            })

            -- Toggle Background
            local toggleBg = Make("Frame", {
                Size = UDim2.fromOffset(50, 30),
                Position = UDim2.new(1, -64, 0.5, -15),
                BackgroundColor3 = isOn and Theme.ToggleOn or Theme.ToggleOff,
                Parent = row,
            })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = toggleBg })

            -- Toggle Knob
            local toggleKnob = Make("Frame", {
                Size = UDim2.fromOffset(26, 26),
                Position = isOn and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13),
                BackgroundColor3 = Theme.White,
                Parent = toggleBg,
            })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = toggleKnob })
            Make("UIStroke", { Color = Color3.new(0,0,0), Thickness = 0.5, Transparency = 0.85, Parent = toggleKnob })

            -- Click area
            local clickArea = Make("TextButton", {
                Size = UDim2.fromOffset(54, 34),
                Position = UDim2.new(1, -66, 0.5, -17),
                Text = "",
                BackgroundTransparency = 1,
                Parent = row,
            })

            local function setToggle(val, animate)
                isOn = val
                local dur = (animate ~= false) and 0.2 or 0
                Tween(toggleBg, dur, {
                    BackgroundColor3 = isOn and Theme.ToggleOn or Theme.ToggleOff,
                })
                Tween(toggleKnob, dur, {
                    Position = isOn and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13),
                })
                pcall(callback, isOn)
            end

            clickArea.MouseButton1Click:Connect(function()
                setToggle(not isOn, true)
            end)

            -- Hover na row inteira
            row.MouseEnter:Connect(function()
                Tween(row, 0.12, { BackgroundColor3 = Theme.Input, BackgroundTransparency = 0.5 })
            end)
            row.MouseLeave:Connect(function()
                Tween(row, 0.12, { BackgroundTransparency = 1 })
            end)

            -- Separador
            Make("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 1, -1),
                BackgroundColor3 = Theme.Sep,
                Transparency = 0.5,
                Parent = row,
            })

            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)

            return {
                SetValue = function(v) setToggle(v, true) end,
                GetValue = function() return isOn end,
            }
        end

        -- ───────────────────────────────────────────────────────────
        -- SLIDER
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddSlider(options)
            local opts = options or {}
            local name = opts.Name or "Slider"
            local min = opts.Min or 0
            local max = opts.Max or 100
            local default = opts.Default or min
            local step = opts.Step or 1
            local suffix = opts.Suffix or ""
            local callback = opts.Callback or function() end

            local value = default

            local row = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 68),
                BackgroundTransparency = 1,
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            -- Label
            Make("TextLabel", {
                Size = UDim2.new(0.5, 0, 0, 20),
                Position = UDim2.new(0, 14, 0, 8),
                Text = name,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Parent = row,
            })

            -- Valor
            local valLabel = Make("TextLabel", {
                Size = UDim2.new(0.4, -14, 0, 20),
                Position = UDim2.new(0.5, 0, 0, 8),
                Text = value .. suffix,
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = Theme.Accent,
                TextXAlignment = Enum.TextXAlignment.Right,
                BackgroundTransparency = 1,
                Parent = row,
            })

            -- Track
            local track = Make("Frame", {
                Size = UDim2.new(1, -28, 0, 6),
                Position = UDim2.new(0, 14, 0, 42),
                BackgroundColor3 = Theme.Input,
                Parent = row,
            })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })

            -- Fill
            local pct = (value - min) / math.max(1, max - min)
            local fill = Make("Frame", {
                Size = UDim2.new(pct, 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                Parent = track,
            })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })

            -- Knob
            local knob = Make("Frame", {
                Size = UDim2.fromOffset(20, 20),
                Position = UDim2.new(pct, -10, 0.5, -10),
                BackgroundColor3 = Theme.White,
                ZIndex = 2,
                Parent = track,
            })
            Make("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })
            Make("UIStroke", { Color = Color3.new(0,0,0), Thickness = 0.5, Transparency = 0.8, Parent = knob })

            local draggingSlider = false

            local function updateSlider(newVal)
                value = math.clamp(
                    math.floor(newVal / step + 0.5) * step,
                    min, max
                )
                local p = (value - min) / math.max(1, max - min)
                fill.Size = UDim2.new(p, 0, 1, 0)
                knob.Position = UDim2.new(p, -10, 0.5, -10)
                valLabel.Text = value .. suffix
                pcall(callback, value)
            end

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                    local rel = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                    updateSlider(min + rel * (max - min))
                end
            end)

            Track(UserInputService.InputChanged:Connect(function(input)
                if not draggingSlider then return end
                if input.UserInputType == Enum.UserInputType.MouseMovement or
                   input.UserInputType == Enum.UserInputType.Touch then
                    local rel = math.clamp(
                        (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X,
                        0, 1
                    )
                    updateSlider(min + rel * (max - min))
                end
            end))

            Track(UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = false
                end
            end))

            knob.MouseEnter:Connect(function()
                Tween(knob, 0.12, { Size = UDim2.fromOffset(24, 24) })
            end)
            knob.MouseLeave:Connect(function()
                Tween(knob, 0.12, { Size = UDim2.fromOffset(20, 20) })
            end)

            -- Separador
            Make("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 1, -1),
                BackgroundColor3 = Theme.Sep,
                Transparency = 0.5,
                Parent = row,
            })

            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)

            return {
                SetValue = function(v) updateSlider(v) end,
                GetValue = function() return value end,
            }
        end

        -- ───────────────────────────────────────────────────────────
        -- DROPDOWN (FIXED - opções aparecem agora)
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddDropdown(options)
            local opts = options or {}
            local name = opts.Name or "Dropdown"
            local optList = opts.Options or {}
            local default = opts.Default or ""
            local callback = opts.Callback or function() end

            local selected = default
            local isOpen = false

            -- ✅ ROW COM ZIndex ALTO E ClipsDescendants FALSE
            local row = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 48),
                BackgroundTransparency = 1,
                ClipsDescendants = false, -- ✅ PERMITE DROPDOWN APARECER FORA
                ZIndex = 10,              -- ✅ ACIMA DE OUTROS ELEMENTOS
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            -- Label
            Make("TextLabel", {
                Size = UDim2.new(0.4, 0, 0, 48),
                Position = UDim2.new(0, 14, 0, 0),
                Text = name,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                ZIndex = 11,
                Parent = row,
            })

            -- Valor selecionado
            local valLabel = Make("TextLabel", {
                Size = UDim2.new(0.35, 0, 0, 48),
                Position = UDim2.new(0.45, 0, 0, 0),
                Text = tostring(selected),
                Font = Enum.Font.Gotham,
                TextSize = 12,
                TextColor3 = Theme.SubText,
                TextXAlignment = Enum.TextXAlignment.Right,
                TextTruncate = Enum.TextTruncate.AtEnd,
                BackgroundTransparency = 1,
                ZIndex = 11,
                Parent = row,
            })

            -- Chevron
            local chevron = Make("TextLabel", {
                Size = UDim2.fromOffset(16, 16),
                Position = UDim2.new(1, -24, 0.5, -8),
                Text = "▾",
                Font = Enum.Font.GothamBold,
                TextSize = 14,
                TextColor3 = Theme.SubText,
                BackgroundTransparency = 1,
                ZIndex = 11,
                Parent = row,
            })

            -- Container do dropdown (aparece abaixo)
            -- ✅ ZINDEX ALTO PARA SOBREPOR TUDO
            local dropFrame = Make("Frame", {
                Size = UDim2.new(1, -28, 0, 0),
                Position = UDim2.new(0, 14, 1, 2),
                BackgroundColor3 = Theme.Card,
                ClipsDescendants = true,
                Visible = false,
                ZIndex = 100, -- ✅ ZINDEX ALTO
                Parent = row,
            })
            Make("UICorner", { CornerRadius = UDim.new(0, 10), Parent = dropFrame })
            Make("UIStroke", { Color = Theme.Sep, Thickness = 0.5, Parent = dropFrame })

            local dropLayout = Make("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = dropFrame,
            })

            -- Cria opções
            for i, opt in ipairs(optList) do
                local optName = type(opt) == "table" and opt.Name or tostring(opt)
                local optVal = type(opt) == "table" and opt.Value or opt

                local optBtn = Make("TextButton", {
                    Size = UDim2.new(1, 0, 0, 34),
                    Text = "  " .. optName,
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    AutoButtonColor = false,
                    ZIndex = 101, -- ✅ ACIMA DO dropFrame
                    LayoutOrder = i,
                    Parent = dropFrame,
                })

                optBtn.MouseButton1Click:Connect(function()
                    selected = optVal
                    valLabel.Text = optName
                    pcall(callback, optVal, optName)
                    -- Fecha dropdown
                    isOpen = false
                    Tween(chevron, 0.2, { Rotation = 0 })
                    Tween(dropFrame, 0.2, { Size = UDim2.new(1, -28, 0, 0) })
                    task.delay(0.2, function()
                        dropFrame.Visible = false
                        row.Size = UDim2.new(1, 0, 0, 48)
                    end)
                end)

                optBtn.MouseEnter:Connect(function()
                    Tween(optBtn, 0.1, { BackgroundColor3 = Theme.Input, BackgroundTransparency = 0.3 })
                end)
                optBtn.MouseLeave:Connect(function()
                    Tween(optBtn, 0.1, { BackgroundTransparency = 1 })
                end)

                if i < #optList then
                    Make("Frame", {
                        Size = UDim2.new(1, -16, 0, 1),
                        Position = UDim2.new(0, 8, 1, -1),
                        BackgroundColor3 = Theme.Sep,
                        Transparency = 0.5,
                        ZIndex = 102,
                        Parent = optBtn,
                    })
                end
            end

            -- Click para abrir/fechar
            local clickBtn = Make("TextButton", {
                Size = UDim2.new(1, 0, 0, 48),
                Text = "",
                BackgroundTransparency = 1,
                ZIndex = 12,
                Parent = row,
            })

            clickBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    dropFrame.Visible = true
                    local h = math.min(#optList * 34, 170)
                    row.Size = UDim2.new(1, 0, 0, 48 + h + 6)
                    Tween(chevron, 0.2, { Rotation = 180 })
                    Tween(dropFrame, 0.25, { Size = UDim2.new(1, -28, 0, h) })
                else
                    Tween(chevron, 0.2, { Rotation = 0 })
                    Tween(dropFrame, 0.2, { Size = UDim2.new(1, -28, 0, 0) })
                    task.delay(0.2, function()
                        dropFrame.Visible = false
                        row.Size = UDim2.new(1, 0, 0, 48)
                    end)
                end
            end)

            -- Separador
            Make("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 0, 47),
                BackgroundColor3 = Theme.Sep,
                Transparency = 0.5,
                Parent = row,
            })

            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)

            return {
                SetValue = function(v)
                    selected = v
                    valLabel.Text = tostring(v)
                end,
                GetValue = function() return selected end,
            }
        end

        -- ───────────────────────────────────────────────────────────
        -- TEXTBOX
        -- ───────────────────────────────────────────────────────────
        function secAPI:AddTextbox(options)
            local opts = options or {}
            local name = opts.Name or "Input"
            local placeholder = opts.Placeholder or "Digite aqui..."
            local default = opts.Default or ""
            local callback = opts.Callback or function() end

            local row = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 48),
                BackgroundTransparency = 1,
                LayoutOrder = getOrder(),
                Parent = sectionFrame,
            })

            Make("TextLabel", {
                Size = UDim2.new(0.35, 0, 1, 0),
                Position = UDim2.new(0, 14, 0, 0),
                Text = name,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
