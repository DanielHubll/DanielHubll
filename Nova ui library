--- Cria uma nova janela
function Library.CreateWindow(config)
    local cfg = {
        Title = config.Title or "iOS Library",
        Subtitle = config.Subtitle or "Premium UI",
        Icon = config.Icon or "",
    }

    local self = setmetatable({}, Library)
    self._tabs = {}
    self._activeTabId = nil
    self._minimized = false
    self._connections = {}
    self._savedConfig = {}

    -- ─── ScreenGui ───
    local screenGui = Make("ScreenGui", {
        Name = "iOSLib_" .. tostring(math.random(10000, 99999)),
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = PlayerGui,
    })
    self._screenGui = screenGui

    -- Inicializa sistema de notificações
    InitNotifications(screenGui)

    -- ─── Calcula tamanho da janela ───
    local mobile = IsMobile()
    local winSize = mobile
        and UDim2.new(0.95, 0, 0.85, 0)
        or UDim2.fromOffset(520, 480)

    -- ─── Janela Principal ───
    local window = Make("Frame", {
        Name = "Window",
        Size = UDim2.fromOffset(0, 0),
        Position = mobile
            and UDim2.new(0.5, 0, 0.5, 0)
            or UDim2.fromOffset(120, 80),
        AnchorPoint = mobile and Vector2.new(0.5, 0.5) or Vector2.new(0, 0),
        BackgroundColor3 = Theme.Bg,
        ClipsDescendants = true,
        Parent = screenGui,
    })
    self._window = window
    Make("UICorner", { CornerRadius = UDim.new(0, 16), Parent = window })
    Make("UIStroke", { Color = Theme.Sep, Thickness = 0.5, Transparency = 0.5, Parent = window })

    -- ═══════════════════════════════════════════════════════════════
    -- RESIZE HANDLE (SISTEMA DE REDIMENSIONAMENTO)
    -- ═══════════════════════════════════════════════════════════════
    local MIN_SIZE = Vector2.new(300, 250) -- Tamanho mínimo da janela

    local resizeHandle = Make("Frame", {
        Name = "ResizeHandle",
        Size = UDim2.fromOffset(24, 24),
        Position = UDim2.new(1, -24, 1, -24),
        BackgroundTransparency = 1,
        ZIndex = 10,
        Parent = window,
    })

    -- Ícone visual da alça (duas linhas diagonais)
    Make("Frame", {
        Size = UDim2.fromOffset(10, 2),
        Position = UDim2.new(1, -14, 1, -10),
        Rotation = -45,
        BackgroundColor3 = Theme.CapText,
        BackgroundTransparency = 0.4,
        ZIndex = 11,
        Parent = resizeHandle,
    })

    Make("Frame", {
        Size = UDim2.fromOffset(10, 2),
        Position = UDim2.new(1, -16, 1, -6),
        Rotation = -45,
        BackgroundColor3 = Theme.CapText,
        BackgroundTransparency = 0.4,
        ZIndex = 11,
        Parent = resizeHandle,
    })

    -- LÓGICA DE REDIMENSIONAMENTO
    local resizing = false
    local resizeStartPos = nil
    local resizeStartSize = nil

    resizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            resizing = true
            resizeStartPos = input.Position
            resizeStartSize = Vector2.new(window.AbsoluteSize.X, window.AbsoluteSize.Y)
        end
    end)

    table.insert(self._connections,
        UserInputService.InputChanged:Connect(function(input)
            if not resizing then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement or
               input.UserInputType == Enum.UserInputType.Touch then
                local delta = input.Position - resizeStartPos
                local newW = math.max(MIN_SIZE.X, resizeStartSize.X + delta.X)
                local newH = math.max(MIN_SIZE.Y, resizeStartSize.Y + delta.Y)
                window.Size = UDim2.fromOffset(newW, newH)
            end
        end)
    )

    table.insert(self._connections,
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or
               input.UserInputType == Enum.UserInputType.Touch then
                resizing = false
            end
        end)
    )

    -- Muda cursor ao passar na alça
    resizeHandle.MouseEnter:Connect(function()
        UserInputService.MouseIcon = "rbxasset://SystemCursors/SizeNWSE"
    end)
    resizeHandle.MouseLeave:Connect(function()
        if not resizing then
            UserInputService.MouseIcon = ""
        end
    end)

    -- ─── HEADER ───
    local header = Make("Frame", {
        Name = "Header",
        Size = UDim2.new(1, 0, 0, 48),
        BackgroundColor3 = Theme.Header,
        Parent = window,
    })
    Make("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Theme.Sep,
        Transparency = 0.5,
        Parent = header,
    })

    -- Título
    Make("TextLabel", {
        Size = UDim2.new(1, -130, 0, 18),
        Position = UDim2.new(0, 14, 0, 8),
        Text = cfg.Title,
        Font = Enum.Font.GothamBold,
        TextSize = 15,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = header,
