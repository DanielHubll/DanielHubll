                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 12,
                Font = Cfg.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = wrap
            })

            local valLbl = New("TextLabel", {
                Size = UDim2.new(0, 55, 0, 16),
                Position = UDim2.new(1, -59, 0, 2),
                BackgroundTransparency = 1,
                Text = string.format("%."..dec.."f", val),
                TextColor3 = Theme.TextSec,
                TextSize = 11,
                Font = Cfg.Bold,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = wrap
            })

            local track = New("Frame", {
                Size = UDim2.new(1, -8, 0, 6),
                Position = UDim2.new(0, 4, 0, 28),
                BackgroundColor3 = Theme.SliderTrack,
                Parent = wrap
            })
            Rnd(track, UDim.new(1, 0))

            local fill = New("Frame", {
                Size = UDim2.new((val-min)/(max-min), 0, 1, 0),
                BackgroundColor3 = Theme.SliderFill,
                Parent = track
            })
            Rnd(fill, UDim.new(1, 0))

            local handle = New("Frame", {
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new((val-min)/(max-min), -7, 0.5, -7),
                BackgroundColor3 = Theme.Accent,
                Parent = track
            })
            Rnd(handle, UDim.new(1, 0))
            Str(handle, Theme.Bg, 2)

            local function SetVal(v)
                v = math.clamp(v, min, max)
                val = v
                local p = (val-min)/(max-min)
                Tw(fill, {Size = UDim2.new(p,0,1,0)}, 0.06)
                Tw(handle, {Position = UDim2.new(p,-7,0.5,-7)}, 0.06)
                valLbl.Text = string.format("%."..dec.."f", val)
                task.spawn(cb, val)
            end

            local sBtn = New("TextButton", {
                Size = UDim2.new(1, 14, 0, 22),
                Position = UDim2.new(0, -7, 0, 22),
                BackgroundTransparency = 1,
                Text = "",
                Parent = wrap
            })

            local sliding = false
            sBtn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                end
            end)
            UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)
            UIS.InputChanged:Connect(function(inp)
                if sliding and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                    local r = (inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                    SetVal(min + (max-min) * math.clamp(r, 0, 1))
                end
            end)

            SetVal(val)

            return {
                SetValue = function(_, v) SetVal(v) end,
                GetValue = function() return val end
            }
        end

