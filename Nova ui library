                        TextTransparency = states[opt] and 0 or 1
                    }, 0.15)
                    task.spawn(callback, states, opt)
                end)
            end

            return {
                GetStates = function() return states end,
                SetState = function(self, opt, val)
                    states[opt] = val
                end
            }
        end

        -- ═══ IMAGE LABEL ═══
        function section:AddImage(imageId, size)
            size = size or UDim2.new(1, -20, 0, 120)
            local img = New("ImageLabel", {
                Size = size,
                Position = UDim2.new(0, 10, 0, 0),
                BackgroundTransparency = 1,
                Image = imageId,
                ScaleType = Enum.ScaleType.Fit,
                LayoutOrder = section.ItemOrder,
                Parent = section.Frame
            })
            section.ItemOrder = section.ItemOrder + 1

            return {
                SetImage = function(self, id) img.Image = id end
            }
        end

        -- ═══ PROGRESS BAR ═══
        function section:AddProgressBar(text, default)
            default = default or 0

            local frame = New("Frame", {
                Size = UDim2.new(1, -12, 0, 40),
                Position = UDim2.new(0, 6, 0, 0),
                BackgroundTransparency = 1,
                LayoutOrder = section.ItemOrder,
                Parent = section.Frame
            })
            section.ItemOrder = section.ItemOrder + 1

            local label = New("TextLabel", {
                Size = UDim2.new(1, -50, 0, 16),
                Position = UDim2.new(0, 4, 0, 2),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = Theme.Text,
                TextSize = 13,
                Font = Config.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = frame
            })

            local pctLabel = New("TextLabel", {
                Size = UDim2.new(0, 45, 0, 16),
                Position = UDim2.new(1, -49, 0, 2),
                BackgroundTransparency = 1,
                Text = math.floor(default) .. "%",
                TextColor3 = Theme.TextDim,
                TextSize = 12,
                Font = Config.FontBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = frame
            })

            local barBg = New("Frame", {
                Size = UDim2.new(1, -8, 0, 8),
                Position = UDim2.new(0, 4, 0, 24),
                BackgroundColor3 = Theme.SliderBg,
                Parent = frame
            })
            Corner(barBg, UDim.new(1, 0))

            local barFill = New("Frame", {
                Size = UDim2.new(math.clamp(default, 0, 100) / 100, 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                Parent = barBg
            })
            Corner(barFill, UDim.new(1, 0))

            return {
                SetValue = function(self, val)
                    val = math.clamp(val, 0, 100)
                    Tween(barFill, {Size = UDim2.new(val / 100, 0, 1, 0)}, 0.3)
                    pctLabel.Text = math.floor(val) .. "%"
                end
            }
        end

        -- ═══ CODE BOX ═══
        function section:AddCodeBox(text, code)
            local frame = New("Frame", {
                Size = UDim2.new(1, -12, 0, 60),
                Position = UDim2.new(0, 6, 0, 0),
                BackgroundColor3 = Theme.BackgroundDark,
                LayoutOrder = section.ItemOrder,
                Parent = section.Frame
            })
            Corner(frame, Config.SmallRadius)
            Stroke(frame, Theme.Border, 1)
            section.ItemOrder = section.ItemOrder + 1

            New("TextLabel", {
                Size = UDim2.new(1, -16, 0, 16),
                Position = UDim2.new(0, 8, 0, 4),
                BackgroundTransparency = 1,
                Text = text or "Code",
                TextColor3 = Theme.TextDim,
                TextSize = 10,
                Font = Config.FontBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = frame
            })

            local codeLabel = New("TextLabel", {
                Size = UDim2.new(1, -16, 1, -24),
                Position = UDim2.new(0, 8, 0, 20),
                BackgroundTransparency = 1,
                Text = code or "",
                TextColor3 = Theme.AccentDim,
                TextSize = 11,
                Font = Enum.Font.Code,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextYAlignment = Enum.TextYAlignment.Top,
                TextWrapped = true,
                Parent = frame
            })

            return {
                SetCode = function(self, c) codeLabel.Text = c end
            }
        end

        return section
    end

    return tab
end

