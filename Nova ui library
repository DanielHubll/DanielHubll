    })
    Corner(notif, Config.SmallRadius)
    Stroke(notif, Theme.Border, 1)
    
    -- Accent bar
    local accentBar = New("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        Parent = notif
    })
    Corner(accentBar, Config.TinyRadius)
    
    -- Icon
    if icon then
        New("ImageLabel", {
            Size = UDim2.new(0, 20, 0, 20),
            Position = UDim2.new(0, 12, 0, 12),
            BackgroundTransparency = 1,
            Image = icon,
            ImageColor3 = accentColor,
            ZIndex = 101,
            Parent = notif
        })
    end
    
    local titleLbl = New("TextLabel", {
        Size = UDim2.new(1, icon and -50 or -40, 0, 18),
        Position = UDim2.new(0, icon and 38 or 14, 0, 8),
        BackgroundTransparency = 1,
        Text = title or "Notificação",
        TextColor3 = Theme.Text,
        TextSize = 13,
        Font = Config.FontBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 101,
        Parent = notif
    })
    
    local msgLbl = New("TextLabel", {
        Size = UDim2.new(1, icon and -50 or -40, 0, 0),
        Position = UDim2.new(0, icon and 38 or 14, 0, 28),
        BackgroundTransparency = 1,
        Text = message or "",
        TextColor3 = Theme.TextDim,
        TextSize = 12,
        Font = Config.FontLight,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        ZIndex = 101,
        Parent = notif
    })
    
    local totalHeight = 36 + msgLbl.TextBounds.Y + 10
    
    -- Close button with icon
    local closeBtn = New("TextButton", {
        Size = UDim2.new(0, 22, 0, 22),
        Position = UDim2.new(1, -28, 0, 8),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        ZIndex = 102,
        Parent = notif
    })
    Corner(closeBtn, Config.TinyRadius)
    
    New("ImageLabel", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(0.5, -6, 0.5, -6),
        BackgroundTransparency = 1,
        Image = Icons.Close,
        ImageColor3 = Theme.TextDark,
        Parent = closeBtn
    })
    
    -- Progress bar
    local progressBar = New("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = accentColor,
        ZIndex = 101,
        Parent = notif
    })
    
    -- Animate in
    Tween(notif, {Size = UDim2.new(1, 0, 0, totalHeight), BackgroundTransparency = 0}, 0.35)
    
    local removed = false
    local startTime = tick()
    
    local function Remove()
        if removed then return end
        removed = true
        Tween(notif, {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1
        }, 0.3)
        task.delay(0.3, function()
            notif:Destroy()
        end)
    end
    
    closeBtn.MouseButton1Click:Connect(Remove)
    task.delay(duration, Remove)
    
    -- Update progress
    task.spawn(function()
        while not removed and notif.Parent do
            local elapsed = tick() - startTime
            local progress = 1 - (elapsed / duration)
            progressBar.Size = UDim2.new(math.max(progress, 0), 0, 0, 2)
            task.wait()
        end
    end)
    
    return {Remove = Remove}
end

