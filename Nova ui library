-- TOOLTIP SYSTEM
-- ═══════════════════════════════════════════════════════════════════
local TooltipSystem = {}
TooltipSystem.CurrentTooltip = nil
TooltipSystem.Container = nil

function TooltipSystem.Init(parent)
    TooltipSystem.Container = parent
end

function TooltipSystem.Show(element, text)
    TooltipSystem.Hide()

    local tooltip = Utility.CreateInstance("Frame", {
        Name = "Tooltip",
        Size = UDim2.fromOffset(0, 28),
        Position = UDim2.fromOffset(
            element.AbsolutePosition.X + element.AbsoluteSize.X / 2,
            element.AbsolutePosition.Y - 35
        ),
        AnchorPoint = Vector2.new(0.5, 0),
        BackgroundColor3 = Color3.fromRGB(40, 40, 40),
        BackgroundTransparency = 0.1,
        ZIndex = 200,
        Parent = TooltipSystem.Container
    })
    Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(0, 6), Parent = tooltip })

    local label = Utility.CreateInstance("TextLabel", {
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        Text = text,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 1,
        ZIndex = 201,
        Parent = tooltip
    })

    -- Ajusta tamanho ao texto
    local textSize = label.TextBounds.X + 16
    tooltip.Size = UDim2.fromOffset(math.max(textSize, 60), 28)

    -- Animação
    tooltip.BackgroundTransparency = 1
    label.TextTransparency = 1
    TweenEngine.Create(tooltip, 0.15, { BackgroundTransparency = 0.1 })
    TweenEngine.Create(label, 0.15, { TextTransparency = 0 })

    TooltipSystem.CurrentTooltip = tooltip
end

function TooltipSystem.Hide()
    if TooltipSystem.CurrentTooltip then
        local tt = TooltipSystem.CurrentTooltip
        TweenEngine.Create(tt, 0.1, { BackgroundTransparency = 1 }).Completed:Connect(function()
            if tt then tt:Destroy() end
        end)
        TooltipSystem.CurrentTooltip = nil
    end
end

-- ═══════════════════════════════════════════════════════════════════
-- SCROLLBAR CUSTOM (iOS Style)
-- ═══════════════════════════════════════════════════════════════════
local function CreateCustomScrollbar(scrollingFrame, parent)
    local scrollbar = Utility.CreateInstance("Frame", {
        Name = "Scrollbar",
        Size = UDim2.new(0, 4, 1, -10),
        Position = UDim2.new(1, -6, 0, 5),
        BackgroundColor3 = THEME.Separator,
        BackgroundTransparency = 0.7,
        ZIndex = 10,
        Parent = parent or scrollingFrame.Parent
    })
    Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = scrollbar })

    local thumb = Utility.CreateInstance("Frame", {
        Name = "Thumb",
        Size = UDim2.new(1, 0, 0.3, 0),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = THEME.SecondaryText,
        BackgroundTransparency = 0.3,
        ZIndex = 11,
        Parent = scrollbar
    })
    Utility.CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })

    -- Atualiza o thumb baseado no scroll
    Utility.Connect(scrollingFrame:GetPropertyChangedSignal("CanvasPosition"), function()
        local canvasSize = scrollingFrame.AbsoluteCanvasSize.Y
        local frameSize = scrollingFrame.AbsoluteSize.Y
        if canvasSize > 0 and canvasSize > frameSize then
            local scrollPercent = scrollingFrame.CanvasPosition.Y / (canvasSize - frameSize)
            local thumbHeight = math.clamp(frameSize / canvasSize, 0.1, 1)
            thumb.Size = UDim2.new(1, 0, thumbHeight, 0)
            thumb.Position = UDim2.new(0, 0, scrollPercent * (1 - thumbHeight), 0)
        end
    end, "scrollbar")

    -- Fade in/out
    scrollbar.BackgroundTransparency = 1
    thumb.BackgroundTransparency = 1

    local scrollConnection = Utility.Connect(scrollingFrame:GetPropertyChangedSignal("CanvasPosition"), function()
        scrollbar.BackgroundTransparency = 0.7
        thumb.BackgroundTransparency = 0.3
    end, "scrollbar_fade")

    return scrollbar
end

