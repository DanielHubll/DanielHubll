-- ==========================================
-- LUMINA UI: SISTEMA DE ABAS E COMPONENTES
-- ==========================================

local LuminaLib = {}
local TweenService = game:GetService("TweenService")

-- Configurações de Design (Estética Premium Dark/Neon)
local Theme = {
    Background = Color3.fromRGB(18, 18, 18),
    ComponentBg = Color3.fromRGB(25, 25, 25),
    AccentCiano = Color3.fromRGB(0, 255, 255),
    AccentRoxo = Color3.fromRGB(138, 43, 226),
    TextWhite = Color3.fromRGB(255, 255, 255),
    TextGray = Color3.fromRGB(180, 180, 180)
}

local UI = LMG2L["Lumina UI_1"]
local TabsContainer = LMG2L["Tabs_c"]
local MainComponents = LMG2L["Components_1c"]

-- Limpa os componentes iniciais para evitar sobreposição se você rodar de novo
for _, child in pairs(MainComponents:GetChildren()) do
    if child:IsA("Frame") then child:Destroy() end
end

-- Layout da Área de Componentes
local UIListLayout = Instance.new("UIListLayout", MainComponents)
UIListLayout.Padding = UDim.new(0, 6)
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder

local UIPadding = Instance.new("UIPadding", MainComponents)
UIPadding.PaddingTop = UDim.new(0, 5)
UIPadding.PaddingLeft = UDim.new(0, 5)
UIPadding.PaddingRight = UDim.new(0, 5)

local ActiveTabIndicator = nil
local TabContainers = {}

-- Função para animar cores
local function TweenColor(instance, property, color, duration)
    TweenService:Create(instance, TweenInfo.new(duration or 0.2), {[property] = color}):Play()
end

function LuminaLib:CriarAba(nome, iconeId)
    local AbaBase = {}
    
    -- Cria o botão da Aba clonando o seu Tab1 original (ou criando do zero para garantir)
    local TabBtn = LMG2L["Tab1_d"]:Clone()
    TabBtn.Parent = TabsContainer
    TabBtn.NameTab_f.Text = nome
    if iconeId then
        TabBtn.IconTab_10.Image = "rbxassetid://" .. iconeId
    end
    
    -- Cria o container de componentes dessa aba
    local Page = Instance.new("Frame", MainComponents)
    Page.Name = nome .. "_Page"
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    
    local PageLayout = Instance.new("UIListLayout", Page)
    PageLayout.Padding = UDim.new(0, 8)
    PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    TabContainers[nome] = Page
    
    -- Lógica de Clique na Aba
    TabBtn.OpenTab_11.MouseButton1Click:Connect(function()
        -- Esconde todas as páginas e reseta cores
        for _, page in pairs(TabContainers) do
            page.Visible = false
        end
        for _, tab in pairs(TabsContainer:GetChildren()) do
            if tab:IsA("Frame") and tab.Name ~= "UIListLayout" then
                TweenColor(tab, "BackgroundColor3", Theme.Background)
                TweenColor(tab.NameTab_f, "TextColor3", Theme.TextGray)
            end
        end
        
        -- Ativa a página atual
        Page.Visible = true
        TweenColor(TabBtn, "BackgroundColor3", Theme.ComponentBg)
        TweenColor(TabBtn.NameTab_f, "TextColor3", Theme.AccentCiano) -- Destaque Ciano na aba ativa
    end)
    
    -- Se for a primeira aba, ativa ela por padrão
    if #MainComponents:GetChildren() == 3 then -- Conta o ListLayout, Padding e a 1ª página
        Page.Visible = true
        TabBtn.BackgroundColor3 = Theme.ComponentBg
        TabBtn.NameTab_f.TextColor3 = Theme.AccentCiano
    end
    
    -- Oculta o Tab1 original que serviu de molde
    LMG2L["Tab1_d"].Visible = false
    
    -- ==========================================
    -- CRIADOR DE COMPONENTES DA ABA
    -- ==========================================
    
    function AbaBase:CriarBotao(texto, callback)
        local ButtonFrame = Instance.new("Frame", Page)
        ButtonFrame.Size = UDim2.new(1, 0, 0, 32)
        ButtonFrame.BackgroundColor3 = Theme.ComponentBg
        
        Instance.new("UICorner", ButtonFrame).CornerRadius = UDim.new(0, 6)
        local Stroke = Instance.new("UIStroke", ButtonFrame)
        Stroke.Color = Color3.fromRGB(40, 40, 40)
        Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        
        local Btn = Instance.new("TextButton", ButtonFrame)
        Btn.Size = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text = texto
        Btn.TextColor3 = Theme.TextWhite
        Btn.Font = Enum.Font.GothamMedium
        Btn.TextSize = 14
        
        Btn.MouseEnter:Connect(function()
            TweenColor(Stroke, "Color", Theme.AccentRoxo) -- Destaque Roxo no hover
        end)
        
        Btn.MouseLeave:Connect(function()
            TweenColor(Stroke, "Color", Color3.fromRGB(40, 40, 40))
        end)
        
        Btn.MouseButton1Click:Connect(function()
            -- Efeito de clique
            TweenColor(Btn, "TextColor3", Theme.AccentCiano, 0.1)
            task.wait(0.1)
            TweenColor(Btn, "TextColor3", Theme.TextWhite, 0.1)
            if callback then callback() end
        end)
    end
    
    function AbaBase:CriarToggle(texto, estadoPadrao, callback)
        local estado = estadoPadrao or false
        
        local ToggleFrame = Instance.new("Frame", Page)
        ToggleFrame.Size = UDim2.new(1, 0, 0, 32)
        ToggleFrame.BackgroundColor3 = Theme.ComponentBg
        Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)
        
        local Label = Instance.new("TextLabel", ToggleFrame)
        Label.Size = UDim2.new(1, -50, 1, 0)
        Label.Position = UDim2.new(0, 10, 0, 0)
        Label.BackgroundTransparency = 1
        Label.Text = texto
        Label.TextColor3 = Theme.TextWhite
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 14
        Label.TextXAlignment = Enum.TextXAlignment.Left
        
        local ToggleOuter = Instance.new("Frame", ToggleFrame)
        ToggleOuter.Size = UDim2.new(0, 36, 0, 18)
        ToggleOuter.Position = UDim2.new(1, -46, 0.5, -9)
        ToggleOuter.BackgroundColor3 = estado and Theme.AccentCiano or Color3.fromRGB(40, 40, 40)
        Instance.new("UICorner", ToggleOuter).CornerRadius = UDim.new(1, 0)
        
        local ToggleInner = Instance.new("Frame", ToggleOuter)
        ToggleInner.Size = UDim2.new(0, 14, 0, 14)
        ToggleInner.Position = UDim2.new(estado and 1 or 0, estado and -16 or 2, 0.5, -7)
        ToggleInner.BackgroundColor3 = Theme.TextWhite
        Instance.new("UICorner", ToggleInner).CornerRadius = UDim.new(1, 0)
        
        local Btn = Instance.new("TextButton", ToggleFrame)
        Btn.Size = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text = ""
        
        Btn.MouseButton1Click:Connect(function()
            estado = not estado
            local metaOuter = estado and Theme.AccentCiano or Color3.fromRGB(40, 40, 40)
            local metaInnerPos = estado and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            
            TweenColor(ToggleOuter, "BackgroundColor3", metaOuter)
            TweenService:Create(ToggleInner, TweenInfo.new(0.2), {Position = metaInnerPos}):Play()
            
            if callback then callback(estado) end
        end)
    end
    
    return AbaBase
end
