    local ActiveIndicator = Create("Frame", {
        Size = UDim2.fromOffset(3, 24),
        Position = UDim2.new(0, -2, 0.5, -12),
        BackgroundColor3 = Theme.Accent,
        BackgroundTransparency = 1,
