function Library:AddTab(name, icon)
    local tab = {}
    tab.Name = name
    tab.Icon = icon -- rbxassetid:// ou nil
    tab.Sections = {}
    tab.SectionCount = 0
    tab.Order = self.TabCount
    self.TabCount = self.TabCount + 1
    
    local isMobile = IsMobile()
    local tabWidth = isMobile and 90 or 120

    -- ═══ Tab Button ═══
    tab.Button = New("TextButton", {
        Size = UDim2.new(0, tabWidth, 1, 0),
        BackgroundColor3 = Theme.BackgroundDark,
        BackgroundTransparency = 1,
        AutoButtonColor = false,
        LayoutOrder = tab.Order,
        Parent = self.TabBarScroll
    })

    -- Icon (if provided)
    if icon and icon ~= "" then
        local iconLabel = New("ImageLabel", {
            Size = UDim2.new(0, 18, 0, 18),
            Position = UDim2.new(0.5, -9, 0, 5),
            AnchorPoint = Vector2.new(0, 0),
            BackgroundTransparency = 1,
            Image = icon,
            ImageColor3 = Theme.TextDim,
            ScaleType = Enum.ScaleType.Fit,
            Parent = tab.Button
        })
        tab.IconLabel = iconLabel

        tab.TextLabel = New("TextLabel", {
            Size = UDim2.new(1, -4, 0, 14),
            Position = UDim2.new(0, 2, 0, 25),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = Theme.TextDim,
            TextSize = isMobile and 10 or 11,
            Font = Config.Font,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = tab.Button
        })
    else
        tab.TextLabel = New("TextLabel", {
            Size = UDim2.new(1, -4, 1, 0),
            Position = UDim2.new(0, 2, 0, 0),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = Theme.TextDim,
            TextSize = isMobile and 11 or 13,
            Font = Config.Font,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = tab.Button
        })
    end

    -- Active indicator line
    tab.Indicator = New("Frame", {
        Size = UDim2.new(1, -8, 0, 2),
        Position = UDim2.new(0, 4, 1, -3),
        BackgroundColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        Parent = tab.Button
    })
    Corner(tab.Indicator, Config.TinyRadius)

    -- ═══ Tab Content Page ═══
    tab.ContentPage = New("ScrollingFrame", {
        Size = UDim2.new(1, -16, 1, -10),
        Position = UDim2.new(0, 8, 0, 5),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Theme.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = self.ContentContainer
    })

    tab.ContentLayout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        Parent = tab.ContentPage
    })

    tab.ContentPadding = New("UIPadding", {
        PaddingTop = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 10),
        PaddingLeft = UDim.new(0, 4),
        PaddingRight = UDim.new(0, 4),
        Parent = tab.ContentPage
    })

    -- ═══ Tab Activation ═══
    local function ActivateTab()
        -- Deactivate all
        for _, t in ipairs(self.Tabs) do
            t.ContentPage.Visible = false
            Tween(t.Indicator, {BackgroundTransparency = 1}, 0.15)
            Tween(t.TextLabel, {TextColor3 = Theme.TextDim}, 0.15)
            if t.IconLabel then
                Tween(t.IconLabel, {ImageColor3 = Theme.TextDim}, 0.15)
            end
            Tween(t.Button, {BackgroundTransparency = 1}, 0.15)
        end
        -- Activate this
        tab.ContentPage.Visible = true
        Tween(tab.Indicator, {BackgroundTransparency = 0}, 0.2)
        Tween(tab.TextLabel, {TextColor3 = Theme.Text}, 0.2)
        if tab.IconLabel then
            Tween(tab.IconLabel, {ImageColor3 = Theme.Text}, 0.2)
        end
        Tween(tab.Button, {BackgroundTransparency = 0.7}, 0.2)
        self.ActiveTab = tab
    end

    tab.Button.MouseButton1Click:Connect(ActivateTab)

    tab.Button.MouseEnter:Connect(function()
        if self.ActiveTab ~= tab then
            Tween(tab.Button, {BackgroundTransparency = 0.85}, 0.15)
        end
    end)
    tab.Button.MouseLeave:Connect(function()
        if self.ActiveTab ~= tab then
            Tween(tab.Button, {BackgroundTransparency = 1}, 0.15)
        end
    end)

    -- Add to library
    table.insert(self.Tabs, tab)

    -- Auto-select first tab
    if self.TabCount == 1 then
        task.delay(0.05, ActivateTab)
    end

    -- ════════════════════════════════════════════
    -- ██  SECTION (dentro do tab)
    -- ════════════════════════════════════════════
    function tab:AddSection(sectionTitle)
        local section = {}
        section.Title = sectionTitle or ""
        section.Order = tab.SectionCount
        tab.SectionCount = tab.SectionCount + 1

        -- Section Container
        section.Frame = New("Frame", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Theme.Surface,
            ClipsDescendants = true,
            LayoutOrder = section.Order,
            Parent = tab.ContentPage
        })
        Corner(section.Frame, Config.CornerRadius)
        Stroke(section.Frame, Theme.Border, 1)

        -- Section header
        local headerHeight = 36
        local header = New("Frame", {
            Size = UDim2.new(1, 0, 0, headerHeight),
            BackgroundTransparency = 1,
            Parent = section.Frame
        })

        if sectionTitle and sectionTitle ~= "" then
            New("TextLabel", {
                Size = UDim2.new(1, -20, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                BackgroundTransparency = 1,
                Text = sectionTitle,
                TextColor3 = Theme.TextDim,
                TextSize = 12,
                Font = Config.FontBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = header
            })
        end

        -- Content layout
        section.ContentLayout = New("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 4),
            Parent = section.Frame
        })

        section.ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            section.Frame.Size = UDim2.new(1, 0, 0, section.ContentLayout.AbsoluteContentSize.Y + 8)
