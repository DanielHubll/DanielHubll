function Library:ConnectResize()
    local camera = workspace.CurrentCamera
    
    self.Connections:Add(camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
        self:UpdateScale()
    end))
    
    self:UpdateScale()
end

function Library:UpdateScale()
    local viewportSize = workspace.CurrentCamera.ViewportSize
    local scaleX = Utils.Clamp(viewportSize.X / 800, 0.6, 1.2)
    local scaleY = Utils.Clamp(viewportSize.Y / 550, 0.6, 1.2)
    self.UIScale.Scale = math.min(scaleX, scaleY)
end

function Library:Minimize()
    if self.IsMinimized then
        self.IsMinimized = false
        Utils.Tween(self.MainFrame, Animations.Medium, {
            Size = UDim2.new(0, 750, 0, 500),
            Position = UDim2.new(0.5, -375, 0.5, -250)
        })
    else
        self.IsMinimized = true
        Utils.Tween(self.MainFrame, Animations.Medium, {
            Size = UDim2.new(0, 750, 0, 55),
            Position = UDim2.new(0.5, -375, 0, 10)
        })
    end
end

function Library:Maximize()
    local vpSize = workspace.CurrentCamera.ViewportSize
    Utils.Tween(self.MainFrame, Animations.Medium, {
        Size = UDim2.new(0, vpSize.X - 40, 0, vpSize.Y - 40),
        Position = UDim2.new(0, 20, 0, 20)
    })
end

function Library:Close()
    self.IsOpen = false
    Utils.Tween(self.MainFrame, Animations.Medium, {
        Size = UDim2.new(0, 750, 0, 0),
        Position = UDim2.new(0.5, -375, 0.5, 0)
    })
    task.delay(0.3, function()
        self.MainFrame.Visible = false
    end)
end

function Library:Open()
    self.IsOpen = true
    self.MainFrame.Visible = true
    Utils.Tween(self.MainFrame, Animations.Bounce, {
        Size = UDim2.new(0, 750, 0, 500),
        Position = UDim2.new(0.5, -375, 0.5, -250)
    })
end

function Library:Toggle()
    if self.IsOpen then
        self:Close()
    else
        self:Open()
    end
end

function Library:CreateTab(name, iconId)
    iconId = iconId or Icons.Home
    
    local tabIndex = #self.Tabs + 1
    local isSelected = (tabIndex == 1)
    
    local tabBtn = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = isSelected and Theme.Accent or Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = isSelected and 0.85 or 1,
        LayoutOrder = tabIndex,
        Parent = self.TabList
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(0, 8), Parent = tabBtn})
    Utils.Create("UIPadding", {PaddingLeft = UDim.new(0, 14), Parent = tabBtn})
    
    local selector = Utils.Create("Frame", {
        Size = UDim2.new(0, 3, 0, 20),
        Position = UDim2.new(0, -10, 0.5, -10),
        BackgroundColor3 = Theme.Accent,
        Visible = isSelected,
        Parent = tabBtn
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = selector})
    
    Utils.Create("ImageLabel", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, 0, 0.5, -9),
        BackgroundTransparency = 1,
        Image = iconId,
        ImageColor3 = isSelected and Theme.Accent or Theme.TextMuted,
        Parent = tabBtn
    })
    
    Utils.Create("TextLabel", {
        Size = UDim2.new(1, -30, 1, 0),
        Position = UDim2.new(0, 28, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = isSelected and Theme.TextPrimary or Theme.TextSecondary,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabBtn
    })
    
    local clickBtn = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = tabBtn
    })
    
    local page = Utils.Create("ScrollingFrame", {
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = Theme.Scrollbar or Theme.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = isSelected,
        Parent = self.ContentArea
    })
    
    Utils.Create("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = page
    })
    
    Utils.Create("UIPadding", {
        PaddingTop = UDim.new(0, 8),
        PaddingBottom = UDim.new(0, 20),
        Parent = page
    })
    
    local tabData = {
        Name = name,
        Button = tabBtn,
        Page = page,
        Selector = selector,
        ClickBtn = clickBtn,
        Sections = {},
    }
    
    table.insert(self.Tabs, tabData)
    
    local function selectTab()
        for _, tab in ipairs(self.Tabs) do
            local isThis = (tab == tabData)
            
            Utils.Tween(tab.Button, Animations.Medium, {
                BackgroundColor3 = isThis and Theme.Accent or Color3.fromRGB(0, 0, 0),
                BackgroundTransparency = isThis and 0.85 or 1,
            })
            
            tab.Selector.Visible = isThis
            tab.Page.Visible = isThis
        end
        
        self.CurrentTab = tabData
    end
    
    clickBtn.MouseButton1Click:Connect(selectTab)
    
    clickBtn.MouseEnter:Connect(function()
        if self.CurrentTab ~= tabData then
            Utils.Tween(tabBtn, Animations.Fast, {
                BackgroundColor3 = Theme.CardHover,
                BackgroundTransparency = 0.7,
            })
        end
    end)
    
    clickBtn.MouseLeave:Connect(function()
        if self.CurrentTab ~= tabData then
            Utils.Tween(tabBtn, Animations.Fast, {BackgroundTransparency = 1})
        end
    end)
    
    if isSelected then
        self.CurrentTab = tabData
    end
    
    -- Tab API
    local tabAPI = {}
    
    function tabAPI:CreateSection(sectionName)
        Components.CreateSection(page, {Name = sectionName})
        
        local sectionContent = Utils.Create("Frame", {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
            Parent = page
        })
        
        local sectionLayout = Utils.Create("UIListLayout", {
            Padding = UDim.new(0, 6),
            Parent = sectionContent
        })
        
        sectionLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            sectionContent.Size = UDim2.new(1, 0, 0, sectionLayout.AbsoluteContentSize.Y)
        end)
        
        local sectionData = {
            Name = sectionName,
            Content = sectionContent,
        }
        
        table.insert(self.Sections, sectionData)
        
        local sectionAPI = {}
        
        function sectionAPI:CreateToggle(options)
            return Components.CreateToggle(sectionContent, options)
        end
        
        function sectionAPI:CreateButton(options)
            return Components.CreateButton(sectionContent, options)
        end
        
        function sectionAPI:CreateSlider(options)
            return Components.CreateSlider(sectionContent, options)
        end
        
        function sectionAPI:CreateDropdown(options)
            return Components.CreateDropdown(sectionContent, options)
        end
        
        function sectionAPI:CreateMultiDropdown(options)
            options.Multi = true
            return Components.CreateDropdown(sectionContent, options)
        end
        
        function sectionAPI:CreateTextbox(options)
            return Components.CreateTextbox(sectionContent, options)
        end
        
        function sectionAPI:CreateKeybind(options)
            return Components.CreateKeybind(sectionContent, options)
        end
        
        function sectionAPI:CreateColorPicker(options)
            return Components.CreateColorPicker(sectionContent, options)
        end
        
        function sectionAPI:CreateLabel(options)
            return Components.CreateLabel(sectionContent, options)
        end
        
        function sectionAPI:CreateParagraph(options)
            return Components.CreateParagraph(sectionContent, options)
        end
        
        function sectionAPI:CreateDivider()
            return Components.CreateDivider(sectionContent)
        end
        
        return sectionAPI
    end
    
    return tabAPI
end

function Library:Notify(options)
    return NotificationSystem.Notify(options)
end

function Library:SetToggleKey(key)
    self.Connections:Add(UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == key then
            self:Toggle()
        end
    end))
end

function Library:Destroy()
    self.Connections:DisconnectAll()
    self.DragSystem:Destroy()
    self.ScreenGui:Destroy()
end

