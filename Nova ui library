-- NOTIFICATION CONTAINER
-- ═══════════════════════════════════════════════════════════════════
local NotifGui = nil
local NotifContainer = nil

local function InitNotifications(screenGui)
    NotifGui = screenGui
    NotifContainer = Make("Frame", {
        Name = "NotifContainer",
        Size = UDim2.new(0, 300, 1, 0),
        Position = UDim2.new(1, -310, 0, 10),
        BackgroundTransparency = 1,
        Parent = screenGui
    })
    Make("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = NotifContainer
    })
end

local function Notify(opts)
    if not NotifContainer then return end
    local title = opts.Title or "Info"
    local msg = opts.Message or ""
    local dur = opts.Duration or 4
    local ntype = opts.Type or "Info"

    local colors = {
        Info = Theme.Accent,
        Success = Theme.Green,
        Warning = Theme.Orange,
        Error = Theme.Red,
    }
    local accent = colors[ntype] or Theme.Accent

    local notif = Make("Frame", {
        Size = UDim2.new(1, 0, 0, 60),
        BackgroundColor3 = Theme.Card,
        Parent = NotifContainer
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 12), Parent = notif })
    Make("UIStroke", { Color = accent, Thickness = 1, Transparency = 0.6, Parent = notif })

    -- Barra lateral colorida
    local bar = Make("Frame", {
        Size = UDim2.new(0, 4, 1, -16),
        Position = UDim2.new(0, 6, 0, 8),
        BackgroundColor3 = accent,
        Parent = notif
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 2), Parent = bar })

    -- Título
    Make("TextLabel", {
        Size = UDim2.new(1, -30, 0, 18),
        Position = UDim2.new(0, 18, 0, 8),
        Text = title,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Parent = notif
    })

    -- Mensagem
    Make("TextLabel", {
        Size = UDim2.new(1, -30, 0, 16),
        Position = UDim2.new(0, 18, 0, 28),
        Text = msg,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        BackgroundTransparency = 1,
        Parent = notif
    })

    -- Barra de progresso
    local prog = Make("Frame", {
        Size = UDim2.new(1, -16, 0, 3),
        Position = UDim2.new(0, 8, 1, -8),
        BackgroundColor3 = accent,
        Transparency = 0.4,
        Parent = notif
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 2), Parent = prog })

    -- Anima entrada
    notif.Position = UDim2.new(1, 60, 0, 0)
    Tween(notif, 0.35, { Position = UDim2.new(0, 0, 0, 0) })

    -- Timer de dismiss
    Tween(prog, dur, { Size = UDim2.new(0, 0, 0, 3) })
    task.delay(dur, function()
        if notif and notif.Parent then
            local t = Tween(notif, 0.3, { Position = UDim2.new(1, 60, 0, 0) })
            if t then
                t.Completed:Connect(function()
                    if notif then notif:Destroy() end
                end)
            end
        end
    end)

    return notif
end

