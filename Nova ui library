    local function UpdateColorFromWheel()
        local r, g, b = HSVToRGB(h, s, v)
        currentColor = Color3.fromRGB(r, g, b)
        UpdateDisplay()
        callback(currentColor)
    end
    
    local function UpdateDisplay()
        -- Update preview
        Tween(preview, {BackgroundColor3 = currentColor}, 0.1)
        
        -- Update wheel dot position
        wheelDot.Position = UDim2.new(s, -8, 1 - v, -8)
        
        -- Update hue dot
        hueDot.Position = UDim2.new(0, -3, h, -4)
        
        -- Update RGB inputs
        local r = math.floor(currentColor.R * 255)
        local g = math.floor(currentColor.G * 255)
        local b = math.floor(currentColor.B * 255)
        
        for _, child in pairs(container:GetChildren()) do
            if child.Name == "RInput" then child.Text = tostring(r) end
            if child.Name == "GInput" then child.Text = tostring(g) end
            if child.Name == "BInput" then child.Text = tostring(b) end
        end
        
        -- Update hex
        hexInput.Text = string.format("#%02X%02X%02X", r, g, b)
        
        -- Update wheel hue gradient
        local hueColor = Color3.fromRGB(HSVToRGB(h, 1, 1))
        wheelFrame.BackgroundColor3 = hueColor
    end
    
    -- ═══ INPUT HANDLING ═══
    local draggingWheel = false
    local draggingHue = false
    
    -- Wheel interaction
    local wheelButton = New("TextButton", {
