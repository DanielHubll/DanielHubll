-- ═══════════════ WINDOW METHODS ═══════════════
function Library:Toggle(state)
    if state == nil then state = not self.Visible end
    self.Visible = state
    self.Main.Visible = state
end

function Library:Minimize()
    self.Minimized = not self.Minimized
    if self.Minimized then
        Tw(self.Content, {Size = UDim2.new(1,0,0,0)}, 0.25)
        Tw(self.TabBar, {Size = UDim2.new(1,0,0,0)}, 0.25)
    else
        Tw(self.Content, {Size = UDim2.new(1,0,1,-87)}, 0.25)
        Tw(self.TabBar, {Size = UDim2.new(1,0,0,42)}, 0.25)
    end
end

