				BackgroundTransparency = 1,
				Size = UDim2.new(0, 14, 0, 14),
				Position = UDim2.new(1, -24, 0.5, -7),
				Name = "Chevron",
				Parent = Box,
			})

			local Dropdown = {}
			local open = false

			local function createDropdownList()
				CloseDropdown()

				-- Calcular posição global do Box
				local boxAbsPos = Box.AbsolutePosition
				local boxAbsSize = Box.AbsoluteSize

				local listH = math.min(#options * 30 + 4, 150)

				local ListFrame = New("Frame", {
					BackgroundColor3 = Theme.Panel,
					Size = UDim2.new(0, boxAbsSize.X, 0, listH),
					Position = UDim2.new(0, boxAbsPos.X, 0, boxAbsPos.Y + boxAbsSize.Y + 4),
					ZIndex = 100,
					Parent = gui,
				})
				Corner(ListFrame, 8)
				Stroke(ListFrame, Theme.Accent, 1)
				Pad(ListFrame, 2, 2, 0, 0)

				local ListScroll = New("ScrollingFrame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 1, 0),
					CanvasSize = UDim2.new(0, 0, 0, #options * 30),
					ScrollBarThickness = 2,
					ScrollBarImageColor3 = Theme.Accent,
					BorderSizePixel = 0,
					ZIndex = 100,
					Parent = ListFrame,
				})

				for i, opt in ipairs(options) do
					local OptBtn = New("TextButton", {
						Text = "",
						AutoButtonColor = false,
						BackgroundColor3 = (opt == selected) and Theme.Card or Theme.Panel,
						Size = UDim2.new(1, 0, 0, 30),
						ZIndex = 100,
						Parent = ListScroll,
					})
					New("TextLabel", {
						Text = opt,
						Font = FontRegular,
						TextSize = IsMobile and 12 or 13,
						TextColor3 = (opt == selected) and Theme.AccentLight or Theme.SubText,
						TextXAlignment = Enum.TextXAlignment.Left,
						BackgroundTransparency = 1,
						Size = UDim2.new(1, -20, 1, 0),
						Position = UDim2.new(0, 10, 0, 0),
						ZIndex = 100,
						Parent = OptBtn,
					})

					-- Hover effect
					OptBtn.MouseEnter:Connect(function()
						OptBtn.BackgroundColor3 = Theme.Card
					end)
					OptBtn.MouseLeave:Connect(function()
						OptBtn.BackgroundColor3 = (opt == selected) and Theme.Card or Theme.Panel
					end)

					OptBtn.MouseButton1Click:Connect(function()
						selected = opt
						Label.Text = opt
						CloseDropdown()
						Tween(Chevron, { Rotation = 0 }, 0.15)
						open = false
						if cfg.Flag then Library.Flags[cfg.Flag] = selected end
						if cfg.Callback then task.spawn(cfg.Callback, selected) end
					end)
				end

				ActiveDropdown = ListFrame
			end

			local function closeDropdown()
				CloseDropdown()
				open = false
				Tween(Chevron, { Rotation = 0 }, 0.15)
			end

			Box.MouseButton1Click:Connect(function()
				open = not open
				if open then
					Tween(Chevron, { Rotation = 180 }, 0.15)
					createDropdownList()
				else
					closeDropdown()
				end
			end)

			-- Fechar ao clicar fora
			UserInputService.InputBegan:Connect(function(input)
				if open and ActiveDropdown then
					local absPos = ActiveDropdown.AbsolutePosition
					local absSize = ActiveDropdown.AbsoluteSize
					local pos = input.Position
					if pos and (pos.X < absPos.X or pos.X > absPos.X + absSize.X or
						pos.Y < absPos.Y or pos.Y > absPos.Y + absSize.Y) then
						-- Verificar se clicou no box também
						local boxAbsPos = Box.AbsolutePosition
						local boxAbsSize = Box.AbsoluteSize
						if pos.X < boxAbsPos.X or pos.X > boxAbsPos.X + boxAbsSize.X or
							pos.Y < boxAbsPos.Y or pos.Y > boxAbsPos.Y + boxAbsSize.Y then
							closeDropdown()
						end
					end
				end
			end)

			if cfg.Flag then Library.Flags[cfg.Flag] = selected end
			return Dropdown
		end

