-- RESPONSIVE SYSTEM
-- ═══════════════════════════════════════════════════════════════════
local ResponsiveSystem = {}
ResponsiveSystem.Breakpoints = {
    Mobile = 480,
    Tablet = 768,
    Desktop = 1024,
    Large = 1440,
}
ResponsiveSystem.Callbacks = {}

function ResponsiveSystem.GetCurrentBreakpoint()
    local viewport = Utility.GetViewportSize()
    local width = viewport.X
    if width <= ResponsiveSystem.Breakpoints.Mobile then
        return "Mobile"
    elseif width <= ResponsiveSystem.Breakpoints.Tablet then
        return "Tablet"
    elseif width <= ResponsiveSystem.Breakpoints.Desktop then
        return "Desktop"
    else
        return "Large"
    end
end

function ResponsiveSystem.OnBreakpointChange(callback)
    table.insert(ResponsiveSystem.Callbacks, callback)
end

function ResponsiveSystem.Init()
    local lastBreakpoint = ResponsiveSystem.GetCurrentBreakpoint()

    Utility.Connect(Camera:GetPropertyChangedSignal("ViewportSize"), function()
        local current = ResponsiveSystem.GetCurrentBreakpoint()
        if current ~= lastBreakpoint then
            lastBreakpoint = current
            for _, cb in ipairs(ResponsiveSystem.Callbacks) do
                task.spawn(cb, current)
            end
        end
    end, "responsive")
end

