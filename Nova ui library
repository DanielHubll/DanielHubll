local function ShowPopup(opts, parentGui)
    local overlay = Make("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.new(0, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = 100,
        Parent = parentGui
    })
    Tween(overlay, 0.2, { BackgroundTransparency = 0.6 })

    local popup = Make("Frame", {
        Size = UDim2.fromOffset(0, 0),
        Position = UDim2.new(0.5, -140, 0.5, -90),
        BackgroundColor3 = Theme.Card,
        ZIndex = 101,
        Parent = overlay
    })
    Make("UICorner", { CornerRadius = UDim.new(0, 16), Parent = popup })

    Tween(popup, 0.35, { Size = UDim2.fromOffset(280, 180) }, Enum.EasingStyle.Back)

    Make("TextLabel", {
        Size = UDim2.new(1, -40, 0, 24),
        Position = UDim2.new(0, 20, 0, 20),
        Text = opts.Title or "Alerta",
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Center,
        BackgroundTransparency = 1,
        ZIndex = 102,
        Parent = popup
    })

    Make("TextLabel", {
        Size = UDim2.new(1, -40, 0, 40),
        Position = UDim2.new(0, 20, 0, 50),
        Text = opts.Message or "",
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextWrapped = true,
        BackgroundTransparency = 1,
        ZIndex = 102,
        Parent = popup
    })

    Make("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -46),
        BackgroundColor3 = Theme.Sep,
        Transparency = 0.5,
        ZIndex = 102,
        Parent = popup
    })

    local buttons = opts.Buttons or { { Text = "OK", Primary = true } }
    local btnCount = #buttons
    local btnW = (260 / btnCount) - 4

    for i, bCfg in ipairs(buttons) do
        local btn = Make("TextButton", {
            Size = UDim2.fromOffset(btnW, 36),
            Position = UDim2.new(0, 10 + (i - 1) * (btnW + 4), 1, -42),
            Text = bCfg.Text or "OK",
            Font = bCfg.Primary and Enum.Font.GothamBold or Enum.Font.Gotham,
            TextSize = 14,
            TextColor3 = bCfg.Primary and Theme.Accent or Theme.SubText,
            BackgroundColor3 = bCfg.Primary and Theme.Accent or Color3.new(0, 0, 0),
            BackgroundTransparency = bCfg.Primary and 0.9 or 1,
            AutoButtonColor = false,
            ZIndex = 102,
            Parent = popup
        })
        Make("UICorner", { CornerRadius = UDim.new(0, 8), Parent = btn })

        btn.MouseButton1Click:Connect(function()
            Tween(overlay, 0.2, { BackgroundTransparency = 1 })
            Tween(popup, 0.25, { Size = UDim2.fromOffset(240, 150) }, Enum.EasingStyle.Back)
            task.delay(0.25, function()
                overlay:Destroy()
            end)
            if opts.Callback then
                opts.Callback(i)
            end
        end)
    end

    return overlay
end

