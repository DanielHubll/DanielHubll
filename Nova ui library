        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding = UDim.new(0, 6),
        Parent = Library.NotificationContainer
    })
end

function Library.Notify(title, message, duration, notifType)
    if not Library.NotificationContainer then return end
    duration = duration or 5
    
    local colors = {
        Info = Theme.Accent,
        Success = Theme.Success,
        Warning = Theme.Warning,
        Error = Theme.Danger,
    }
    local accentColor = colors[notifType] or colors.Info

    local notif = New("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Theme.BackgroundLight,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 100,
        Parent = Library.NotificationContainer
    })
    Corner(notif, Config.SmallRadius)
    Stroke(notif, Theme.Border, 1)

    local accentBar = New("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        Parent = notif
    })
    Corner(accentBar, Config.TinyRadius)

    local titleLbl = New("TextLabel", {
        Size = UDim2.new(1, -40, 0, 18),
        Position = UDim2.new(0, 14, 0, 8),
        BackgroundTransparency = 1,
        Text = title or "Notificação",
        TextColor3 = Theme.Text,
        TextSize = 13,
        Font = Config.FontBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 101,
        Parent = notif
    })

    local msgLbl = New("TextLabel", {
        Size = UDim2.new(1, -40, 0, 0),
        Position = UDim2.new(0, 14, 0, 28),
        BackgroundTransparency = 1,
        Text = message or "",
        TextColor3 = Theme.TextDim,
        TextSize = 12,
        Font = Config.FontLight,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        ZIndex = 101,
        Parent = notif
    })

    -- Auto-size height
    local textBounds = msgLbl.TextBounds
    local totalHeight = 36 + textBounds.Y + 10
    notif.Size = UDim2.new(1, 0, 0, 0)

    local closeBtn = New("TextButton", {
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -26, 0, 6),
        BackgroundTransparency = 1,
        Text = "✕",
        TextColor3 = Theme.TextDark,
        TextSize = 14,
        Font = Config.Font,
        ZIndex = 102,
        Parent = notif
    })

    -- Progress bar
    local progressBar = New("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = accentColor,
        BackgroundTransparency = 0.3,
        ZIndex = 101,
        Parent = notif
    })

    -- Animate in
    Tween(notif, {Size = UDim2.new(1, 0, 0, totalHeight), BackgroundTransparency = 0}, 0.35)

    -- Auto remove
    local startTime = tick()
    local removed = false

    local function Remove()
        if removed then return end
        removed = true
        Tween(notif, {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1
        }, 0.3)
        task.delay(0.3, function()
            notif:Destroy()
        end)
    end

    closeBtn.MouseButton1Click:Connect(Remove)

    task.delay(duration, function()
        Remove()
    end)

    -- Update progress
    task.spawn(function()
        while not removed and notif.Parent do
            local elapsed = tick() - startTime
            local progress = 1 - (elapsed / duration)
            if progress < 0 then progress = 0 end
            progressBar.Size = UDim2.new(math.max(progress, 0), 0, 0, 2)
            task.wait()
        end
    end)

    return {Remove = Remove}
end

