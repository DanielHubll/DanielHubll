                Text = name,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Parent = row,
            })

            local preview = Make("Frame", {
                Size = UDim2.fromOffset(36, 28),
                Position = UDim2.new(1, -50, 0.5, -14),
                BackgroundColor3 = currentColor,
                Parent = row,
            })
            Make("UICorner", { CornerRadius = UDim.new(0, 6), Parent = preview })
            Make("UIStroke", { Color = Theme.Sep, Thickness = 1, Parent = preview })

            local colorBtn = Make("TextButton", {
                Size = UDim2.fromOffset(40, 32),
                Position = UDim2.new(1, -52, 0.5, -16),
                Text = "",
                BackgroundTransparency = 1,
                Parent = row,
            })

            -- Cores predefinidas para seleção rápida
            local presets = {
                Color3.fromRGB(255, 0, 0),
                Color3.fromRGB(0, 255, 0),
                Color3.fromRGB(0, 100, 255),
                Color3.fromRGB(255, 200, 0),
                Color3.fromRGB(255, 100, 200),
                Color3.fromRGB(150, 0, 255),
                Color3.fromRGB(0, 200, 200),
                Color3.fromRGB(255, 128, 0),
            }

            colorBtn.MouseButton1Click:Connect(function()
                -- Cicla entre cores predefinidas
                local idx = 1
                for i, c in ipairs(presets) do
                    if math.abs(c.R - currentColor.R) < 0.05 and
                       math.abs(c.G - currentColor.G) < 0.05 and
                       math.abs(c.B - currentColor.B) < 0.05 then
                        idx = i + 1
                        break
                    end
                end
                if idx > #presets then idx = 1 end
                currentColor = presets[idx]
                Tween(preview, 0.2, { BackgroundColor3 = currentColor })
                pcall(callback, currentColor)
            end)

            Make("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 1, -1),
                BackgroundColor3 = Theme.Sep,
                Transparency = 0.5,
                Parent = row,
            })

            table.insert(tab.Components, { SearchName = name, Container = row })
            table.insert(section.Components, row)

            return {
                GetValue = function() return currentColor end,
                SetValue = function(c)
                    currentColor = c
                    Tween(preview, 0.2, { BackgroundColor3 = c })
                end,
            }
        end

