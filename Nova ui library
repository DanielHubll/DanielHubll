-- ═══════════════ HELPERS ═══════════════
local function Tw(obj, props, t, s, d)
    local tw = TS:Create(obj, TweenInfo.new(t or Cfg.Speed, s or Cfg.Style, d or Cfg.Dir), props)
    tw:Play()
    return tw
end

local function New(class, props, kids)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then inst[k] = v end
    end
    for _, c in ipairs(kids or {}) do c.Parent = inst end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function Rnd(p, r) return New("UICorner", {CornerRadius = r or Cfg.Radius, Parent = p}) end
local function Str(p, c, t, tr) return New("UIStroke", {Color = c or Theme.Border, Thickness = t or 1, Transparency = tr or 0, Parent = p}) end
local function Pad(p, v) return New("UIPadding", {PaddingTop = UDim.new(0,v or 8), PaddingBottom = UDim.new(0,v or 8), PaddingLeft = UDim.new(0,v or 8), PaddingRight = UDim.new(0,v or 8), Parent = p}) end

local function Mobile() return UIS.TouchEnabled and not UIS.KeyboardEnabled end

