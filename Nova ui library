            page.Visible = true
            Utils.Tween(tabIndicator, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {Size = UDim2.new(0, 3, 0.6, 0)})
            Utils.Tween(tabLabel, 0.2, nil, nil, {TextColor3 = Theme.Text})
            Utils.Tween(tabIcon, 0.2, nil, nil, {TextColor3 = Theme.Accent})
            Utils.Tween(tabButton, 0.2, nil, nil, {BackgroundColor3 = Theme.BackgroundLight, BackgroundTransparency = 0.5})
            activeTab = tabData
        end

        tabButton.MouseButton1Click:Connect(selectTab)

        -- Selecionar primeira tab automaticamente
        if #tabs == 1 then
            selectTab()
        end

        -- ──────────────────────────────────
        --  CRIAR SECTION
        -- ──────────────────────────────────
        function Tab:CreateSection(config)
            local Section = {}
            Section.__index = Section

            local sectionName = config.Name or "Seção"

            local sectionFrame = Utils.Create("Frame", {
                Name = "Section_" .. sectionName,
                Size = UDim2.new(1, 0, 0, 40),
