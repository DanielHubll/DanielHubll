        Parent = notif
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(0, 2), Parent = accentBar})
    
    local titleLabel = Utils.Create("TextLabel", {
        Name = "Title",
        Size = UDim2.new(1, -50, 0, 20),
        Position = UDim2.new(0, 16, 0, 12),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Theme.TextPrimary,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
        Parent = notif
    })
    
    local messageLabel = Utils.Create("TextLabel", {
        Name = "Message",
        Size = UDim2.new(1, -50, 0, 20),
        Position = UDim2.new(0, 16, 0, 36),
        BackgroundTransparency = 1,
        Text = message,
        TextColor3 = Theme.TextSecondary,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        TextTransparency = 1,
        Parent = notif
    })
    
    local closeBtn = Utils.Create("TextButton", {
        Name = "CloseBtn",
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -32, 0, 10),
        BackgroundTransparency = 1,
        Text = "×",
        TextColor3 = Theme.TextMuted,
        TextSize = 18,
        Font = Enum.Font.GothamBold,
        TextTransparency = 1,
        Parent = notif
    })
    
    local progressBg = Utils.Create("Frame", {
        Name = "ProgressBg",
        Size = UDim2.new(1, -24, 0, 3),
        Position = UDim2.new(0, 12, 1, -12),
        BackgroundColor3 = Theme.SliderTrack,
        BackgroundTransparency = 1,
        Parent = notif
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = progressBg})
    
    local progressBar = Utils.Create("Frame", {
        Name = "Progress",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accentColor,
        BackgroundTransparency = 1,
        Parent = progressBg
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = progressBar})
    
    local notifData = {Frame = notif, StartTime = tick(), Duration = duration}
    table.insert(NotificationSystem.ActiveNotifications, notifData)
    
    task.defer(function()
        Utils.Tween(notif, Animations.Medium, {BackgroundTransparency = 0})
        Utils.Tween(stroke, Animations.Medium, {Transparency = 0})
        Utils.Tween(accentBar, Animations.Medium, {BackgroundTransparency = 0})
        Utils.Tween(titleLabel, Animations.Medium, {TextTransparency = 0})
        Utils.Tween(messageLabel, Animations.Medium, {TextTransparency = 0})
        Utils.Tween(closeBtn, Animations.Medium, {TextTransparency = 0})
        Utils.Tween(progressBg, Animations.Medium, {BackgroundTransparency = 0.5})
        Utils.Tween(progressBar, Animations.Medium, {BackgroundTransparency = 0})
    end)
    
    local progressTween = TweenService:Create(progressBar, 
        TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.In),
        {Size = UDim2.new(0, 0, 1, 0)}
    )
    progressTween:Play()
    
    local function closeNotification()
        progressTween:Cancel()
        
        Utils.Tween(notif, Animations.Medium, {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
        })
        Utils.Tween(stroke, Animations.Medium, {Transparency = 1})
        Utils.Tween(accentBar, Animations.Medium, {BackgroundTransparency = 1})
        Utils.Tween(titleLabel, Animations.Medium, {TextTransparency = 1})
        Utils.Tween(messageLabel, Animations.Medium, {TextTransparency = 1})
        Utils.Tween(closeBtn, Animations.Medium, {TextTransparency = 1})
        Utils.Tween(progressBg, Animations.Medium, {BackgroundTransparency = 1})
        Utils.Tween(progressBar, Animations.Medium, {BackgroundTransparency = 1})
        
        task.delay(0.3, function()
            for i, n in ipairs(NotificationSystem.ActiveNotifications) do
                if n == notifData then
                    table.remove(NotificationSystem.ActiveNotifications, i)
                    break
                end
            end
            notif:Destroy()
        end)
    end
    
    closeBtn.MouseButton1Click:Connect(closeNotification)
    
    task.delay(duration, function()
        if notif and notif.Parent then
            closeNotification()
        end
    end)
    
    return {Close = closeNotification}
end

