-- SLIDER
function Components.CreateSlider(parent, options)
    local name = options.Name or "Slider"
    local min = options.Min or 0
    local max = options.Max or 100
    local default = options.Default or min
    local step = options.Step or 1
    local callback = options.Callback or function() end
    local suffix = options.Suffix or ""
    
    local frame = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 60),
        BackgroundColor3 = Theme.Card,
        Parent = parent
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = frame})
    Utils.Create("UIPadding", {
        PaddingLeft = UDim.new(0, 16),
        PaddingRight = UDim.new(0, 16),
        PaddingTop = UDim.new(0, 12),
        Parent = frame
    })
    
    local header = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Parent = frame
    })
    
    Utils.Create("TextLabel", {
        Size = UDim2.new(0.7, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = header
    })
    
    local valueLabel = Utils.Create("TextLabel", {
        Size = UDim2.new(0.3, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = tostring(default) .. suffix,
        TextColor3 = Theme.Accent,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = header
    })
    
    local trackFrame = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 8),
        Position = UDim2.new(0, 0, 0, 28),
        BackgroundTransparency = 1,
        Parent = frame
    })
    
    local track = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Theme.SliderTrack,
        Parent = trackFrame
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = track})
    
    local fillPercent = (default - min) / (max - min)
    
    local fill = Utils.Create("Frame", {
        Size = UDim2.new(fillPercent, 0, 1, 0),
        BackgroundColor3 = Theme.SliderFill,
        Parent = track
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fill})
    
    local thumb = Utils.Create("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(fillPercent, -8, 0.5, -8),
        BackgroundColor3 = Theme.SliderThumb,
        ZIndex = 5,
        Parent = track
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = thumb})
    Utils.Create("UIStroke", {Color = Theme.Accent, Thickness = 2, Parent = thumb})
    
    local inputBtn = Utils.Create("TextButton", {
        Size = UDim2.new(1, 20, 0, 30),
        Position = UDim2.new(0, -10, 0, 20),
        BackgroundTransparency = 1,
        Text = "",
        Parent = frame
    })
    
    local currentVal = default
    local dragging = false
    local connections = ConnectionManager.new()
    
    local function updateSlider(inputPos)
        local trackAbsPos = track.AbsolutePosition.X
        local trackAbsSize = track.AbsoluteSize.X
        
        local percent = Utils.Clamp((inputPos - trackAbsPos) / trackAbsSize, 0, 1)
        local rawValue = min + (max - min) * percent
        local steppedValue = math.floor(rawValue / step + 0.5) * step
        steppedValue = Utils.Clamp(steppedValue, min, max)
        
        currentVal = steppedValue
        local newPercent = (steppedValue - min) / (max - min)
        
        fill.Size = UDim2.new(newPercent, 0, 1, 0)
        thumb.Position = UDim2.new(newPercent, -8, 0.5, -8)
        valueLabel.Text = tostring(steppedValue) .. suffix
        
        callback(steppedValue)
    end
    
    connections:Add(inputBtn.MouseButton1Down:Connect(function()
        dragging = true
        Utils.Tween(thumb, Animations.Fast, {Size = UDim2.new(0, 20, 0, 20)})
    end))
    
    connections:Add(UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position.X)
        end
    end))
    
    connections:Add(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            local pct = (currentVal - min) / (max - min)
            Utils.Tween(thumb, Animations.Fast, {Size = UDim2.new(0, 16, 0, 16)})
        end
    end))
    
    return {
        Frame = frame,
        Set = function(self, value)
            currentVal = Utils.Clamp(value, min, max)
            local pct = (currentVal - min) / (max - min)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            thumb.Position = UDim2.new(pct, -8, 0.5, -8)
            valueLabel.Text = tostring(currentVal) .. suffix
            callback(currentVal)
        end,
        Get = function() return currentVal end,
        Destroy = function()
            connections:DisconnectAll()
            frame:Destroy()
        end
    }
end

-- DROPDOWN
function Components.CreateDropdown(parent, options)
    local name = options.Name or "Dropdown"
    local optionList = options.Options or {}
    local default = options.Default or (optionList[1] or "")
    local callback = options.Callback or function() end
    local multi = options.Multi or false
    
    local selectedValues = {}
    if multi then
        selectedValues = type(default) == "table" and default or {default}
    else
        selectedValues = {default}
    end
    
    local isOpen = false
    
    local frame = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundColor3 = Theme.Card,
        ClipsDescendants = true,
        Parent = parent
    })
    
    Utils.Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = frame})
    Utils.Create("UIPadding", {
        PaddingLeft = UDim.new(0, 16),
        PaddingRight = UDim.new(0, 16),
        Parent = frame
    })
    
    local header = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Parent = frame
    })
    
    Utils.Create("TextLabel", {
        Size = UDim2.new(0.5, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = header
    })
    
    local selectedLabel = Utils.Create("TextLabel", {
        Size = UDim2.new(0.4, 0, 1, 0),
        Position = UDim2.new(0.5, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = multi and (#selectedValues .. " selected") or (selectedValues[1] or "None"),
        TextColor3 = Theme.TextSecondary,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Right,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = header
    })
    
    local arrow = Utils.Create("ImageLabel", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(1, -16, 0.5, -8),
        BackgroundTransparency = 1,
        Image = Icons.ChevronDown,
        ImageColor3 = Theme.TextMuted,
        Parent = header
    })
    
    local clickBtn = Utils.Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Text = "",
        Parent = frame
    })
    
    local optionsContainer = Utils.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 50),
        BackgroundTransparency = 1,
        Visible = false,
        Parent = frame
    })
    
    local optLayout = Utils.Create("UIListLayout", {
        Padding = UDim.new(0, 4),
        Parent = optionsContainer
    })
    
    Utils.Create("UIPadding", {
        PaddingTop = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 8),
        Parent = optionsContainer
    })
    
    local function createOption(optName)
        local optFrame = Utils.Create("Frame", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Theme.Input,
            Parent = optionsContainer
        })
        
        Utils.Create("UICorner", {CornerRadius = UDim.new(0, 8), Parent = optFrame})
        
        local isSelected = false
        if multi then
            for _, v in ipairs(selectedValues) do
                if v == optName then isSelected = true break end
            end
        else
            isSelected = (selectedValues[1] == optName)
        end
        
        if isSelected then
            optFrame.BackgroundColor3 = Theme.AccentDark
        end
        
        local optLabel = Utils.Create("TextLabel", {
            Size = UDim2.new(1, -20, 1, 0),
            Position = UDim2.new(0, 12, 0, 0),
            BackgroundTransparency = 1,
            Text = optName,
            TextColor3 = isSelected and Theme.TextPrimary or Theme.TextSecondary,
            TextSize = 13,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = optFrame
        })
        
        local optBtn = Utils.Create("TextButton", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            Parent = optFrame
        })
        
        optBtn.MouseEnter:Connect(function()
            if not isSelected then
                Utils.Tween(optFrame, Animations.Fast, {BackgroundColor3 = Theme.CardHover})
            end
        end)
        
        optBtn.MouseLeave:Connect(function()
            if not isSelected then
                Utils.Tween(optFrame, Animations.Fast, {BackgroundColor3 = Theme.Input})
            end
        end)
        
        optBtn.MouseButton1Click:Connect(function()
            if multi then
                local found = false
                for i, v in ipairs(selectedValues) do
                    if v == optName then
                        table.remove(selectedValues, i)
                        found = true
                        isSelected = false
                        break
                    end
                end
                if not found then
                    table.insert(selectedValues, optName)
                    isSelected = true
                end
                
                optFrame.BackgroundColor3 = isSelected and Theme.AccentDark or Theme.Input
                optLabel.TextColor3 = isSelected and Theme.TextPrimary or Theme.TextSecondary
                selectedLabel.Text = #selectedValues .. " selected"
                callback(selectedValues)
            else
                selectedValues = {optName}
                selectedLabel.Text = optName
                optFrame.BackgroundColor3 = Theme.AccentDark
                optLabel.TextColor3 = Theme.TextPrimary
                callback(optName)
                
                isOpen = false
                Utils.Tween(frame, Animations.Medium, {Size = UDim2.new(1, 0, 0, 50)})
                Utils.Tween(arrow, Animations.Medium, {Rotation = 0})
                task.delay(0.25, function()
                    optionsContainer.Visible = false
                end)
            end
        end)
    end
    
    for _, opt in ipairs(optionList) do
        createOption(opt)
    end
    
    local function toggleDropdown()
        isOpen = not isOpen
        
        if isOpen then
            optionsContainer.Visible = true
            local totalHeight = 50 + optLayout.AbsoluteContentSize.Y + 12
            Utils.Tween(frame, Animations.Medium, {Size = UDim2.new(1, 0, 0, totalHeight)})
            Utils.Tween(arrow, Animations.Medium, {Rotation = 180})
        else
            Utils.Tween(frame, Animations.Medium, {Size = UDim2.new(1, 0, 0, 50)})
            Utils.Tween(arrow, Animations.Medium, {Rotation = 0})
            task.delay(0.25, function()
                if not isOpen then
                    optionsContainer.Visible = false
                end
            end)
        end
    end
    
    clickBtn.MouseButton1Click:Connect(toggleDropdown)
    
    clickBtn.MouseEnter:Connect(function()
        Utils.Tween(frame, Animations.Fast, {BackgroundColor3 = Theme.CardHover})
    end)
    
    clickBtn.MouseLeave:Connect(function()
        Utils.Tween(frame, Animations.Fast, {BackgroundColor3 = Theme.Card})
    end)
    
    return {
        Frame = frame,
        Set = function(self, value)
            if multi and type(value) == "table" then
                selectedValues = value
                selectedLabel.Text = #selectedValues .. " selected"
            else
                selectedValues = {value}
                selectedLabel.Text = tostring(value)
            end
            callback(multi and selectedValues or selectedValues[1])
        end,
        Get = function() return multi and selectedValues or selectedValues[1] end
    }
end

