            local min = 0    
            local sliderValue = defaultValue or 0    
            local max = max or 100    
            local dragging = false    

            local function updateValue(newValue)    
                sliderValue = math.clamp(newValue, min, max)    
                local percentage = (sliderValue - min) / (max - min)    
                SliderFill.Size = UDim2.new(percentage, 0, 1, 0)    
                InfoNumber.Text = tostring(math.floor(sliderValue))    
                if callback then callback(sliderValue) end    
            end    

            local function blockCamera(_, inputState)    
                if inputState == Enum.UserInputState.Begin or inputState == Enum.UserInputState.Change then    
                    return Enum.ContextActionResult.Sink    
                end    
            end    

            local function updateSliderFromPosition(input)    
                if not SliderTrack:IsDescendantOf(game) then return end    
                local absPos = SliderTrack.AbsolutePosition    
                local absSize = SliderTrack.AbsoluteSize    
                local relativeX = (input.Position.X - absPos.X) / absSize.X    
                relativeX = math.clamp(relativeX, 0, 1)    
                local newValue = min + (relativeX * (max - min))    
                updateValue(newValue)    
            end    

            SliderTrack.InputBegan:Connect(function(input)    
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then    
                    dragging = true    
                    ContextActionService:BindAction("BlockCameraSlider", blockCamera, false, Enum.UserInputType.MouseMovement, Enum.UserInputType.Touch)    
                    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition    
                    updateSliderFromPosition(input)    
                end    
            end)    

            SliderTrack.InputEnded:Connect(function(input)    
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then    
                    dragging = false    
                    ContextActionService:UnbindAction("BlockCameraSlider")    
                    UserInputService.MouseBehavior = Enum.MouseBehavior.Default    
                end    
            end)    

            UserInputService.InputChanged:Connect(function(input)    
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateSliderFromPosition(input) end    
            end)    

            UserInputService.TouchMoved:Connect(function(input)    
                if dragging then updateSliderFromPosition({Position = input.Position, UserInputType = Enum.UserInputType.Touch}) end    
            end)    

            updateValue(defaultValue or 0)    

            local elementData = { frame = SliderFrame, height = 30, visible = true, isSub = false }      
            table.insert(tabData.elements, elementData)      
            updateLayout()    

            return {    
                SetValue = function(self, value) updateValue(value) end,    
                GetValue = function(self) return sliderValue end,  
                SetVisible = function(self, state) elementData.visible = state; SliderFrame.Visible = state; updateLayout() end,  
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end  
            }  
        end  

        function tabMethods:AddButton(text, callback)      
            local ButtonFrame = Instance.new("Frame", ElementsContainer)      
            ButtonFrame.BorderSizePixel = 0      
            ButtonFrame.Size = UDim2.new(0, 236, 0, 22)    
            ButtonFrame.BackgroundTransparency = 1    
                  
            local Button = Instance.new("TextButton", ButtonFrame)      
            Button.TextWrapped = true      
            Button.BorderSizePixel = 0      
            Button.TextSize = 13      
            Button.TextColor3 = Color3.fromRGB(255, 255, 255)      
            Button.BackgroundColor3 = currentThemeColor      
            Button.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)      
            Button.Size = UDim2.new(0, 238, 0, 22)    
            Button.Text = text or "Button"      
            Button.AutoButtonColor = false      
            Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 3)    
            
            table.insert(themeElements, { type = "Button", instance = Button })
                  
            Button.MouseEnter:Connect(function() 
                local h, s, v = currentThemeColor:ToHSV()
                Button.BackgroundColor3 = Color3.fromHSV(h, s, math.clamp(v + 0.1, 0, 1)) 
            end)      
            Button.MouseLeave:Connect(function() Button.BackgroundColor3 = currentThemeColor end)      
            Button.MouseButton1Click:Connect(function() if callback then callback() end end)      
                  
            local elementData = { frame = ButtonFrame, height = 30, visible = true, isSub = false }      
            table.insert(tabData.elements, elementData)      
            updateLayout()    

            return {  
                SetVisible = function(self, state) elementData.visible = state; ButtonFrame.Visible = state; updateLayout() end,  
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end  
            }      
        end   

        function tabMethods:AddRadioButtons(text, options, callback)      
            local RadioFrame = Instance.new("Frame", ElementsContainer)      
            RadioFrame.BorderSizePixel = 0      
            RadioFrame.Size = UDim2.new(0, 162, 0, 38)   
            RadioFrame.BackgroundTransparency = 1      
                  
            local InfoLabel = Instance.new("TextLabel", RadioFrame)      
            InfoLabel.TextWrapped = true      
            InfoLabel.BorderSizePixel = 0      
            InfoLabel.TextSize = 10      
            InfoLabel.TextXAlignment = Enum.TextXAlignment.Left      
            InfoLabel.TextScaled = true      
            InfoLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)      
            InfoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)      
            InfoLabel.BackgroundTransparency = 1      
            InfoLabel.Size = UDim2.new(0, 132, 0, 12)    
            InfoLabel.Text = text or "Radio Buttons"      
            InfoLabel.Position = UDim2.new(0, 0, 0, -2)    
                  
            local radioButtons = {}      
            local selectedOption = options[1]      
                  
            for i, option in ipairs(options) do      
                local RadioOption = Instance.new("Frame", RadioFrame)      
                RadioOption.BorderSizePixel = 0      
                RadioOption.Size = UDim2.new(0, 70, 0, 16)    
                RadioOption.Position = UDim2.new(0, (i-1) * 78, 0, 16)      
                RadioOption.BackgroundTransparency = 1      
                      
                local OptionLabel = Instance.new("TextLabel", RadioOption)      
                OptionLabel.BorderSizePixel = 0      
                OptionLabel.TextSize = 9      
                OptionLabel.TextXAlignment = Enum.TextXAlignment.Left      
                OptionLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)      
                OptionLabel.TextColor3 = Color3.fromRGB(255, 255, 255)      
                OptionLabel.BackgroundTransparency = 1      
                OptionLabel.Size = UDim2.new(0, 58, 0, 16)      
                OptionLabel.Text = option      
                OptionLabel.Position = UDim2.new(0, 20, 0, 0)      
                      
                local RadioButton = Instance.new("TextButton", RadioOption)      
                RadioButton.BorderSizePixel = 0      
                RadioButton.BackgroundColor3 = i == 1 and currentThemeColor or Color3.fromRGB(53, 53, 53)      
                RadioButton.Size = UDim2.new(0, 16, 0, 16)      
                RadioButton.Text = ""      
                RadioButton.AutoButtonColor = false      
                Instance.new("UICorner", RadioButton).CornerRadius = UDim.new(1, 9)    
                
                table.insert(themeElements, { type = "RadioButton", instance = RadioButton, getState = function() return selectedOption == option end })
                table.insert(radioButtons, {button = RadioButton, option = option, index = i})      
                      
                RadioButton.MouseButton1Click:Connect(function()      
                    for _, rb in ipairs(radioButtons) do      
                        rb.button.BackgroundColor3 = Color3.fromRGB(53, 53, 53)      
                    end      
                    RadioButton.BackgroundColor3 = currentThemeColor      
                    selectedOption = option      
                    if callback then callback(option) end      
                end)      
            end      
                  
            RadioFrame.Size = UDim2.new(0, math.min(#options * 78, 162), 0, 38)  
            local elementData = { frame = RadioFrame, height = 42, visible = true, isSub = false }      
            table.insert(tabData.elements, elementData)      
            updateLayout()    
                  
            return {      
                SetValue = function(self, value)      
                    for _, rb in ipairs(radioButtons) do      
                        if rb.option == value then      
                            rb.button.BackgroundColor3 = currentThemeColor      
                            selectedOption = value      
                        else      
                            rb.button.BackgroundColor3 = Color3.fromRGB(53, 53, 53)      
                        end      
                    end      
                    if callback then callback(value) end     
                end,      
                GetValue = function(self) return selectedOption end,  
                SetVisible = function(self, state) elementData.visible = state; RadioFrame.Visible = state; updateLayout() end,  
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end  
            }      
        end   

        return tabMethods    
    end    

    return publicMethods
end

