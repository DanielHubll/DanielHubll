            Button.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
            Button.Size = UDim2.new(1, 0, 0, 22)
            Button.Text = text or "Button"
            Button.AutoButtonColor = false
            Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 3)
            table.insert(themeElements, { type = "Button", instance = Button })

            Button.MouseEnter:Connect(function()
                local h, s, v = currentThemeColor:ToHSV()
                Button.BackgroundColor3 = Color3.fromHSV(h, s, math.clamp(v + 0.1, 0, 1))
            end)
            Button.MouseLeave:Connect(function() Button.BackgroundColor3 = currentThemeColor end)
            Button.MouseButton1Click:Connect(function() if callback then callback() end end)

            local elementData = { frame = ButtonFrame, height = 30, visible = true, isSub = false }
            table.insert(tabData.elements, elementData)
            updateLayout()

            return {
                SetVisible = function(self, state) elementData.visible = state; ButtonFrame.Visible = state; updateLayout() end,
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end
            }
        end

        -- RadioButtons
        function tabMethods:AddRadioButtons(text, options, callback)
            local RadioFrame = Instance.new("Frame", ElementsContainer)
            RadioFrame.BorderSizePixel = 0
            RadioFrame.Size = UDim2.new(1, -12, 0, 38)
            RadioFrame.BackgroundTransparency = 1

            local InfoLabel = Instance.new("TextLabel", RadioFrame)
            InfoLabel.TextWrapped = true
            InfoLabel.BorderSizePixel = 0
            InfoLabel.TextSize = 10
            InfoLabel.TextXAlignment = Enum.TextXAlignment.Left
            InfoLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
            InfoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            InfoLabel.BackgroundTransparency = 1
            InfoLabel.Size = UDim2.new(0, 130, 0, 12)
            InfoLabel.Text = text or "Radio Buttons"
            InfoLabel.Position = UDim2.new(0, 0, 0, -2)

            local radioButtons = {}
            local selectedOption = options[1]
            local currentX = 0
            local currentY = 16
            local maxContainerWidth = 246

            for i, option in ipairs(options) do
                local textStr = tostring(option)
                local textSize = TextService:GetTextSize(textStr, 9, Enum.Font.GothamBold, Vector2.new(500, 16))
                local optionWidth = 16 + 4 + textSize.X + 10
                if currentX + optionWidth > maxContainerWidth then
                    currentX = 0; currentY = currentY + 22
                end
                local RadioOption = Instance.new("Frame", RadioFrame)
                RadioOption.BorderSizePixel = 0
                RadioOption.Size = UDim2.new(0, optionWidth, 0, 16)
                RadioOption.Position = UDim2.new(0, currentX, 0, currentY)
                RadioOption.BackgroundTransparency = 1

                local RadioButton = Instance.new("TextButton", RadioOption)
                RadioButton.BorderSizePixel = 0
                RadioButton.BackgroundColor3 = i == 1 and currentThemeColor or Color3.fromRGB(53, 53, 53)
                RadioButton.Size = UDim2.new(0, 16, 0, 16)
                RadioButton.Text = ""
                RadioButton.AutoButtonColor = false
                Instance.new("UICorner", RadioButton).CornerRadius = UDim.new(1, 9)

                local OptionLabel = Instance.new("TextLabel", RadioOption)
                OptionLabel.BorderSizePixel = 0
                OptionLabel.TextSize = 9
                OptionLabel.TextXAlignment = Enum.TextXAlignment.Left
                OptionLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
                OptionLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                OptionLabel.BackgroundTransparency = 1
                OptionLabel.Size = UDim2.new(0, textSize.X, 0, 16)
                OptionLabel.Text = textStr
                OptionLabel.Position = UDim2.new(0, 20, 0, 0)

                table.insert(themeElements, { type = "RadioButton", instance = RadioButton, getState = function() return selectedOption == option end })
                table.insert(radioButtons, { button = RadioButton, option = option, index = i })

                RadioButton.MouseButton1Click:Connect(function()
                    for _, rb in ipairs(radioButtons) do rb.button.BackgroundColor3 = Color3.fromRGB(53, 53, 53) end
                    RadioButton.BackgroundColor3 = currentThemeColor
                    selectedOption = option
                    if callback then callback(option) end
                end)

                currentX = currentX + optionWidth
            end

            local finalHeight = currentY + 20
            RadioFrame.Size = UDim2.new(1, -12, 0, finalHeight)

            local elementData = { frame = RadioFrame, height = finalHeight + 4, visible = true, isSub = false }
            table.insert(tabData.elements, elementData)
            updateLayout()

            local RadioObject = {
                SetValue = function(self, value)
                    for _, rb in ipairs(radioButtons) do
                        if rb.option == value then
                            rb.button.BackgroundColor3 = currentThemeColor
                            selectedOption = value
                        else
                            rb.button.BackgroundColor3 = Color3.fromRGB(53, 53, 53)
                        end
                    end
                    if callback then callback(value) end
                end,
                GetValue = function(self) return selectedOption end,
                SetVisible = function(self, state) elementData.visible = state; RadioFrame.Visible = state; updateLayout() end,
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end
            }

            registerConfigElement("RadioButton", text, RadioObject, function() return RadioObject:GetValue() end, function(val) RadioObject:SetValue(val) end)
            return RadioObject
        end

