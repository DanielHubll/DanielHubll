        function tabMethods:AddSlider(text, defaultValue, max, callback)
            local SliderFrame = Instance.new("Frame", ElementsContainer)
            SliderFrame.BorderSizePixel = 0
            SliderFrame.Size = UDim2.new(0, 246, 0, 22)
            SliderFrame.BackgroundTransparency = 1

            local Main = Instance.new("Frame", SliderFrame)
            Main.BorderSizePixel = 0
            Main.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Main.Size = UDim2.new(0, 168, 0, 22)
            Main.BackgroundTransparency = 1
            Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 3)

            local SliderTrack = Instance.new("Frame", Main)
            SliderTrack.BorderSizePixel = 0
            SliderTrack.BackgroundColor3 = Color3.fromRGB(37, 37, 37)
            SliderTrack.Size = UDim2.new(0, 168, 0, 22)
            SliderTrack.Active = true
            Instance.new("UICorner", SliderTrack).CornerRadius = UDim.new(0, 3)

            local SliderFill = Instance.new("Frame", SliderTrack)
            SliderFill.BorderSizePixel = 0
            SliderFill.BackgroundColor3 = currentThemeColor
            SliderFill.Size = UDim2.new(0, 0, 1, 0)
            Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(0, 3)
            table.insert(themeElements, { type = "Slider", instance = SliderFill })

            local InfoNumber = Instance.new("TextLabel", Main)
            InfoNumber.BorderSizePixel = 0
            InfoNumber.TextColor3 = Color3.fromRGB(255, 255, 255)
            InfoNumber.BackgroundTransparency = 1
            InfoNumber.Size = UDim2.new(0, 168, 0, 22)
            InfoNumber.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
            InfoNumber.TextSize = 20
            InfoNumber.TextTransparency = 0.3

            local InfoLabel = Instance.new("TextLabel", SliderFrame)
            InfoLabel.BorderSizePixel = 0
            InfoLabel.TextSize = 10
            InfoLabel.TextXAlignment = Enum.TextXAlignment.Left
            InfoLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
            InfoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            InfoLabel.BackgroundTransparency = 1
            InfoLabel.Size = UDim2.new(0, 70, 0, 20)
            InfoLabel.Text = text or "Slider"
            InfoLabel.Position = UDim2.new(0, 176, 0, 2)

            local minVal = 0
            local sliderValue = defaultValue or 0
            local maxVal = max or 100
            local dragging = false

            local function updateValue(newValue)
                sliderValue = math.clamp(newValue, minVal, maxVal)
                local percentage = (sliderValue - minVal) / (maxVal - minVal)
                SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
                InfoNumber.Text = tostring(math.floor(sliderValue))
                if callback then callback(sliderValue) end
            end

            local function blockCamera(_, inputState)
                if inputState == Enum.UserInputState.Begin
                or inputState == Enum.UserInputState.Change then
                    return Enum.ContextActionResult.Sink
                end
            end

            local function updateSliderFromPosition(input)
                if not SliderTrack:IsDescendantOf(game) then return end
                local absPos = SliderTrack.AbsolutePosition
                local absSize = SliderTrack.AbsoluteSize
                local relativeX = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
                updateValue(minVal + (relativeX * (maxVal - minVal)))
            end

            SliderTrack.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    ContextActionService:BindAction("BlockCameraSlider", blockCamera, false,
                        Enum.UserInputType.MouseMovement, Enum.UserInputType.Touch)
                    updateSliderFromPosition(input)
                end
            end)

            SliderTrack.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    ContextActionService:UnbindAction("BlockCameraSlider")
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSliderFromPosition(input)
                end
            end)

            UserInputService.TouchMoved:Connect(function(input)
                if dragging then
                    updateSliderFromPosition({ Position = input.Position, UserInputType = Enum.UserInputType.Touch })
                end
            end)

            updateValue(defaultValue or 0)

            local elementData = { frame = SliderFrame, height = 30, visible = true, isSub = false }
            table.insert(tabData.elements, elementData)
            updateLayout()

            local SliderObject = {
                SetValue = function(self, value) updateValue(value) end,
                GetValue = function(self) return sliderValue end,
                SetVisible = function(self, state) elementData.visible = state; SliderFrame.Visible = state; updateLayout() end,
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end
            }

            registerConfigElement("Slider", text, SliderObject,
                function() return SliderObject:GetValue() end,
                function(val) SliderObject:SetValue(val) end
            )
            return SliderObject
