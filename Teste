    local function sendNotification(text, duration, nType)
        local t = duration or 2
        local frame = Instance.new("Frame", NotificationHolder)
        frame.Size = UDim2.new(1, 0, 0, 40)
        frame.BackgroundColor3 = nType == "error" and Color3.fromRGB(200, 50, 50) or nType == "info" and Color3.fromRGB(50, 150, 200) or Color3.fromRGB(50, 200, 50)
        frame.BorderSizePixel = 0
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
        local label = Instance.new("TextLabel", frame)
        label.Size = UDim2.new(1, -10, 1, 0)
        label.Position = UDim2.new(0, 5, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 12
        label.TextWrapped = true
        label.TextXAlignment = Enum.TextXAlignment.Left

        frame.Position = UDim2.new(1, 0, 0, (#notificationQueue) * 48)
        table.insert(notificationQueue, frame)

        local tween = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 0, frame.Position.Y.Scale, frame.Position.Y.Offset)})
        tween:Play()
        task.delay(t, function()
            local fade = TweenService:Create(frame, TweenInfo.new(0.3), {BackgroundTransparency = 1})
            fade:Play()
            fade.Completed:Connect(function()
                frame:Destroy()
                for i, notif in ipairs(notificationQueue) do
                    if notif == frame then
                        table.remove(notificationQueue, i)
                        break
                    end
                end
                -- reordenar
                for i, notif in ipairs(notificationQueue) do
                    notif.Position = UDim2.new(0, 0, 0, (i-1) * 48)
                end
            end)
        end)
    end

    publicMethods.SendNotification = function(text, duration, nType)
