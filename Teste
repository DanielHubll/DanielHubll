        function tabMethods:AddToggle(text, callback)        
            local ToggleFrame = Instance.new("Frame", ElementsContainer)        
            ToggleFrame.BorderSizePixel = 0        
            ToggleFrame.Size = UDim2.new(0, 240, 0, 22)        
            ToggleFrame.BackgroundTransparency = 1        
                    
            local InfoLabel = Instance.new("TextLabel", ToggleFrame)        
            InfoLabel.BorderSizePixel = 0        
            InfoLabel.TextSize = 10        
            InfoLabel.TextXAlignment = Enum.TextXAlignment.Left        
            InfoLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)        
            InfoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)        
            InfoLabel.BackgroundTransparency = 1        
            InfoLabel.Size = UDim2.new(0, 150, 0, 22)        
            InfoLabel.Text = text or "Toggle"        
            InfoLabel.Position = UDim2.new(0, 28, 0, 0)        
                    
            local ToggleButton = Instance.new("TextButton", ToggleFrame)        
            ToggleButton.BackgroundColor3 = Color3.fromRGB(37, 37, 37)      
            ToggleButton.Size = UDim2.new(0, 22, 0, 22)        
            ToggleButton.BorderSizePixel = 0        
            ToggleButton.Text = ""        
            ToggleButton.AutoButtonColor = false        
            Instance.new("UICorner", ToggleButton).CornerRadius = UDim.new(0, 3)      
                    
            local toggleState = false        
            local floatingVisible = false
            local floatingFrame = nil
            local updateFloatingVisual = nil

            local function updateToggle()        
                ToggleButton.BackgroundColor3 = toggleState and currentThemeColor or Color3.fromRGB(37, 37, 37)        
                if updateFloatingVisual then
                    updateFloatingVisual()
                end
                if callback then callback(toggleState) end     
            end        
                    
            ToggleButton.MouseButton1Click:Connect(function()        
                toggleState = not toggleState        
                updateToggle()        
            end)        

            -- BOTAO SHOW/HIDE AO LADO DO TOGGLE ORIGINAL
            local ShowHide = Instance.new("TextButton", ToggleFrame)
            ShowHide.Size = UDim2.new(0, 45, 0, 18)
            ShowHide.Position = UDim2.new(0, 185, 0, 2)
            ShowHide.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            ShowHide.TextColor3 = Color3.fromRGB(255, 255, 255)
            ShowHide.Text = "Show"
            ShowHide.TextSize = 10
            ShowHide.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
            Instance.new("UICorner", ShowHide).CornerRadius = UDim.new(0, 4)

            -- LOGICA INTERNA DO FLOATING DIRECIONADO PARA ESTE TOGGLE
            local function CreateFloating()
                local frame = Instance.new("Frame")
                frame.Parent = LMG2L["Floating_1"]
                frame.Size = UDim2.new(0, 130, 0, 35)
                frame.Position = UDim2.new(0, 400, 0, 200)
                frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                frame.BorderSizePixel = 0
                
                local stroke = Instance.new("UIStroke", frame)
                stroke.Thickness = 1.5
                stroke.Color = currentThemeColor
                
                Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

                local FloatToggle = Instance.new("TextButton", frame)
                FloatToggle.Size = UDim2.new(0, 22, 0, 22)
                FloatToggle.Position = UDim2.new(0, 6, 0, 6.5)
                FloatToggle.Text = ""
                FloatToggle.BackgroundColor3 = Color3.fromRGB(37, 37, 37)
                FloatToggle.AutoButtonColor = false
                Instance.new("UICorner", FloatToggle).CornerRadius = UDim.new(0, 4)

                local Label = Instance.new("TextLabel", frame)
                Label.BackgroundTransparency = 1
                Label.Position = UDim2.new(0, 35, 0, 0)
                Label.Size = UDim2.new(1, -35, 1, 0)
                Label.Text = text or "Toggle"
                Label.TextColor3 = Color3.fromRGB(255, 255, 255)
                Label.TextSize = 10
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)

                local function UpdateFloatingVisual()
                    FloatToggle.BackgroundColor3 = toggleState and currentThemeColor or Color3.fromRGB(37, 37, 37)
                    stroke.Color = currentThemeColor
                end

                FloatToggle.MouseButton1Click:Connect(function()
                    toggleState = not toggleState
                    updateToggle()
                end)

                MakeDraggable(frame, frame)
                table.insert(themeElements, { type = "FloatingStroke", instance = stroke })

                return frame, UpdateFloatingVisual
            end

            ShowHide.MouseButton1Click:Connect(function()
                floatingVisible = not floatingVisible
                if floatingVisible then
                    ShowHide.Text = "Hide"
                    ShowHide.BackgroundColor3 = currentThemeColor
                    if not floatingFrame then
                        floatingFrame, updateFloatingVisual = CreateFloating()
                    end
                    floatingFrame.Visible = true
                    updateFloatingVisual()
                else
                    ShowHide.Text = "Show"
                    ShowHide.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                    if floatingFrame then
                        floatingFrame.Visible = false
                    end
                end
            end)

            table.insert(themeElements, { type = "Toggle", instance = ToggleButton, getState = function() return toggleState end })
            table.insert(themeElements, { type = "FloatingShowHide", instance = ShowHide, getVisible = function() return floatingVisible end })
            table.insert(tabData.elements, {frame = ToggleFrame, height = 30, visible = true, isSub = false})      
            updateLayout()      
                    
            local ToggleObject = {}      
            function ToggleObject:SetState(state) toggleState = state; updateToggle() end      
            function ToggleObject:GetState() return toggleState end      
                
            function ToggleObject:BindToDropdown(dropdownObject)      
                if not dropdownObject then return end     
                if dropdownObject.SetAsSubElement then dropdownObject:SetAsSubElement(true) end   
                dropdownObject:SetVisible(toggleState)      
                local oldCallback = callback      
                callback = function(v) if oldCallback then oldCallback(v) end; dropdownObject:SetVisible(v) end      
            end      
                
            function ToggleObject:BindToColorPicker(colorPickerObject)    
                if not colorPickerObject then return end    
                if colorPickerObject.SetAsSubElement then colorPickerObject:SetAsSubElement(true) end   
                colorPickerObject:SetVisible(toggleState)    
                local oldCallback = callback    
                callback = function(v)     
                    if oldCallback then oldCallback(v) end    
                    colorPickerObject:SetVisible(v)    
                end    
            end    

            function ToggleObject:AddDropdown(dropdownText, options, dropCallback)    
                local dropdownObj = tabMethods:AddDropdown(dropdownText, options, dropCallback)    
                self:BindToDropdown(dropdownObj)    
                return dropdownObj    
            end    

            function ToggleObject:AddColorPicker(pickerText, defaultColor, pickerCallback)    
                local pickerObj = tabMethods:AddColorPicker(pickerText, defaultColor, pickerCallback)    
                self:BindToColorPicker(pickerObj)    
                return pickerObj    
            end    

            return ToggleObject      
        end        
            
