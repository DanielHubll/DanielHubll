    local function isInsideFrame(frame, posX, posY)
        if not frame or not frame.Parent then return false end
        local absPos = frame.AbsolutePosition
        local absSize = frame.AbsoluteSize
        return posX >= absPos.X and posX <= absPos.X + absSize.X and posY >= absPos.Y and posY <= absPos.Y + absSize.Y
    end

    -- Aplica cor do tema
    local function applyTheme()
        for _, item in ipairs(themeElements) do
            local obj = item.instance
            local state = item.getState and item:getState() or true
            if item.type == "Toggle" and state then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "FloatingTopo" then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "ShowButton" and state then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "Button" then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "Slider" then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "RadioButton" and state then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "SectionLine" then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "Separator" then
                obj.BackgroundColor3 = currentThemeColor
            elseif item.type == "DropdownIcon" then
                obj.BackgroundColor3 = currentThemeColor
            end
        end
    end

