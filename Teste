    local function collectCurrentConfig()
        local config = {}
        for tabName, elements in pairs(configElements) do
            config[tabName] = {}
            for _, elem in ipairs(elements) do
                local value = elem.getValue()
                if elem.type == "ColorPicker" and typeof(value) == "Color3" then
                    value = value:ToHex()
                elseif elem.type == "MultiDropdown" and type(value) == "table" then
                    value = table.concat(value, "|")
                elseif elem.type == "Keybind" and typeof(value) == "EnumItem" then
                    value = value.Name
                end
                table.insert(config[tabName], {
                    type = elem.type,
                    text = elem.text,
                    value = value
                })
            end
        end
        return config
    end

    local function loadConfiguration(config)
        if not config then return end
        for tabName, elements in pairs(configElements) do
            if config[tabName] then
                for _, elem in ipairs(elements) do
                    for _, savedElem in ipairs(config[tabName]) do
                        if savedElem.text == elem.text and savedElem.type == elem.type then
                            local value = savedElem.value
                            if elem.type == "ColorPicker" and type(value) == "string" then
                                local ok, color = pcall(Color3.fromHex, value)
                                if ok then value = color end
                            elseif elem.type == "MultiDropdown" and type(value) == "string" then
                                local parts = {}
                                for part in value:gmatch("[^|]+") do
                                    table.insert(parts, part)
                                end
                                value = parts
                            elseif elem.type == "Keybind" and type(value) == "string" then
                                value = Enum.KeyCode[value]
                            end
                            elem.setValue(value)
                            break
                        end
                    end
                end
            end
        end
    end

    local autoConfigCreated = false
    local function createAutoConfigTab()
        if autoConfigCreated then return end
        autoConfigCreated = true

        ensureFolder()

        local meta = loadMeta()
        local autoLoadEnabled = meta.autoLoad or false

        local configTab = publicMethods:AddTab("Config", "rbxassetid://10709852168")

        local currentConfigName = meta.lastConfig or ""
        local configDropdown = nil
        local nameInput = nil
        local autoLoadToggle = nil

        local function getConfigList()
            local list = {}
            loadAllConfigsFromDisk()
            local diskConfigs = getConfigFiles()
            for _, name in ipairs(diskConfigs) do
                table.insert(list, name)
            end
            if #list == 0 then
                table.insert(list, "Nenhuma config salva")
            end
            return list
        end

        local function updateDropdown(selectName)
            local configList = getConfigList()
            if configDropdown and configDropdown.Refresh then
                configDropdown:Refresh(configList)
            end
            local nameToSelect = selectName or currentConfigName
            if nameToSelect and nameToSelect ~= "" and configDropdown and configDropdown.SetValue then
                for _, v in ipairs(getConfigList()) do
                    if v == nameToSelect then
                        configDropdown:SetValue(nameToSelect)
                        break
                    end
                end
            end
        end

        configTab:AddSection("Gerenciador de Configs")

        nameInput = configTab:AddTextBox("Nome", currentConfigName, function(text)
            currentConfigName = text
        end)

        configDropdown = configTab:AddDropdown("Configs Salvas", getConfigList(), function(selected)
            if selected and selected ~= "Nenhuma config salva" then
                currentConfigName = selected
                if nameInput then
                    nameInput:SetText(selected)
                end
            end
        end)

        configTab:AddSeparator()

        configTab:AddButton("Salvar", function()
            local name = nameInput:GetText()
            if not name or name == "" or name == "Nenhuma config salva" then return end
            local configData = collectCurrentConfig()
            savedConfigs[name] = configData
            saveToFile(configData, name)
            currentConfigName = name
            meta.lastConfig = name
            meta.autoLoad = autoLoadEnabled
            saveMeta(meta)
            updateDropdown(name)
            NotificationSystem:CreateNotification("Sucesso", "Configuração salva!", 2, "Success")
        end, "rbxassetid://97582400811473")

        configTab:AddButton("Carregar", function()
            local name = nameInput:GetText()
            if not name or name == "" then return end
            local configToLoad = savedConfigs[name] or loadFromFile(name)
            if configToLoad then
                savedConfigs[name] = configToLoad
                loadConfiguration(configToLoad)
                currentConfigName = name
                meta.lastConfig = name
                meta.autoLoad = autoLoadEnabled
                saveMeta(meta)
                updateDropdown(name)
                NotificationSystem:CreateNotification("Sucesso", "Configuração carregada!", 2, "Success")
            end
        end, "rbxassetid://106415964550855")

        configTab:AddButton("Deletar", function()
            local name = nameInput:GetText()
            if not name or name == "" then return end
            if savedConfigs[name] then
                savedConfigs[name] = nil
                pcall(function() delfile("VLG_Configs/" .. name .. ".json") end)
                if meta.lastConfig == name then
                    meta.lastConfig = nil
                    saveMeta(meta)
                end
                currentConfigName = ""
                if nameInput then nameInput:SetText("") end
                updateDropdown()
                NotificationSystem:CreateNotification("Deletado", "Configuração removida!", 2, "Warning")
            end
        end, "rbxassetid://119483803631956")

        configTab:AddSeparator()

        configTab:AddSection("Auto Load")

        autoLoadToggle = configTab:AddToggle("Auto Load ao Entrar", function(state)
            autoLoadEnabled = state
            meta.autoLoad = state
            saveMeta(meta)
        end)

        if autoLoadEnabled then
            autoLoadToggle:SetState(true)
        end

        configTab:AddSeparator()

        configTab:AddButton("Atualizar Lista", function()
            updateDropdown(currentConfigName)
        end, "rbxassetid://119636414179025")

        configTab:AddButton("Resetar Tudo", function()
            for _, elements in pairs(configElements) do
                for _, elem in ipairs(elements) do
                    if     elem.type == "Toggle"       then elem.setValue(false)
                    elseif elem.type == "Slider"       then elem.setValue(0)
                    elseif elem.type == "TextBox"      then elem.setValue("")
                    elseif elem.type == "Dropdown"     then elem.setValue("")
                    elseif elem.type == "ColorPicker"  then elem.setValue(Color3.fromRGB(255, 255, 255))
                    elseif elem.type == "RadioButton"  then elem.setValue("")
                    elseif elem.type == "NumberBox"    then elem.setValue(0)
                    elseif elem.type == "ProgressBar"  then elem.setValue(0)
                    elseif elem.type == "MultiDropdown" then elem.setValue({})
                    elseif elem.type == "Label"        then elem.setValue("")
                    end
                end
            end
            NotificationSystem:CreateNotification("Reset", "Tudo foi resetado!", 2, "Warning")
        end, "rbxassetid://93898339468067")
        
        if currentConfigName ~= "" then
            updateDropdown(currentConfigName)
            if nameInput then nameInput:SetText(currentConfigName) end
        end

        if autoLoadEnabled and meta.lastConfig and meta.lastConfig ~= "" then
            spawn(function()
                wait(0.5)
                local configToLoad = savedConfigs[meta.lastConfig] or loadFromFile(meta.lastConfig)
                if configToLoad then
                    savedConfigs[meta.lastConfig] = configToLoad
                    loadConfiguration(configToLoad)
                    NotificationSystem:CreateNotification("Auto Load", "Config '" .. meta.lastConfig .. "' carregada!", 3, "Info")
                end
            end)
        end
    end

    spawn(function()
        wait(0.2)
        createAutoConfigTab()
    end)

