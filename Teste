            DropdownContainerCorner.CornerRadius = UDim.new(0, 5)
            
            local OptionsList = Instance.new("UIListLayout", DropdownContainer)
            OptionsList.Padding = UDim.new(0, 2)
            OptionsList.SortOrder = Enum.SortOrder.LayoutOrder

            local function createOption(optionText, index)
                local OptionButton = Instance.new("TextButton")  
                OptionButton.Size = UDim2.new(1, -10, 0, 25)  
                OptionButton.Position = UDim2.new(0, 5, 0, (index-1)*27)  
                OptionButton.Text = optionText  
                OptionButton.TextSize = 11  
                OptionButton.TextColor3 = currentTheme.TextColor
                OptionButton.BackgroundColor3 = currentTheme.ElementBackground
                OptionButton.BorderSizePixel = 0  
                OptionButton.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular)  
                OptionButton.LayoutOrder = index
                OptionButton.Parent = DropdownContainer
                
                local OptionCorner = Instance.new("UICorner", OptionButton)
                OptionCorner.CornerRadius = UDim.new(0, 3)
                
                -- Efeitos hover
                OptionButton.MouseEnter:Connect(function()
                    TweenService:Create(OptionButton, TweenInfo.new(0.2), {
                        BackgroundColor3 = currentTheme.ElementBackgroundHover
                    }):Play()
                end)
                
                OptionButton.MouseLeave:Connect(function()
                    TweenService:Create(OptionButton, TweenInfo.new(0.2), {
                        BackgroundColor3 = currentTheme.ElementBackground
                    }):Play()
                end)
                
                OptionButton.MouseButton1Click:Connect(function()  
                    Selected.Text = optionText  
                    if callback then callback(optionText) end  
                    closeDropdown()
                end)
                
                return OptionButton
            end

            for i, option in ipairs(options) do  
                createOption(option, i)
            end
            
            local function updateDropdownSize()
                local optionCount = math.min(#options, 5)
                DropdownContainer.Size = UDim2.new(1, 0, 0, optionCount * 27 + 5)
            end
            
            updateDropdownSize()
            
            local dropdownOpen = false
            
            local function openDropdown()
                dropdownOpen = true
                DropdownContainer.Visible = true
                TweenService:Create(Open, TweenInfo.new(0.3), {Rotation = 0}):Play()
                TweenService:Create(DropdownContainer, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, math.min(#options, 5) * 27 + 5)}):Play()
                TweenService:Create(DropdownFrame, TweenInfo.new(0.3), {
                    Size = UDim2.new(0, 246, 0, 30 + math.min(#options, 5) * 27 + 10)
                }):Play()
            end
            
            local function closeDropdown()
                dropdownOpen = false
                TweenService:Create(Open, TweenInfo.new(0.3), {Rotation = 180}):Play()
                TweenService:Create(DropdownContainer, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                TweenService:Create(DropdownFrame, TweenInfo.new(0.3), {
                    Size = UDim2.new(0, 246, 0, 30)
                }):Play()
                
                task.wait(0.3)
                if not dropdownOpen then
                    DropdownContainer.Visible = false
                end
            end
            
            Open.MouseButton1Click:Connect(function()  
                if dropdownOpen then
                    closeDropdown()
                else
                    openDropdown()
                end
            end)
            
            -- Efeitos hover no frame principal
            DropdownFrame.MouseEnter:Connect(function()
                TweenService:Create(DropdownFrame, TweenInfo.new(0.2), {
                    BackgroundColor3 = currentTheme.ElementBackgroundHover
                }):Play()
            end)
            
            DropdownFrame.MouseLeave:Connect(function()
                if not dropdownOpen then
                    TweenService:Create(DropdownFrame, TweenInfo.new(0.2), {
                        BackgroundColor3 = currentTheme.ElementBackground
                    }):Play()
                end
            end)
            
            -- Fechar dropdown ao clicar fora
            local function onGlobalClick(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 and dropdownOpen then
                    local mouse = UserInputService:GetMouseLocation()
                    local framePos = DropdownFrame.AbsolutePosition
                    local frameSize = DropdownFrame.AbsoluteSize
                    
                    if not (mouse.X >= framePos.X and mouse.X <= framePos.X + frameSize.X and
                           mouse.Y >= framePos.Y and mouse.Y <= framePos.Y + frameSize.Y) then
                        closeDropdown()
                    end
                end
            end
            
            UserInputService.InputBegan:Connect(onGlobalClick)

            DropdownFrame.Parent = ElementsContainer  
            tabData.elementCount = tabData.elementCount + 1
            updateScrollability(LMG2L["Main_7"], tabData.elementCount)

            return {  
                SetValue = function(_, val)  
                    if table.find(options, val) then  
                        Selected.Text = val  
                        if callback then callback(val) end  
                    end  
                end,  
                GetValue = function() 
                    return Selected.Text 
                end,
                Refresh = function(self, newOptions)
                    options = newOptions
                    for _, child in ipairs(DropdownContainer:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end
                    
                    for i, option in ipairs(options) do  
                        createOption(option, i)
                    end
                    updateDropdownSize()
                    Selected.Text = options[1] or "Select"
                end
            }
        end
      
