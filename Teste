    -- FUNÇÃO DE ATUALIZAÇÃO DO TEMA ATUALIZADA COM FLOATING
    local function applyTheme()
        local th, ts, tv = currentThemeColor:ToHSV()
        local darkerTheme = Color3.fromHSV(th, ts, math.clamp(tv - 0.2, 0, 1))

        LMG2L["Topo_2"].BackgroundColor3 = currentThemeColor
        LMG2L["Effect_6"].BackgroundColor3 = currentThemeColor
        PaletaTop.BackgroundColor3 = currentThemeColor
        ConfirmBtn.BackgroundColor3 = currentThemeColor

        for _, tab in ipairs(tabs) do
            if tab == currentTab then
                tab.button.BackgroundColor3 = darkerTheme
            else
                tab.button.BackgroundColor3 = currentThemeColor
            end
        end

        for _, element in ipairs(themeElements) do
            if element.type == "Toggle" then
                element.instance.BackgroundColor3 = element.getState() and currentThemeColor or Color3.fromRGB(37, 37, 37)
            elseif element.type == "Slider" then
                element.instance.BackgroundColor3 = currentThemeColor
            elseif element.type == "Button" then
                element.instance.BackgroundColor3 = currentThemeColor
            elseif element.type == "DropdownIcon" then
                element.instance.BackgroundColor3 = currentThemeColor
            elseif element.type == "RadioButton" then
                if element.getState() then
                    element.instance.BackgroundColor3 = currentThemeColor
                else
                    element.instance.BackgroundColor3 = Color3.fromRGB(53, 53, 53)
                end
            elseif element.type == "FloatingShowHide" then
                element.instance.BackgroundColor3 = element.getVisible() and currentThemeColor or Color3.fromRGB(45, 45, 45)
            elseif element.type == "FloatingStroke" then
                if element.instance and element.instance.Parent then
                    element.instance.Color = currentThemeColor
                end
            end
        end
    end

