            -- Atualizar cores
            LMG2L["Topo_2"].BackgroundColor3 = currentTheme.MainColor
            LMG2L["TitleMenu_3"].TextColor3 = currentTheme.TextColor
            LMG2L["TitleIcon_3a"].ImageColor3 = currentTheme.TextColor
            LMG2L["CloseMenu_4"].TextColor3 = currentTheme.TextColor
            LMG2L["MinimizeMenu_4a"].TextColor3 = currentTheme.TextColor
            LMG2L["Main_5"].BackgroundColor3 = currentTheme.Background
            LMG2L["Effect_6"].BackgroundColor3 = currentTheme.MainColor
            
            -- Atualizar botões das tabs
            for _, tab in ipairs(tabs) do
                if tab.button then
                    tab.button.BackgroundColor3 = currentTheme.MainColor
                end
            end
        end
    end
    
