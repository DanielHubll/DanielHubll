local function ensureFolder()
    if not isfolder("VLG_Configs") then makefolder("VLG_Configs") end
end

local function saveToFile(data, filename)
    ensureFolder()
    local success, err = pcall(function()
        writefile("VLG_Configs/" .. filename .. ".json", HttpService:JSONEncode(data))
    end)
    return success
end

local function loadFromFile(filename)
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile("VLG_Configs/" .. filename .. ".json"))
    end)
    if success then return data end
    return nil
end

local function getConfigFiles()
    local success, files = pcall(function()
        return listfiles("VLG_Configs")
    end)
    if success then
        local configs = {}
        for _, file in ipairs(files) do
            if file:match("%.json$") then
                local name = file:match("VLG_Configs[/\\](.+)%.json$")
                if name and name ~= "_meta" then
                    table.insert(configs, name)
                end
            end
        end
        return configs
    end
    return {}
end

local META_FILE = "VLG_Configs/_meta.json"

local function saveMeta(data)
    ensureFolder()
    pcall(function()
        writefile(META_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadMeta()
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(META_FILE))
    end)
    if ok and type(data) == "table" then return data end
    return { lastConfig = nil, autoLoad = false }
end

