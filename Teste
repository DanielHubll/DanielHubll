            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                draggingWindow = true
                dragStart = input.Position
                startPos = Topo.Position
                
                -- Feedback visual
                TweenService:Create(Topo, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(
                        math.floor(currentTheme.MainColor.R * 255 * 0.9),
                        math.floor(currentTheme.MainColor.G * 255 * 0.9),
                        math.floor(currentTheme.MainColor.B * 255 * 0.9)
                    )
                }):Play()
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if draggingWindow and (
                input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch
            ) then
                local delta = input.Position - dragStart
                local newX = math.clamp(startPos.X.Offset + delta.X, 0, workspace.CurrentCamera.ViewportSize.X - Topo.AbsoluteSize.X)
                local newY = math.clamp(startPos.Y.Offset + delta.Y, 0, workspace.CurrentCamera.ViewportSize.Y - Topo.AbsoluteSize.Y)
                Topo.Position = UDim2.new(0, newX, 0, newY)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                draggingWindow = false
                
                -- Restaurar cor
                TweenService:Create(Topo, TweenInfo.new(0.2), {
                    BackgroundColor3 = currentTheme.MainColor
                }):Play()
            end
        end)
    end
  
    -- *** NOVA FUNÇÃO: Atualizar Scroll Adaptativo ***
    local function updateScrollability(container, elementCount)
        local containerHeight = 186
        local totalHeight = elementCount * CONFIG.ELEMENT_HEIGHT + 20
        
        if totalHeight > containerHeight then
            container.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
            -- Barra de scroll estilizada
            container.ScrollBarThickness = 3
            container.ScrollBarImageColor3 = currentTheme.MainColor
        else
            container.CanvasSize = UDim2.new(0, 0, 0, 0)
            container.ScrollBarThickness = 0
        end
    end

    -- FUNÇÃO PARA CRIAR NOVA TAB  
    function publicMethods:AddTab(tabName, iconId)  
        local tabIndex = #tabs + 1  
        local tabData = {  
            name = tabName,  
            elements = {},  
            container = nil,  
            button = nil,  
            elementCount = 0  
        }  
          
        -- Criar botão da tab
        local TabButton = Instance.new("ImageButton", LMG2L["Tabs_2a"])  
        TabButton["BorderSizePixel"] = 0  
        TabButton["BackgroundColor3"] = currentTheme.MainColor
        TabButton["Size"] = UDim2.new(0, 40, 0, 40)  
        TabButton["Name"] = "Tab" .. tabIndex  
        TabButton["LayoutOrder"] = tabIndex
        TabButton["Image"] = iconId or getIcon("folder")  
          
        local UICorner = Instance.new("UICorner", TabButton)  
        UICorner["CornerRadius"] = UDim.new(0, 5)  
          
        -- Efeito hover
        TabButton.MouseEnter:Connect(function()
            if currentTab ~= tabData then
                TweenService:Create(TabButton, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(
                        math.floor(currentTheme.MainColor.R * 255 * 1.2),
                        math.floor(currentTheme.MainColor.G * 255 * 1.2),
                        math.floor(currentTheme.MainColor.B * 255 * 1.2)
                    )
                }):Play()
            end
        end)
        
        TabButton.MouseLeave:Connect(function()
            if currentTab ~= tabData then
                TweenService:Create(TabButton, TweenInfo.new(0.2), {
                    BackgroundColor3 = currentTab == tabData and Color3.fromRGB(110, 0, 140) or currentTheme.MainColor
                }):Play()
            end
        end)
        
        -- *** ALTERADO: Container agora é Frame normal (filho do ScrollingFrame) ***
        local ElementsContainer = Instance.new("Frame", LMG2L["Main_7"])  
        ElementsContainer["BackgroundTransparency"] = 1  
        ElementsContainer["Size"] = UDim2.new(1, 0, 1, 0)  
        ElementsContainer["Name"] = "Container_" .. tabName  
        ElementsContainer["Visible"] = false  
          
        tabData.container = ElementsContainer  
        tabData.button = TabButton  
          
        -- Função para trocar de tab  
        local function switchToTab()  
            for _, tab in ipairs(tabs) do  
                tab.container.Visible = false  
                if tab.button then
                    TweenService:Create(tab.button, TweenInfo.new(0.2), {
                        BackgroundColor3 = currentTheme.MainColor
                    }):Play()
                end
            end  
              
            ElementsContainer.Visible = true  
            TweenService:Create(TabButton, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(110, 0, 140)
            }):Play()
            currentTab = tabData
            
            -- *** ATUALIZAR SCROLL ao trocar de tab ***
            updateScrollability(LMG2L["Main_7"], tabData.elementCount)
        end  
          
        TabButton.MouseButton1Click:Connect(switchToTab)  
        table.insert(tabs, tabData)  
          
        if tabIndex == 1 then  
            switchToTab()  
        end
    
        -- *** ATUALIZAR Canvas Size das tabs ***
        local tabsHeight = tabIndex * 45 + 10
        if tabsHeight > 194 then
            LMG2L["Tabs_2a"].CanvasSize = UDim2.new(0, 0, 0, tabsHeight)
        end
          
