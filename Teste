            Scroll.ClipsDescendants = true
            Scroll.Active = true
            Instance.new("UICorner", Scroll).CornerRadius = UDim.new(0, 3)

            local btnHeight = 22
            local padding = 2

            local function getHeight()
                return math.min(#options, 4) * (btnHeight + padding) + 4
            end

            local function updateScrollPos()
                if Scroll.Visible then
                    local mainAbsPos = MainContainer.AbsolutePosition
                    local mainAbsSize = MainContainer.AbsoluteSize
                    local btnAbsPos = Main.AbsolutePosition
                    local newY = (btnAbsPos.Y - mainAbsPos.Y) + 24
                    local newX = (btnAbsPos.X - mainAbsPos.X) + 2
                    if newY + getHeight() > mainAbsSize.Y then
                        newY = newY - getHeight() - 26
                    end
                    Scroll.Position = UDim2.new(0, newX, 0, newY)
                end
            end

            local function CloseDropdown()
                Scroll.Visible = false
                Open.Rotation = 180
                DropdownFrame.ZIndex = 10
                Main.ZIndex = 11
                if openDropdownInfo and openDropdownInfo.Main == Main then
                    openDropdownInfo = nil
                end
            end

            local function OpenDropdown()
                if openDropdownInfo then openDropdownInfo.Close() end
                Scroll.Visible = true; Open.Rotation = 0
                DropdownFrame.ZIndex = 100; Main.ZIndex = 101
                Scroll.Size = UDim2.new(0, 136, 0, getHeight())
                updateScrollPos()
                openDropdownInfo = { Main = Main, Scroll = Scroll, Close = CloseDropdown }
            end

            Open.MouseButton1Click:Connect(function()
                if Scroll.Visible then CloseDropdown() else OpenDropdown() end
            end)

            local elementData = { frame = DropdownFrame, height = 30, visible = true, isSub = false }
            table.insert(tabData.elements, elementData)
            updateLayout()

            local DropdownObject = {
                SetVisible = function(self, state) elementData.visible = state; DropdownFrame.Visible = state; updateLayout() end,
                SetAsSubElement = function(self, state) elementData.isSub = state; updateLayout() end,
                Refresh = function(self, NewOptions)
                    options = NewOptions
                    for _, child in ipairs(Scroll:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end
                    for i, opt in ipairs(options) do
                        local Btn = Instance.new("TextButton", Scroll)
                        Btn.Size = UDim2.new(1, -4, 0, btnHeight)
                        Btn.Position = UDim2.new(0, 2, 0, (i - 1) * (btnHeight + padding))
                        Btn.Text = opt
                        Btn.TextSize = 11
                        Btn.BorderSizePixel = 0
                        Btn.BackgroundColor3 = Color3.fromRGB(37, 37, 37)
                        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                        Btn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
                        Btn.ZIndex = 1000
                        Btn.TextWrapped = false
                        Btn.TextTruncate = Enum.TextTruncate.AtEnd
                        Btn.ClipsDescendants = true
                        Btn.MouseEnter:Connect(function() Btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50) end)
                        Btn.MouseLeave:Connect(function() Btn.BackgroundColor3 = Color3.fromRGB(37, 37, 37) end)
                        Btn.MouseButton1Click:Connect(function()
                            Selected.Text = opt
                            CloseDropdown()
                            if callback then callback(opt) end
                        end)
                    end
                    local totalContentHeight = #options * (btnHeight + padding)
                    Scroll.CanvasSize = UDim2.new(0, 0, 0, totalContentHeight)
                    if Scroll.Visible then Scroll.Size = UDim2.new(0, 136, 0, getHeight()) end
                end,
                GetValue = function(self) return Selected.Text end,
                SetValue = function(self, val) Selected.Text = val end
            }

            DropdownObject:Refresh(options)

            registerConfigElement("Dropdown", text, DropdownObject, function() return DropdownObject:GetValue() end, function(val) DropdownObject:SetValue(val) end)
            return DropdownObject
        end

