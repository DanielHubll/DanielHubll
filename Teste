        titleLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.ZIndex = 10000
        
        local messageLabel = Instance.new("TextLabel", dialog)
        messageLabel.BackgroundTransparency = 1
        messageLabel.Size = UDim2.new(1, -20, 0, 36)
        messageLabel.Position = UDim2.new(0, 10, 0, 34)
        messageLabel.Text = message or ""
        messageLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        messageLabel.TextSize = 11
        messageLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium)
        messageLabel.TextWrapped = true
        messageLabel.ZIndex = 10000
        
        local confirmBtn = Instance.new("TextButton", dialog)
        confirmBtn.BorderSizePixel = 0
        confirmBtn.BackgroundColor3 = currentThemeColor
        confirmBtn.Size = UDim2.new(0, 100, 0, 28)
        confirmBtn.Position = UDim2.new(0, 24, 0, 80)
        confirmBtn.Text = "Confirmar"
        confirmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        confirmBtn.TextSize = 12
        confirmBtn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
        confirmBtn.ZIndex = 10000
        Instance.new("UICorner", confirmBtn).CornerRadius = UDim.new(0, 4)
        
        local cancelBtn = Instance.new("TextButton", dialog)
        cancelBtn.BorderSizePixel = 0
        cancelBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        cancelBtn.Size = UDim2.new(0, 100, 0, 28)
        cancelBtn.Position = UDim2.new(0, 136, 0, 80)
        cancelBtn.Text = "Cancelar"
        cancelBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        cancelBtn.TextSize = 12
        cancelBtn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
        cancelBtn.ZIndex = 10000
        Instance.new("UICorner", cancelBtn).CornerRadius = UDim.new(0, 4)
        
        local function closeDialog()
            confirmGui:Destroy()
        end
        
        confirmBtn.MouseButton1Click:Connect(function()
            closeDialog()
            if onConfirm then onConfirm() end
        end)
        
        cancelBtn.MouseButton1Click:Connect(function()
            closeDialog()
            if onCancel then onCancel() end
        end)
        
        bg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local absPos = dialog.AbsolutePosition
                local absSize = dialog.AbsoluteSize
                local mx, my = input.Position.X, input.Position.Y
                if not (mx >= absPos.X and mx <= absPos.X + absSize.X
                    and my >= absPos.Y and my <= absPos.Y + absSize.Y) then
                    closeDialog()
                end
            end
        end)
    end

    return publicMethods
end

if _G.VLG_UILibrary then
    return _G.VLG_UILibrary
else
    _G.VLG_UILibrary = UILibrary
    return UILibrary
end
