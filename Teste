local h, s, v = 0, 1, 1  
local colorDragging = false  
local hueDragging = false  

local function updateColorInternal()  
    local realColor = Color3.fromHSV(h, s, v)  
    local pureColor = Color3.fromHSV(h, s, 1)  
    HueGradient.Color = ColorSequence.new(pureColor, Color3.fromRGB(0, 0, 0))  
    ColorPreview.BackgroundColor3 = realColor  
    if activeColorTarget then activeColorTarget.BackgroundColor3 = realColor end  
    if activeColorCallback then activeColorCallback(realColor) end  
end  

local function updateSV(input)  
    local relX = math.clamp((input.Position.X - SVMap.AbsolutePosition.X) / SVMap.AbsoluteSize.X, 0, 1)  
    local relY = math.clamp((input.Position.Y - SVMap.AbsolutePosition.Y) / SVMap.AbsoluteSize.Y, 0, 1)  
    h = relX; s = relY  
    SVCursor.Position = UDim2.new(relX, -2, relY, -2)  
    updateColorInternal()  
end  

local function updateHue(input)  
    local relY = math.clamp((input.Position.Y - HueMap.AbsolutePosition.Y) / HueMap.AbsoluteSize.Y, 0, 1)  
    v = 1 - relY   
    HueCursor.Position = UDim2.new(0, 0, relY, -1)  
    updateColorInternal()  
end  

SVMap.InputBegan:Connect(function(input)  
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then  
        colorDragging = true; updateSV(input)  
    end  
end)  

HueMap.InputBegan:Connect(function(input)  
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then  
        hueDragging = true; updateHue(input)  
    end  
end)  

UserInputService.InputEnded:Connect(function(input)  
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then  
        colorDragging = false; hueDragging = false  
    end  
end)  

UserInputService.InputChanged:Connect(function(input)  
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then  
        if colorDragging then updateSV(input) end  
        if hueDragging then updateHue(input) end  
    end  
end)  

