local function OpenColorPicker(targetFrame, defaultColor, callback)  
    activeColorTarget = targetFrame; activeColorCallback = callback  
    local dh, ds, dv = defaultColor:ToHSV()  
    h, s, v = dh, ds, dv  
    local pureColor = Color3.fromHSV(h, s, 1)  
    HueGradient.Color = ColorSequence.new(pureColor, Color3.fromRGB(0, 0, 0))  
    ColorPreview.BackgroundColor3 = defaultColor  
    SVCursor.Position = UDim2.new(h, -2, s, -2)  
    HueCursor.Position = UDim2.new(0, 0, 1-v, -1)   
    Paleta_d.Visible = true  
end  

