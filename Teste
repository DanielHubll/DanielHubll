    local TabButton = Instance.new("ImageButton", LMG2L["Tabs_2a"])      
    TabButton["BorderSizePixel"] = 0      
    TabButton["BackgroundColor3"] = Color3.fromRGB(144, 0, 181)    
    TabButton["Size"] = UDim2.new(0, 40, 0, 40)      
    TabButton["Position"] = UDim2.new(0, 6, 0, 4 + ((tabIndex - 1) * 48))  
    TabButton["Image"] = iconId or "rbxassetid://10709852168"      
    Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 5)      
          
    local ElementsContainer = Instance.new("Frame", LMG2L["Main_7"])      
    ElementsContainer["BackgroundTransparency"] = 1      
    ElementsContainer["Size"] = UDim2.new(1, 0, 1, 0)      
    ElementsContainer["Visible"] = false      
          
    tabData.container = ElementsContainer      
    tabData.button = TabButton      

    -- 🔥 MUDANÇA AQUI: Layout agora checa se é "Sub Elemento" para puxar pro lado
    local function updateLayout()    
        local y = 8    
        for _, element in ipairs(tabData.elements) do    
            if element.visible then    
                local positionX = element.isSub and 10 or 6 -- Se for sub (Drop/Color no Toggle), indenta para 24
                element.frame.Position = UDim2.new(0, positionX, 0, y)    
                y = y + element.height    
            end    
        end    
        tabData.elementCount = math.floor(y / 30)    
        updateScrollability(LMG2L["Main_7"], tabData.elementCount)    
    end    
          
    local function switchToTab()      
        for _, tab in ipairs(tabs) do      
            tab.container.Visible = false      
            tab.button.BackgroundColor3 = Color3.fromRGB(144, 0, 181)    
        end      
        ElementsContainer.Visible = true      
        TabButton.BackgroundColor3 = Color3.fromRGB(110, 0, 140)    
        currentTab = tabData    
        updateScrollability(LMG2L["Main_7"], tabData.elementCount)    
    end      
          
    TabButton.MouseButton1Click:Connect(switchToTab)      
    table.insert(tabs, tabData)      
          
    if tabIndex == 1 then switchToTab() end    
      
    local tabsHeight = tabIndex * 48 + 8  
    if tabsHeight > 194 then LMG2L["Tabs_2a"].CanvasSize = UDim2.new(0, 0, 0, tabsHeight) end    
          
