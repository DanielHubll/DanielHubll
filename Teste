                        knob.Position = UDim2.new(relX, -3, 0, -3)
                        setter(relX)
                        if openDropdownInfo then closeAllDropdowns() end
                    end)
                    UserInputService.InputEnded:Connect(function(inp)
                        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                            con:Disconnect()
                        end
                    end)
                end
            end)
        end

