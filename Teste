    -- ==========================================
    -- SISTEMA DE SALVAR CONFIGS (NOVO)
    -- ==========================================
    function publicMethods:CreateConfigSystem(folderName)
        folderName = folderName or "VLG_Configs"

        -- Cria a aba por último usando o ícone de engrenagem
        local ConfigTab = self:AddTab("Configurações", "rbxassetid://10709852168")
        
        ConfigTab:AddSection("Gerenciador")

        local configNameInput = ""
        ConfigTab:AddTextBox("Nome da Config", "MinhaConfig", function(val)
            configNameInput = val
        end)

        local ConfigDropdown
        local selectedLoadConfig = ""

        local function GetConfigList()
            local list = {}
            if isfolder and listfiles then
                if not isfolder(folderName) then makefolder(folderName) end
                for _, file in ipairs(listfiles(folderName)) do
                    local name = file:match("([^/\\]+)%.json$")
                    if name then table.insert(list, name) end
                end
            end
            if #list == 0 then table.insert(list, "Nenhuma") end
            return list
        end

        ConfigDropdown = ConfigTab:AddDropdown("Configs Salvas", GetConfigList(), function(val)
            selectedLoadConfig = val
        end)

        ConfigTab:AddButton("Salvar Configuração", function()
            if configNameInput == "" or configNameInput == "Nenhuma" then return end
            
            if writefile then
                local dataToSave = {}
                for key, elem in pairs(UI_Elements) do
                    local val = elem.Get()
                    -- Evita erro ao codificar o Color3 em JSON, passando pra Hexadecimal
                    if elem.Type == "ColorPicker" then
                        val = val:ToHex()
                    end
                    dataToSave[key] = { Type = elem.Type, Value = val }
                end
                
                if not isfolder(folderName) then makefolder(folderName) end
                writefile(folderName.."/"..configNameInput..".json", HttpService:JSONEncode(dataToSave))
                
                -- Atualiza a lista na hora
                if ConfigDropdown then ConfigDropdown:Refresh(GetConfigList()) end
            end
        end)

        ConfigTab:AddButton("Carregar Configuração", function()
            if selectedLoadConfig == "" or selectedLoadConfig == "Nenhuma" then return end
            local path = folderName.."/"..selectedLoadConfig..".json"
            
            if isfile and readfile and isfile(path) then
                local success, decoded = pcall(function()
                    return HttpService:JSONDecode(readfile(path))
                end)
                
                if success and decoded then
                    for key, savedElem in pairs(decoded) do
                        local uiElem = UI_Elements[key]
                        if uiElem and uiElem.Type == savedElem.Type then
                            if savedElem.Type == "ColorPicker" then
                                uiElem.Set(Color3.fromHex(savedElem.Value))
                            else
                                uiElem.Set(savedElem.Value)
                            end
                        end
                    end
                end
            end
        end)
        
        ConfigTab:AddSeparator()
        
        ConfigTab:AddButton("Atualizar Lista", function()
            if ConfigDropdown then ConfigDropdown:Refresh(GetConfigList()) end
        end)
    end

    return publicMethods
