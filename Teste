    local function applyTheme()  
        local th, ts, tv = currentThemeColor:ToHSV()  
        local darkerTheme = Color3.fromHSV(th, ts, math.clamp(tv - 0.2, 0, 1))  

        LMG2L["Topo_2"].BackgroundColor3 = currentThemeColor  
        LMG2L["Effect_6"].BackgroundColor3 = currentThemeColor  
        PaletaTop.BackgroundColor3 = currentThemeColor  
        ConfirmBtn.BackgroundColor3 = currentThemeColor  

        for _, tab in ipairs(tabs) do  
            if tab == currentTab then  
                tab.button.BackgroundColor3 = darkerTheme  
            else  
                tab.button.BackgroundColor3 = currentThemeColor  
            end  
        end  

        for _, element in ipairs(themeElements) do  
            if element.type == "Toggle" then  
                element.instance.BackgroundColor3 = element.getState() and currentThemeColor or Color3.fromRGB(37, 37, 37)  
            elseif element.type == "FloatingTopo" then  
                element.instance.BackgroundColor3 = currentThemeColor  
            elseif element.type == "ShowButton" then  
                element.instance.BackgroundColor3 = element.getState() and currentThemeColor or Color3.fromRGB(45, 45, 45)  
            elseif element.type == "Slider" then  
                element.instance.BackgroundColor3 = currentThemeColor  
            elseif element.type == "Button" then  
                element.instance.BackgroundColor3 = currentThemeColor  
            elseif element.type == "DropdownIcon" then  
                element.instance.BackgroundColor3 = currentThemeColor  
            elseif element.type == "RadioButton" then  
                if element.getState() then  
                    element.instance.BackgroundColor3 = currentThemeColor  
                else  
                    element.instance.BackgroundColor3 = Color3.fromRGB(53, 53, 53)  
                end  
            elseif element.type == "Separator" then  
                element.instance.BackgroundColor3 = currentThemeColor  
            end  
        end  
    end  

    local function MakeDraggable(frameToDrag, dragArea)      
        local dragging = false      
        local dragStart, startPos      
        dragArea.InputBegan:Connect(function(input)      
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then      
                dragging = true; dragStart = input.Position; startPos = frameToDrag.Position      
            end      
        end)      
        UserInputService.InputChanged:Connect(function(input)      
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then      
                local delta = input.Position - dragStart      
                frameToDrag.Position = UDim2.new(0, startPos.X.Offset + delta.X, 0, startPos.Y.Offset + delta.Y)      
            end      
        end)      
        UserInputService.InputEnded:Connect(function(input)      
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then      
                dragging = false      
            end      
        end)      
    end      

