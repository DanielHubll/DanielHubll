    notificationGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notificationGui.ResetOnSpawn = false
    notificationGui.IgnoreGuiInset = true
    notificationGui.Parent = CoreGui
    
    local yOffset = 10
    for _, notif in ipairs(ActiveNotifications) do
        yOffset = yOffset + notif.frame.AbsoluteSize.Y + 6
    end
    
    local frame = Instance.new("Frame", notificationGui)
    frame.BorderSizePixel = 0
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.Size = UDim2.new(0, 260, 0, 60)
    frame.Position = UDim2.new(1, -270, 0, yOffset)
    frame.AnchorPoint = Vector2.new(0, 0)
    frame.ZIndex = 9999
    frame.ClipsDescendants = true
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    
    local colors = {
        Success = Color3.fromRGB(46, 204, 113),
        Error = Color3.fromRGB(231, 76, 60),
        Warning = Color3.fromRGB(241, 196, 15),
        Info = Color3.fromRGB(52, 152, 219)
    }
    
    local accentBar = Instance.new("Frame", frame)
    accentBar.BorderSizePixel = 0
    accentBar.BackgroundColor3 = colors[notifType] or colors.Info
    accentBar.Size = UDim2.new(0, 4, 1, 0)
    accentBar.ZIndex = 10000
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(0, 2)
    
    local titleLabel = Instance.new("TextLabel", frame)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -50, 0, 20)
    titleLabel.Position = UDim2.new(0, 12, 0, 6)
    titleLabel.Text = title or "Notificação"
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.TextSize = 13
    titleLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.ZIndex = 10000
    
    local messageLabel = Instance.new("TextLabel", frame)
    messageLabel.BackgroundTransparency = 1
    messageLabel.Size = UDim2.new(1, -50, 0, 24)
    messageLabel.Position = UDim2.new(0, 12, 0, 28)
    messageLabel.Text = message or ""
    messageLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    messageLabel.TextSize = 11
    messageLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium)
    messageLabel.TextXAlignment = Enum.TextXAlignment.Left
    messageLabel.TextWrapped = true
    messageLabel.ZIndex = 10000
    
    local closeBtn = Instance.new("TextButton", frame)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Size = UDim2.new(0, 20, 0, 20)
    closeBtn.Position = UDim2.new(1, -26, 0, 4)
    closeBtn.Text = "×"
    closeBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
    closeBtn.TextSize = 18
    closeBtn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    closeBtn.ZIndex = 10000
    
    local timerBar = Instance.new("Frame", frame)
    timerBar.BorderSizePixel = 0
    timerBar.BackgroundColor3 = colors[notifType] or colors.Info
    timerBar.Size = UDim2.new(1, -8, 0, 2)
    timerBar.Position = UDim2.new(0, 4, 1, -4)
    timerBar.ZIndex = 10000
    timerBar.BackgroundTransparency = 0.5
    Instance.new("UICorner", timerBar).CornerRadius = UDim.new(0, 1)
    
    local notifData = { gui = notificationGui, frame = frame, timerBar = timerBar }
    table.insert(ActiveNotifications, notifData)
    
    local function removeNotification()
        local index = nil
        for i, notif in ipairs(ActiveNotifications) do
            if notif == notifData then index = i; break end
        end
        if index then table.remove(ActiveNotifications, index) end
        
        local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tween = TweenService:Create(frame, tweenInfo, { BackgroundTransparency = 1 })
        tween:Play()
        
        for _, child in ipairs(frame:GetChildren()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                local t2 = TweenService:Create(child, tweenInfo, { TextTransparency = 1 })
                t2:Play()
            end
        end
        
        delay(0.3, function()
            notificationGui:Destroy()
            local currentY = 10
            for _, notif in ipairs(ActiveNotifications) do
                local tweenY = TweenService:Create(notif.frame, TweenInfo.new(0.2), { Position = UDim2.new(1, -270, 0, currentY) })
                tweenY:Play()
                currentY = currentY + notif.frame.AbsoluteSize.Y + 6
            end
        end)
    end
    
    closeBtn.MouseButton1Click:Connect(removeNotification)
    
    local startTime = tick()
    local connection
    connection = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        local progress = math.clamp(1 - (elapsed / duration), 0, 1)
        timerBar.Size = UDim2.new(progress, -8, 0, 2)
        if elapsed >= duration then
            connection:Disconnect()
            removeNotification()
        end
    end)
    
    -- Animação de entrada
    frame.Position = UDim2.new(1, 0, 0, yOffset)
    local tweenIn = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Position = UDim2.new(1, -270, 0, yOffset) })
    tweenIn:Play()
    
    return { Close = removeNotification }
end

